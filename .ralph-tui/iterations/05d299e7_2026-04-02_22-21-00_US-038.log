{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M4y7TwCAEK26oYtqwikgXr","type":"tool_result","content":"1\tuse serde::{Deserialize, Serialize};\n2\t\n3\t#[derive(Debug, Clone, Serialize, Deserialize, Default)]\n4\tpub struct Config {\n5\t    #[serde(default)]\n6\t    pub providers: ProvidersConfig,\n7\t    #[serde(default)]\n8\t    pub routing: RoutingConfig,\n9\t    #[serde(default)]\n10\t    pub mcp: McpConfig,\n11\t    pub sandbox: Option<SandboxConfig>,\n12\t    pub memory: Option<MemoryConfig>,\n13\t    #[serde(default)]\n14\t    pub context: ContextConfig,\n15\t    #[serde(default)]\n16\t    pub remote_runtime: RemoteRuntimeConfig,\n17\t    #[serde(default)]\n18\t    pub tui: TuiConfig,\n19\t}\n20\t\n21\t/// TUI display and accessibility settings.\n22\t#[derive(Debug, Clone, Serialize, Deserialize, Default)]\n23\tpub struct TuiConfig {\n24\t    /// Color theme for the terminal UI.\n25\t    /// Accepted values: `\"default\"` (16-color), `\"high_contrast\"` (bold+bright),\n26\t    /// `\"no_color\"` (modifiers only).\n27\t    /// Overridden automatically when `NO_COLOR` env var is set or `TERM=dumb`.\n28\t    pub theme: Option<String>,\n29\t}\n30\t\n31\t#[derive(Debug, Clone, Serialize, Deserialize, Default)]\n32\tpub struct McpConfig {\n33\t    #[serde(default)]\n34\t    pub enable_chicago_mcp_feature_gate: bool,\n35\t    #[serde(default)]\n36\t    pub allow_privileged_computer_use: bool,\n37\t    #[serde(default)]\n38\t    pub servers: Vec<McpServerConfig>,\n39\t}\n40\t\n41\t#[derive(Debug, Clone, Serialize, Deserialize)]\n42\tpub struct McpServerConfig {\n43\t    pub name: String,\n44\t    pub command: String,\n45\t    #[serde(default)]\n46\t    pub args: Vec<String>,\n47\t    #[serde(default)]\n48\t    pub declared_capabilities: Vec<String>,\n49\t    #[serde(default)]\n50\t    pub enable_computer_use: bool,\n51\t}\n52\t\n53\t#[derive(Debug, Clone, Serialize, Deserialize, Default)]\n54\tpub struct RemoteRuntimeConfig {\n55\t    #[serde(default)]\n56\t    pub ccr_http: CcrHttpConfig,\n57\t}\n58\t\n59\t#[derive(Debug, Clone, Serialize, Deserialize)]\n60\tpub struct CcrHttpConfig {\n61\t    #[serde(default = \"default_ccr_timeout_ms\")]\n62\t    pub timeout_ms: u64,\n63\t    #[serde(default = \"default_ccr_retry_count\")]\n64\t    pub max_retries: u32,\n65\t    #[serde(default = \"default_ccr_retry_delay_ms\")]\n66\t    pub retry_delay_ms: u64,\n67\t}\n68\t\n69\timpl Default for CcrHttpConfig {\n70\t    fn default() -> Self {\n71\t        Self {\n72\t            timeout_ms: default_ccr_timeout_ms(),\n73\t            max_retries: default_ccr_retry_count(),\n74\t            retry_delay_ms: default_ccr_retry_delay_ms(),\n75\t        }\n76\t    }\n77\t}\n78\t\n79\tfn default_ccr_timeout_ms() -> u64 {\n80\t    10_000"}]},"parent_tool_use_id":"toolu_01AmhVkZizi2XSNnQreLfzwh","session_id":"523981ce-25d5-4aed-a492-78dcbb263a10","uuid":"84ab172e-28c3-42a1-a977-54fd7088d65d","timestamp":"2026-04-02T14:21:55.196Z"}
