{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XqVq3rv7owNcgNXSLarwUH","type":"tool_result","content":"1\tuse crate::error::AppError;\n2\tuse async_trait::async_trait;\n3\tuse ccode_domain::{\n4\t    message::{Message, Role},\n5\t    session::{Session, SessionId},\n6\t};\n7\tuse ccode_ports::{\n8\t    provider::{LlmClient, LlmError, LlmRequest, LlmStream, StreamEvent, ToolDefinition},\n9\t    repositories::SessionRepository,\n10\t};\n11\tuse futures::StreamExt;\n12\tuse std::future::Future;\n13\tuse std::pin::Pin;\n14\tuse std::sync::Arc;\n15\tuse std::time::{SystemTime, UNIX_EPOCH};\n16\t\n17\t/// Configures context window management for the agentic loop.\n18\t/// All values have sensible defaults — only override what you need.\n19\t#[derive(Debug, Clone)]\n20\tpub struct ContextPolicy {\n21\t    /// Trigger compression when total context size (all messages concatenated)\n22\t    /// exceeds this many characters. Rough estimate: 4 chars ≈ 1 token.\n23\t    /// Default: 600_000 (~150k tokens, leaves buffer for a 200k-context model).\n24\t    pub compress_chars_threshold: usize,\n25\t    /// Number of most-recent messages kept verbatim after compression.\n26\t    /// Default: 8.\n27\t    pub keep_recent_messages: usize,\n28\t    /// Truncate any single tool result exceeding this many characters.\n29\t    /// Default: 40_000 (~10k tokens).\n30\t    pub tool_result_max_chars: usize,\n31\t}\n32\t\n33\timpl Default for ContextPolicy {\n34\t    fn default() -> Self {\n35\t        Self {\n36\t            compress_chars_threshold: 600_000,\n37\t            keep_recent_messages: 8,\n38\t            tool_result_max_chars: 40_000,\n39\t        }\n40\t    }\n41\t}\n42\t\n43\tpub struct AgentRunCommand<R> {\n44\t    repo: R,\n45\t    provider: Arc<dyn LlmClient>,\n46\t    context: ContextPolicy,\n47\t    computer_use_lifecycle: Option<Arc<dyn ComputerUseLifecycle>>,\n48\t}\n49\t\n50\ttype ExecuteToolFn = dyn Fn(String, serde_json::Value) -> Pin<Box<dyn Future<Output = Result<String, String>> + Send>>\n51\t    + Send\n52\t    + Sync;\n53\t\n54\t#[derive(Debug, thiserror::Error)]\n55\tpub enum ComputerUseLifecycleError {\n56\t    #[error(\"transport error\")]\n57\t    TransportError,\n58\t    #[error(\"invalid tool payload\")]\n59\t    InvalidToolPayload,\n60\t    #[error(\"cleanup failed\")]\n61\t    CleanupFailed,\n62\t}\n63\t\n64\t#[async_trait]\n65\tpub trait ComputerUseLifecycle: Send + Sync {\n66\t    async fn before_tool_call(&self) -> Result<(), ComputerUseLifecycleError>;\n67\t    async fn after_turn_cleanup(&self) -> Result<(), ComputerUseLifecycleError>;\n68\t    async fn on_interrupt_cleanup(&self) -> Result<(), ComputerUseLifecycleError>;\n69\t}\n70\t\n71\timpl<R: SessionRepository> AgentRunCommand<R> {\n72\t    pub fn new(repo: R, provider: Arc<dyn LlmClient>) -> Self {\n73\t        Self {\n74\t            repo,\n75\t            provider,\n76\t            context: ContextPolicy::default(),\n77\t            computer_use_lifecycle: None,\n78\t        }\n79\t    }\n80\t\n81\t    pub fn with_context(mut self, policy: ContextPolicy) -> Self {\n82\t        self.context = policy;\n83\t        self\n84\t    }\n85\t\n86\t    pub fn with_computer_use_lifecycle(mut self, lifecycle: Arc<dyn ComputerUseLifecycle>) -> Self {\n87\t        self.computer_use_lifecycle = Some(lifecycle);\n88\t        self\n89\t    }\n90\t\n91\t    /// Full agentic loop — keeps calling the model and executing tools until\n92\t    /// the model produces no more tool calls (or max_iterations is reached).\n93\t    pub async fn run(\n94\t        &self,\n95\t        session_id: Option<String>,\n96\t        system_prompt: Option<String>,\n97\t        user_content: String,\n98\t        tools: Vec<ToolDefinition>,\n99\t        on_delta: &(dyn Fn(String) + Send + Sync),\n100\t        execute_tool: &ExecuteToolFn,\n101\t    ) -> Result<SessionId, AppError> {\n102\t        let lifecycle = self.computer_use_lifecycle.as_deref();\n103\t        let now = now_ms();\n104\t\n105\t        let mut session = match session_id {\n106\t            Some(ref id) => {\n107\t                let sid = SessionId(id.clone());\n108\t                self.repo\n109\t                    .find_by_id(&sid)\n110\t                    .await?\n111\t                    .unwrap_or_else(|| Session::new(id.clone(), now))\n112\t            }\n113\t            None => Session::new(format!(\"sess-{now}\"), now),\n114\t        };\n115\t\n116\t        // Prepend system prompt only when starting a fresh session\n117\t        if let Some(ref prompt) = system_prompt\n118\t            && session.messages.is_empty()\n119\t        {\n120\t            let sys_id = format!(\"msg-{now}-sys\");\n121\t            session.add_message(Message::new(sys_id, Role::System, prompt.clone(), now), now);\n122\t        }\n123\t\n124\t        // Add the user message\n125\t        let msg_id = format!(\"msg-{now}-u\");\n126\t        session.add_message(Message::new(msg_id, Role::User, user_content, now), now);\n127\t        self.repo.save(&session).await?;\n128\t\n129\t        const MAX_ITERATIONS: usize = 10;\n130\t\n131\t        for _iter in 0..MAX_ITERATIONS {\n132\t            // ── Context compression ────────────────────────────────────────────\n133\t            // Trigger on total character size (not message count) to catch large\n134\t            // tool results that would overflow the model's context window.\n135\t            let total_chars: usize = session.messages.iter().map(|m| m.content.len()).sum();\n136\t            if total_chars > self.context.compress_chars_threshold {\n137\t                session =\n138\t                    compress_context(session, &*self.provider, self.context.keep_recent_messages)\n139\t                        .await?;\n140\t                self.repo.save(&session).await?;\n141\t            }\n142\t\n143\t            let req = LlmRequest {\n144\t                messages: session.messages.clone(),\n145\t                model: None,\n146\t                max_tokens: None,\n147\t                temperature: None,\n148\t                tools: tools.clone(),\n149\t            };\n150\t\n151\t            let mut stream = self.provider.stream(req).await?;\n152\t\n153\t            let mut assistant_content = String::new();\n154\t            let mut captured_tool_calls: Vec<ccode_domain::message::ToolCall> = Vec::new();\n155\t            let mut last_usage = None;\n156\t\n157\t            while let Some(event) = stream.next().await {\n158\t                match event {\n159\t                    Err(err @ LlmError::StreamInterrupted(_)) => {\n160\t                        run_interrupt_cleanup(lifecycle).await;\n161\t                        return Err(AppError::from(err));\n162\t                    }\n163\t                    Err(err) => return Err(AppError::from(err)),\n164\t                    Ok(StreamEvent::Delta { content }) => {\n165\t                        on_delta(content.clone());\n166\t                        assistant_content.push_str(&content);\n167\t                    }\n168\t                    Ok(StreamEvent::ToolCallDone { tool_calls }) => {\n169\t                        captured_tool_calls.extend(tool_calls);\n170\t                    }\n171\t                    Ok(StreamEvent::Done { usage }) => {\n172\t                        last_usage = usage;\n173\t                        break;\n174\t                    }\n175\t                }\n176\t            }\n177\t\n178\t            // Save assistant message with tool_calls if any\n179\t            let ts = now_ms();\n180\t            let msg_id = format!(\"msg-{ts}-a\");\n181\t            let mut asst_msg = Message::new(msg_id, Role::Assistant, assistant_content, ts);\n182\t            if !captured_tool_calls.is_empty() {\n183\t                asst_msg.tool_calls = Some(captured_tool_calls.clone());\n184\t            }\n185\t            session.add_message(asst_msg, ts);\n186\t            self.repo.save(&session).await?;\n187\t\n188\t            // If no tool calls, we're done\n189\t            if captured_tool_calls.is_empty() {\n190\t                break;\n191\t            }\n192\t\n193\t            // Execute each tool call and add results to session\n194\t            for tc in &captured_tool_calls {\n195\t                if let Some(lifecycle) = lifecycle\n196\t                    && let Err(err) = lifecycle.before_tool_call().await\n197\t                {\n198\t                    tracing::warn!(\"computer-use before_tool_call hook failed: {err}\");\n199\t                }\n200\t\n201\t                let args_value: serde_json::Value =\n202\t                    serde_json::from_str(&tc.arguments).unwrap_or(serde_json::Value::Null);\n203\t                let result = execute_tool(tc.name.clone(), args_value).await;\n204\t\n205\t                let result_content = match result {\n206\t                    Ok(s) => s,\n207\t                    Err(e) => format!(\"{{\\\"error\\\": \\\"{}\\\"}}\", e.replace('\"', \"\\\\\\\"\")),\n208\t                };\n209\t                // Truncate oversized tool results before adding to context\n210\t                let result_content = if result_content.len() > self.context.tool_result_max_chars {\n211\t                    format!(\n212\t                        \"{}…[truncated: {} chars total, showing first {}]\",\n213\t                        &result_content[..self.context.tool_result_max_chars],\n214\t                        result_content.len(),\n215\t                        self.context.tool_result_max_chars,\n216\t                    )\n217\t                } else {\n218\t                    result_content\n219\t                };\n220\t\n221\t                let ts2 = now_ms();\n222\t                let result_msg = Message::new_tool_result(\n223\t                    format!(\"msg-{ts2}-t\"),\n224\t                    tc.id.clone(),\n225\t                    result_content,\n226\t                    ts2,\n227\t                );\n228\t                session.add_message(result_msg, ts2);\n229\t            }\n230\t            self.repo.save(&session).await?;\n231\t\n232\t            let _ = last_usage; // suppress unused warning\n233\t        }\n234\t\n235\t        run_after_turn_cleanup(lifecycle).await;\n236\t        Ok(session.id)\n237\t    }\n238\t\n239\t    /// Append the user message to the session (creating it if needed), then\n240\t    /// start a streaming completion.  Returns `(session_id, stream)`.\n241\t    ///\n242\t    /// After draining the stream, call [`finish`] to persist the assistant reply.\n243\t    pub async fn start(\n244\t        &self,\n245\t        session_id: Option<String>,\n246\t        user_content: String,\n247\t    ) -> Result<(SessionId, LlmStream), AppError> {\n248\t        let now = now_ms();\n249\t\n250\t        let mut session = match session_id {\n251\t            Some(ref id) => {\n252\t                let sid = SessionId(id.clone());\n253\t                self.repo\n254\t                    .find_by_id(&sid)\n255\t                    .await?\n256\t                    .unwrap_or_else(|| Session::new(id.clone(), now))\n257\t            }\n258\t            None => Session::new(format!(\"sess-{now}\"), now),\n259\t        };\n260\t\n261\t        let msg_id = format!(\"msg-{now}-u\");\n262\t        session.add_message(Message::new(msg_id, Role::User, user_content, now), now);\n263\t        self.repo.save(&session).await?;\n264\t\n265\t        let req = LlmRequest {\n266\t            messages: session.messages.clone(),\n267\t            model: None,\n268\t            max_tokens: None,\n269\t            temperature: None,\n270\t            tools: Vec::new(),\n271\t        };\n272\t\n273\t        let stream = self.provider.stream(req).await?;\n274\t        Ok((session.id, stream))\n275\t    }\n276\t\n277\t    /// Persist the collected assistant response to the session.\n278\t    pub async fn finish(\n279\t        &self,\n280\t        session_id: &SessionId,\n281\t        assistant_content: String,\n282\t    ) -> Result<(), AppError> {\n283\t        let now = now_ms();\n284\t        let mut session = self\n285\t            .repo\n286\t            .find_by_id(session_id)\n287\t            .await?\n288\t            .unwrap_or_else(|| Session::new(session_id.0.clone(), now));\n289\t\n290\t        let msg_id = format!(\"msg-{now}-a\");\n291\t        session.add_message(\n292\t            Message::new(msg_id, Role::Assistant, assistant_content, now),\n293\t            now,\n294\t        );\n295\t        self.repo.save(&session).await?;\n296\t        Ok(())\n297\t    }\n298\t}\n299\t\n300\tasync fn run_after_turn_cleanup(lifecycle: Option<&dyn ComputerUseLifecycle>) {\n301\t    if let Some(lifecycle) = lifecycle\n302\t        && let Err(err) = lifecycle.after_turn_cleanup().await\n303\t    {\n304\t        tracing::warn!(\"computer-use after_turn_cleanup hook failed: {err}\");\n305\t    }\n306\t}\n307\t\n308\tasync fn run_interrupt_cleanup(lifecycle: Option<&dyn ComputerUseLifecycle>) {\n309\t    if let Some(lifecycle) = lifecycle\n310\t        && let Err(err) = lifecycle.on_interrupt_cleanup().await\n311\t    {\n312\t        tracing::warn!(\"computer-use on_interrupt_cleanup hook failed: {err}\");\n313\t    }\n314\t}\n315\t\n316\t/// Summarise all but the most recent `keep_recent` messages into a single\n317\t/// system-level summary message, replacing the old messages in the session.\n318\tasync fn compress_context(\n319\t    mut session: Session,\n320\t    provider: &dyn LlmClient,\n321\t    keep_recent: usize,\n322\t) -> Result<Session, AppError> {\n323\t    let total = session.messages.len();\n324\t    if total <= keep_recent {\n325\t        return Ok(session);\n326\t    }\n327\t\n328\t    let split_at = total - keep_recent;\n329\t    let to_compress: Vec<_> = session.messages.drain(..split_at).collect();\n330\t    let recent = session.messages.clone();\n331\t\n332\t    // Build a text transcript for the LLM to summarise\n333\t    let transcript: String = to_compress\n334\t        .iter()\n335\t        .map(|m| {\n336\t            format!(\n337\t                \"[{}]: {}\",\n338\t                format!(\"{:?}\", m.role).to_lowercase(),\n339\t                m.content\n340\t            )\n341\t        })\n342\t        .collect::<Vec<_>>()\n343\t        .join(\"\\n\");\n344\t\n345\t    let summary_prompt = format!(\n346\t        \"Summarise the following conversation history concisely. \\\n347\t         Preserve key facts, decisions, tool results, and any important context \\\n348\t         the assistant will need to continue the task. \\\n349\t         Do not include meta-commentary about the summary itself.\\n\\n{transcript}\"\n350\t    );\n351\t\n352\t    let req = LlmRequest {\n353\t        messages: vec![Message::new(\n354\t            \"compress-req\",\n355\t            Role::User,\n356\t            summary_prompt,\n357\t            now_ms(),\n358\t        )],\n359\t        model: None,\n360\t        max_tokens: Some(1024),\n361\t        temperature: Some(0.0),\n362\t        tools: vec![],\n363\t    };\n364\t\n365\t    let summary_text = match provider.complete(req).await {\n366\t        Ok(r) => r.content,\n367\t        Err(_) => {\n368\t            // If compression fails, just restore and continue (non-fatal)\n369\t            let mut restored = to_compress;\n370\t            restored.extend(recent);\n371\t            session.messages = restored;\n372\t            return Ok(session);\n373\t        }\n374\t    };\n375\t\n376\t    let now = now_ms();\n377\t    let summary_msg = Message::new(\n378\t        format!(\"msg-{now}-summary\"),\n379\t        Role::System,\n380\t        format!(\"[Conversation summary — earlier context compressed]\\n{summary_text}\"),\n381\t        now,\n382\t    );\n383\t\n384\t    let mut new_messages = vec![summary_msg];\n385\t    new_messages.extend(recent);\n386\t    session.messages = new_messages;\n387\t\n388\t    tracing::info!(\n389\t        \"[compress] session {} reduced from {} → {} messages\",\n390\t        session.id,\n391\t        total,\n392\t        session.messages.len()\n393\t    );\n394\t\n395\t    Ok(session)\n396\t}\n397\t\n398\tfn now_ms() -> u64 {\n399\t    SystemTime::now()\n400\t        .duration_since(UNIX_EPOCH)\n401\t        .unwrap_or_default()\n402\t        .as_millis() as u64\n403\t}\n404\t\n405\t#[cfg(test)]\n406\tmod tests {\n407\t    use super::*;\n408\t    use async_trait::async_trait;\n409\t    use ccode_domain::session::{Session, SessionId, SessionSummary};\n410\t    use ccode_ports::{\n411\t        PortError,\n412\t        provider::{LlmError, LlmResponse},\n413\t    };\n414\t    use futures::stream;\n415\t    use std::collections::VecDeque;\n416\t    use std::sync::{\n417\t        Arc, Mutex,\n418\t        atomic::{AtomicUsize, Ordering},\n419\t    };\n420\t\n421\t    #[derive(Default)]\n422\t    struct MockRepo {\n423\t        sessions: Mutex<Vec<Session>>,\n424\t    }\n425\t\n426\t    #[async_trait]\n427\t    impl SessionRepository for MockRepo {\n428\t        async fn list(&self, _limit: usize) -> Result<Vec<SessionSummary>, PortError> {\n429\t            Ok(Vec::new())\n430\t        }\n431\t\n432\t        async fn find_by_id(&self, id: &SessionId) -> Result<Option<Session>, PortError> {\n433\t            let sessions = self.sessions.lock().expect(\"poisoned\");\n434\t            Ok(sessions.iter().find(|s| &s.id == id).cloned())\n435\t        }\n436\t\n437\t        async fn save(&self, session: &Session) -> Result<(), PortError> {\n438\t            let mut sessions = self.sessions.lock().expect(\"poisoned\");\n439\t            if let Some(existing) = sessions.iter_mut().find(|s| s.id == session.id) {\n440\t                *existing = session.clone();\n441\t            } else {\n442\t                sessions.push(session.clone());\n443\t            }\n444\t            Ok(())\n445\t        }\n446\t\n447\t        async fn delete(&self, _id: &SessionId) -> Result<(), PortError> {\n448\t            Ok(())\n449\t        }\n450\t    }\n451\t\n452\t    struct MockProvider {\n453\t        streams: Mutex<VecDeque<Vec<Result<StreamEvent, LlmError>>>>,\n454\t    }\n455\t\n456\t    #[async_trait]\n457\t    impl LlmClient for MockProvider {\n458\t        fn name(&self) -> &str {\n459\t            \"mock\"\n460\t        }\n461\t\n462\t        fn default_model(&self) -> &str {\n463\t            \"mock-model\"\n464\t        }\n465\t\n466\t        async fn health_check(&self) -> Result<(), LlmError> {\n467\t            Ok(())\n468\t        }\n469\t\n470\t        async fn complete(&self, _req: LlmRequest) -> Result<LlmResponse, LlmError> {\n471\t            Ok(LlmResponse {\n472\t                content: String::new(),\n473\t                model: \"mock-model\".to_string(),\n474\t                usage: None,\n475\t            })\n476\t        }\n477\t\n478\t        async fn stream(&self, _req: LlmRequest) -> Result<LlmStream, LlmError> {\n479\t            let mut streams = self.streams.lock().expect(\"poisoned\");\n480\t            let events = streams.pop_front().unwrap_or_default();\n481\t            Ok(Box::pin(stream::iter(events)))\n482\t        }\n483\t    }\n484\t\n485\t    #[derive(Default)]\n486\t    struct MockLifecycle {\n487\t        before_calls: AtomicUsize,\n488\t        cleanup_calls: AtomicUsize,\n489\t        interrupt_cleanup_calls: AtomicUsize,\n490\t        fail_cleanup: bool,\n491\t    }\n492\t\n493\t    #[async_trait]\n494\t    impl ComputerUseLifecycle for MockLifecycle {\n495\t        async fn before_tool_call(&self) -> Result<(), ComputerUseLifecycleError> {\n496\t            self.before_calls.fetch_add(1, Ordering::SeqCst);\n497\t            Ok(())\n498\t        }\n499\t\n500\t        async fn after_turn_cleanup(&self) -> Result<(), ComputerUseLifecycleError> {\n501\t            self.cleanup_calls.fetch_add(1, Ordering::SeqCst);\n502\t            if self.fail_cleanup {\n503\t                return Err(ComputerUseLifecycleError::CleanupFailed);\n504\t            }\n505\t            Ok(())\n506\t        }\n507\t\n508\t        async fn on_interrupt_cleanup(&self) -> Result<(), ComputerUseLifecycleError> {\n509\t            self.interrupt_cleanup_calls.fetch_add(1, Ordering::SeqCst);\n510\t            if self.fail_cleanup {\n511\t                return Err(ComputerUseLifecycleError::CleanupFailed);\n512\t            }\n513\t            Ok(())\n514\t        }\n515\t    }\n516\t\n517\t    #[tokio::test]\n518\t    async fn normal_exit_runs_cleanup_even_when_cleanup_returns_error() {\n519\t        let repo = MockRepo::default();\n520\t        let provider = Arc::new(MockProvider {\n521\t            streams: Mutex::new(VecDeque::from([vec![Ok(StreamEvent::Done {\n522\t                usage: None,\n523\t            })]])),\n524\t        });\n525\t        let lifecycle = Arc::new(MockLifecycle {\n526\t            fail_cleanup: true,\n527\t            ..Default::default()\n528\t        });\n529\t        let cmd =\n530\t            AgentRunCommand::new(repo, provider).with_computer_use_lifecycle(lifecycle.clone());\n531\t\n532\t        let session_id = cmd\n533\t            .run(\n534\t                None,\n535\t                None,\n536\t                \"hello\".to_string(),\n537\t                Vec::new(),\n538\t                &|_| {},\n539\t                &|_, _| Box::pin(async { Ok(String::new()) }),\n540\t            )\n541\t            .await\n542\t            .expect(\"cleanup failure must be non-fatal\");\n543\t\n544\t        assert!(!session_id.0.is_empty());\n545\t        assert_eq!(lifecycle.cleanup_calls.load(Ordering::SeqCst), 1);\n546\t        assert_eq!(lifecycle.interrupt_cleanup_calls.load(Ordering::SeqCst), 0);\n547\t    }\n548\t\n549\t    #[tokio::test]\n550\t    async fn stream_interrupt_runs_interrupt_cleanup() {\n551\t        let repo = MockRepo::default();\n552\t        let provider = Arc::new(MockProvider {\n553\t            streams: Mutex::new(VecDeque::from([vec![Err(LlmError::StreamInterrupted(\n554\t                \"ctrl-c\".to_string(),\n555\t            ))]])),\n556\t        });\n557\t        let lifecycle = Arc::new(MockLifecycle::default());\n558\t        let cmd =\n559\t            AgentRunCommand::new(repo, provider).with_computer_use_lifecycle(lifecycle.clone());\n560\t\n561\t        let result = cmd\n562\t            .run(\n563\t                None,\n564\t                None,\n565\t                \"hello\".to_string(),\n566\t                Vec::new(),\n567\t                &|_| {},\n568\t                &|_, _| Box::pin(async { Ok(String::new()) }),\n569\t            )\n570\t            .await;\n571\t\n572\t        assert!(matches!(\n573\t            result,\n574\t            Err(AppError::Llm(LlmError::StreamInterrupted(_)))\n575\t        ));\n576\t        assert_eq!(lifecycle.interrupt_cleanup_calls.load(Ordering::SeqCst), 1);\n577\t        assert_eq!(lifecycle.cleanup_calls.load(Ordering::SeqCst), 0);\n578\t    }\n579\t\n580\t    #[tokio::test]\n581\t    async fn lifecycle_before_tool_call_is_invoked_before_tool_execution() {\n582\t        let repo = MockRepo::default();\n583\t        let provider = Arc::new(MockProvider {\n584\t            streams: Mutex::new(VecDeque::from([\n585\t                vec![\n586\t                    Ok(StreamEvent::ToolCallDone {\n587\t                        tool_calls: vec![ccode_domain::message::ToolCall {\n588\t                            id: \"t1\".to_string(),\n589\t                            name: \"echo\".to_string(),\n590\t                            arguments: \"{}\".to_string(),\n591\t                        }],\n592\t                    }),\n593\t                    Ok(StreamEvent::Done { usage: None }),\n594\t                ],\n595\t                vec![Ok(StreamEvent::Done { usage: None })],\n596\t            ])),\n597\t        });\n598\t        let lifecycle = Arc::new(MockLifecycle::default());\n599\t        let cmd =\n600\t            AgentRunCommand::new(repo, provider).with_computer_use_lifecycle(lifecycle.clone());\n601\t\n602\t        let _ = cmd\n603\t            .run(\n604\t                None,\n605\t                None,\n606\t                \"hello\".to_string(),\n607\t                vec![ToolDefinition {\n608\t                    name: \"echo\".to_string(),\n609\t                    description: \"echo\".to_string(),\n610\t                    parameters: serde_json::json!({\"type\":\"object\"}),\n611\t                }],\n612\t                &|_| {},\n613\t                &|_, _| Box::pin(async { Ok(\"ok\".to_string()) }),\n614\t            )\n615\t            .await\n616\t            .expect(\"run should succeed\");\n617\t\n618\t        assert_eq!(lifecycle.before_calls.load(Ordering::SeqCst), 1);\n619\t        assert_eq!(lifecycle.cleanup_calls.load(Ordering::SeqCst), 1);\n620\t    }\n621\t}\n622\t"}]},"parent_tool_use_id":null,"session_id":"523981ce-25d5-4aed-a492-78dcbb263a10","uuid":"a1c7d468-bc57-4b00-b98f-953ff4aa46f4","timestamp":"2026-04-02T14:23:00.346Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/application/src/commands/agent_run.rs","content":"use crate::error::AppError;\nuse async_trait::async_trait;\nuse ccode_domain::{\n    message::{Message, Role},\n    session::{Session, SessionId},\n};\nuse ccode_ports::{\n    provider::{LlmClient, LlmError, LlmRequest, LlmStream, StreamEvent, ToolDefinition},\n    repositories::SessionRepository,\n};\nuse futures::StreamExt;\nuse std::future::Future;\nuse std::pin::Pin;\nuse std::sync::Arc;\nuse std::time::{SystemTime, UNIX_EPOCH};\n\n/// Configures context window management for the agentic loop.\n/// All values have sensible defaults — only override what you need.\n#[derive(Debug, Clone)]\npub struct ContextPolicy {\n    /// Trigger compression when total context size (all messages concatenated)\n    /// exceeds this many characters. Rough estimate: 4 chars ≈ 1 token.\n    /// Default: 600_000 (~150k tokens, leaves buffer for a 200k-context model).\n    pub compress_chars_threshold: usize,\n    /// Number of most-recent messages kept verbatim after compression.\n    /// Default: 8.\n    pub keep_recent_messages: usize,\n    /// Truncate any single tool result exceeding this many characters.\n    /// Default: 40_000 (~10k tokens).\n    pub tool_result_max_chars: usize,\n}\n\nimpl Default for ContextPolicy {\n    fn default() -> Self {\n        Self {\n            compress_chars_threshold: 600_000,\n            keep_recent_messages: 8,\n            tool_result_max_chars: 40_000,\n        }\n    }\n}\n\npub struct AgentRunCommand<R> {\n    repo: R,\n    provider: Arc<dyn LlmClient>,\n    context: ContextPolicy,\n    computer_use_lifecycle: Option<Arc<dyn ComputerUseLifecycle>>,\n}\n\ntype ExecuteToolFn = dyn Fn(String, serde_json::Value) -> Pin<Box<dyn Future<Output = Result<String, String>> + Send>>\n    + Send\n    + Sync;\n\n#[derive(Debug, thiserror::Error)]\npub enum ComputerUseLifecycleError {\n    #[error(\"transport error\")]\n    TransportError,\n    #[error(\"invalid tool payload\")]\n    InvalidToolPayload,\n    #[error(\"cleanup failed\")]\n    CleanupFailed,\n}\n\n#[async_trait]\npub trait ComputerUseLifecycle: Send + Sync {\n    async fn before_tool_call(&self) -> Result<(), ComputerUseLifecycleError>;\n    async fn after_turn_cleanup(&self) -> Result<(), ComputerUseLifecycleError>;\n    async fn on_interrupt_cleanup(&self) -> Result<(), ComputerUseLifecycleError>;\n}\n\nimpl<R: SessionRepository> AgentRunCommand<R> {\n    pub fn new(repo: R, provider: Arc<dyn LlmClient>) -> Self {\n        Self {\n            repo,\n            provider,\n            context: ContextPolicy::default(),\n            computer_use_lifecycle: None,\n        }\n    }\n\n    pub fn with_context(mut self, policy: ContextPolicy) -> Self {\n        self.context = policy;\n        self\n    }\n\n    pub fn with_computer_use_lifecycle(mut self, lifecycle: Arc<dyn ComputerUseLifecycle>) -> Self {\n        self.computer_use_lifecycle = Some(lifecycle);\n        self\n    }\n\n    /// Full agentic loop — keeps calling the model and executing tools until\n    /// the model produces no more tool calls (or max_iterations is reached).\n    pub async fn run(\n        &self,\n        session_id: Option<String>,\n        system_prompt: Option<String>,\n        user_content: String,\n        tools: Vec<ToolDefinition>,\n        on_delta: &(dyn Fn(String) + Send + Sync),\n        execute_tool: &ExecuteToolFn,\n    ) -> Result<SessionId, AppError> {\n        let lifecycle = self.computer_use_lifecycle.as_deref();\n        let now = now_ms();\n\n        let mut session = match session_id {\n            Some(ref id) => {\n                let sid = SessionId(id.clone());\n                self.repo\n                    .find_by_id(&sid)\n                    .await?\n                    .unwrap_or_else(|| Session::new(id.clone(), now))\n            }\n            None => Session::new(format!(\"sess-{now}\"), now),\n        };\n\n        // Prepend system prompt only when starting a fresh session\n        if let Some(ref prompt) = system_prompt\n            && session.messages.is_empty()\n        {\n            let sys_id = format!(\"msg-{now}-sys\");\n            session.add_message(Message::new(sys_id, Role::System, prompt.clone(), now), now);\n        }\n\n        // Add the user message\n        let msg_id = format!(\"msg-{now}-u\");\n        session.add_message(Message::new(msg_id, Role::User, user_content, now), now);\n        self.repo.save(&session).await?;\n\n        const MAX_ITERATIONS: usize = 10;\n\n        for _iter in 0..MAX_ITERATIONS {\n            // ── Context compression ────────────────────────────────────────────\n            // Trigger on total character size (not message count) to catch large\n            // tool results that would overflow the model's context window.\n            let total_chars: usize = session.messages.iter().map(|m| m.content.len()).sum();\n            if total_chars > self.context.compress_chars_threshold {\n                session =\n                    compress_context(session, &*self.provider, self.context.keep_recent_messages)\n                        .await?;\n                self.repo.save(&session).await?;\n            }\n\n            let req = LlmRequest {\n                messages: session.messages.clone(),\n                model: None,\n                max_tokens: None,\n                temperature: None,\n                tools: tools.clone(),\n            };\n\n            let mut stream = self.provider.stream(req).await?;\n\n            let mut assistant_content = String::new();\n            let mut captured_tool_calls: Vec<ccode_domain::message::ToolCall> = Vec::new();\n            let mut last_usage = None;\n\n            while let Some(event) = stream.next().await {\n                match event {\n                    Err(err @ LlmError::StreamInterrupted(_)) => {\n                        run_interrupt_cleanup(lifecycle).await;\n                        return Err(AppError::from(err));\n                    }\n                    Err(err) => return Err(AppError::from(err)),\n                    Ok(StreamEvent::Delta { content }) => {\n                        on_delta(content.clone());\n                        assistant_content.push_str(&content);\n                    }\n                    Ok(StreamEvent::ToolCallDone { tool_calls }) => {\n                        captured_tool_calls.extend(tool_calls);\n                    }\n                    Ok(StreamEvent::Done { usage }) => {\n                        last_usage = usage;\n                        break;\n                    }\n                }\n            }\n\n            // Save assistant message with tool_calls if any\n            let ts = now_ms();\n            let msg_id = format!(\"msg-{ts}-a\");\n            let mut asst_msg = Message::new(msg_id, Role::Assistant, assistant_content, ts);\n            if !captured_tool_calls.is_empty() {\n                asst_msg.tool_calls = Some(captured_tool_calls.clone());\n            }\n            session.add_message(asst_msg, ts);\n            self.repo.save(&session).await?;\n\n            // If no tool calls, we're done\n            if captured_tool_calls.is_empty() {\n                break;\n            }\n\n            // Execute each tool call and add results to session\n            for tc in &captured_tool_calls {\n                if let Some(lifecycle) = lifecycle\n                    && let Err(err) = lifecycle.before_tool_call().await\n                {\n                    tracing::warn!(\"computer-use before_tool_call hook failed: {err}\");\n                }\n\n                let args_value: serde_json::Value =\n                    serde_json::from_str(&tc.arguments).unwrap_or(serde_json::Value::Null);\n                let result = execute_tool(tc.name.clone(), args_value).await;\n\n                let result_content = match result {\n                    Ok(s) => s,\n                    Err(e) => format!(\"{{\\\"error\\\": \\\"{}\\\"}}\", e.replace('\"', \"\\\\\\\"\")),\n                };\n                // Truncate oversized tool results before adding to context\n                let result_content = if result_content.len() > self.context.tool_result_max_chars {\n                    format!(\n                        \"{}…[truncated: {} chars total, showing first {}]\",\n                        &result_content[..self.context.tool_result_max_chars],\n                        result_content.len(),\n                        self.context.tool_result_max_chars,\n                    )\n                } else {\n                    result_content\n                };\n\n                let ts2 = now_ms();\n                let result_msg = Message::new_tool_result(\n                    format!(\"msg-{ts2}-t\"),\n                    tc.id.clone(),\n                    result_content,\n                    ts2,\n                );\n                session.add_message(result_msg, ts2);\n            }\n            self.repo.save(&session).await?;\n\n            let _ = last_usage; // suppress unused warning\n        }\n\n        run_after_turn_cleanup(lifecycle).await;\n        Ok(session.id)\n    }\n\n    /// Append the user message to the session (creating it if needed), then\n    /// start a streaming completion.  Returns `(session_id, stream)`.\n    ///\n    /// After draining the stream, call [`finish`] to persist the assistant reply.\n    pub async fn start(\n        &self,\n        session_id: Option<String>,\n        user_content: String,\n    ) -> Result<(SessionId, LlmStream), AppError> {\n        let now = now_ms();\n\n        let mut session = match session_id {\n            Some(ref id) => {\n                let sid = SessionId(id.clone());\n                self.repo\n                    .find_by_id(&sid)\n                    .await?\n                    .unwrap_or_else(|| Session::new(id.clone(), now))\n            }\n            None => Session::new(format!(\"sess-{now}\"), now),\n        };\n\n        let msg_id = format!(\"msg-{now}-u\");\n        session.add_message(Message::new(msg_id, Role::User, user_content, now), now);\n        self.repo.save(&session).await?;\n\n        let req = LlmRequest {\n            messages: session.messages.clone(),\n            model: None,\n            max_tokens: None,\n            temperature: None,\n            tools: Vec::new(),\n        };\n\n        let stream = self.provider.stream(req).await?;\n        Ok((session.id, stream))\n    }\n\n    /// Persist the collected assistant response to the session.\n    pub async fn finish(\n        &self,\n        session_id: &SessionId,\n        assistant_content: String,\n    ) -> Result<(), AppError> {\n        let now = now_ms();\n        let mut session = self\n            .repo\n            .find_by_id(session_id)\n            .await?\n            .unwrap_or_else(|| Session::new(session_id.0.clone(), now));\n\n        let msg_id = format!(\"msg-{now}-a\");\n        session.add_message(\n            Message::new(msg_id, Role::Assistant, assistant_content, now),\n            now,\n        );\n        self.repo.save(&session).await?;\n        Ok(())\n    }\n}\n\nasync fn run_after_turn_cleanup(lifecycle: Option<&dyn ComputerUseLifecycle>) {\n    if let Some(lifecycle) = lifecycle\n        && let Err(err) = lifecycle.after_turn_cleanup().await\n    {\n        tracing::warn!(\"computer-use after_turn_cleanup hook failed: {err}\");\n    }\n}\n\nasync fn run_interrupt_cleanup(lifecycle: Option<&dyn ComputerUseLifecycle>) {\n    if let Some(lifecycle) = lifecycle\n        && let Err(err) = lifecycle.on_interrupt_cleanup().await\n    {\n        tracing::warn!(\"computer-use on_interrupt_cleanup hook failed: {err}\");\n    }\n}\n\n/// Summarise all but the most recent `keep_recent` messages into a single\n/// system-level summary message, replacing the old messages in the session.\nasync fn compress_context(\n    mut session: Session,\n    provider: &dyn LlmClient,\n    keep_recent: usize,\n) -> Result<Session, AppError> {\n    let total = session.messages.len();\n    if total <= keep_recent {\n        return Ok(session);\n    }\n\n    let split_at = total - keep_recent;\n    let to_compress: Vec<_> = session.messages.drain(..split_at).collect();\n    let recent = session.messages.clone();\n\n    // Build a text transcript for the LLM to summarise\n    let transcript: String = to_compress\n        .iter()\n        .map(|m| {\n            format!(\n                \"[{}]: {}\",\n                format!(\"{:?}\", m.role).to_lowercase(),\n                m.content\n            )\n        })\n        .collect::<Vec<_>>()\n        .join(\"\\n\");\n\n    let summary_prompt = format!(\n        \"Summarise the following conversation history concisely. \\\n         Preserve key facts, decisions, tool results, and any important context \\\n         the assistant will need to continue the task. \\\n         Do not include meta-commentary about the summary itself.\\n\\n{transcript}\"\n    );\n\n    let req = LlmRequest {\n        messages: vec![Message::new(\n            \"compress-req\",\n            Role::User,\n            summary_prompt,\n            now_ms(),\n        )],\n        model: None,\n        max_tokens: Some(1024),\n        temperature: Some(0.0),\n        tools: vec![],\n    };\n\n    let summary_text = match provider.complete(req).await {\n        Ok(r) => r.content,\n        Err(_) => {\n            // If compression fails, just restore and continue (non-fatal)\n            let mut restored = to_compress;\n            restored.extend(recent);\n            session.messages = restored;\n            return Ok(session);\n        }\n    };\n\n    let now = now_ms();\n    let summary_msg = Message::new(\n        format!(\"msg-{now}-summary\"),\n        Role::System,\n        format!(\"[Conversation summary — earlier context compressed]\\n{summary_text}\"),\n        now,\n    );\n\n    let mut new_messages = vec![summary_msg];\n    new_messages.extend(recent);\n    session.messages = new_messages;\n\n    tracing::info!(\n        \"[compress] session {} reduced from {} → {} messages\",\n        session.id,\n        total,\n        session.messages.len()\n    );\n\n    Ok(session)\n}\n\nfn now_ms() -> u64 {\n    SystemTime::now()\n        .duration_since(UNIX_EPOCH)\n        .unwrap_or_default()\n        .as_millis() as u64\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use async_trait::async_trait;\n    use ccode_domain::session::{Session, SessionId, SessionSummary};\n    use ccode_ports::{\n        PortError,\n        provider::{LlmError, LlmResponse},\n    };\n    use futures::stream;\n    use std::collections::VecDeque;\n    use std::sync::{\n        Arc, Mutex,\n        atomic::{AtomicUsize, Ordering},\n    };\n\n    #[derive(Default)]\n    struct MockRepo {\n        sessions: Mutex<Vec<Session>>,\n    }\n\n    #[async_trait]\n    impl SessionRepository for MockRepo {\n        async fn list(&self, _limit: usize) -> Result<Vec<SessionSummary>, PortError> {\n            Ok(Vec::new())\n        }\n\n        async fn find_by_id(&self, id: &SessionId) -> Result<Option<Session>, PortError> {\n            let sessions = self.sessions.lock().expect(\"poisoned\");\n            Ok(sessions.iter().find(|s| &s.id == id).cloned())\n        }\n\n        async fn save(&self, session: &Session) -> Result<(), PortError> {\n            let mut sessions = self.sessions.lock().expect(\"poisoned\");\n            if let Some(existing) = sessions.iter_mut().find(|s| s.id == session.id) {\n                *existing = session.clone();\n            } else {\n                sessions.push(session.clone());\n            }\n            Ok(())\n        }\n\n        async fn delete(&self, _id: &SessionId) -> Result<(), PortError> {\n            Ok(())\n        }\n    }\n\n    struct MockProvider {\n        streams: Mutex<VecDeque<Vec<Result<StreamEvent, LlmError>>>>,\n    }\n\n    #[async_trait]\n    impl LlmClient for MockProvider {\n        fn name(&self) -> &str {\n            \"mock\"\n        }\n\n        fn default_model(&self) -> &str {\n            \"mock-model\"\n        }\n\n        async fn health_check(&self) -> Result<(), LlmError> {\n            Ok(())\n        }\n\n        async fn complete(&self, _req: LlmRequest) -> Result<LlmResponse, LlmError> {\n            Ok(LlmResponse {\n                content: String::new(),\n                model: \"mock-model\".to_string(),\n                usage: None,\n            })\n        }\n\n        async fn stream(&self, _req: LlmRequest) -> Result<LlmStream, LlmError> {\n            let mut streams = self.streams.lock().expect(\"poisoned\");\n            let events = streams.pop_front().unwrap_or_default();\n            Ok(Box::pin(stream::iter(events)))\n        }\n    }\n\n    #[derive(Default)]\n    struct MockLifecycle {\n        before_calls: AtomicUsize,\n        cleanup_calls: AtomicUsize,\n        interrupt_cleanup_calls: AtomicUsize,\n        fail_cleanup: bool,\n    }\n\n    #[async_trait]\n    impl ComputerUseLifecycle for MockLifecycle {\n        async fn before_tool_call(&self) -> Result<(), ComputerUseLifecycleError> {\n            self.before_calls.fetch_add(1, Ordering::SeqCst);\n            Ok(())\n        }\n\n        async fn after_turn_cleanup(&self) -> Result<(), ComputerUseLifecycleError> {\n            self.cleanup_calls.fetch_add(1, Ordering::SeqCst);\n            if self.fail_cleanup {\n                return Err(ComputerUseLifecycleError::CleanupFailed);\n            }\n            Ok(())\n        }\n\n        async fn on_interrupt_cleanup(&self) -> Result<(), ComputerUseLifecycleError> {\n            self.interrupt_cleanup_calls.fetch_add(1, Ordering::SeqCst);\n            if self.fail_cleanup {\n                return Err(ComputerUseLifecycleError::CleanupFailed);\n            }\n            Ok(())\n        }\n    }\n\n    #[tokio::test]\n    async fn normal_exit_runs_cleanup_even_when_cleanup_returns_error() {\n        let repo = MockRepo::default();\n        let provider = Arc::new(MockProvider {\n            streams: Mutex::new(VecDeque::from([vec![Ok(StreamEvent::Done {\n                usage: None,\n            })]])),\n        });\n        let lifecycle = Arc::new(MockLifecycle {\n            fail_cleanup: true,\n            ..Default::default()\n        });\n        let cmd =\n            AgentRunCommand::new(repo, provider).with_computer_use_lifecycle(lifecycle.clone());\n\n        let session_id = cmd\n            .run(\n                None,\n                None,\n                \"hello\".to_string(),\n                Vec::new(),\n                &|_| {},\n                &|_, _| Box::pin(async { Ok(String::new()) }),\n            )\n            .await\n            .expect(\"cleanup failure must be non-fatal\");\n\n        assert!(!session_id.0.is_empty());\n        assert_eq!(lifecycle.cleanup_calls.load(Ordering::SeqCst), 1);\n        assert_eq!(lifecycle.interrupt_cleanup_calls.load(Ordering::SeqCst), 0);\n    }\n\n    #[tokio::test]\n    async fn stream_interrupt_runs_interrupt_cleanup() {\n        let repo = MockRepo::default();\n        let provider = Arc::new(MockProvider {\n            streams: Mutex::new(VecDeque::from([vec![Err(LlmError::StreamInterrupted(\n                \"ctrl-c\".to_string(),\n            ))]])),\n        });\n        let lifecycle = Arc::new(MockLifecycle::default());\n        let cmd =\n            AgentRunCommand::new(repo, provider).with_computer_use_lifecycle(lifecycle.clone());\n\n        let result = cmd\n            .run(\n                None,\n                None,\n                \"hello\".to_string(),\n                Vec::new(),\n                &|_| {},\n                &|_, _| Box::pin(async { Ok(String::new()) }),\n            )\n            .await;\n\n        assert!(matches!(\n            result,\n            Err(AppError::Llm(LlmError::StreamInterrupted(_)))\n        ));\n        assert_eq!(lifecycle.interrupt_cleanup_calls.load(Ordering::SeqCst), 1);\n        assert_eq!(lifecycle.cleanup_calls.load(Ordering::SeqCst), 0);\n    }\n\n    #[tokio::test]\n    async fn lifecycle_before_tool_call_is_invoked_before_tool_execution() {\n        let repo = MockRepo::default();\n        let provider = Arc::new(MockProvider {\n            streams: Mutex::new(VecDeque::from([\n                vec![\n                    Ok(StreamEvent::ToolCallDone {\n                        tool_calls: vec![ccode_domain::message::ToolCall {\n                            id: \"t1\".to_string(),\n                            name: \"echo\".to_string(),\n                            arguments: \"{}\".to_string(),\n                        }],\n                    }),\n                    Ok(StreamEvent::Done { usage: None }),\n                ],\n                vec![Ok(StreamEvent::Done { usage: None })],\n            ])),\n        });\n        let lifecycle = Arc::new(MockLifecycle::default());\n        let cmd =\n            AgentRunCommand::new(repo, provider).with_computer_use_lifecycle(lifecycle.clone());\n\n        let _ = cmd\n            .run(\n                None,\n                None,\n                \"hello\".to_string(),\n                vec![ToolDefinition {\n                    name: \"echo\".to_string(),\n                    description: \"echo\".to_string(),\n                    parameters: serde_json::json!({\"type\":\"object\"}),\n                }],\n                &|_| {},\n                &|_, _| Box::pin(async { Ok(\"ok\".to_string()) }),\n            )\n            .await\n            .expect(\"run should succeed\");\n\n        assert_eq!(lifecycle.before_calls.load(Ordering::SeqCst), 1);\n        assert_eq!(lifecycle.cleanup_calls.load(Ordering::SeqCst), 1);\n    }\n}\n","numLines":622,"startLine":1,"totalLines":622}}}
