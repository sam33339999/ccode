    let cli = Cli::parse();\n    if let Err(e) = cmd::run(cli.command).await {\n        eprintln!(\"{}\", render_error(&e, &ErrorContext::unknown()));\n        std::process::exit(1);\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::Cli;\n    use clap::Parser;\n\n    #[test]\n    fn parses_tui_subcommand() {\n        assert!(\n            Cli::try_parse_from([\"ccode\", \"tui\"]).is_ok(),\n            \"`ccode tui` should parse\"\n        );\n    }\n}\n","numLines":41,"startLine":1,"totalLines":41}}}
