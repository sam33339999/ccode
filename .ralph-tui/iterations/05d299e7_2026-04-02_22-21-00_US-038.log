ug, thiserror::Error)]\n61\tpub enum McpRuntimeError {\n62\t    #[error(\"transport error\")]\n63\t    TransportError,\n64\t    #[error(\"invalid tool payload\")]\n65\t    InvalidToolPayload,\n66\t    #[error(\"cleanup failed\")]\n67\t    CleanupFailed,\n68\t}\n69\t\n70\timpl From<McpRuntimeError> for McpPolicyError {\n71\t    fn from(value: McpRuntimeError) -> Self {\n72\t        match value {\n73\t            McpRuntimeError::TransportError => Self::TransportError,\n74\t            McpRuntimeError::InvalidToolPayload => Self::InvalidToolPayload,\n75\t            McpRuntimeError::CleanupFailed => Self::CleanupFailed,\n76\t        }\n77\t    }\n78\t}\n79\t\n80\tpub trait McpCapabilityPolicy: Send + Sync {\n81\t    fn validate_server_name(&self, name: &str) -> Result<(), McpPolicyError>;\n82\t    fn capability_level(&self, server: &McpServerRef) -> CapabilityLevel;\n83\t}\n84\t\n85\t#[async_trait]\n86\tpub trait ComputerUseLifecycle: Send + Sync {\n87\t    async fn before_tool_call(&self) -> Result<(), McpRuntimeError>;\n88\t    async fn after_turn_cleanup(&self) -> Result<(), McpRuntimeError>;\n89\t    async fn on_interrupt_cleanup(&self) -> Result<(), McpRuntimeError>;\n90\t}\n91\t\n92\tpub struct DefaultMcpCapabilityPolicy {\n93\t    reserved_server_names: BTreeSet<String>,\n94\t    allow_privileged_computer_use: bool,\n95\t}\n96\t\n97\timpl DefaultMcpCapabilityPolicy {\n98\t    pub fn new(_chicago_mcp_feature_gate: bool, allow_privileged_computer_use: bool) -> Self {\n99\t        let mut reserved_server_names = BTreeSet::new();\n100\t        reserved_server_names.insert(\"computer\".to_string());\n101\t        Self {\n102\t            reserved_server_names,\n103\t            allow_privileged_computer_use,\n104\t        }\n105\t    }\n106\t}\n107\t\n108\timpl McpCapabilityPolicy for DefaultMcpCapabilityPolicy {\n109\t    fn validate_server_name(&self, name: &str) -> Result<(), McpPolicyError> {\n110\t        let lowered = name.to_ascii_lowercase();\n111\t        if self.reserved_server_names.contains(&lowered) {\n112\t            return Err(McpPolicyError::ReservedServerName);\n113\t        }\n114\t        Ok(())\n115\t    }\n116\t\n117\t    fn capability_level(&self, server: &McpServerRef) -> CapabilityLevel {\n118\t        if server.computer_use_requested && self.allow_privileged_computer_use {\n119\t            CapabilityLevel::PrivilegedComputerUse\n120\t        } else {\n121\t            CapabilityLevel::Standard\n122\t        }\n123\t    }\n124\t}\n125\t\n126\tpub fn enforce_capability_policy(\n127\t    policy: &dyn McpCapabilityPolicy,\n128\t    server: &McpServerRef,\n129\t    chicago_mcp_feature_gate: bool,\n130\t) -> Result<CapabilityLevel, McpPolicyError> {\n131\t    policy.validate_server_name(&server.name)?;\n132\t\n133\t    if !server.computer_use_requested {\n134\t        return Ok(CapabilityLevel::Standard);\n135\t    }\n136\t\n137\t    if !chicago_mcp_feature_gate {\n138\t        return Err(McpPolicyError::FeatureGateDisabled);\n139\t    }\n140\t\n141\t    if !server.supports(CapabilityLevel::PrivilegedComputerUse) {\n142\t        return Err(McpPolicyError::PrivilegedCapabilityDenied);\n143\t    }\n144\t\n145\t    let negotiated = policy.capability_level(server);\n146\t    if negotiated != CapabilityLevel::PrivilegedComputerUse {\n147\t        return Err(McpPolicyError::PrivilegedCapabilityDenied);\n148\t    }\n149\t\n150\t    Ok(negotiated)\n151\t}\n152\t\n153\t#[cfg(test)]\n154\tmod tests {\n155\t    use super::*;\n156\t\n157\t    #[test]\n158\t    fn reserved_name_is_rejected() {\n159\t        let policy = DefaultMcpCapabilityPolicy::new(true, false);\n160\t        let server =\n161\t            McpServerRef::new(\"computer\").with_declared_capabilities([CapabilityLevel::Standard]);\n162\t        let err =\n163\t            enforce_capability_policy(&policy, &server, true).expect_err(\"must reject reserved\");\n164\t        assert!(matches!(err, McpPolicyError::ReservedServerName));\n165\t    }\n166\t\n167\t    #[test]\n168\t    fn privileged_requires_gate_and_policy_pass() {\n169\t        let policy = DefaultMcpCapabilityPolicy::new(false, true);\n170\t        let server = McpServerRef::new(\"desktop\")\n171\t            .with_computer_use_requested(true)\n172\t            .with_declared_capabilities([CapabilityLevel::PrivilegedComputerUse]);\n173\t        let err = enforce_capability_policy(&policy, &server, false)\n174\t            .expect_err(\"must fail when feature gate is disabled\");\n175\t        assert!(matches!(err, McpPolicyError::FeatureGateDisabled));\n176\t    }\n177\t\n178\t    #[test]\n179\t    fn capability_negotiation_only_enables_declared_capabilities() {\n180\t        let policy = DefaultMcpCapabilityPolicy::new(true, true);\n181\t        let server = McpServerRef::new(\"desktop\").with_computer_use_requested(true);\n182\t        let err = enforce_capability_policy(&policy, &server, true)\n183\t            .expect_err(\"must fail when server does not declare support\");\n184\t        assert!(matches!(err, McpPolicyError::PrivilegedCapabilityDenied));\n185\t    }\n186\t}\n187\t"}]},"parent_tool_use_id":null,"session_id":"523981ce-25d5-4aed-a492-78dcbb263a10","uuid":"ee3511ee-d98f-4a70-a4f3-19a096e279ec","timestamp":"2026-04-02T14:22:55.038Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/mcp-runtime/src/contracts.rs","content":"use async_trait::async_trait;\nuse std::collections::BTreeSet;\n\n#[derive(Debug, Clone)]\npub struct McpServerRef {\n    pub name: String,\n    pub computer_use_requested: bool,\n    declared_capabilities: BTreeSet<CapabilityLevel>,\n}\n\nimpl McpServerRef {\n    pub fn new(name: impl Into<String>) -> Self {\n        Self {\n            name: name.into(),\n            computer_use_requested: false,\n            declared_capabilities: BTreeSet::from([CapabilityLevel::Standard]),\n        }\n    }\n\n    pub fn with_computer_use_requested(mut self, requested: bool) -> Self {\n        self.computer_use_requested = requested;\n        self\n    }\n\n    pub fn with_declared_capabilities(\n        mut self,\n        capabilities: impl IntoIterator<Item = CapabilityLevel>,\n    ) -> Self {\n        self.declared_capabilities = capabilities.into_iter().collect();\n        self\n    }\n\n    pub fn supports(&self, capability: CapabilityLevel) -> bool {\n        self.declared_capabilities.contains(&capability)\n    }\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]\npub enum CapabilityLevel {\n    Standard,\n    PrivilegedComputerUse,\n}\n\n#[derive(Debug, thiserror::Error)]\npub enum McpPolicyError {\n    #[error(\"reserved server name\")]\n    ReservedServerName,\n    #[error(\"feature gate disabled\")]\n    FeatureGateDisabled,\n    #[error(\"privileged capability denied\")]\n    PrivilegedCapabilityDenied,\n    #[error(\"transport error\")]\n    TransportError,\n    #[error(\"invalid tool payload\")]\n    InvalidToolPayload,\n    #[error(\"cleanup failed\")]\n    CleanupFailed,\n}\n\n#[derive(Debug, thiserror::Error)]\npub enum McpRuntimeError {\n    #[error(\"transport error\")]\n    TransportError,\n    #[error(\"invalid tool payload\")]\n    InvalidToolPayload,\n    #[error(\"cleanup failed\")]\n    CleanupFailed,\n}\n\nimpl From<McpRuntimeError> for McpPolicyError {\n    fn from(value: McpRuntimeError) -> Self {\n        match value {\n            McpRuntimeError::TransportError => Self::TransportError,\n            McpRuntimeError::InvalidToolPayload => Self::InvalidToolPayload,\n            McpRuntimeError::CleanupFailed => Self::CleanupFailed,\n        }\n    }\n}\n\npub trait McpCapabilityPolicy: Send + Sync {\n    fn validate_server_name(&self, name: &str) -> Result<(), McpPolicyError>;\n    fn capability_level(&self, server: &McpServerRef) -> CapabilityLevel;\n}\n\n#[async_trait]\npub trait ComputerUseLifecycle: Send + Sync {\n    async fn before_tool_call(&self) -> Result<(), McpRuntimeError>;\n    async fn after_turn_cleanup(&self) -> Result<(), McpRuntimeError>;\n    async fn on_interrupt_cleanup(&self) -> Result<(), McpRuntimeError>;\n}\n\npub struct DefaultMcpCapabilityPolicy {\n    reserved_server_names: BTreeSet<String>,\n    allow_privileged_computer_use: bool,\n}\n\nimpl DefaultMcpCapabilityPolicy {\n    pub fn new(_chicago_mcp_feature_gate: bool, allow_privileged_computer_use: bool) -> Self {\n        let mut reserved_server_names = BTreeSet::new();\n        reserved_server_names.insert(\"computer\".to_string());\n        Self {\n            reserved_server_names,\n            allow_privileged_computer_use,\n        }\n    }\n}\n\nimpl McpCapabilityPolicy for DefaultMcpCapabilityPolicy {\n    fn validate_server_name(&self, name: &str) -> Result<(), McpPolicyError> {\n        let lowered = name.to_ascii_lowercase();\n        if self.reserved_server_names.contains(&lowered) {\n            return Err(McpPolicyError::ReservedServerName);\n        }\n        Ok(())\n    }\n\n    fn capability_level(&self, server: &McpServerRef) -> CapabilityLevel {\n        if server.computer_use_requested && self.allow_privileged_computer_use {\n            CapabilityLevel::PrivilegedComputerUse\n        } else {\n            CapabilityLevel::Standard\n        }\n    }\n}\n\npub fn enforce_capability_policy(\n    policy: &dyn McpCapabilityPolicy,\n    server: &McpServerRef,\n    chicago_mcp_feature_gate: bool,\n) -> Result<CapabilityLevel, McpPolicyError> {\n    policy.validate_server_name(&server.name)?;\n\n    if !server.computer_use_requested {\n        return Ok(CapabilityLevel::Standard);\n    }\n\n    if !chicago_mcp_feature_gate {\n        return Err(McpPolicyError::FeatureGateDisabled);\n    }\n\n    if !server.supports(CapabilityLevel::PrivilegedComputerUse) {\n        return Err(McpPolicyError::PrivilegedCapabilityDenied);\n    }\n\n    let negotiated = policy.capability_level(server);\n    if negotiated != CapabilityLevel::PrivilegedComputerUse {\n        return Err(McpPolicyError::PrivilegedCapabilityDenied);\n    }\n\n    Ok(negotiated)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn reserved_name_is_rejected() {\n        let policy = DefaultMcpCapabilityPolicy::new(true, false);\n        let server =\n            McpServerRef::new(\"computer\").with_declared_capabilities([CapabilityLevel::Standard]);\n        let err =\n            enforce_capability_policy(&policy, &server, true).expect_err(\"must reject reserved\");\n        assert!(matches!(err, McpPolicyError::ReservedServerName));\n    }\n\n    #[test]\n    fn privileged_requires_gate_and_policy_pass() {\n        let policy = DefaultMcpCapabilityPolicy::new(false, true);\n        let server = McpServerRef::new(\"desktop\")\n            .with_computer_use_requested(true)\n            .with_declared_capabilities([CapabilityLevel::PrivilegedComputerUse]);\n        let err = enforce_capability_policy(&policy, &server, false)\n            .expect_err(\"must fail when feature gate is disabled\");\n        assert!(matches!(err, McpPolicyError::FeatureGateDisabled));\n    }\n\n    #[test]\n    fn capability_negotiation_only_enables_declared_capabilities() {\n        let policy = DefaultMcpCapabilityPolicy::new(true, true);\n        let server = McpServerRef::new(\"desktop\").with_computer_use_requested(true);\n        let err = enforce_capability_policy(&policy, &server, true)\n            .expect_err(\"must fail when server does not declare support\");\n        assert!(matches!(err, McpPolicyError::PrivilegedCapabilityDenied));\n    }\n}\n","numLines":187,"startLine":1,"totalLines":187}}}
