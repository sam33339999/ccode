{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U3upv9kYs3EA1t9xguyC2o","type":"tool_result","content":"1\tuse async_trait::async_trait;\n2\tuse serde_json::json;\n3\tuse std::collections::VecDeque;\n4\t\n5\tuse crate::client::JsonRpcMcpClient;\n6\tuse crate::transport::{McpTransport, TransportError};\n7\t\n8\tstruct MockTransport {\n9\t    sent: Vec<serde_json::Value>,\n10\t    recv: VecDeque<Result<serde_json::Value, TransportError>>,\n11\t}\n12\t\n13\timpl MockTransport {\n14\t    fn with_responses(responses: Vec<Result<serde_json::Value, TransportError>>) -> Self {\n15\t        Self {\n16\t            sent: Vec::new(),\n17\t            recv: responses.into(),\n18\t        }\n19\t    }\n20\t}\n21\t\n22\t#[async_trait]\n23\timpl McpTransport for MockTransport {\n24\t    async fn send(&mut self, message: &serde_json::Value) -> Result<(), TransportError> {\n25\t        self.sent.push(message.clone());\n26\t        Ok(())\n27\t    }\n28\t\n29\t    async fn receive(&mut self) -> Result<serde_json::Value, TransportError> {\n30\t        self.recv\n31\t            .pop_front()\n32\t            .expect(\"mock must have queued response\")\n33\t    }\n34\t\n35\t    async fn close(&mut self) -> Result<(), TransportError> {\n36\t        Ok(())\n37\t    }\n38\t}\n39\t\n40\t#[tokio::test]\n41\tasync fn list_tools_parses_tool_definitions() {\n42\t    let response = json!({\n43\t        \"jsonrpc\": \"2.0\",\n44\t        \"id\": 1,\n45\t        \"result\": {\n46\t            \"tools\": [\n47\t                {\n48\t                    \"name\": \"read_file\",\n49\t                    \"description\": \"Read file\",\n50\t                    \"inputSchema\": {\n51\t                        \"type\": \"object\",\n52\t                        \"properties\": {\n53\t                            \"path\": { \"type\": \"string\" }\n54\t                        },\n55\t                        \"required\": [\"path\"]\n56\t                    }\n57\t                }\n58\t            ]\n59\t        }\n60\t    });\n61\t    let mock = MockTransport::with_responses(vec![Ok(response)]);\n62\t    let mut client = JsonRpcMcpClient::new(Box::new(mock));\n63\t\n64\t    let tools = client\n65\t        .list_tools()\n66\t        .await\n67\t        .expect(\"tools/list should succeed\");\n68\t\n69\t    assert_eq!(tools.len(), 1);\n70\t    assert_eq!(tools[0].name, \"read_file\");\n71\t    assert_eq!(tools[0].description, \"Read file\");\n72\t    assert_eq!(tools[0].input_schema[\"type\"], \"object\");\n73\t}\n74\t\n75\t#[tokio::test]\n76\tasync fn call_tool_returns_result_payload() {\n77\t    let response = json!({\n78\t        \"jsonrpc\": \"2.0\",\n79\t        \"id\": 1,\n80\t        \"result\": {\n81\t            \"content\": [\n82\t                { \"type\": \"text\", \"text\": \"hello\" }\n83\t            ]\n84\t        }\n85\t    });\n86\t    let mock = MockTransport::with_responses(vec![Ok(response)]);\n87\t    let mut client = JsonRpcMcpClient::new(Box::new(mock));\n88\t\n89\t    let result = client\n90\t        .call_tool(\"echo\", json!({\"message\":\"hello\"}))\n91\t        .await\n92\t        .expect(\"tools/call should succeed\");\n93\t\n94\t    assert_eq!(\n95\t        result[\"content\"][0][\"text\"].as_str(),\n96\t        Some(\"hello\"),\n97\t        \"result payload should flow through\"\n98\t    );\n99\t}\n100\t"}]},"parent_tool_use_id":"toolu_01AmhVkZizi2XSNnQreLfzwh","session_id":"523981ce-25d5-4aed-a492-78dcbb263a10","uuid":"b9a1be9e-5d7f-4ef2-9a1c-c0c287006130","timestamp":"2026-04-02T14:21:36.974Z"}
