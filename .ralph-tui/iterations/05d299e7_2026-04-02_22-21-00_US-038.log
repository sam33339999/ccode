{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01He7LCNEGtxtgTSa24HCJJW","type":"tool_result","content":"1\tuse crate::error::AppError;\n2\tuse async_trait::async_trait;\n3\tuse ccode_domain::{\n4\t    message::{Message, Role},\n5\t    session::{Session, SessionId},\n6\t};\n7\tuse ccode_ports::{\n8\t    provider::{LlmClient, LlmError, LlmRequest, LlmStream, StreamEvent, ToolDefinition},\n9\t    repositories::SessionRepository,\n10\t};\n11\tuse futures::StreamExt;\n12\tuse std::future::Future;\n13\tuse std::pin::Pin;\n14\tuse std::sync::Arc;\n15\tuse std::time::{SystemTime, UNIX_EPOCH};\n16\t\n17\t/// Configures context window management for the agentic loop.\n18\t/// All values have sensible defaults — only override what you need.\n19\t#[derive(Debug, Clone)]\n20\tpub struct ContextPolicy {\n21\t    /// Trigger compression when total context size (all messages concatenated)\n22\t    /// exceeds this many characters. Rough estimate: 4 chars ≈ 1 token.\n23\t    /// Default: 600_000 (~150k tokens, leaves buffer for a 200k-context model).\n24\t    pub compress_chars_threshold: usize,\n25\t    /// Number of most-recent messages kept verbatim after compression.\n26\t    /// Default: 8.\n27\t    pub keep_recent_messages: usize,\n28\t    /// Truncate any single tool result exceeding this many characters.\n29\t    /// Default: 40_000 (~10k tokens).\n30\t    pub tool_result_max_chars: usize,\n31\t}\n32\t\n33\timpl Default for ContextPolicy {\n34\t    fn default() -> Self {\n35\t        Self {\n36\t            compress_chars_threshold: 600_000,\n37\t            keep_recent_messages: 8,\n38\t            tool_result_max_chars: 40_000,\n39\t        }\n40\t    }\n41\t}\n42\t\n43\tpub struct AgentRunCommand<R> {\n44\t    repo: R,\n45\t    provider: Arc<dyn LlmClient>,\n46\t    context: ContextPolicy,\n47\t    computer_use_lifecycle: Option<Arc<dyn ComputerUseLifecycle>>,\n48\t}\n49\t\n50\ttype ExecuteToolFn = dyn Fn(String, serde_json::Value) -> Pin<Box<dyn Future<Output = Result<String, String>> + Send>>\n51\t    + Send\n52\t    + Sync;\n53\t\n54\t#[derive(Debug, thiserror::Error)]\n55\tpub enum ComputerUseLifecycleError {\n56\t    #[error(\"transport error\")]\n57\t    TransportError,\n58\t    #[error(\"invalid tool payload\")]\n59\t    InvalidToolPayload,\n60\t    #[error(\"cleanup failed\")]\n61\t    CleanupFailed,\n62\t}\n63\t\n64\t#[async_trait]\n65\tpub trait ComputerUseLifecycle: Send + Sync {\n66\t    async fn before_tool_call(&self) -> Result<(), ComputerUseLifecycleError>;\n67\t    async fn after_turn_cleanup(&self) -> Result<(), ComputerUseLifecycleError>;\n68\t    async fn on_interrupt_cleanup(&self) -> Result<(), ComputerUseLifecycleError>;\n69\t}\n70\t\n71\timpl<R: SessionRepository> AgentRunCommand<R> {\n72\t    pub fn new(repo: R, provider: Arc<dyn LlmClient>) -> Self {\n73\t        Self {\n74\t            repo,\n75\t            provider,\n76\t            context: ContextPolicy::default(),\n77\t            computer_use_lifecycle: None,\n78\t        }\n79\t    }\n80\t\n81\t    pub fn with_context(mut self, policy: ContextPolicy) -> Self {\n82\t        self.context = policy;\n83\t        self\n84\t    }\n85\t\n86\t    pub fn with_computer_use_lifecycle(mut self, lifecycle: Arc<dyn ComputerUseLifecycle>) -> Self {\n87\t        self.computer_use_lifecycle = Some(lifecycle);\n88\t        self\n89\t    }\n90\t\n91\t    /// Full agentic loop — keeps calling the model and executing tools until\n92\t    /// the model produces no more tool calls (or max_iterations is reached).\n93\t    pub async fn run(\n94\t        &self,\n95\t        session_id: Option<String>,\n96\t        system_prompt: Option<String>,\n97\t        user_content: String,\n98\t        tools: Vec<ToolDefinition>,\n99\t        on_delta: &(dyn Fn(String) + Send + Sync),\n100\t        execute_tool: &ExecuteToolFn,\n101\t    ) -> Result<SessionId, AppError> {\n102\t        let lifecycle = self.computer_use_lifecycle.as_deref();\n103\t        let now = now_ms();\n104\t\n105\t        let mut session = match session_id {\n106\t            Some(ref id) => {\n107\t                let sid = SessionId(id.clone());\n108\t                self.repo\n109\t                    .find_by_id(&sid)\n110\t                    .await?\n111\t                    .unwrap_or_else(|| Session::new(id.clone(), now))\n112\t            }\n113\t            None => Session::new(format!(\"sess-{now}\"), now),\n114\t        };\n115\t\n116\t        // Prepend system prompt only when starting a fresh session\n117\t        if let Some(ref prompt) = system_prompt\n118\t            && session.messages.is_empty()\n119\t        {\n120\t            let sys_id = format!(\"msg-{now}-sys\");\n121\t            session.add_message(Message::new(sys_id, Role::System, prompt.clone(), now), now);\n122\t        }\n123\t\n124\t        // Add the user message\n125\t        let msg_id = format!(\"msg-{now}-u\");\n126\t        session.add_message(Message::new(msg_id, Role::User, user_content, now), now);\n127\t        self.repo.save(&session).await?;\n128\t\n129\t        const MAX_ITERATIONS: usize = 10;\n130\t\n131\t        for _iter in 0..MAX_ITERATIONS {\n132\t            // ── Context compression ────────────────────────────────────────────\n133\t            // Trigger on total character size (not message count) to catch large\n134\t            // tool results that would overflow the model's context window.\n135\t            let total_chars: usize = session.messages.iter().map(|m| m.content.len()).sum();\n136\t            if total_chars > self.context.compress_chars_threshold {\n137\t                session =\n138\t                    compress_context(session, &*self.provider, self.context.keep_recent_messages)\n139\t                        .await?;\n140\t                self.repo.save(&session).await?;\n141\t            }\n142\t\n143\t            let req = LlmRequest {\n144\t                messages: session.messages.clone(),\n145\t                model: None,\n146\t                max_tokens: None,\n147\t                temperature: None,\n148\t                tools: tools.clone(),\n149\t            };\n150\t"}]},"parent_tool_use_id":"toolu_01AmhVkZizi2XSNnQreLfzwh","session_id":"523981ce-25d5-4aed-a492-78dcbb263a10","uuid":"1cc53d78-7208-4fca-8dbd-e7ed4011f474","timestamp":"2026-04-02T14:22:12.221Z"}
