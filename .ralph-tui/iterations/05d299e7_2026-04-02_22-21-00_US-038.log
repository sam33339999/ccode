{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017dPoQ3yArsHgpxYkkuySUe","type":"tool_result","content":"1\tuse async_trait::async_trait;\n2\tuse ccode_mcp_runtime::{\n3\t    client::{JsonRpcMcpClient, McpClientError, McpToolDefinition},\n4\t    contracts::{\n5\t        enforce_capability_policy, CapabilityLevel, McpCapabilityPolicy, McpPolicyError,\n6\t        McpServerRef,\n7\t    },\n8\t    transport::{StdioTransport, TransportError},\n9\t};\n10\tuse ccode_ports::{\n11\t    tool::{ToolContext, ToolPort},\n12\t    PortError,\n13\t};\n14\tuse serde_json::Value;\n15\tuse std::sync::Arc;\n16\tuse tokio::sync::Mutex;\n17\t\n18\tuse crate::registry::MCP_DISCONNECTED_MARKER;\n19\t\n20\t#[derive(Debug, Clone)]\n21\tpub struct McpServerLaunch {\n22\t    pub name: String,\n23\t    pub command: String,\n24\t    pub args: Vec<String>,\n25\t    pub declared_capabilities: Vec<CapabilityLevel>,\n26\t    pub enable_computer_use: bool,\n27\t}\n28\t\n29\tpub struct DiscoveredMcpTool {\n30\t    pub source: String,\n31\t    pub adapter: Arc<dyn ToolPort>,\n32\t}\n33\t\n34\tpub async fn discover_mcp_tools(\n35\t    servers: &[McpServerLaunch],\n36\t    policy: &dyn McpCapabilityPolicy,\n37\t    chicago_mcp_feature_gate: bool,\n38\t) -> Result<Vec<DiscoveredMcpTool>, PortError> {\n39\t    let mut discovered = Vec::new();\n40\t\n41\t    for server in servers {\n42\t        let server_ref = McpServerRef::new(server.name.clone())\n43\t            .with_computer_use_requested(server.enable_computer_use)\n44\t            .with_declared_capabilities(server.declared_capabilities.iter().copied());\n45\t        enforce_capability_policy(policy, &server_ref, chicago_mcp_feature_gate)\n46\t            .map_err(map_policy_error)?;\n47\t\n48\t        let args: Vec<&str> = server.args.iter().map(String::as_str).collect();\n49\t        let transport = StdioTransport::spawn(&server.command, &args)\n50\t            .await\n51\t            .map_err(|e| {\n52\t                PortError::Tool(format!(\"mcp server `{}` spawn failed: {e}\", server.name))\n53\t            })?;\n54\t        let mut client = JsonRpcMcpClient::new(Box::new(transport));\n55\t        let tools = client.list_tools().await.map_err(|e| {\n56\t            PortError::Tool(format!(\n57\t                \"mcp server `{}` tools/list failed: {e}\",\n58\t                server.name\n59\t            ))\n60\t        })?;\n61\t        let session = Arc::new(Mutex::new(client));\n62\t        let source = format!(\"mcp:{}\", server.name);\n63\t\n64\t        for tool in tools {\n65\t            let adapter = McpToolAdapter::new(server.name.clone(), tool, Arc::clone(&session));\n66\t            discovered.push(DiscoveredMcpTool {\n67\t                source: source.clone(),\n68\t                adapter: Arc::new(adapter),\n69\t            });\n70\t        }\n71\t    }\n72\t\n73\t    Ok(discovered)\n74\t}\n75\t\n76\tfn map_policy_error(err: McpPolicyError) -> PortError {\n77\t    PortError::Tool(format!(\"mcp policy rejected server: {err}\"))\n78\t}\n79\t\n80\tstruct McpToolAdapter {\n81\t    server_name: String,\n82\t    tool_name: String,\n83\t    description: String,\n84\t    input_schema: Value,\n85\t    session: Arc<Mutex<JsonRpcMcpClient>>,\n86\t}\n87\t\n88\timpl McpToolAdapter {\n89\t    fn new(\n90\t        server_name: String,\n91\t        tool: McpToolDefinition,\n92\t        session: Arc<Mutex<JsonRpcMcpClient>>,\n93\t    ) -> Self {\n94\t        Self {\n95\t            server_name,\n96\t            tool_name: tool.name,\n97\t            description: tool.description,\n98\t            input_schema: tool.input_schema,\n99\t            session,\n100\t        }\n101\t    }\n102\t}\n103\t\n104\t#[async_trait]\n105\timpl ToolPort for McpToolAdapter {\n106\t    fn name(&self) -> &str {\n107\t        &self.tool_name\n108\t    }\n109\t\n110\t    fn description(&self) -> &str {\n111\t        &self.description\n112\t    }\n113\t\n114\t    fn parameters_schema(&self) -> Value {\n115\t        self.input_schema.clone()\n116\t    }\n117\t\n118\t    async fn execute(&self, args: Value, _ctx: &ToolContext) -> Result<String, PortError> {\n119\t        let mut client = self.session.lock().await;\n120\t        let result = client\n121\t            .call_tool(&self.tool_name, args)\n122\t            .await\n123\t            .map_err(|err| {\n124\t                if is_disconnect_error(&err) {\n125\t                    return PortError::Tool(format!(\n126\t                        \"{MCP_DISCONNECTED_MARKER}server={}\",\n127\t                        self.server_name\n128\t                    ));\n129\t                }\n130\t                PortError::Tool(format!(\n131\t                    \"mcp server `{}` tool `{}` call failed: {err}\",\n132\t                    self.server_name, self.tool_name\n133\t                ))\n134\t            })?;\n135\t\n136\t        Ok(format_tool_result(&result))\n137\t    }\n138\t}\n139\t\n140\tfn is_disconnect_error(err: &McpClientError) -> bool {\n141\t    matches!(\n142\t        err,\n143\t        McpClientError::Transport(TransportError::Closed)\n144\t            | McpClientError::Transport(TransportError::Io(_))\n145\t            | McpClientError::Transport(TransportError::Protocol(_))\n146\t    )\n147\t}\n148\t\n149\tfn format_tool_result(result: &Value) -> String {\n150\t    if let Some(items) = result.get(\"content\").and_then(Value::as_array) {\n151\t        let text = items\n152\t            .iter()\n153\t            .filter_map(|item| item.get(\"text\").and_then(Value::as_str))\n154\t            .collect::<Vec<_>>()\n155\t            .join(\"\\n\");\n156\t        if !text.is_empty() {\n157\t            return text;\n158\t        }\n159\t    }\n160\t\n161\t    result.to_string()\n162\t}\n163\t\n164\t#[cfg(test)]\n165\tmod tests {\n166\t    use super::*;\n167\t    use ccode_mcp_runtime::contracts::{DefaultMcpCapabilityPolicy, McpCapabilityPolicy};\n168\t\n169\t    #[tokio::test]\n170\t    async fn privileged_capability_cannot_be_enabled_from_generic_registration() {\n171\t        let policy = DefaultMcpCapabilityPolicy::new(true, true);\n172\t        let servers = vec![McpServerLaunch {\n173\t            name: \"generic-mcp\".to_string(),\n174\t            command: \"/definitely/not/used\".to_string(),\n175\t            args: Vec::new(),\n176\t            declared_capabilities: vec![CapabilityLevel::Standard],\n177\t            enable_computer_use: true,\n178\t        }];\n179\t\n180\t        let result = discover_mcp_tools(&servers, &policy, true).await;\n181\t        assert!(\n182\t            result.is_err(),\n183\t            \"generic registration must not negotiate privileged mode\"\n184\t        );\n185\t        let err = result.err().expect(\"error should be present\");\n186\t\n187\t        let rendered = err.to_string();\n188\t        assert!(rendered.contains(\"mcp policy rejected server\"));\n189\t        assert!(rendered.contains(\"privileged capability denied\"));\n190\t    }\n191\t\n192\t    #[tokio::test]\n193\t    async fn policy_failure_prevents_spawn_side_effects() {\n194\t        struct DenyPolicy;\n195\t        impl McpCapabilityPolicy for DenyPolicy {\n196\t            fn validate_server_name(&self, _name: &str) -> Result<(), McpPolicyError> {\n197\t                Err(McpPolicyError::ReservedServerName)\n198\t            }\n199\t\n200\t            fn capability_level(&self, _server: &McpServerRef) -> CapabilityLevel {\n201\t                CapabilityLevel::Standard\n202\t            }\n203\t        }\n204\t\n205\t        let servers = vec![McpServerLaunch {\n206\t            name: \"blocked\".to_string(),\n207\t            command: \"/definitely/does/not/exist\".to_string(),\n208\t            args: Vec::new(),\n209\t            declared_capabilities: vec![CapabilityLevel::Standard],\n210\t            enable_computer_use: false,\n211\t        }];\n212\t\n213\t        let result = discover_mcp_tools(&servers, &DenyPolicy, true).await;\n214\t        assert!(\n215\t            result.is_err(),\n216\t            \"policy should short-circuit before transport spawn\"\n217\t        );\n218\t        let err = result.err().expect(\"error should be present\");\n219\t        let rendered = err.to_string();\n220\t\n221\t        assert!(rendered.contains(\"mcp policy rejected server\"));\n222\t        assert!(!rendered.contains(\"spawn failed\"));\n223\t    }\n224\t}\n225\t"}]},"parent_tool_use_id":null,"session_id":"523981ce-25d5-4aed-a492-78dcbb263a10","uuid":"d21160a6-7352-446f-840f-a20c5e53d8fd","timestamp":"2026-04-02T14:22:59.735Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/tools/src/mcp.rs","content":"use async_trait::async_trait;\nuse ccode_mcp_runtime::{\n    client::{JsonRpcMcpClient, McpClientError, McpToolDefinition},\n    contracts::{\n        enforce_capability_policy, CapabilityLevel, McpCapabilityPolicy, McpPolicyError,\n        McpServerRef,\n    },\n    transport::{StdioTransport, TransportError},\n};\nuse ccode_ports::{\n    tool::{ToolContext, ToolPort},\n    PortError,\n};\nuse serde_json::Value;\nuse std::sync::Arc;\nuse tokio::sync::Mutex;\n\nuse crate::registry::MCP_DISCONNECTED_MARKER;\n\n#[derive(Debug, Clone)]\npub struct McpServerLaunch {\n    pub name: String,\n    pub command: String,\n    pub args: Vec<String>,\n    pub declared_capabilities: Vec<CapabilityLevel>,\n    pub enable_computer_use: bool,\n}\n\npub struct DiscoveredMcpTool {\n    pub source: String,\n    pub adapter: Arc<dyn ToolPort>,\n}\n\npub async fn discover_mcp_tools(\n    servers: &[McpServerLaunch],\n    policy: &dyn McpCapabilityPolicy,\n    chicago_mcp_feature_gate: bool,\n) -> Result<Vec<DiscoveredMcpTool>, PortError> {\n    let mut discovered = Vec::new();\n\n    for server in servers {\n        let server_ref = McpServerRef::new(server.name.clone())\n            .with_computer_use_requested(server.enable_computer_use)\n            .with_declared_capabilities(server.declared_capabilities.iter().copied());\n        enforce_capability_policy(policy, &server_ref, chicago_mcp_feature_gate)\n            .map_err(map_policy_error)?;\n\n        let args: Vec<&str> = server.args.iter().map(String::as_str).collect();\n        let transport = StdioTransport::spawn(&server.command, &args)\n            .await\n            .map_err(|e| {\n                PortError::Tool(format!(\"mcp server `{}` spawn failed: {e}\", server.name))\n            })?;\n        let mut client = JsonRpcMcpClient::new(Box::new(transport));\n        let tools = client.list_tools().await.map_err(|e| {\n            PortError::Tool(format!(\n                \"mcp server `{}` tools/list failed: {e}\",\n                server.name\n            ))\n        })?;\n        let session = Arc::new(Mutex::new(client));\n        let source = format!(\"mcp:{}\", server.name);\n\n        for tool in tools {\n            let adapter = McpToolAdapter::new(server.name.clone(), tool, Arc::clone(&session));\n            discovered.push(DiscoveredMcpTool {\n                source: source.clone(),\n                adapter: Arc::new(adapter),\n            });\n        }\n    }\n\n    Ok(discovered)\n}\n\nfn map_policy_error(err: McpPolicyError) -> PortError {\n    PortError::Tool(format!(\"mcp policy rejected server: {err}\"))\n}\n\nstruct McpToolAdapter {\n    server_name: String,\n    tool_name: String,\n    description: String,\n    input_schema: Value,\n    session: Arc<Mutex<JsonRpcMcpClient>>,\n}\n\nimpl McpToolAdapter {\n    fn new(\n        server_name: String,\n        tool: McpToolDefinition,\n        session: Arc<Mutex<JsonRpcMcpClient>>,\n    ) -> Self {\n        Self {\n            server_name,\n            tool_name: tool.name,\n            description: tool.description,\n            input_schema: tool.input_schema,\n            session,\n        }\n    }\n}\n\n#[async_trait]\nimpl ToolPort for McpToolAdapter {\n    fn name(&self) -> &str {\n        &self.tool_name\n    }\n\n    fn description(&self) -> &str {\n        &self.description\n    }\n\n    fn parameters_schema(&self) -> Value {\n        self.input_schema.clone()\n    }\n\n    async fn execute(&self, args: Value, _ctx: &ToolContext) -> Result<String, PortError> {\n        let mut client = self.session.lock().await;\n        let result = client\n            .call_tool(&self.tool_name, args)\n            .await\n            .map_err(|err| {\n                if is_disconnect_error(&err) {\n                    return PortError::Tool(format!(\n                        \"{MCP_DISCONNECTED_MARKER}server={}\",\n                        self.server_name\n                    ));\n                }\n                PortError::Tool(format!(\n                    \"mcp server `{}` tool `{}` call failed: {err}\",\n                    self.server_name, self.tool_name\n                ))\n            })?;\n\n        Ok(format_tool_result(&result))\n    }\n}\n\nfn is_disconnect_error(err: &McpClientError) -> bool {\n    matches!(\n        err,\n        McpClientError::Transport(TransportError::Closed)\n            | McpClientError::Transport(TransportError::Io(_))\n            | McpClientError::Transport(TransportError::Protocol(_))\n    )\n}\n\nfn format_tool_result(result: &Value) -> String {\n    if let Some(items) = result.get(\"content\").and_then(Value::as_array) {\n        let text = items\n            .iter()\n            .filter_map(|item| item.get(\"text\").and_then(Value::as_str))\n            .collect::<Vec<_>>()\n            .join(\"\\n\");\n        if !text.is_empty() {\n            return text;\n        }\n    }\n\n    result.to_string()\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use ccode_mcp_runtime::contracts::{DefaultMcpCapabilityPolicy, McpCapabilityPolicy};\n\n    #[tokio::test]\n    async fn privileged_capability_cannot_be_enabled_from_generic_registration() {\n        let policy = DefaultMcpCapabilityPolicy::new(true, true);\n        let servers = vec![McpServerLaunch {\n            name: \"generic-mcp\".to_string(),\n            command: \"/definitely/not/used\".to_string(),\n            args: Vec::new(),\n            declared_capabilities: vec![CapabilityLevel::Standard],\n            enable_computer_use: true,\n        }];\n\n        let result = discover_mcp_tools(&servers, &policy, true).await;\n        assert!(\n            result.is_err(),\n            \"generic registration must not negotiate privileged mode\"\n        );\n        let err = result.err().expect(\"error should be present\");\n\n        let rendered = err.to_string();\n        assert!(rendered.contains(\"mcp policy rejected server\"));\n        assert!(rendered.contains(\"privileged capability denied\"));\n    }\n\n    #[tokio::test]\n    async fn policy_failure_prevents_spawn_side_effects() {\n        struct DenyPolicy;\n        impl McpCapabilityPolicy for DenyPolicy {\n            fn validate_server_name(&self, _name: &str) -> Result<(), McpPolicyError> {\n                Err(McpPolicyError::ReservedServerName)\n            }\n\n            fn capability_level(&self, _server: &McpServerRef) -> CapabilityLevel {\n                CapabilityLevel::Standard\n            }\n        }\n\n        let servers = vec![McpServerLaunch {\n            name: \"blocked\".to_string(),\n            command: \"/definitely/does/not/exist\".to_string(),\n            args: Vec::new(),\n            declared_capabilities: vec![CapabilityLevel::Standard],\n            enable_computer_use: false,\n        }];\n\n        let result = discover_mcp_tools(&servers, &DenyPolicy, true).await;\n        assert!(\n            result.is_err(),\n            \"policy should short-circuit before transport spawn\"\n        );\n        let err = result.err().expect(\"error should be present\");\n        let rendered = err.to_string();\n\n        assert!(rendered.contains(\"mcp policy rejected server\"));\n        assert!(!rendered.contains(\"spawn failed\"));\n    }\n}\n","numLines":225,"startLine":1,"totalLines":225}}}
