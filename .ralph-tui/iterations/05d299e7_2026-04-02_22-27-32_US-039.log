{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VFRCes15ecqW5vDV7tuDQW","type":"tool_result","content":"1\tuse crate::spec_contracts::{\n2\t    CoordinatorMode, CoordinatorModeError, EffectiveMode, EffectiveModeSource,\n3\t    ModeCoordinatorService, ModeReconcileAction, ModeReconcileResult, ModeResolutionInput,\n4\t    ModeSwitchEvent, ModeSwitchReason, SessionMode,\n5\t};\n6\t\n7\t#[derive(Debug, Clone, Copy)]\n8\tpub struct DefaultModeCoordinatorService {\n9\t    pub policy_enabled: bool,\n10\t    pub env_mode: Option<CoordinatorMode>,\n11\t    pub current_mode: CoordinatorMode,\n12\t}\n13\t\n14\timpl Default for DefaultModeCoordinatorService {\n15\t    fn default() -> Self {\n16\t        Self {\n17\t            policy_enabled: true,\n18\t            env_mode: None,\n19\t            current_mode: CoordinatorMode::Standard,\n20\t        }\n21\t    }\n22\t}\n23\t\n24\timpl DefaultModeCoordinatorService {\n25\t    pub fn from_env(policy_enabled: bool, current_mode: CoordinatorMode) -> Self {\n26\t        Self {\n27\t            policy_enabled,\n28\t            env_mode: std::env::var(crate::spec_contracts::CLAUDE_CODE_COORDINATOR_MODE)\n29\t                .ok()\n30\t                .as_deref()\n31\t                .and_then(CoordinatorMode::parse),\n32\t            current_mode,\n33\t        }\n34\t    }\n35\t\n36\t    fn transition_allowed(from: CoordinatorMode, to: CoordinatorMode) -> bool {\n37\t        // Coordinator mode is currently sticky once entered to keep orchestration behavior stable.\n38\t        !matches!(\n39\t            (from, to),\n40\t            (CoordinatorMode::Coordinator, CoordinatorMode::Standard)\n41\t        )\n42\t    }\n43\t\n44\t    fn mode_event(\n45\t        from: CoordinatorMode,\n46\t        to: CoordinatorMode,\n47\t        reason: ModeSwitchReason,\n48\t    ) -> Option<ModeSwitchEvent> {\n49\t        (from != to).then_some(ModeSwitchEvent { from, to, reason })\n50\t    }\n51\t}\n52\t\n53\timpl ModeCoordinatorService for DefaultModeCoordinatorService {\n54\t    fn resolve_effective_mode(&self, input: ModeResolutionInput) -> EffectiveMode {\n55\t        if !input.policy_enabled {\n56\t            return EffectiveMode {\n57\t                mode: CoordinatorMode::Standard,\n58\t                source: EffectiveModeSource::Default,\n59\t                switch_event: None,\n60\t                error: Some(CoordinatorModeError::DisabledByPolicy),\n61\t            };\n62\t        }\n63\t\n64\t        let (candidate_mode, source, reason) = if let Some(session_mode) = input.session_mode {\n65\t            (\n66\t                session_mode.mode,\n67\t                EffectiveModeSource::Session,\n68\t                ModeSwitchReason::SessionPrecedence,\n69\t            )\n70\t        } else if let Some(env_mode) = input.env_mode {\n71\t            (\n72\t                env_mode,\n73\t                EffectiveModeSource::Env,\n74\t                ModeSwitchReason::EnvConfigured,\n75\t            )\n76\t        } else {\n77\t            (\n78\t                CoordinatorMode::Standard,\n79\t                EffectiveModeSource::Default,\n80\t                ModeSwitchReason::DefaultFallback,\n81\t            )\n82\t        };\n83\t\n84\t        if let Some(previous_mode) = input.previous_mode\n85\t            && !Self::transition_allowed(previous_mode, candidate_mode)\n86\t        {\n87\t            return EffectiveMode {\n88\t                mode: previous_mode,\n89\t                source,\n90\t                switch_event: None,\n91\t                error: Some(CoordinatorModeError::InvalidModeTransition),\n92\t            };\n93\t        }\n94\t\n95\t        EffectiveMode {\n96\t            mode: candidate_mode,\n97\t            source,\n98\t            switch_event: input\n99\t                .previous_mode\n100\t                .and_then(|previous| Self::mode_event(previous, candidate_mode, reason)),\n101\t            error: None,\n102\t        }\n103\t    }\n104\t\n105\t    fn reconcile_on_resume(&self, session_mode: Option<SessionMode>) -> ModeReconcileResult {\n106\t        if !self.policy_enabled {\n107\t            return ModeReconcileResult {\n108\t                mode: CoordinatorMode::Standard,\n109\t                action: ModeReconcileAction::Noop,\n110\t                switch_event: None,\n111\t                error: Some(CoordinatorModeError::DisabledByPolicy),\n112\t            };\n113\t        }\n114\t\n115\t        if let Some(session_mode) = session_mode {\n116\t            if !Self::transition_allowed(self.current_mode, session_mode.mode) {\n117\t                return ModeReconcileResult {\n118\t                    mode: self.current_mode,\n119\t                    action: ModeReconcileAction::Noop,\n120\t                    switch_event: None,\n121\t                    error: Some(CoordinatorModeError::InvalidModeTransition),\n122\t                };\n123\t            }\n124\t\n125\t            let conflict = self.env_mode.is_some_and(|env| env != session_mode.mode);\n126\t            return ModeReconcileResult {\n127\t                mode: session_mode.mode,\n128\t                action: ModeReconcileAction::SessionWins,\n129\t                switch_event: Self::mode_event(\n130\t                    self.current_mode,\n131\t                    session_mode.mode,\n132\t                    ModeSwitchReason::ResumeReconcile,\n133\t                ),\n134\t                error: conflict.then_some(CoordinatorModeError::SessionModeMismatch),\n135\t            };\n136\t        }\n137\t\n138\t        let target_mode = self.env_mode.unwrap_or(CoordinatorMode::Standard);\n139\t        if !Self::transition_allowed(self.current_mode, target_mode) {\n140\t            return ModeReconcileResult {\n141\t                mode: self.current_mode,\n142\t                action: ModeReconcileAction::Noop,\n143\t                switch_event: None,\n144\t                error: Some(CoordinatorModeError::InvalidModeTransition),\n145\t            };\n146\t        }\n147\t\n148\t        ModeReconcileResult {\n149\t            mode: target_mode,\n150\t            action: ModeReconcileAction::EnvAdopted,\n151\t            switch_event: Self::mode_event(\n152\t                self.current_mode,\n153\t                target_mode,\n154\t                ModeSwitchReason::ResumeReconcile,\n155\t            ),\n156\t            error: None,\n157\t        }\n158\t    }\n159\t}\n160\t\n161\t#[cfg(test)]\n162\tmod tests {\n163\t    use super::*;\n164\t    use crate::spec_contracts::ModeCoordinatorService;\n165\t\n166\t    #[test]\n167\t    fn resolve_effective_mode_prefers_session_over_env_mode() {\n168\t        let service = DefaultModeCoordinatorService::default();\n169\t        let result = service.resolve_effective_mode(ModeResolutionInput {\n170\t            policy_enabled: true,\n171\t            env_mode: Some(CoordinatorMode::Standard),\n172\t            session_mode: Some(SessionMode {\n173\t                mode: CoordinatorMode::Coordinator,\n174\t            }),\n175\t            previous_mode: Some(CoordinatorMode::Standard),\n176\t        });\n177\t\n178\t        assert_eq!(result.mode, CoordinatorMode::Coordinator);\n179\t        assert_eq!(result.source, EffectiveModeSource::Session);\n180\t        assert!(result.error.is_none());\n181\t        assert!(matches!(\n182\t            result.switch_event,\n183\t            Some(ModeSwitchEvent {\n184\t                from: CoordinatorMode::Standard,\n185\t                to: CoordinatorMode::Coordinator,\n186\t                reason: ModeSwitchReason::SessionPrecedence,\n187\t            })\n188\t        ));\n189\t    }\n190\t\n191\t    #[test]\n192\t    fn reconcile_on_resume_uses_session_mode_and_marks_conflict_deterministically() {\n193\t        let service = DefaultModeCoordinatorService {\n194\t            policy_enabled: true,\n195\t            env_mode: Some(CoordinatorMode::Standard),\n196\t            current_mode: CoordinatorMode::Standard,\n197\t        };\n198\t\n199\t        let result = service.reconcile_on_resume(Some(SessionMode {\n200\t            mode: CoordinatorMode::Coordinator,\n201\t        }));\n202\t\n203\t        assert_eq!(result.mode, CoordinatorMode::Coordinator);\n204\t        assert_eq!(result.action, ModeReconcileAction::SessionWins);\n205\t        assert!(matches!(\n206\t            result.error,\n207\t            Some(CoordinatorModeError::SessionModeMismatch)\n208\t        ));\n209\t        assert!(matches!(\n210\t            result.switch_event,\n211\t            Some(ModeSwitchEvent {\n212\t                from: CoordinatorMode::Standard,\n213\t                to: CoordinatorMode::Coordinator,\n214\t                reason: ModeSwitchReason::ResumeReconcile,\n215\t            })\n216\t        ));\n217\t    }\n218\t\n219\t    #[test]\n220\t    fn resolve_effective_mode_reports_disabled_by_policy() {\n221\t        let service = DefaultModeCoordinatorService::default();\n222\t        let result = service.resolve_effective_mode(ModeResolutionInput {\n223\t            policy_enabled: false,\n224\t            env_mode: Some(CoordinatorMode::Coordinator),\n225\t            session_mode: Some(SessionMode {\n226\t                mode: CoordinatorMode::Coordinator,\n227\t            }),\n228\t            previous_mode: Some(CoordinatorMode::Standard),\n229\t        });\n230\t\n231\t        assert!(matches!(\n232\t            result.error,\n233\t            Some(CoordinatorModeError::DisabledByPolicy)\n234\t        ));\n235\t    }\n236\t\n237\t    #[test]\n238\t    fn resolve_effective_mode_reports_invalid_transition() {\n239\t        let service = DefaultModeCoordinatorService::default();\n240\t        let result = service.resolve_effective_mode(ModeResolutionInput {\n241\t            policy_enabled: true,\n242\t            env_mode: Some(CoordinatorMode::Standard),\n243\t            session_mode: None,\n244\t            previous_mode: Some(CoordinatorMode::Coordinator),\n245\t        });\n246\t\n247\t        assert!(matches!(\n248\t            result.error,\n249\t            Some(CoordinatorModeError::InvalidModeTransition)\n250\t        ));\n251\t    }\n252\t\n253\t    #[test]\n254\t    fn reconcile_on_resume_can_surface_each_error_variant() {\n255\t        let disabled = DefaultModeCoordinatorService {\n256\t            policy_enabled: false,\n257\t            env_mode: Some(CoordinatorMode::Coordinator),\n258\t            current_mode: CoordinatorMode::Standard,\n259\t        }\n260\t        .reconcile_on_resume(Some(SessionMode {\n261\t            mode: CoordinatorMode::Coordinator,\n262\t        }));\n263\t        assert!(matches!(\n264\t            disabled.error,\n265\t            Some(CoordinatorModeError::DisabledByPolicy)\n266\t        ));\n267\t\n268\t        let invalid = DefaultModeCoordinatorService {\n269\t            policy_enabled: true,\n270\t            env_mode: Some(CoordinatorMode::Standard),\n271\t            current_mode: CoordinatorMode::Coordinator,\n272\t        }\n273\t        .reconcile_on_resume(None);\n274\t        assert!(matches!(\n275\t            invalid.error,\n276\t            Some(CoordinatorModeError::InvalidModeTransition)\n277\t        ));\n278\t\n279\t        let mismatch = DefaultModeCoordinatorService {\n280\t            policy_enabled: true,\n281\t            env_mode: Some(CoordinatorMode::Standard),\n282\t            current_mode: CoordinatorMode::Standard,\n283\t        }\n284\t        .reconcile_on_resume(Some(SessionMode {\n285\t            mode: CoordinatorMode::Coordinator,\n286\t        }));\n287\t        assert!(matches!(\n288\t            mismatch.error,\n289\t            Some(CoordinatorModeError::SessionModeMismatch)\n290\t        ));\n291\t    }\n292\t}\n293\t"}]},"parent_tool_use_id":"toolu_01W5T7riSnQ6Hs4WmL3e6Z9H","session_id":"e9f8098c-603d-4cfe-8b30-43f06752a5e5","uuid":"bfa30229-d9e0-421f-bb8e-0b0b67df885b","timestamp":"2026-04-02T14:28:04.840Z"}
