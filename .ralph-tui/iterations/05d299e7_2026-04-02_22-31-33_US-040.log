{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AcSTXwY8YN6LheC5UDi7Qp","type":"tool_result","content":"1\t/// Bridge mode acceptance tests (US-037)\n2\t///\n3\t/// Covers all scenarios from bridge-mode-contract.md §8 Acceptance Criteria:\n4\t///   §8.1 Contract tests  – transport and policy layer invariants\n5\t///   §8.2 Integration tests – multi-step lifecycle flows\n6\t///\n7\t/// CLI behaviour tests live in crates/cli/src/cmd/bridge.rs.\n8\tuse crate::{\n9\t    remote_session_service::ApplicationRemoteSessionService,\n10\t    spec_contracts::{\n11\t        ArchivePolicy, ArchiveResult, CcrClient, CcrClientError, CreateRemoteSessionRequest,\n12\t        RemoteSessionError, RemoteSessionService, RemoteSessionState, RemoteSessionSummary,\n13\t        SessionEvent,\n14\t    },\n15\t};\n16\tuse std::{collections::VecDeque, sync::Arc, time::Duration};\n17\tuse tokio::sync::Mutex;\n18\t\n19\t// ── shared test doubles ────────────────────────────────────────────────────\n20\t\n21\t#[derive(Default)]\n22\tstruct MockCcrClient {\n23\t    create_results: Arc<Mutex<VecDeque<Result<RemoteSessionSummary, CcrClientError>>>>,\n24\t    get_results: Arc<Mutex<VecDeque<Result<RemoteSessionSummary, CcrClientError>>>>,\n25\t    archive_results: Arc<Mutex<VecDeque<Result<ArchiveResult, CcrClientError>>>>,\n26\t    patch_results: Arc<Mutex<VecDeque<Result<(), CcrClientError>>>>,\n27\t    archive_delay: Option<Duration>,\n28\t}\n29\t\n30\timpl MockCcrClient {\n31\t    fn with_create(results: Vec<Result<RemoteSessionSummary, CcrClientError>>) -> Self {\n32\t        Self {\n33\t            create_results: Arc::new(Mutex::new(results.into())),\n34\t            ..Self::default()\n35\t        }\n36\t    }\n37\t\n38\t    fn with_get(results: Vec<Result<RemoteSessionSummary, CcrClientError>>) -> Self {\n39\t        Self {\n40\t            get_results: Arc::new(Mutex::new(results.into())),\n41\t            ..Self::default()\n42\t        }\n43\t    }\n44\t\n45\t    fn with_archive(results: Vec<Result<ArchiveResult, CcrClientError>>) -> Self {\n46\t        Self {\n47\t            archive_results: Arc::new(Mutex::new(results.into())),\n48\t            ..Self::default()\n49\t        }\n50\t    }\n51\t\n52\t    fn with_archive_delay(delay: Duration) -> Self {\n53\t        Self {\n54\t            archive_delay: Some(delay),\n55\t            archive_results: Arc::new(Mutex::new(vec![Ok(ArchiveResult::Archived)].into())),\n56\t            ..Self::default()\n57\t        }\n58\t    }\n59\t\n60\t    fn for_happy_path(session_id: &str, state: RemoteSessionState) -> Self {\n61\t        let summary = summary_for(session_id, state);\n62\t        Self {\n63\t            create_results: Arc::new(Mutex::new(vec![Ok(summary.clone())].into())),\n64\t            get_results: Arc::new(Mutex::new(vec![Ok(summary)].into())),\n65\t            archive_results: Arc::new(Mutex::new(vec![Ok(ArchiveResult::Archived)].into())),\n66\t            ..Self::default()\n67\t        }\n68\t    }\n69\t}\n70\t\n71\t#[async_trait::async_trait]\n72\timpl CcrClient for MockCcrClient {\n73\t    async fn create(\n74\t        &self,\n75\t        _req: CreateRemoteSessionRequest,\n76\t    ) -> Result<RemoteSessionSummary, CcrClientError> {\n77\t        self.create_results\n78\t            .lock()\n79\t            .await\n80\t            .pop_front()\n81\t            .expect(\"no create result queued\")\n82\t    }\n83\t\n84\t    async fn get(&self, _session_id: &str) -> Result<RemoteSessionSummary, CcrClientError> {\n85\t        self.get_results\n86\t            .lock()\n87\t            .await\n88\t            .pop_front()\n89\t            .expect(\"no get result queued\")\n90\t    }\n91\t\n92\t    async fn archive(&self, _session_id: &str) -> Result<ArchiveResult, CcrClientError> {\n93\t        if let Some(delay) = self.archive_delay {\n94\t            tokio::time::sleep(delay).await;\n95\t        }\n96\t        self.archive_results\n97\t            .lock()\n98\t            .await\n99\t            .pop_front()\n100\t            .expect(\"no archive result queued\")\n101\t    }\n102\t\n103\t    async fn patch_title(&self, _session_id: &str, _title: &str) -> Result<(), CcrClientError> {\n104\t        self.patch_results\n105\t            .lock()\n106\t            .await\n107\t            .pop_front()\n108\t            .expect(\"no patch result queued\")\n109\t    }\n110\t}\n111\t\n112\tfn summary_for(session_id: &str, state: RemoteSessionState) -> RemoteSessionSummary {\n113\t    RemoteSessionSummary {\n114\t        session_id: session_id.to_string(),\n115\t        title: Some(\"acceptance-test session\".to_string()),\n116\t        environment_id: Some(\"env_test\".to_string()),\n117\t        state,\n118\t    }\n119\t}\n120\t\n121\tfn sample_create_request() -> CreateRemoteSessionRequest {\n122\t    CreateRemoteSessionRequest {\n123\t        environment_id: \"env_test\".to_string(),\n124\t        title: Some(\"acceptance-test\".to_string()),\n125\t        permission_mode: Some(\"default\".to_string()),\n126\t        events: vec![SessionEvent {\n127\t            event_type: \"started\".to_string(),\n128\t            payload_json: serde_json::json!({\"ok\": true}),\n129\t        }],\n130\t    }\n131\t}\n132\t\n133\tfn short_timeout() -> ArchivePolicy {\n134\t    ArchivePolicy {\n135\t        timeout: Duration::from_millis(10),\n136\t        idempotent: true,\n137\t    }\n138\t}\n139\t\n140\t// ── §8.1 Contract tests ────────────────────────────────────────────────────\n141\t\n142\t/// AC: archive(409) maps to success-equivalent result.\n143\t///\n144\t/// HTTP 409 Conflict on an archive call means the session is already\n145\t/// archived; the service must treat this as Ok(()) — never an error.\n146\t#[tokio::test]\n147\tasync fn contract_archive_409_is_success_equivalent() {\n148\t    let client = MockCcrClient::with_archive(vec![Ok(ArchiveResult::AlreadyArchived)]);\n149\t    let svc = ApplicationRemoteSessionService::new(client, true);\n150\t\n151\t    let result = svc.archive_session(\"session_123\", short_timeout()).await;\n152\t\n153\t    assert!(\n154\t        result.is_ok(),\n155\t        \"AlreadyArchived (HTTP 409) must be treated as success; got {result:?}\"\n156\t    );\n157\t}\n158\t\n159\t/// AC: session_ and cse_ IDs round-trip correctly through the compatibility adapter.\n160\t///\n161\t/// The service layer is ID-agnostic: it stores and returns whatever the\n162\t/// transport returned, without performing prefix rewriting itself.\n163\t/// Prefix translation is a remote-runtime concern (see ccr_client_tests.rs).\n164\t#[tokio::test]\n165\tasync fn contract_session_id_is_preserved_opaquely_by_service() {\n166\t    let session_id = \"session_abc123\";\n167\t    let client = MockCcrClient::with_create(vec![Ok(summary_for(\n168\t        session_id,\n169\t        RemoteSessionState::Running,\n170\t    ))]);\n171\t    let svc = ApplicationRemoteSessionService::new(client, true);\n172\t\n173\t    let result = svc.create_session(sample_create_request()).await.unwrap();\n174\t\n175\t    assert_eq!(\n176\t        result.session_id, session_id,\n177\t        \"service must not rewrite session IDs; expected {session_id}, got {}\",\n178\t        result.session_id\n179\t    );\n180\t}\n181\t\n182\t/// Companion: verify that a cse_-prefixed ID is also preserved opaquely.\n183\t#[tokio::test]\n184\tasync fn contract_cse_id_is_preserved_opaquely_by_service() {\n185\t    let cse_id = \"cse_abc123\";\n186\t    let client =\n187\t        MockCcrClient::with_get(vec![Ok(summary_for(cse_id, RemoteSessionState::Running))]);\n188\t    let svc = ApplicationRemoteSessionService::new(client, true);\n189\t\n190\t    let result = svc.fetch_session(cse_id).await.unwrap();\n191\t\n192\t    assert_eq!(\n193\t        result.session_id, cse_id,\n194\t        \"service must not rewrite cse_ IDs; expected {cse_id}, got {}\",\n195\t        result.session_id\n196\t    );\n197\t}\n198\t\n199\t/// AC: missing token produces AuthUnavailable (never panic).\n200\t///\n201\t/// Unauthorized (HTTP 401) from the transport maps to AuthUnavailable at\n202\t/// the service boundary. The call must return Err — not panic.\n203\t#[tokio::test]\n204\tasync fn contract_missing_token_produces_auth_unavailable() {\n205\t    let client = MockCcrClient::with_get(vec![Err(CcrClientError::Unauthorized)]);\n206\t    let svc = ApplicationRemoteSessionService::new(client, true);\n207\t\n208\t    let result = svc.fetch_session(\"session_123\").await;\n209\t\n210\t    assert!(\n211\t        matches!(result, Err(RemoteSessionError::AuthUnavailable)),\n212\t        \"Unauthorized must map to AuthUnavailable; got {result:?}\"\n213\t    );\n214\t}\n215\t\n216\t/// AC: missing org produces EntitlementDenied (never panic).\n217\t///\n218\t/// Forbidden (HTTP 403) — which is returned when the org header is absent or\n219\t/// unrecognised — maps to EntitlementDenied at the service boundary.\n220\t#[tokio::test]\n221\tasync fn contract_missing_org_produces_entitlement_denied() {\n222\t    let client = MockCcrClient {\n223\t        patch_results: Arc::new(Mutex::new(vec![Err(CcrClientError::Forbidden)].into())),\n224\t        ..MockCcrClient::default()\n225\t    };\n226\t    let svc = ApplicationRemoteSessionService::new(client, true);\n227\t\n228\t    let result = svc.update_title(\"session_123\", \"title\").await;\n229\t\n230\t    assert!(\n231\t        matches!(result, Err(RemoteSessionError::EntitlementDenied)),\n232\t        \"Forbidden must map to EntitlementDenied; got {result:?}\"\n233\t    );\n234\t}\n235\t\n236\t// ── §8.2 Integration tests ─────────────────────────────────────────────────\n237\t\n238\t/// AC: create → fetch → archive happy path passes.\n239\t///\n240\t/// Executes the full lifecycle sequentially against a mock transport and\n241\t/// asserts each step succeeds with the expected session ID.\n242\t#[tokio::test]\n243\tasync fn integration_create_fetch_archive_happy_path() {\n244\t    let session_id = \"session_happy\";\n245\t    let client = MockCcrClient::for_happy_path(session_id, RemoteSessionState::Running);\n246\t    let svc = ApplicationRemoteSessionService::new(client, true);\n247\t\n248\t    // Step 1: create\n249\t    let created = svc\n250\t        .create_session(sample_create_request())\n251\t        .await\n252\t        .expect(\"create must succeed\");\n253\t    assert_eq!(created.session_id, session_id);\n254\t    assert_eq!(created.state, RemoteSessionState::Running);\n255\t\n256\t    // Step 2: fetch\n257\t    let fetched = svc\n258\t        .fetch_session(session_id)\n259\t        .await\n260\t        .expect(\"fetch must succeed\");\n261\t    assert_eq!(fetched.session_id, session_id);\n262\t\n263\t    // Step 3: archive\n264\t    svc.archive_session(session_id, short_timeout())\n265\t        .await\n266\t        .expect(\"archive must succeed\");\n267\t}\n268\t\n269\t/// AC: resume with stale/expired session returns deterministic error classification.\n270\t///\n271\t/// Expired sessions are not resumable; the service must return Expired,\n272\t/// not a generic upstream error or a panic.\n273\t#[tokio::test]\n274\tasync fn integration_resume_with_expired_session_returns_deterministic_error() {\n275\t    let client = MockCcrClient::with_get(vec![Ok(summary_for(\n276\t        \"session_stale\",\n277\t        RemoteSessionState::Expired,\n278\t    ))]);\n279\t    let svc = ApplicationRemoteSessionService::new(client, true);\n280\t\n281\t    let result = svc.reconcile_resume(\"session_stale\").await;\n282\t\n283\t    assert!(\n284\t        matches!(result, Err(RemoteSessionError::Expired)),\n285\t        \"expired session must yield RemoteSessionError::Expired; got {result:?}\"\n286\t    );\n287\t}\n288\t\n289\t/// Companion: archived sessions must yield InvalidStateTransition on resume\n290\t/// (Archived is a terminal state — cannot re-enter Running).\n291\t#[tokio::test]\n292\tasync fn integration_resume_with_archived_session_returns_invalid_state_transition() {\n293\t    let client = MockCcrClient::with_get(vec![Ok(summary_for(\n294\t        \"session_archived\",\n295\t        RemoteSessionState::Archived,\n296\t    ))]);\n297\t    let svc = ApplicationRemoteSessionService::new(client, true);\n298\t\n299\t    let result = svc.reconcile_resume(\"session_archived\").await;\n300\t\n301\t    assert!(\n302\t        matches!(result, Err(RemoteSessionError::InvalidStateTransition)),\n303\t        \"archived session resume must yield InvalidStateTransition; got {result:?}\"\n304\t    );\n305\t}\n306\t\n307\t/// AC: shutdown path performs best-effort archive under timeout budget.\n308\t///\n309\t/// When the archive call exceeds the policy timeout the best-effort helper\n310\t/// must return false (degraded) rather than blocking or panicking.\n311\t#[tokio::test]\n312\tasync fn integration_shutdown_best_effort_archive_under_timeout_budget() {\n313\t    let client = MockCcrClient::with_archive_delay(Duration::from_millis(100));\n314\t    let svc = ApplicationRemoteSessionService::new(client, true);\n315\t\n316\t    let archived = svc\n317\t        .archive_on_shutdown_best_effort(\n318\t            \"session_shutdown\",\n319\t            ArchivePolicy {\n320\t                timeout: Duration::from_millis(5),\n321\t                idempotent: true,\n322\t            },\n323\t        )\n324\t        .await;\n325\t\n326\t    assert!(\n327\t        !archived,\n328\t        \"best-effort archive must degrade gracefully when transport exceeds timeout\"\n329\t    );\n330\t}\n331\t\n332\t/// Companion: best-effort archive returns true when transport completes in time.\n333\t#[tokio::test]\n334\tasync fn integration_shutdown_best_effort_archive_succeeds_within_budget() {\n335\t    let client = MockCcrClient::with_archive(vec![Ok(ArchiveResult::Archived)]);\n336\t    let svc = ApplicationRemoteSessionService::new(client, true);\n337\t\n338\t    let archived = svc\n339\t        .archive_on_shutdown_best_effort(\n340\t            \"session_ok\",\n341\t            ArchivePolicy {\n342\t                timeout: Duration::from_millis(200),\n343\t                idempotent: true,\n344\t            },\n345\t        )\n346\t        .await;\n347\t\n348\t    assert!(\n349\t        archived,\n350\t        \"best-effort archive must return true when transport completes within budget\"\n351\t    );\n352\t}\n353\t"}]},"parent_tool_use_id":"toolu_013X19bThc964g3DNsp4No5N","session_id":"6362e84a-6f04-4b0f-bbe9-0adfe63953c5","uuid":"e9af0873-afd0-44c3-bcb6-577303bb509b","timestamp":"2026-04-02T14:31:56.049Z"}
