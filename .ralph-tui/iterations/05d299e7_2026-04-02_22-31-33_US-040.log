{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WS1nrKzMbatXFMMXpoTN8f","type":"tool_result","content":"1\t/// Chicago MCP acceptance tests (US-038)\n2\t///\n3\t/// Covers all scenarios from chicago-mcp-contract.md §8 Acceptance Criteria:\n4\t///   §8.1 Contract tests  – policy and lifecycle trait invariants\n5\t///   §8.2 Integration tests – multi-step registration and cleanup flows\n6\t///\n7\t/// CLI behaviour tests live in crates/cli/src/cmd/chicago.rs.\n8\tuse crate::contracts::{\n9\t    CapabilityLevel, ComputerUseLifecycle, DefaultMcpCapabilityPolicy, McpPolicyError,\n10\t    McpRuntimeError, McpServerRef, enforce_capability_policy,\n11\t};\n12\tuse async_trait::async_trait;\n13\tuse std::sync::Arc;\n14\tuse std::sync::atomic::{AtomicBool, AtomicUsize, Ordering};\n15\t\n16\t// ── shared test doubles ────────────────────────────────────────────────────\n17\t\n18\t/// Mock lifecycle that tracks call counts and optionally fails cleanup.\n19\t#[derive(Default)]\n20\tstruct MockLifecycle {\n21\t    before_calls: AtomicUsize,\n22\t    cleanup_calls: AtomicUsize,\n23\t    interrupt_cleanup_calls: AtomicUsize,\n24\t    fail_cleanup: AtomicBool,\n25\t}\n26\t\n27\t#[async_trait]\n28\timpl ComputerUseLifecycle for MockLifecycle {\n29\t    async fn before_tool_call(&self) -> Result<(), McpRuntimeError> {\n30\t        self.before_calls.fetch_add(1, Ordering::SeqCst);\n31\t        Ok(())\n32\t    }\n33\t\n34\t    async fn after_turn_cleanup(&self) -> Result<(), McpRuntimeError> {\n35\t        self.cleanup_calls.fetch_add(1, Ordering::SeqCst);\n36\t        if self.fail_cleanup.load(Ordering::SeqCst) {\n37\t            return Err(McpRuntimeError::CleanupFailed);\n38\t        }\n39\t        Ok(())\n40\t    }\n41\t\n42\t    async fn on_interrupt_cleanup(&self) -> Result<(), McpRuntimeError> {\n43\t        self.interrupt_cleanup_calls.fetch_add(1, Ordering::SeqCst);\n44\t        if self.fail_cleanup.load(Ordering::SeqCst) {\n45\t            return Err(McpRuntimeError::CleanupFailed);\n46\t        }\n47\t        Ok(())\n48\t    }\n49\t}\n50\t\n51\t// ── §8.1 Contract tests ────────────────────────────────────────────────────\n52\t\n53\t/// AC: Reserved names rejected with ReservedServerName.\n54\t///\n55\t/// The \"computer\" name is hard-reserved. Validation must fail before any\n56\t/// transport or persistence side-effect occurs, regardless of case.\n57\t#[test]\n58\tfn contract_reserved_names_rejected_with_reserved_server_name() {\n59\t    let policy = DefaultMcpCapabilityPolicy::new(true, true);\n60\t\n61\t    for name in [\"computer\", \"Computer\", \"COMPUTER\"] {\n62\t        let server = McpServerRef::new(name);\n63\t        let err = enforce_capability_policy(&policy, &server, true)\n64\t            .expect_err(&format!(\"reserved name '{name}' must be rejected\"));\n65\t        assert!(\n66\t            matches!(err, McpPolicyError::ReservedServerName),\n67\t            \"'{name}' must yield ReservedServerName, got {err:?}\"\n68\t        );\n69\t    }\n70\t}\n71\t\n72\t/// AC: Privileged capability denied without gate/policy.\n73\t///\n74\t/// Even when the server declares PrivilegedComputerUse, if the feature gate\n75\t/// is disabled the request must fail with FeatureGateDisabled.\n76\t#[test]\n77\tfn contract_privileged_capability_denied_without_feature_gate() {\n78\t    let policy = DefaultMcpCapabilityPolicy::new(false, true);\n79\t    let server = McpServerRef::new(\"desktop\")\n80\t        .with_computer_use_requested(true)\n81\t        .with_declared_capabilities([CapabilityLevel::PrivilegedComputerUse]);\n82\t\n83\t    let err = enforce_capability_policy(&policy, &server, false)\n84\t        .expect_err(\"must fail when feature gate is off\");\n85\t    assert!(\n86\t        matches!(err, McpPolicyError::FeatureGateDisabled),\n87\t        \"expected FeatureGateDisabled, got {err:?}\"\n88\t    );\n89\t}\n90\t\n91\t/// Companion: even with the gate enabled, if the policy disallows privileged\n92\t/// use the result must be PrivilegedCapabilityDenied.\n93\t#[test]\n94\tfn contract_privileged_capability_denied_without_policy_pass() {\n95\t    let policy = DefaultMcpCapabilityPolicy::new(true, false);\n96\t    let server = McpServerRef::new(\"desktop\")\n97\t        .with_computer_use_requested(true)\n98\t        .with_declared_capabilities([CapabilityLevel::PrivilegedComputerUse]);\n99\t\n100\t    let err = enforce_capability_policy(&policy, &server, true)\n101\t        .expect_err(\"must fail when policy disallows privileged\");\n102\t    assert!(\n103\t        matches!(err, McpPolicyError::PrivilegedCapabilityDenied),\n104\t        \"expected PrivilegedCapabilityDenied, got {err:?}\"\n105\t    );\n106\t}\n107\t\n108\t/// AC: Cleanup API called for both normal and interrupt exits.\n109\t///\n110\t/// The lifecycle trait has separate hooks for normal turn cleanup and\n111\t/// interrupt cleanup. Both must be independently callable.\n112\t#[tokio::test]\n113\tasync fn contract_cleanup_api_called_for_normal_exit() {\n114\t    let lifecycle = MockLifecycle::default();\n115\t\n116\t    lifecycle\n117\t        .after_turn_cleanup()\n118\t        .await\n119\t        .expect(\"normal cleanup must succeed\");\n120\t    assert_eq!(\n121\t        lifecycle.cleanup_calls.load(Ordering::SeqCst),\n122\t        1,\n123\t        \"after_turn_cleanup must have been invoked exactly once\"\n124\t    );\n125\t    assert_eq!(\n126\t        lifecycle.interrupt_cleanup_calls.load(Ordering::SeqCst),\n127\t        0,\n128\t        \"on_interrupt_cleanup must not be called on normal exit\"\n129\t    );\n130\t}\n131\t\n132\t#[tokio::test]\n133\tasync fn contract_cleanup_api_called_for_interrupt_exit() {\n134\t    let lifecycle = MockLifecycle::default();\n135\t\n136\t    lifecycle\n137\t        .on_interrupt_cleanup()\n138\t        .await\n139\t        .expect(\"interrupt cleanup must succeed\");\n140\t    assert_eq!(\n141\t        lifecycle.interrupt_cleanup_calls.load(Ordering::SeqCst),\n142\t        1,\n143\t        \"on_interrupt_cleanup must have been invoked exactly once\"\n144\t    );\n145\t    assert_eq!(\n146\t        lifecycle.cleanup_calls.load(Ordering::SeqCst),\n147\t        0,\n148\t        \"after_turn_cleanup must not be called on interrupt exit\"\n149\t    );\n150\t}\n151\t\n152\t// ── §8.2 Integration tests ─────────────────────────────────────────────────\n153\t\n154\t/// AC: MCP server registration + tool dispatch happy path.\n155\t///\n156\t/// A non-reserved server with Standard capability should pass policy\n157\t/// enforcement and return CapabilityLevel::Standard.\n158\t#[test]\n159\tfn integration_registration_and_dispatch_happy_path() {\n160\t    let policy = DefaultMcpCapabilityPolicy::new(true, false);\n161\t    let server = McpServerRef::new(\"my-custom-server\")\n162\t        .with_declared_capabilities([CapabilityLevel::Standard]);\n163\t\n164\t    let level = enforce_capability_policy(&policy, &server, true)\n165\t        .expect(\"non-reserved standard server must pass\");\n166\t    assert_eq!(\n167\t        level,\n168\t        CapabilityLevel::Standard,\n169\t        \"standard server must negotiate Standard capability\"\n170\t    );\n171\t}\n172\t\n173\t/// Companion: privileged happy path — gate on, policy allows, server declares.\n174\t#[test]\n175\tfn integration_privileged_registration_happy_path() {\n176\t    let policy = DefaultMcpCapabilityPolicy::new(true, true);\n177\t    let server = McpServerRef::new(\"desktop-automation\")\n178\t        .with_computer_use_requested(true)\n179\t        .with_declared_capabilities([CapabilityLevel::PrivilegedComputerUse]);\n180\t\n181\t    let level = enforce_capability_policy(&policy, &server, true)\n182\t        .expect(\"fully-qualified privileged server must pass\");\n183\t    assert_eq!(\n184\t        level,\n185\t        CapabilityLevel::PrivilegedComputerUse,\n186\t        \"must negotiate PrivilegedComputerUse\"\n187\t    );\n188\t}\n189\t\n190\t/// AC: Interrupt during tool call triggers cleanup once.\n191\t///\n192\t/// When an interrupt fires, on_interrupt_cleanup must be called exactly once\n193\t/// — not duplicated with after_turn_cleanup.\n194\t#[tokio::test]\n195\tasync fn integration_interrupt_triggers_cleanup_once() {\n196\t    let lifecycle = Arc::new(MockLifecycle::default());\n197\t\n198\t    // Simulate: before_tool_call, then interrupt fires\n199\t    lifecycle\n200\t        .before_tool_call()\n201\t        .await\n202\t        .expect(\"before_tool_call must succeed\");\n203\t\n204\t    // Interrupt path\n205\t    let _ = lifecycle.on_interrupt_cleanup().await;\n206\t\n207\t    assert_eq!(\n208\t        lifecycle.interrupt_cleanup_calls.load(Ordering::SeqCst),\n209\t        1,\n210\t        \"interrupt cleanup must be called exactly once\"\n211\t    );\n212\t    assert_eq!(\n213\t        lifecycle.cleanup_calls.load(Ordering::SeqCst),\n214\t        0,\n215\t        \"normal cleanup must NOT be called during interrupt path\"\n216\t    );\n217\t    assert_eq!(\n218\t        lifecycle.before_calls.load(Ordering::SeqCst),\n219\t        1,\n220\t        \"before_tool_call should have been called once\"\n221\t    );\n222\t}\n223\t\n224\t/// AC: Cleanup exception does not poison subsequent turns.\n225\t///\n226\t/// If after_turn_cleanup fails on one turn, the lifecycle must still be\n227\t/// usable for the next turn — no poisoned state.\n228\t#[tokio::test]\n229\tasync fn integration_cleanup_exception_does_not_poison_subsequent_turns() {\n230\t    let lifecycle = Arc::new(MockLifecycle {\n231\t        fail_cleanup: AtomicBool::new(true),\n232\t        ..Default::default()\n233\t    });\n234\t\n235\t    // Turn 1: cleanup fails\n236\t    let result = lifecycle.after_turn_cleanup().await;\n237\t    assert!(result.is_err(), \"first cleanup should fail as configured\");\n238\t    assert_eq!(lifecycle.cleanup_calls.load(Ordering::SeqCst), 1);\n239\t\n240\t    // Turn 2: stop failing, lifecycle should still work\n241\t    lifecycle.fail_cleanup.store(false, Ordering::SeqCst);\n242\t\n243\t    lifecycle\n244\t        .before_tool_call()\n245\t        .await\n246\t        .expect(\"before_tool_call must succeed after prior cleanup failure\");\n247\t    lifecycle\n248\t        .after_turn_cleanup()\n249\t        .await\n250\t        .expect(\"cleanup must succeed on subsequent turn\");\n251\t\n252\t    assert_eq!(\n253\t        lifecycle.cleanup_calls.load(Ordering::SeqCst),\n254\t        2,\n255\t        \"lifecycle must remain usable after cleanup failure\"\n256\t    );\n257\t    assert_eq!(lifecycle.before_calls.load(Ordering::SeqCst), 1);\n258\t}\n259\t\n260\t/// Companion: interrupt cleanup failure also does not poison.\n261\t#[tokio::test]\n262\tasync fn integration_interrupt_cleanup_failure_does_not_poison() {\n263\t    let lifecycle = Arc::new(MockLifecycle {\n264\t        fail_cleanup: AtomicBool::new(true),\n265\t        ..Default::default()\n266\t    });\n267\t\n268\t    // Interrupt cleanup fails\n269\t    let result = lifecycle.on_interrupt_cleanup().await;\n270\t    assert!(result.is_err());\n271\t\n272\t    // Next turn: should still work\n273\t    lifecycle.fail_cleanup.store(false, Ordering::SeqCst);\n274\t    lifecycle\n275\t        .before_tool_call()\n276\t        .await\n277\t        .expect(\"lifecycle must not be poisoned by prior interrupt cleanup failure\");\n278\t    lifecycle\n279\t        .after_turn_cleanup()\n280\t        .await\n281\t        .expect(\"normal cleanup must work after interrupt cleanup failure\");\n282\t}\n283\t"}]},"parent_tool_use_id":"toolu_013X19bThc964g3DNsp4No5N","session_id":"6362e84a-6f04-4b0f-bbe9-0adfe63953c5","uuid":"43253cb5-97bf-4d4d-9487-8b0ec8f553a8","timestamp":"2026-04-02T14:31:55.503Z"}
