{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EcXtzKaWinX9YkLBEB5HAH","type":"tool_result","content":"1\tuse crate::spec_contracts::{\n2\t    AssistantModeContext, AssistantModeDecision, AssistantModeService, CapabilityPolicy,\n3\t    KairosError, KairosTelemetryTags, PromptComposeContext, PromptComposeResult,\n4\t    PromptPrecedenceLayer, ResolvedModeSource, RouteDecision, RouteInputContext, RouteSource,\n5\t};\n6\tuse ccode_domain::{\n7\t    assistant_mode::{AssistantMode, ModeSwitchTrigger},\n8\t    event::DomainEvent,\n9\t    session::SessionId,\n10\t};\n11\tuse std::collections::BTreeSet;\n12\t\n13\t#[derive(Debug, Default)]\n14\tpub struct DefaultAssistantModeService;\n15\t\n16\timpl AssistantModeService for DefaultAssistantModeService {\n17\t    fn resolve_mode(&self, ctx: AssistantModeContext) -> AssistantModeDecision {\n18\t        if !ctx.policy_enabled || !ctx.capability_policy.allow_assistant_modes {\n19\t            return AssistantModeDecision {\n20\t                effective_mode: ctx.configured_mode,\n21\t                source: ResolvedModeSource::Config,\n22\t                switch_event: None,\n23\t                visible_tools: Vec::new(),\n24\t                telemetry_tags: Self::telemetry(\n25\t                    ctx.configured_mode,\n26\t                    ModeSwitchTrigger::ConfigDefault,\n27\t                    0,\n28\t                ),\n29\t                error: Some(KairosError::DisabledByPolicy),\n30\t            };\n31\t        }\n32\t\n33\t        let (effective_mode, source, trigger) = match ctx.session_mode {\n34\t            Some(mode) => (\n35\t                mode,\n36\t                ResolvedModeSource::Session,\n37\t                ModeSwitchTrigger::SessionState,\n38\t            ),\n39\t            None => (\n40\t                ctx.configured_mode,\n41\t                ResolvedModeSource::Config,\n42\t                ModeSwitchTrigger::ConfigDefault,\n43\t            ),\n44\t        };\n45\t\n46\t        if !Self::mode_allowed(effective_mode, &ctx.capability_policy) {\n47\t            return AssistantModeDecision {\n48\t                effective_mode: ctx.configured_mode,\n49\t                source: ResolvedModeSource::Config,\n50\t                switch_event: None,\n51\t                visible_tools: Vec::new(),\n52\t                telemetry_tags: Self::telemetry(\n53\t                    ctx.configured_mode,\n54\t                    ModeSwitchTrigger::ConfigDefault,\n55\t                    0,\n56\t                ),\n57\t                error: Some(KairosError::InvalidModeState),\n58\t            };\n59\t        }\n60\t\n61\t        AssistantModeDecision {\n62\t            effective_mode,\n63\t            source,\n64\t            switch_event: Self::mode_switch_event(\n65\t                &ctx.session_id,\n66\t                ctx.configured_mode,\n67\t                effective_mode,\n68\t                trigger,\n69\t            ),\n70\t            visible_tools: Self::visible_tools(\n71\t                effective_mode,\n72\t                &ctx.available_tools,\n73\t                &ctx.capability_policy,\n74\t            ),\n75\t            telemetry_tags: Self::telemetry(effective_mode, trigger, 0),\n76\t            error: None,\n77\t        }\n78\t    }\n79\t\n80\t    fn build_prompt(&self, ctx: PromptComposeContext) -> PromptComposeResult {\n81\t        if !ctx.policy_enabled || !ctx.capability_policy.allow_assistant_modes {\n82\t            return PromptComposeResult {\n83\t                system_prompt: String::new(),\n84\t                precedence: Vec::new(),\n85\t                telemetry_tags: Self::telemetry(ctx.mode, ModeSwitchTrigger::ConfigDefault, 0),\n86\t                error: Some(KairosError::DisabledByPolicy),\n87\t            };\n88\t        }\n89\t        if !Self::mode_allowed(ctx.mode, &ctx.capability_policy) {\n90\t            return PromptComposeResult {\n91\t                system_prompt: String::new(),\n92\t                precedence: Vec::new(),\n93\t                telemetry_tags: Self::telemetry(ctx.mode, ModeSwitchTrigger::ConfigDefault, 0),\n94\t                error: Some(KairosError::InvalidModeState),\n95\t            };\n96\t        }\n97\t\n98\t        let mut precedence = Vec::new();\n99\t        let mut layers = Vec::new();\n100\t\n101\t        if let Some(base) = ctx\n102\t            .base_prompt\n103\t            .as_ref()\n104\t            .map(|s| s.trim())\n105\t            .filter(|s| !s.is_empty())\n106\t        {\n107\t            precedence.push(PromptPrecedenceLayer::Base);\n108\t            layers.push(base.to_owned());\n109\t        }\n110\t\n111\t        precedence.push(PromptPrecedenceLayer::ModeDefault);\n112\t        layers.push(Self::default_mode_prompt(ctx.mode).to_owned());\n113\t\n114\t        if let Some(mode_override) = ctx\n115\t            .mode_prompt_override\n116\t            .as_ref()\n117\t            .map(|s| s.trim())\n118\t            .filter(|s| !s.is_empty())\n119\t        {\n120\t            precedence.push(PromptPrecedenceLayer::ModeOverride);\n121\t            layers.push(mode_override.to_owned());\n122\t        }\n123\t\n124\t        if let Some(policy_prompt) = ctx\n125\t            .policy_prompt\n126\t            .as_ref()\n127\t            .map(|s| s.trim())\n128\t            .filter(|s| !s.is_empty())\n129\t        {\n130\t            precedence.push(PromptPrecedenceLayer::Policy);\n131\t            layers.push(policy_prompt.to_owned());\n132\t        }\n133\t\n134\t        if let Some(runtime_prompt) = ctx\n135\t            .runtime_prompt\n136\t            .as_ref()\n137\t            .map(|s| s.trim())\n138\t            .filter(|s| !s.is_empty())\n139\t        {\n140\t            precedence.push(PromptPrecedenceLayer::Runtime);\n141\t            layers.push(runtime_prompt.to_owned());\n142\t        }\n143\t\n144\t        let system_prompt = layers.join(\"\\n\\n\");\n145\t        if system_prompt.is_empty() {\n146\t            return PromptComposeResult {\n147\t                system_prompt,\n148\t                precedence,\n149\t                telemetry_tags: Self::telemetry(ctx.mode, ModeSwitchTrigger::ConfigDefault, 0),\n150\t                error: Some(KairosError::PromptComposeFailed(\n151\t                    \"no prompt layers available\".to_owned(),\n152\t                )),\n153\t            };\n154\t        }\n155\t\n156\t        let layer_count = precedence.len();\n157\t        PromptComposeResult {\n158\t            system_prompt,\n159\t            precedence,\n160\t            telemetry_tags: Self::telemetry(\n161\t                ctx.mode,\n162\t                ModeSwitchTrigger::ConfigDefault,\n163\t                layer_count,\n164\t            ),\n165\t            error: None,\n166\t        }\n167\t    }\n168\t\n169\t    fn route_input(&self, ctx: RouteInputContext) -> RouteDecision {\n170\t        if !ctx.policy_enabled || !ctx.capability_policy.allow_assistant_modes {\n171\t            return RouteDecision {\n172\t                source: RouteSource::Noop,\n173\t                next_mode: ctx.current_mode,\n174\t                passthrough_input: ctx.raw_input,\n175\t                command_consumed: false,\n176\t                switch_event: None,\n177\t                telemetry_tags: Self::telemetry(\n178\t                    ctx.current_mode,\n179\t                    ModeSwitchTrigger::ConfigDefault,\n180\t                    0,\n181\t                ),\n182\t                error: Some(KairosError::DisabledByPolicy),\n183\t            };\n184\t        }\n185\t\n186\t        let slash = Self::parse_slash_mode(&ctx.raw_input);\n187\t        let slash_mode = slash.as_ref().map(|(mode, _)| *mode);\n188\t\n189\t        if let (Some(explicit), Some(from_slash)) = (ctx.explicit_mode, slash_mode)\n190\t            && explicit != from_slash\n191\t        {\n192\t            return RouteDecision {\n193\t                source: RouteSource::Conflict,\n194\t                next_mode: ctx.current_mode,\n195\t                passthrough_input: ctx.raw_input,\n196\t                command_consumed: false,\n197\t                switch_event: None,\n198\t                telemetry_tags: Self::telemetry(\n199\t                    ctx.current_mode,\n200\t                    ModeSwitchTrigger::ConfigDefault,\n201\t                    0,\n202\t                ),\n203\t                error: Some(KairosError::RouteConflict),\n204\t            };\n205\t        }\n206\t\n207\t        let next_mode = ctx.explicit_mode.or(slash_mode).unwrap_or(ctx.current_mode);\n208\t\n209\t        if !Self::mode_allowed(next_mode, &ctx.capability_policy) {\n210\t            return RouteDecision {\n211\t                source: RouteSource::Noop,\n212\t                next_mode: ctx.current_mode,\n213\t                passthrough_input: ctx.raw_input,\n214\t                command_consumed: false,\n215\t                switch_event: None,\n216\t                telemetry_tags: Self::telemetry(\n217\t                    ctx.current_mode,\n218\t                    ModeSwitchTrigger::ConfigDefault,\n219\t                    0,\n220\t                ),\n221\t                error: Some(KairosError::InvalidModeState),\n222\t            };\n223\t        }\n224\t\n225\t        let source = if ctx.explicit_mode.is_some() {\n226\t            RouteSource::ExplicitOverride\n227\t        } else if slash_mode.is_some() {\n228\t            RouteSource::SlashCommand\n229\t        } else {\n230\t            RouteSource::Noop\n231\t        };\n232\t        let trigger = match source {\n233\t            RouteSource::ExplicitOverride => ModeSwitchTrigger::ExplicitOverride,\n234\t            RouteSource::SlashCommand => ModeSwitchTrigger::SlashCommand,\n235\t            RouteSource::Noop | RouteSource::Conflict => ModeSwitchTrigger::ConfigDefault,\n236\t        };\n237\t\n238\t        let (command_consumed, passthrough_input) = if let Some((_, rest)) = slash {\n239\t            (true, rest)\n240\t        } else {\n241\t            (false, ctx.raw_input)\n242\t        };\n243\t\n244\t        RouteDecision {\n245\t            source,\n246\t            next_mode,\n247\t            passthrough_input,\n248\t            command_consumed,\n249\t            switch_event: Self::mode_switch_event(\n250\t                &ctx.session_id,\n251\t                ctx.current_mode,\n252\t                next_mode,\n253\t                trigger,\n254\t            ),\n255\t            telemetry_tags: Self::telemetry(next_mode, trigger, 0),\n256\t            error: None,\n257\t        }\n258\t    }\n259\t}\n260\t\n261\timpl DefaultAssistantModeService {\n262\t    fn mode_allowed(mode: AssistantMode, capability_policy: &CapabilityPolicy) -> bool {\n263\t        match mode {\n264\t            AssistantMode::Kairos => capability_policy.allow_assistant_modes,\n265\t            AssistantMode::KairosBrief => {\n266\t                capability_policy.allow_assistant_modes && capability_policy.allow_brief_mode\n267\t            }\n268\t            AssistantMode::KairosChannels => {\n269\t                capability_policy.allow_assistant_modes && capability_policy.allow_channels_mode\n270\t            }\n271\t        }\n272\t    }\n273\t\n274\t    fn default_mode_prompt(mode: AssistantMode) -> &'static str {\n275\t        match mode {\n276\t            AssistantMode::Kairos => \"You are KAIROS mode. Balance depth and efficiency.\",\n277\t            AssistantMode::KairosBrief => {\n278\t                \"You are KAIROS BRIEF mode. Keep responses concise and focused.\"\n279\t            }\n280\t            AssistantMode::KairosChannels => {\n281\t                \"You are KAIROS CHANNELS mode. Coordinate multi-channel context safely.\"\n282\t            }\n283\t        }\n284\t    }\n285\t\n286\t    fn mode_switch_event(\n287\t        session_id: &SessionId,\n288\t        from_mode: AssistantMode,\n289\t        to_mode: AssistantMode,\n290\t        trigger: ModeSwitchTrigger,\n291\t    ) -> Option<DomainEvent> {\n292\t        (from_mode != to_mode).then(|| DomainEvent::AssistantModeSwitched {\n293\t            session_id: session_id.clone(),\n294\t            from_mode,\n295\t            to_mode,\n296\t            trigger,\n297\t        })\n298\t    }\n299\t\n300\t    fn telemetry(\n301\t        mode: AssistantMode,\n302\t        mode_source: ModeSwitchTrigger,\n303\t        prompt_layer_count: usize,\n304\t    ) -> KairosTelemetryTags {\n305\t        KairosTelemetryTags {\n306\t            mode,\n307\t            mode_source,\n308\t            kairos_active: true,\n309\t            brief_active: mode == AssistantMode::KairosBrief,\n310\t            channels_active: mode == AssistantMode::KairosChannels,\n311\t            prompt_layer_count,\n312\t        }\n313\t    }\n314\t\n315\t    fn parse_slash_mode(raw_input: &str) -> Option<(AssistantMode, String)> {\n316\t        let trimmed = raw_input.trim_start();\n317\t        let mut parts = trimmed.splitn(2, char::is_whitespace);\n318\t        let command = parts.next()?;\n319\t        let remainder = parts\n320\t            .next()\n321\t            .map(str::trim_start)\n322\t            .unwrap_or_default()\n323\t            .to_owned();\n324\t        let mode = match command {\n325\t            \"/brief\" => AssistantMode::KairosBrief,\n326\t            \"/kairos\" => AssistantMode::Kairos,\n327\t            \"/channels\" => AssistantMode::KairosChannels,\n328\t            _ => return None,\n329\t        };\n330\t        Some((mode, remainder))\n331\t    }\n332\t\n333\t    pub fn visible_tools(\n334\t        mode: AssistantMode,\n335\t        available_tools: &[String],\n336\t        capability_policy: &CapabilityPolicy,\n337\t    ) -> Vec<String> {\n338\t        let blocked: BTreeSet<&str> = capability_policy\n339\t            .blocked_tools\n340\t            .iter()\n341\t            .map(String::as_str)\n342\t            .collect();\n343\t        let brief_blocked: BTreeSet<&str> = capability_policy\n344\t            .brief_blocked_tools\n345\t            .iter()\n346\t            .map(String::as_str)\n347\t            .collect();\n348\t        available_tools\n349\t            .iter()\n350\t            .filter(|tool| !blocked.contains(tool.as_str()))\n351\t            .filter(|tool| {\n352\t                mode != AssistantMode::KairosBrief || !brief_blocked.contains(tool.as_str())\n353\t            })\n354\t            .cloned()\n355\t            .collect()\n356\t    }\n357\t}\n358\t\n359\t#[cfg(test)]\n360\tmod tests {\n361\t    use super::*;\n362\t    use crate::spec_contracts::{\n363\t        CapabilityPolicy, PromptPrecedenceLayer, ResolvedModeSource, RouteSource,\n364\t    };\n365\t    use ccode_domain::{assistant_mode::AssistantMode, event::DomainEvent, session::SessionId};\n366\t\n367\t    #[test]\n368\t    fn resolve_mode_is_deterministic_and_emits_mode_switch_event() {\n369\t        let service = DefaultAssistantModeService;\n370\t        let decision = service.resolve_mode(AssistantModeContext {\n371\t            session_id: SessionId(\"sess-1\".into()),\n372\t            configured_mode: AssistantMode::Kairos,\n373\t            session_mode: Some(AssistantMode::KairosBrief),\n374\t            policy_enabled: true,\n375\t            available_tools: vec![\"read_file\".into(), \"shell\".into()],\n376\t            capability_policy: CapabilityPolicy::default(),\n377\t        });\n378\t\n379\t        assert!(decision.error.is_none());\n380\t        assert_eq!(decision.effective_mode, AssistantMode::KairosBrief);\n381\t        assert_eq!(decision.source, ResolvedModeSource::Session);\n382\t        assert!(matches!(\n383\t            decision.switch_event,\n384\t            Some(DomainEvent::AssistantModeSwitched {\n385\t                from_mode: AssistantMode::Kairos,\n386\t                to_mode: AssistantMode::KairosBrief,\n387\t                ..\n388\t            })\n389\t        ));\n390\t    }\n391\t\n392\t    #[test]\n393\t    fn build_prompt_applies_deterministic_precedence_order() {\n394\t        let service = DefaultAssistantModeService;\n395\t        let result = service.build_prompt(PromptComposeContext {\n396\t            mode: AssistantMode::KairosBrief,\n397\t            policy_enabled: true,\n398\t            capability_policy: CapabilityPolicy::default(),\n399\t            base_prompt: Some(\"base\".into()),\n400\t            mode_prompt_override: Some(\"mode_override\".into()),\n401\t            policy_prompt: Some(\"policy\".into()),\n402\t            runtime_prompt: Some(\"runtime\".into()),\n403\t        });\n404\t\n405\t        assert!(result.error.is_none());\n406\t        assert_eq!(\n407\t            result.precedence,\n408\t            vec![\n409\t                PromptPrecedenceLayer::Base,\n410\t                PromptPrecedenceLayer::ModeDefault,\n411\t                PromptPrecedenceLayer::ModeOverride,\n412\t                PromptPrecedenceLayer::Policy,\n413\t                PromptPrecedenceLayer::Runtime,\n414\t            ]\n415\t        );\n416\t        assert_eq!(\n417\t            result.system_prompt,\n418\t            \"base\\n\\nYou are KAIROS BRIEF mode. Keep responses concise and focused.\\n\\nmode_override\\n\\npolicy\\n\\nruntime\"\n419\t        );\n420\t    }\n421\t\n422\t    #[test]\n423\t    fn route_input_reports_conflict_when_override_and_slash_disagree() {\n424\t        let service = DefaultAssistantModeService;\n425\t        let decision = service.route_input(RouteInputContext {\n426\t            session_id: SessionId(\"sess-1\".into()),\n427\t            current_mode: AssistantMode::Kairos,\n428\t            policy_enabled: true,\n429\t            capability_policy: CapabilityPolicy::default(),\n430\t            raw_input: \"/brief summarize this\".into(),\n431\t            explicit_mode: Some(AssistantMode::KairosChannels),\n432\t        });\n433\t\n434\t        assert_eq!(decision.source, RouteSource::Conflict);\n435\t        assert!(decision.error.is_some());\n436\t        assert!(decision.switch_event.is_none());\n437\t    }\n438\t}\n439\t"}]},"parent_tool_use_id":"toolu_0136ki2H8JXDGpZbLozNj1dB","session_id":"6362e84a-6f04-4b0f-bbe9-0adfe63953c5","uuid":"70af1ece-ab6e-4238-ad1f-dc411ef78b30","timestamp":"2026-04-02T14:32:36.271Z"}
