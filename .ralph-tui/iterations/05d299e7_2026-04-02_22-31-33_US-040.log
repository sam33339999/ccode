{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HpFH13SR53Sr2Zk7R85Ypq","type":"tool_result","content":"1\t/// Coordinator mode acceptance tests (US-039)\n2\t///\n3\t/// Covers all scenarios from coordinator-mode-contract.md §7 Acceptance Matrix:\n4\t///   §7.1 Contract tests  – precedence and reconcile logic invariants\n5\t///   §7.2 Integration tests – resume path mode consistency\n6\t///   §7.3 CLI behaviour tests – tool visibility, prompt branch, event metadata\n7\tuse crate::{\n8\t    mode_coordinator_service::DefaultModeCoordinatorService,\n9\t    spec_contracts::{\n10\t        CoordinatorMode, CoordinatorModeError, EffectiveModeSource, ModeCoordinatorService,\n11\t        ModeReconcileAction, ModeResolutionInput, ModeSwitchEvent, ModeSwitchReason, SessionMode,\n12\t    },\n13\t};\n14\t\n15\t// ── helpers ───────────────────────────────────────────────────────────────\n16\t\n17\tfn standard_session() -> Option<SessionMode> {\n18\t    Some(SessionMode {\n19\t        mode: CoordinatorMode::Standard,\n20\t    })\n21\t}\n22\t\n23\tfn coordinator_session() -> Option<SessionMode> {\n24\t    Some(SessionMode {\n25\t        mode: CoordinatorMode::Coordinator,\n26\t    })\n27\t}\n28\t\n29\tfn service_with(\n30\t    policy_enabled: bool,\n31\t    env_mode: Option<CoordinatorMode>,\n32\t    current_mode: CoordinatorMode,\n33\t) -> DefaultModeCoordinatorService {\n34\t    DefaultModeCoordinatorService {\n35\t        policy_enabled,\n36\t        env_mode,\n37\t        current_mode,\n38\t    }\n39\t}\n40\t\n41\t// ── §7.1 Contract tests ──────────────────────────────────────────────────\n42\t\n43\t/// AC: mode precedence and reconcile logic is deterministic.\n44\t///\n45\t/// The precedence rule is: session_mode > env_mode > default(Standard).\n46\t/// Given identical inputs the result must never vary.\n47\t#[test]\n48\tfn contract_mode_precedence_is_deterministic() {\n49\t    let svc = DefaultModeCoordinatorService::default();\n50\t\n51\t    // Run resolution twice with same inputs → identical results.\n52\t    let input = ModeResolutionInput {\n53\t        policy_enabled: true,\n54\t        env_mode: Some(CoordinatorMode::Coordinator),\n55\t        session_mode: coordinator_session(),\n56\t        previous_mode: Some(CoordinatorMode::Standard),\n57\t    };\n58\t\n59\t    let a = svc.resolve_effective_mode(input.clone());\n60\t    let b = svc.resolve_effective_mode(input);\n61\t\n62\t    assert_eq!(a.mode, b.mode, \"mode must be deterministic across calls\");\n63\t    assert_eq!(\n64\t        a.source, b.source,\n65\t        \"source must be deterministic across calls\"\n66\t    );\n67\t    assert_eq!(\n68\t        a.switch_event, b.switch_event,\n69\t        \"switch_event must be deterministic across calls\"\n70\t    );\n71\t}\n72\t\n73\t/// AC: session_mode > env_mode in precedence.\n74\t///\n75\t/// When both session and env modes are provided, session wins.\n76\t#[test]\n77\tfn contract_session_mode_takes_precedence_over_env_mode() {\n78\t    let svc = DefaultModeCoordinatorService::default();\n79\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n80\t        policy_enabled: true,\n81\t        env_mode: Some(CoordinatorMode::Standard),\n82\t        session_mode: coordinator_session(),\n83\t        previous_mode: Some(CoordinatorMode::Standard),\n84\t    });\n85\t\n86\t    assert_eq!(result.mode, CoordinatorMode::Coordinator);\n87\t    assert_eq!(result.source, EffectiveModeSource::Session);\n88\t    assert!(result.error.is_none());\n89\t}\n90\t\n91\t/// AC: env_mode > default when no session mode.\n92\t#[test]\n93\tfn contract_env_mode_takes_precedence_over_default() {\n94\t    let svc = DefaultModeCoordinatorService::default();\n95\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n96\t        policy_enabled: true,\n97\t        env_mode: Some(CoordinatorMode::Coordinator),\n98\t        session_mode: None,\n99\t        previous_mode: Some(CoordinatorMode::Standard),\n100\t    });\n101\t\n102\t    assert_eq!(result.mode, CoordinatorMode::Coordinator);\n103\t    assert_eq!(result.source, EffectiveModeSource::Env);\n104\t}\n105\t\n106\t/// AC: default fallback is Standard when nothing else is provided.\n107\t#[test]\n108\tfn contract_default_fallback_is_standard() {\n109\t    let svc = DefaultModeCoordinatorService::default();\n110\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n111\t        policy_enabled: true,\n112\t        env_mode: None,\n113\t        session_mode: None,\n114\t        previous_mode: None,\n115\t    });\n116\t\n117\t    assert_eq!(result.mode, CoordinatorMode::Standard);\n118\t    assert_eq!(result.source, EffectiveModeSource::Default);\n119\t    assert!(result.switch_event.is_none());\n120\t    assert!(result.error.is_none());\n121\t}\n122\t\n123\t/// AC: resumed session mode vs env mode has explicit precedence rule.\n124\t///\n125\t/// reconcile_on_resume must prefer session_mode over env_mode and surface\n126\t/// SessionModeMismatch when they disagree.\n127\t#[test]\n128\tfn contract_reconcile_session_wins_over_env_and_flags_mismatch() {\n129\t    let svc = service_with(\n130\t        true,\n131\t        Some(CoordinatorMode::Standard),\n132\t        CoordinatorMode::Standard,\n133\t    );\n134\t\n135\t    let result = svc.reconcile_on_resume(coordinator_session());\n136\t\n137\t    assert_eq!(result.mode, CoordinatorMode::Coordinator);\n138\t    assert_eq!(result.action, ModeReconcileAction::SessionWins);\n139\t    assert!(\n140\t        matches!(\n141\t            result.error,\n142\t            Some(CoordinatorModeError::SessionModeMismatch)\n143\t        ),\n144\t        \"mismatch between session and env must surface SessionModeMismatch\"\n145\t    );\n146\t}\n147\t\n148\t/// AC: reconcile is deterministic — same service + same session → same result.\n149\t#[test]\n150\tfn contract_reconcile_logic_is_deterministic() {\n151\t    let svc = service_with(\n152\t        true,\n153\t        Some(CoordinatorMode::Standard),\n154\t        CoordinatorMode::Standard,\n155\t    );\n156\t\n157\t    let a = svc.reconcile_on_resume(coordinator_session());\n158\t    let b = svc.reconcile_on_resume(coordinator_session());\n159\t\n160\t    assert_eq!(a.mode, b.mode);\n161\t    assert_eq!(a.action, b.action);\n162\t    assert_eq!(a.switch_event, b.switch_event);\n163\t}\n164\t\n165\t/// AC: invalid mode transition returns InvalidModeTransition error.\n166\t///\n167\t/// Coordinator → Standard is forbidden (sticky mode). Attempting it via\n168\t/// resolve_effective_mode must return InvalidModeTransition without changing mode.\n169\t#[test]\n170\tfn contract_invalid_mode_transition_returns_error() {\n171\t    let svc = DefaultModeCoordinatorService::default();\n172\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n173\t        policy_enabled: true,\n174\t        env_mode: Some(CoordinatorMode::Standard),\n175\t        session_mode: None,\n176\t        previous_mode: Some(CoordinatorMode::Coordinator),\n177\t    });\n178\t\n179\t    assert_eq!(\n180\t        result.mode,\n181\t        CoordinatorMode::Coordinator,\n182\t        \"mode must remain Coordinator when transition is rejected\"\n183\t    );\n184\t    assert!(\n185\t        matches!(\n186\t            result.error,\n187\t            Some(CoordinatorModeError::InvalidModeTransition)\n188\t        ),\n189\t        \"Coordinator→Standard must yield InvalidModeTransition; got {:?}\",\n190\t        result.error\n191\t    );\n192\t}\n193\t\n194\t/// AC: invalid mode transition via reconcile_on_resume.\n195\t///\n196\t/// When current mode is Coordinator and no session mode is provided, env\n197\t/// tries to go Standard which is forbidden.\n198\t#[test]\n199\tfn contract_invalid_transition_on_reconcile_returns_error() {\n200\t    let svc = service_with(\n201\t        true,\n202\t        Some(CoordinatorMode::Standard),\n203\t        CoordinatorMode::Coordinator,\n204\t    );\n205\t\n206\t    let result = svc.reconcile_on_resume(None);\n207\t\n208\t    assert_eq!(\n209\t        result.mode,\n210\t        CoordinatorMode::Coordinator,\n211\t        \"mode must stay Coordinator when transition is blocked\"\n212\t    );\n213\t    assert_eq!(result.action, ModeReconcileAction::Noop);\n214\t    assert!(matches!(\n215\t        result.error,\n216\t        Some(CoordinatorModeError::InvalidModeTransition)\n217\t    ));\n218\t}\n219\t\n220\t/// AC: invalid transition via reconcile when session itself tries to downgrade.\n221\t#[test]\n222\tfn contract_invalid_transition_on_reconcile_with_session_returns_error() {\n223\t    let svc = service_with(true, None, CoordinatorMode::Coordinator);\n224\t\n225\t    let result = svc.reconcile_on_resume(standard_session());\n226\t\n227\t    assert_eq!(result.mode, CoordinatorMode::Coordinator);\n228\t    assert_eq!(result.action, ModeReconcileAction::Noop);\n229\t    assert!(matches!(\n230\t        result.error,\n231\t        Some(CoordinatorModeError::InvalidModeTransition)\n232\t    ));\n233\t}\n234\t\n235\t/// AC: disabled policy always returns Standard with DisabledByPolicy.\n236\t#[test]\n237\tfn contract_disabled_policy_returns_standard_with_error() {\n238\t    let svc = DefaultModeCoordinatorService::default();\n239\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n240\t        policy_enabled: false,\n241\t        env_mode: Some(CoordinatorMode::Coordinator),\n242\t        session_mode: coordinator_session(),\n243\t        previous_mode: None,\n244\t    });\n245\t\n246\t    assert_eq!(result.mode, CoordinatorMode::Standard);\n247\t    assert!(matches!(\n248\t        result.error,\n249\t        Some(CoordinatorModeError::DisabledByPolicy)\n250\t    ));\n251\t}\n252\t\n253\t// ── §7.2 Integration tests ───────────────────────────────────────────────\n254\t\n255\t/// AC: resume path updates mode consistently.\n256\t///\n257\t/// Simulate a full resume: service starts Standard, session says Coordinator.\n258\t/// After reconcile the effective mode must be Coordinator with SessionWins action.\n259\t#[test]\n260\tfn integration_resume_path_updates_mode_consistently() {\n261\t    let svc = service_with(true, None, CoordinatorMode::Standard);\n262\t\n263\t    let reconcile = svc.reconcile_on_resume(coordinator_session());\n264\t    assert_eq!(reconcile.mode, CoordinatorMode::Coordinator);\n265\t    assert_eq!(reconcile.action, ModeReconcileAction::SessionWins);\n266\t\n267\t    // Now resolve with the reconciled mode as previous\n268\t    let resolved = svc.resolve_effective_mode(ModeResolutionInput {\n269\t        policy_enabled: true,\n270\t        env_mode: None,\n271\t        session_mode: coordinator_session(),\n272\t        previous_mode: Some(reconcile.mode),\n273\t    });\n274\t\n275\t    assert_eq!(\n276\t        resolved.mode,\n277\t        CoordinatorMode::Coordinator,\n278\t        \"subsequent resolution must be consistent with reconcile result\"\n279\t    );\n280\t}\n281\t\n282\t/// AC: resume without session mode adopts env mode.\n283\t#[test]\n284\tfn integration_resume_without_session_adopts_env_mode() {\n285\t    let svc = service_with(\n286\t        true,\n287\t        Some(CoordinatorMode::Coordinator),\n288\t        CoordinatorMode::Standard,\n289\t    );\n290\t\n291\t    let result = svc.reconcile_on_resume(None);\n292\t\n293\t    assert_eq!(result.mode, CoordinatorMode::Coordinator);\n294\t    assert_eq!(result.action, ModeReconcileAction::EnvAdopted);\n295\t    assert!(result.error.is_none());\n296\t}\n297\t\n298\t/// AC: resume without session and without env falls back to Standard.\n299\t#[test]\n300\tfn integration_resume_without_session_or_env_falls_back_to_standard() {\n301\t    let svc = service_with(true, None, CoordinatorMode::Standard);\n302\t\n303\t    let result = svc.reconcile_on_resume(None);\n304\t\n305\t    assert_eq!(result.mode, CoordinatorMode::Standard);\n306\t    assert_eq!(result.action, ModeReconcileAction::EnvAdopted);\n307\t    assert!(result.error.is_none());\n308\t    assert!(\n309\t        result.switch_event.is_none(),\n310\t        \"no switch event when mode stays the same\"\n311\t    );\n312\t}\n313\t\n314\t/// AC: tool visibility changes when mode switches.\n315\t///\n316\t/// Coordinator mode exposes a wider tool set. After switching from Standard\n317\t/// to Coordinator the tool allowlist must differ.\n318\t#[test]\n319\tfn integration_tool_visibility_changes_on_mode_switch() {\n320\t    let svc = DefaultModeCoordinatorService::default();\n321\t\n322\t    let standard = svc.resolve_effective_mode(ModeResolutionInput {\n323\t        policy_enabled: true,\n324\t        env_mode: None,\n325\t        session_mode: None,\n326\t        previous_mode: None,\n327\t    });\n328\t    assert_eq!(standard.mode, CoordinatorMode::Standard);\n329\t\n330\t    let coordinator = svc.resolve_effective_mode(ModeResolutionInput {\n331\t        policy_enabled: true,\n332\t        env_mode: None,\n333\t        session_mode: coordinator_session(),\n334\t        previous_mode: Some(CoordinatorMode::Standard),\n335\t    });\n336\t    assert_eq!(coordinator.mode, CoordinatorMode::Coordinator);\n337\t\n338\t    // Modes differ → tool allowlists must differ. We verify the mode values\n339\t    // are distinct which is the precondition for the tool-runtime allowlist\n340\t    // filter to produce different outputs.\n341\t    assert_ne!(\n342\t        standard.mode, coordinator.mode,\n343\t        \"modes must differ so tool-runtime produces different allowlists\"\n344\t    );\n345\t    assert!(\n346\t        coordinator.switch_event.is_some(),\n347\t        \"mode switch must emit an event for tool-runtime to react to\"\n348\t    );\n349\t}\n350\t\n351\t/// AC: disabled policy on resume returns Standard with error.\n352\t#[test]\n353\tfn integration_resume_disabled_policy_returns_standard() {\n354\t    let svc = service_with(\n355\t        false,\n356\t        Some(CoordinatorMode::Coordinator),\n357\t        CoordinatorMode::Standard,\n358\t    );\n359\t\n360\t    let result = svc.reconcile_on_resume(coordinator_session());\n361\t\n362\t    assert_eq!(result.mode, CoordinatorMode::Standard);\n363\t    assert_eq!(result.action, ModeReconcileAction::Noop);\n364\t    assert!(matches!(\n365\t        result.error,\n366\t        Some(CoordinatorModeError::DisabledByPolicy)\n367\t    ));\n368\t}\n369\t\n370\t// ── §7.3 CLI behaviour tests ─────────────────────────────────────────────\n371\t\n372\t/// AC: tool visibility and prompt mode branch are correct.\n373\t///\n374\t/// Standard mode produces Default source; Coordinator mode produces Session\n375\t/// source. The source drives the TUI prompt branch selection.\n376\t#[test]\n377\tfn cli_tool_visibility_and_prompt_branch_are_correct() {\n378\t    let svc = DefaultModeCoordinatorService::default();\n379\t\n380\t    // Standard mode → Default source\n381\t    let standard = svc.resolve_effective_mode(ModeResolutionInput {\n382\t        policy_enabled: true,\n383\t        env_mode: None,\n384\t        session_mode: None,\n385\t        previous_mode: None,\n386\t    });\n387\t    assert_eq!(standard.source, EffectiveModeSource::Default);\n388\t\n389\t    // Coordinator via session → Session source\n390\t    let coordinator = svc.resolve_effective_mode(ModeResolutionInput {\n391\t        policy_enabled: true,\n392\t        env_mode: None,\n393\t        session_mode: coordinator_session(),\n394\t        previous_mode: None,\n395\t    });\n396\t    assert_eq!(coordinator.source, EffectiveModeSource::Session);\n397\t\n398\t    // Coordinator via env → Env source\n399\t    let env_coord = svc.resolve_effective_mode(ModeResolutionInput {\n400\t        policy_enabled: true,\n401\t        env_mode: Some(CoordinatorMode::Coordinator),\n402\t        session_mode: None,\n403\t        previous_mode: None,\n404\t    });\n405\t    assert_eq!(env_coord.source, EffectiveModeSource::Env);\n406\t}\n407\t\n408\t/// AC: mode switch event metadata (from, to, reason) is emitted.\n409\t///\n410\t/// Every mode change must produce a ModeSwitchEvent with all three fields\n411\t/// populated so downstream consumers (TUI, telemetry) can react.\n412\t#[test]\n413\tfn cli_mode_switch_event_metadata_is_emitted() {\n414\t    let svc = DefaultModeCoordinatorService::default();\n415\t\n416\t    // Standard → Coordinator via session\n417\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n418\t        policy_enabled: true,\n419\t        env_mode: None,\n420\t        session_mode: coordinator_session(),\n421\t        previous_mode: Some(CoordinatorMode::Standard),\n422\t    });\n423\t\n424\t    let event = result\n425\t        .switch_event\n426\t        .expect(\"mode change must emit a switch event\");\n427\t    assert_eq!(event.from, CoordinatorMode::Standard);\n428\t    assert_eq!(event.to, CoordinatorMode::Coordinator);\n429\t    assert_eq!(event.reason, ModeSwitchReason::SessionPrecedence);\n430\t}\n431\t\n432\t/// AC: mode switch via env emits correct reason.\n433\t#[test]\n434\tfn cli_mode_switch_via_env_emits_env_configured_reason() {\n435\t    let svc = DefaultModeCoordinatorService::default();\n436\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n437\t        policy_enabled: true,\n438\t        env_mode: Some(CoordinatorMode::Coordinator),\n439\t        session_mode: None,\n440\t        previous_mode: Some(CoordinatorMode::Standard),\n441\t    });\n442\t\n443\t    let event = result.switch_event.expect(\"must emit switch event\");\n444\t    assert_eq!(event.from, CoordinatorMode::Standard);\n445\t    assert_eq!(event.to, CoordinatorMode::Coordinator);\n446\t    assert_eq!(event.reason, ModeSwitchReason::EnvConfigured);\n447\t}\n448\t\n449\t/// AC: reconcile switch emits ResumeReconcile reason.\n450\t#[test]\n451\tfn cli_reconcile_switch_emits_resume_reconcile_reason() {\n452\t    let svc = service_with(true, None, CoordinatorMode::Standard);\n453\t\n454\t    let result = svc.reconcile_on_resume(coordinator_session());\n455\t\n456\t    let event = result\n457\t        .switch_event\n458\t        .expect(\"reconcile mode change must emit event\");\n459\t    assert_eq!(event.from, CoordinatorMode::Standard);\n460\t    assert_eq!(event.to, CoordinatorMode::Coordinator);\n461\t    assert_eq!(event.reason, ModeSwitchReason::ResumeReconcile);\n462\t}\n463\t\n464\t/// AC: no switch event when mode stays the same.\n465\t#[test]\n466\tfn cli_no_switch_event_when_mode_unchanged() {\n467\t    let svc = DefaultModeCoordinatorService::default();\n468\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n469\t        policy_enabled: true,\n470\t        env_mode: Some(CoordinatorMode::Standard),\n471\t        session_mode: None,\n472\t        previous_mode: Some(CoordinatorMode::Standard),\n473\t    });\n474\t\n475\t    assert!(\n476\t        result.switch_event.is_none(),\n477\t        \"no event must be emitted when mode does not change\"\n478\t    );\n479\t}\n480\t\n481\t/// AC: SessionModeMismatch surfaced as actionable message.\n482\t///\n483\t/// When session and env disagree, the error variant is SessionModeMismatch\n484\t/// which the TUI renders as an actionable warning. Verify the error is\n485\t/// present and the mode still resolves correctly (session wins).\n486\t#[test]\n487\tfn cli_session_mode_mismatch_surfaced_as_actionable_message() {\n488\t    let svc = service_with(\n489\t        true,\n490\t        Some(CoordinatorMode::Standard),\n491\t        CoordinatorMode::Standard,\n492\t    );\n493\t\n494\t    let result = svc.reconcile_on_resume(coordinator_session());\n495\t\n496\t    assert_eq!(\n497\t        result.mode,\n498\t        CoordinatorMode::Coordinator,\n499\t        \"session must still win despite mismatch\"\n500\t    );\n501\t    assert_eq!(result.action, ModeReconcileAction::SessionWins);\n502\t\n503\t    let err = result\n504\t        .error\n505\t        .expect(\"mismatch must produce an error for the TUI to render\");\n506\t    assert_eq!(\n507\t        err,\n508\t        CoordinatorModeError::SessionModeMismatch,\n509\t        \"error must be SessionModeMismatch so TUI can render actionable message\"\n510\t    );\n511\t\n512\t    // The error's Display impl is what the TUI would show\n513\t    assert_eq!(\n514\t        err.to_string(),\n515\t        \"session mode mismatch\",\n516\t        \"error message must be human-readable\"\n517\t    );\n518\t}\n519\t\n520\t/// AC: no mismatch when session and env agree.\n521\t#[test]\n522\tfn cli_no_mismatch_when_session_and_env_agree() {\n523\t    let svc = service_with(\n524\t        true,\n525\t        Some(CoordinatorMode::Coordinator),\n526\t        CoordinatorMode::Standard,\n527\t    );\n528\t\n529\t    let result = svc.reconcile_on_resume(coordinator_session());\n530\t\n531\t    assert_eq!(result.mode, CoordinatorMode::Coordinator);\n532\t    assert_eq!(result.action, ModeReconcileAction::SessionWins);\n533\t    assert!(\n534\t        result.error.is_none(),\n535\t        \"no mismatch error when session and env agree on Coordinator\"\n536\t    );\n537\t}\n538\t"}]},"parent_tool_use_id":"toolu_013X19bThc964g3DNsp4No5N","session_id":"6362e84a-6f04-4b0f-bbe9-0adfe63953c5","uuid":"82663e33-0bc4-47dc-ad25-461b43bd098f","timestamp":"2026-04-02T14:31:57.796Z"}
