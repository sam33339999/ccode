{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MXtqsvBj9LmvWffMAyXoRq","type":"tool_result","content":"1\t/// KAIROS acceptance tests (US-040)\n2\t///\n3\t/// Covers all scenarios from kairos-contract.md §7 Acceptance Matrix:\n4\t///   §7.1 Contract tests  – mode resolution determinism, route precedence, PromptComposeFailed\n5\t///   §7.2 Integration tests – KAIROS/BRIEF/CHANNELS tool visibility, slash routing, RouteConflict\n6\t///   §7.3 CLI behaviour tests – assistant-mode entry, DisabledByPolicy message, /brief switch\n7\tuse crate::{\n8\t    assistant_mode_service::DefaultAssistantModeService,\n9\t    spec_contracts::{\n10\t        AssistantModeContext, AssistantModeService, CapabilityPolicy, KairosError,\n11\t        PromptComposeContext, PromptPrecedenceLayer, ResolvedModeSource, RouteDecision,\n12\t        RouteInputContext, RouteSource,\n13\t    },\n14\t};\n15\tuse ccode_domain::{\n16\t    assistant_mode::{AssistantMode, ModeSwitchTrigger},\n17\t    event::DomainEvent,\n18\t    session::SessionId,\n19\t};\n20\t\n21\t// ── helpers ───────────────────────────────────────────────────────────────\n22\t\n23\tfn sid() -> SessionId {\n24\t    SessionId(\"kairos-test-sess\".into())\n25\t}\n26\t\n27\tfn svc() -> DefaultAssistantModeService {\n28\t    DefaultAssistantModeService\n29\t}\n30\t\n31\tfn default_policy() -> CapabilityPolicy {\n32\t    CapabilityPolicy::default()\n33\t}\n34\t\n35\tfn all_tools() -> Vec<String> {\n36\t    vec![\n37\t        \"read_file\".into(),\n38\t        \"shell\".into(),\n39\t        \"write_file\".into(),\n40\t        \"search\".into(),\n41\t    ]\n42\t}\n43\t\n44\tfn resolve_ctx(\n45\t    configured: AssistantMode,\n46\t    session: Option<AssistantMode>,\n47\t    policy: CapabilityPolicy,\n48\t) -> AssistantModeContext {\n49\t    AssistantModeContext {\n50\t        session_id: sid(),\n51\t        configured_mode: configured,\n52\t        session_mode: session,\n53\t        policy_enabled: true,\n54\t        available_tools: all_tools(),\n55\t        capability_policy: policy,\n56\t    }\n57\t}\n58\t\n59\tfn route_ctx(\n60\t    current: AssistantMode,\n61\t    raw_input: &str,\n62\t    explicit_mode: Option<AssistantMode>,\n63\t    policy: CapabilityPolicy,\n64\t) -> RouteInputContext {\n65\t    RouteInputContext {\n66\t        session_id: sid(),\n67\t        current_mode: current,\n68\t        policy_enabled: true,\n69\t        capability_policy: policy,\n70\t        raw_input: raw_input.into(),\n71\t        explicit_mode,\n72\t    }\n73\t}\n74\t\n75\t// ── §7.1 Contract tests ──────────────────────────────────────────────────\n76\t\n77\t/// AC: mode resolution is deterministic for same inputs.\n78\t///\n79\t/// Given identical inputs, resolve_mode must produce the same effective_mode,\n80\t/// source, and switch_event every time.\n81\t#[test]\n82\tfn contract_mode_resolution_is_deterministic_for_same_inputs() {\n83\t    let service = svc();\n84\t    let ctx = resolve_ctx(\n85\t        AssistantMode::Kairos,\n86\t        Some(AssistantMode::KairosBrief),\n87\t        default_policy(),\n88\t    );\n89\t\n90\t    let a = service.resolve_mode(ctx.clone());\n91\t    let b = service.resolve_mode(ctx);\n92\t\n93\t    assert_eq!(\n94\t        a.effective_mode, b.effective_mode,\n95\t        \"effective_mode must be deterministic\"\n96\t    );\n97\t    assert_eq!(a.source, b.source, \"source must be deterministic\");\n98\t    assert_eq!(\n99\t        a.visible_tools, b.visible_tools,\n100\t        \"visible_tools must be deterministic\"\n101\t    );\n102\t    assert!(a.error.is_none());\n103\t    assert!(b.error.is_none());\n104\t}\n105\t\n106\t/// AC: mode resolution determinism holds when session_mode is None.\n107\t#[test]\n108\tfn contract_mode_resolution_deterministic_without_session() {\n109\t    let service = svc();\n110\t    let ctx = resolve_ctx(AssistantMode::KairosChannels, None, default_policy());\n111\t\n112\t    let a = service.resolve_mode(ctx.clone());\n113\t    let b = service.resolve_mode(ctx);\n114\t\n115\t    assert_eq!(a.effective_mode, b.effective_mode);\n116\t    assert_eq!(a.source, b.source);\n117\t    assert_eq!(a.source, ResolvedModeSource::Config);\n118\t}\n119\t\n120\t/// AC: route precedence is deterministic.\n121\t///\n122\t/// SlashCommand and ExplicitOverride sources are resolved consistently.\n123\t#[test]\n124\tfn contract_route_precedence_is_deterministic() {\n125\t    let service = svc();\n126\t    let ctx = route_ctx(\n127\t        AssistantMode::Kairos,\n128\t        \"/brief summarize\",\n129\t        None,\n130\t        default_policy(),\n131\t    );\n132\t\n133\t    let a = service.route_input(ctx.clone());\n134\t    let b = service.route_input(ctx);\n135\t\n136\t    assert_eq!(a.source, b.source, \"route source must be deterministic\");\n137\t    assert_eq!(a.next_mode, b.next_mode, \"next_mode must be deterministic\");\n138\t    assert_eq!(\n139\t        a.passthrough_input, b.passthrough_input,\n140\t        \"passthrough must be deterministic\"\n141\t    );\n142\t    assert_eq!(a.source, RouteSource::SlashCommand);\n143\t}\n144\t\n145\t/// AC: explicit override takes precedence over slash command when they agree.\n146\t#[test]\n147\tfn contract_explicit_override_precedence_when_aligned() {\n148\t    let service = svc();\n149\t    let decision = service.route_input(route_ctx(\n150\t        AssistantMode::Kairos,\n151\t        \"/brief summarize\",\n152\t        Some(AssistantMode::KairosBrief),\n153\t        default_policy(),\n154\t    ));\n155\t\n156\t    assert!(decision.error.is_none());\n157\t    assert_eq!(decision.source, RouteSource::ExplicitOverride);\n158\t    assert_eq!(decision.next_mode, AssistantMode::KairosBrief);\n159\t}\n160\t\n161\t/// AC: PromptComposeFailed returned on invalid compose context.\n162\t///\n163\t/// When no prompt layers are available (all None/empty and mode prompt produces\n164\t/// empty after join), PromptComposeFailed is emitted.\n165\t#[test]\n166\tfn contract_prompt_compose_failed_on_invalid_context() {\n167\t    let service = svc();\n168\t\n169\t    // With all optional prompts None, only ModeDefault layer is added,\n170\t    // so it won't be empty. We need to test the contract error path.\n171\t    // The PromptComposeFailed is only returned when system_prompt is empty,\n172\t    // which can't happen with ModeDefault always present.\n173\t    // However, when policy is disabled, we get DisabledByPolicy instead.\n174\t    // Test with a mode not allowed by capability_policy.\n175\t    let mut policy = default_policy();\n176\t    policy.allow_brief_mode = false;\n177\t\n178\t    let result = service.build_prompt(PromptComposeContext {\n179\t        mode: AssistantMode::KairosBrief,\n180\t        policy_enabled: true,\n181\t        capability_policy: policy,\n182\t        base_prompt: None,\n183\t        mode_prompt_override: None,\n184\t        policy_prompt: None,\n185\t        runtime_prompt: None,\n186\t    });\n187\t\n188\t    assert!(\n189\t        result.error.is_some(),\n190\t        \"should return error for disallowed mode\"\n191\t    );\n192\t    assert!(\n193\t        matches!(\n194\t            result.error.as_ref().unwrap(),\n195\t            KairosError::InvalidModeState\n196\t        ),\n197\t        \"expected InvalidModeState for disallowed brief mode, got {:?}\",\n198\t        result.error\n199\t    );\n200\t}\n201\t\n202\t/// AC: PromptComposeFailed specifically – policy disabled yields empty prompt.\n203\t#[test]\n204\tfn contract_prompt_compose_disabled_by_policy() {\n205\t    let service = svc();\n206\t    let result = service.build_prompt(PromptComposeContext {\n207\t        mode: AssistantMode::Kairos,\n208\t        policy_enabled: false,\n209\t        capability_policy: default_policy(),\n210\t        base_prompt: Some(\"base\".into()),\n211\t        mode_prompt_override: None,\n212\t        policy_prompt: None,\n213\t        runtime_prompt: None,\n214\t    });\n215\t\n216\t    assert!(result.error.is_some());\n217\t    assert!(\n218\t        matches!(\n219\t            result.error.as_ref().unwrap(),\n220\t            KairosError::DisabledByPolicy\n221\t        ),\n222\t        \"expected DisabledByPolicy, got {:?}\",\n223\t        result.error\n224\t    );\n225\t    assert!(\n226\t        result.system_prompt.is_empty(),\n227\t        \"system prompt should be empty when disabled\"\n228\t    );\n229\t}\n230\t\n231\t// ── §7.2 Integration tests ──────────────────────────────────────────────\n232\t\n233\t/// AC: KAIROS mode – all tools visible when no blocked tools.\n234\t#[test]\n235\tfn integration_kairos_mode_all_tools_visible() {\n236\t    let service = svc();\n237\t    let decision = service.resolve_mode(resolve_ctx(AssistantMode::Kairos, None, default_policy()));\n238\t\n239\t    assert!(decision.error.is_none());\n240\t    assert_eq!(decision.effective_mode, AssistantMode::Kairos);\n241\t    assert_eq!(decision.visible_tools, all_tools());\n242\t}\n243\t\n244\t/// AC: KAIROS_BRIEF mode – brief_blocked_tools are filtered out.\n245\t#[test]\n246\tfn integration_brief_mode_filters_brief_blocked_tools() {\n247\t    let service = svc();\n248\t    let mut policy = default_policy();\n249\t    policy.brief_blocked_tools = vec![\"shell\".into(), \"write_file\".into()];\n250\t\n251\t    let decision = service.resolve_mode(resolve_ctx(\n252\t        AssistantMode::Kairos,\n253\t        Some(AssistantMode::KairosBrief),\n254\t        policy,\n255\t    ));\n256\t\n257\t    assert!(decision.error.is_none());\n258\t    assert_eq!(decision.effective_mode, AssistantMode::KairosBrief);\n259\t    assert!(\n260\t        !decision.visible_tools.contains(&\"shell\".into()),\n261\t        \"shell should be blocked in brief mode\"\n262\t    );\n263\t    assert!(\n264\t        !decision.visible_tools.contains(&\"write_file\".into()),\n265\t        \"write_file should be blocked in brief mode\"\n266\t    );\n267\t    assert!(\n268\t        decision.visible_tools.contains(&\"read_file\".into()),\n269\t        \"read_file should remain visible\"\n270\t    );\n271\t    assert!(\n272\t        decision.visible_tools.contains(&\"search\".into()),\n273\t        \"search should remain visible\"\n274\t    );\n275\t}\n276\t\n277\t/// AC: KAIROS_CHANNELS mode – globally blocked tools filtered.\n278\t#[test]\n279\tfn integration_channels_mode_respects_blocked_tools() {\n280\t    let service = svc();\n281\t    let mut policy = default_policy();\n282\t    policy.blocked_tools = vec![\"shell\".into()];\n283\t\n284\t    let decision = service.resolve_mode(resolve_ctx(\n285\t        AssistantMode::Kairos,\n286\t        Some(AssistantMode::KairosChannels),\n287\t        policy,\n288\t    ));\n289\t\n290\t    assert!(decision.error.is_none());\n291\t    assert_eq!(decision.effective_mode, AssistantMode::KairosChannels);\n292\t    assert!(\n293\t        !decision.visible_tools.contains(&\"shell\".into()),\n294\t        \"shell should be globally blocked\"\n295\t    );\n296\t    assert_eq!(decision.visible_tools.len(), 3);\n297\t}\n298\t\n299\t/// AC: KAIROS/BRIEF combination – both blocked_tools and brief_blocked_tools apply.\n300\t#[test]\n301\tfn integration_brief_mode_applies_both_block_lists() {\n302\t    let service = svc();\n303\t    let mut policy = default_policy();\n304\t    policy.blocked_tools = vec![\"shell\".into()];\n305\t    policy.brief_blocked_tools = vec![\"write_file\".into()];\n306\t\n307\t    let decision = service.resolve_mode(resolve_ctx(\n308\t        AssistantMode::Kairos,\n309\t        Some(AssistantMode::KairosBrief),\n310\t        policy,\n311\t    ));\n312\t\n313\t    assert!(decision.error.is_none());\n314\t    assert_eq!(\n315\t        decision.visible_tools,\n316\t        vec![\"read_file\".to_string(), \"search\".to_string()],\n317\t        \"only read_file and search should survive both block lists\"\n318\t    );\n319\t}\n320\t\n321\t/// AC: slash routing /brief produces correct mode switch.\n322\t#[test]\n323\tfn integration_slash_brief_routing_matches_semantics() {\n324\t    let service = svc();\n325\t    let decision = service.route_input(route_ctx(\n326\t        AssistantMode::Kairos,\n327\t        \"/brief summarize the code\",\n328\t        None,\n329\t        default_policy(),\n330\t    ));\n331\t\n332\t    assert!(decision.error.is_none());\n333\t    assert_eq!(decision.source, RouteSource::SlashCommand);\n334\t    assert_eq!(decision.next_mode, AssistantMode::KairosBrief);\n335\t    assert!(decision.command_consumed);\n336\t    assert_eq!(decision.passthrough_input, \"summarize the code\");\n337\t    assert!(\n338\t        matches!(\n339\t            decision.switch_event,\n340\t            Some(DomainEvent::AssistantModeSwitched {\n341\t                from_mode: AssistantMode::Kairos,\n342\t                to_mode: AssistantMode::KairosBrief,\n343\t                trigger: ModeSwitchTrigger::SlashCommand,\n344\t                ..\n345\t            })\n346\t        ),\n347\t        \"expected mode switch event, got {:?}\",\n348\t        decision.switch_event\n349\t    );\n350\t}\n351\t\n352\t/// AC: slash routing /channels produces correct mode switch.\n353\t#[test]\n354\tfn integration_slash_channels_routing_matches_semantics() {\n355\t    let service = svc();\n356\t    let decision = service.route_input(route_ctx(\n357\t        AssistantMode::Kairos,\n358\t        \"/channels coordinate agents\",\n359\t        None,\n360\t        default_policy(),\n361\t    ));\n362\t\n363\t    assert!(decision.error.is_none());\n364\t    assert_eq!(decision.source, RouteSource::SlashCommand);\n365\t    assert_eq!(decision.next_mode, AssistantMode::KairosChannels);\n366\t    assert!(decision.command_consumed);\n367\t    assert_eq!(decision.passthrough_input, \"coordinate agents\");\n368\t}\n369\t\n370\t/// AC: slash routing /kairos from brief mode switches back.\n371\t#[test]\n372\tfn integration_slash_kairos_routing_from_brief() {\n373\t    let service = svc();\n374\t    let decision = service.route_input(route_ctx(\n375\t        AssistantMode::KairosBrief,\n376\t        \"/kairos explain in detail\",\n377\t        None,\n378\t        default_policy(),\n379\t    ));\n380\t\n381\t    assert!(decision.error.is_none());\n382\t    assert_eq!(decision.next_mode, AssistantMode::Kairos);\n383\t    assert!(decision.command_consumed);\n384\t    assert_eq!(decision.passthrough_input, \"explain in detail\");\n385\t}\n386\t\n387\t/// AC: non-slash input is passed through without mode change.\n388\t#[test]\n389\tfn integration_non_slash_input_passthrough() {\n390\t    let service = svc();\n391\t    let decision = service.route_input(route_ctx(\n392\t        AssistantMode::Kairos,\n393\t        \"just a normal message\",\n394\t        None,\n395\t        default_policy(),\n396\t    ));\n397\t\n398\t    assert!(decision.error.is_none());\n399\t    assert_eq!(decision.source, RouteSource::Noop);\n400\t    assert_eq!(decision.next_mode, AssistantMode::Kairos);\n401\t    assert!(!decision.command_consumed);\n402\t    assert_eq!(decision.passthrough_input, \"just a normal message\");\n403\t    assert!(decision.switch_event.is_none());\n404\t}\n405\t\n406\t/// AC: RouteConflict handled gracefully when multiple routes match.\n407\t///\n408\t/// When explicit_mode disagrees with slash command, RouteConflict is emitted\n409\t/// and current mode is preserved.\n410\t#[test]\n411\tfn integration_route_conflict_handled_gracefully() {\n412\t    let service = svc();\n413\t    let decision = service.route_input(route_ctx(\n414\t        AssistantMode::Kairos,\n415\t        \"/brief summarize\",\n416\t        Some(AssistantMode::KairosChannels),\n417\t        default_policy(),\n418\t    ));\n419\t\n420\t    assert_eq!(\n421\t        decision.source,\n422\t        RouteSource::Conflict,\n423\t        \"conflicting routes must produce Conflict source\"\n424\t    );\n425\t    assert!(\n426\t        matches!(decision.error.as_ref().unwrap(), KairosError::RouteConflict),\n427\t        \"expected RouteConflict error, got {:?}\",\n428\t        decision.error\n429\t    );\n430\t    assert_eq!(\n431\t        decision.next_mode,\n432\t        AssistantMode::Kairos,\n433\t        \"current mode preserved on conflict\"\n434\t    );\n435\t    assert!(\n436\t        !decision.command_consumed,\n437\t        \"command not consumed on conflict\"\n438\t    );\n439\t    assert!(\n440\t        decision.switch_event.is_none(),\n441\t        \"no switch event on conflict\"\n442\t    );\n443\t}\n444\t\n445\t/// AC: RouteConflict – agreeing explicit and slash is not a conflict.\n446\t#[test]\n447\tfn integration_route_no_conflict_when_modes_agree() {\n448\t    let service = svc();\n449\t    let decision = service.route_input(route_ctx(\n450\t        AssistantMode::Kairos,\n451\t        \"/channels do work\",\n452\t        Some(AssistantMode::KairosChannels),\n453\t        default_policy(),\n454\t    ));\n455\t\n456\t    assert!(decision.error.is_none());\n457\t    assert_eq!(decision.source, RouteSource::ExplicitOverride);\n458\t    assert_eq!(decision.next_mode, AssistantMode::KairosChannels);\n459\t}\n460\t\n461\t// ── §7.3 CLI behaviour tests ────────────────────────────────────────────\n462\t\n463\t/// AC: assistant-mode entry behaviour matches current semantics.\n464\t///\n465\t/// When session_mode is set, it overrides configured_mode.\n466\t/// When session_mode is None, configured_mode is used.\n467\t#[test]\n468\tfn cli_assistant_mode_entry_session_overrides_config() {\n469\t    let service = svc();\n470\t\n471\t    let with_session = service.resolve_mode(resolve_ctx(\n472\t        AssistantMode::Kairos,\n473\t        Some(AssistantMode::KairosBrief),\n474\t        default_policy(),\n475\t    ));\n476\t    assert_eq!(with_session.effective_mode, AssistantMode::KairosBrief);\n477\t    assert_eq!(with_session.source, ResolvedModeSource::Session);\n478\t\n479\t    let without_session =\n480\t        service.resolve_mode(resolve_ctx(AssistantMode::Kairos, None, default_policy()));\n481\t    assert_eq!(without_session.effective_mode, AssistantMode::Kairos);\n482\t    assert_eq!(without_session.source, ResolvedModeSource::Config);\n483\t}\n484\t\n485\t/// AC: assistant-mode entry emits switch event only when modes differ.\n486\t#[test]\n487\tfn cli_assistant_mode_entry_switch_event_only_on_change() {\n488\t    let service = svc();\n489\t\n490\t    // Different modes → event emitted.\n491\t    let switched = service.resolve_mode(resolve_ctx(\n492\t        AssistantMode::Kairos,\n493\t        Some(AssistantMode::KairosChannels),\n494\t        default_policy(),\n495\t    ));\n496\t    assert!(\n497\t        switched.switch_event.is_some(),\n498\t        \"switch event expected when modes differ\"\n499\t    );\n500\t\n501\t    // Same mode → no event.\n502\t    let same = service.resolve_mode(resolve_ctx(\n503\t        AssistantMode::Kairos,\n504\t        Some(AssistantMode::Kairos),\n505\t        default_policy(),\n506\t    ));\n507\t    assert!(\n508\t        same.switch_event.is_none(),\n509\t        \"no switch event when mode stays the same\"\n510\t    );\n511\t}\n512\t\n513\t/// AC: DisabledByPolicy surfaced as actionable message.\n514\t///\n515\t/// When policy_enabled is false, resolve_mode returns DisabledByPolicy\n516\t/// with the configured mode preserved.\n517\t#[test]\n518\tfn cli_disabled_by_policy_surfaced_as_actionable_message() {\n519\t    let service = svc();\n520\t    let decision = service.resolve_mode(AssistantModeContext {\n521\t        session_id: sid(),\n522\t        configured_mode: AssistantMode::Kairos,\n523\t        session_mode: Some(AssistantMode::KairosBrief),\n524\t        policy_enabled: false,\n525\t        available_tools: all_tools(),\n526\t        capability_policy: default_policy(),\n527\t    });\n528\t\n529\t    assert!(\n530\t        matches!(\n531\t            decision.error.as_ref().unwrap(),\n532\t            KairosError::DisabledByPolicy\n533\t        ),\n534\t        \"expected DisabledByPolicy, got {:?}\",\n535\t        decision.error\n536\t    );\n537\t    assert_eq!(\n538\t        decision.effective_mode,\n539\t        AssistantMode::Kairos,\n540\t        \"configured mode preserved when disabled\"\n541\t    );\n542\t    assert_eq!(\n543\t        decision.source,\n544\t        ResolvedModeSource::Config,\n545\t        \"source is Config when disabled by policy\"\n546\t    );\n547\t\n548\t    // Verify the error message is actionable (Display impl).\n549\t    let msg = format!(\"{}\", decision.error.unwrap());\n550\t    assert!(\n551\t        msg.contains(\"disabled by policy\"),\n552\t        \"error message should be actionable: '{msg}'\"\n553\t    );\n554\t}\n555\t\n556\t/// AC: DisabledByPolicy on capability_policy.allow_assistant_modes = false.\n557\t#[test]\n558\tfn cli_disabled_by_capability_policy() {\n559\t    let service = svc();\n560\t    let mut policy = default_policy();\n561\t    policy.allow_assistant_modes = false;\n562\t\n563\t    let decision = service.resolve_mode(AssistantModeContext {\n564\t        session_id: sid(),\n565\t        configured_mode: AssistantMode::Kairos,\n566\t        session_mode: Some(AssistantMode::KairosBrief),\n567\t        policy_enabled: true,\n568\t        available_tools: all_tools(),\n569\t        capability_policy: policy,\n570\t    });\n571\t\n572\t    assert!(matches!(\n573\t        decision.error.as_ref().unwrap(),\n574\t        KairosError::DisabledByPolicy\n575\t    ));\n576\t}\n577\t\n578\t/// AC: mode switch via /brief command works end-to-end.\n579\t///\n580\t/// Starting from Kairos mode, /brief routes correctly, produces a switch event,\n581\t/// and the resulting mode's prompt composition succeeds.\n582\t#[test]\n583\tfn cli_mode_switch_via_brief_end_to_end() {\n584\t    let service = svc();\n585\t\n586\t    // Step 1: Route the /brief command.\n587\t    let route = service.route_input(route_ctx(\n588\t        AssistantMode::Kairos,\n589\t        \"/brief be concise\",\n590\t        None,\n591\t        default_policy(),\n592\t    ));\n593\t    assert!(route.error.is_none());\n594\t    assert_eq!(route.next_mode, AssistantMode::KairosBrief);\n595\t    assert!(route.command_consumed);\n596\t    assert_eq!(route.passthrough_input, \"be concise\");\n597\t    assert!(\n598\t        matches!(\n599\t            route.switch_event,\n600\t            Some(DomainEvent::AssistantModeSwitched {\n601\t                from_mode: AssistantMode::Kairos,\n602\t                to_mode: AssistantMode::KairosBrief,\n603\t                trigger: ModeSwitchTrigger::SlashCommand,\n604\t                ..\n605\t            })\n606\t        ),\n607\t        \"switch event with SlashCommand trigger expected\"\n608\t    );\n609\t\n610\t    // Step 2: Build prompt in the new mode.\n611\t    let prompt = service.build_prompt(PromptComposeContext {\n612\t        mode: route.next_mode,\n613\t        policy_enabled: true,\n614\t        capability_policy: default_policy(),\n615\t        base_prompt: Some(\"system base prompt\".into()),\n616\t        mode_prompt_override: None,\n617\t        policy_prompt: None,\n618\t        runtime_prompt: None,\n619\t    });\n620\t    assert!(prompt.error.is_none());\n621\t    assert!(\n622\t        prompt\n623\t            .system_prompt\n624\t            .contains(\"KAIROS BRIEF mode. Keep responses concise\"),\n625\t        \"brief mode prompt should be in composed output\"\n626\t    );\n627\t    assert_eq!(\n628\t        prompt.precedence,\n629\t        vec![\n630\t            PromptPrecedenceLayer::Base,\n631\t            PromptPrecedenceLayer::ModeDefault,\n632\t        ]\n633\t    );\n634\t    assert_eq!(prompt.telemetry_tags.mode, AssistantMode::KairosBrief);\n635\t    assert!(prompt.telemetry_tags.brief_active);\n636\t    assert!(!prompt.telemetry_tags.channels_active);\n637\t\n638\t    // Step 3: Resolve mode with the switched state persisted in session.\n639\t    let resolved = service.resolve_mode(resolve_ctx(\n640\t        AssistantMode::Kairos,\n641\t        Some(AssistantMode::KairosBrief),\n642\t        default_policy(),\n643\t    ));\n644\t    assert!(resolved.error.is_none());\n645\t    assert_eq!(resolved.effective_mode, AssistantMode::KairosBrief);\n646\t    assert_eq!(resolved.source, ResolvedModeSource::Session);\n647\t}\n648\t\n649\t/// AC: DisabledByPolicy on route_input returns noop with error.\n650\t#[test]\n651\tfn cli_route_disabled_by_policy_returns_noop() {\n652\t    let service = svc();\n653\t    let decision = service.route_input(RouteInputContext {\n654\t        session_id: sid(),\n655\t        current_mode: AssistantMode::Kairos,\n656\t        policy_enabled: false,\n657\t        capability_policy: default_policy(),\n658\t        raw_input: \"/brief test\".into(),\n659\t        explicit_mode: None,\n660\t    });\n661\t\n662\t    assert_eq!(decision.source, RouteSource::Noop);\n663\t    assert!(!decision.command_consumed);\n664\t    assert!(matches!(\n665\t        decision.error.as_ref().unwrap(),\n666\t        KairosError::DisabledByPolicy\n667\t    ));\n668\t}\n669\t\n670\t/// AC: telemetry tags reflect correct mode state.\n671\t#[test]\n672\tfn cli_telemetry_tags_reflect_mode_state() {\n673\t    let service = svc();\n674\t\n675\t    let kairos = service.resolve_mode(resolve_ctx(AssistantMode::Kairos, None, default_policy()));\n676\t    assert!(kairos.telemetry_tags.kairos_active);\n677\t    assert!(!kairos.telemetry_tags.brief_active);\n678\t    assert!(!kairos.telemetry_tags.channels_active);\n679\t\n680\t    let brief = service.resolve_mode(resolve_ctx(\n681\t        AssistantMode::Kairos,\n682\t        Some(AssistantMode::KairosBrief),\n683\t        default_policy(),\n684\t    ));\n685\t    assert!(brief.telemetry_tags.kairos_active);\n686\t    assert!(brief.telemetry_tags.brief_active);\n687\t    assert!(!brief.telemetry_tags.channels_active);\n688\t\n689\t    let channels = service.resolve_mode(resolve_ctx(\n690\t        AssistantMode::Kairos,\n691\t        Some(AssistantMode::KairosChannels),\n692\t        default_policy(),\n693\t    ));\n694\t    assert!(channels.telemetry_tags.kairos_active);\n695\t    assert!(!channels.telemetry_tags.brief_active);\n696\t    assert!(channels.telemetry_tags.channels_active);\n697\t}\n698\t"}]},"parent_tool_use_id":"toolu_018H4SGR6cdK1dzJcYiwu9aQ","session_id":"6429a853-3cab-4876-b6cc-9209ef0cfb79","uuid":"e5ff8922-ea8b-45eb-8f56-300e419e56bd","timestamp":"2026-04-02T14:35:45.916Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016Pp7PLoUGBtGymbenkNFnV","type":"tool_result","content":"1\t/// Bridge mode acceptance tests (US-037)\n2\t///\n3\t/// Covers all scenarios from bridge-mode-contract.md §8 Acceptance Criteria:\n4\t///   §8.1 Contract tests  – transport and policy layer invariants\n5\t///   §8.2 Integration tests – multi-step lifecycle flows\n6\t///\n7\t/// CLI behaviour tests live in crates/cli/src/cmd/bridge.rs.\n8\tuse crate::{\n9\t    remote_session_service::ApplicationRemoteSessionService,\n10\t    spec_contracts::{\n11\t        ArchivePolicy, ArchiveResult, CcrClient, CcrClientError, CreateRemoteSessionRequest,\n12\t        RemoteSessionError, RemoteSessionService, RemoteSessionState, RemoteSessionSummary,\n13\t        SessionEvent,\n14\t    },\n15\t};\n16\tuse std::{collections::VecDeque, sync::Arc, time::Duration};\n17\tuse tokio::sync::Mutex;\n18\t\n19\t// ── shared test doubles ────────────────────────────────────────────────────\n20\t\n21\t#[derive(Default)]\n22\tstruct MockCcrClient {\n23\t    create_results: Arc<Mutex<VecDeque<Result<RemoteSessionSummary, CcrClientError>>>>,\n24\t    get_results: Arc<Mutex<VecDeque<Result<RemoteSessionSummary, CcrClientError>>>>,\n25\t    archive_results: Arc<Mutex<VecDeque<Result<ArchiveResult, CcrClientError>>>>,\n26\t    patch_results: Arc<Mutex<VecDeque<Result<(), CcrClientError>>>>,\n27\t    archive_delay: Option<Duration>,\n28\t}\n29\t\n30\timpl MockCcrClient {\n31\t    fn with_create(results: Vec<Result<RemoteSessionSummary, CcrClientError>>) -> Self {\n32\t        Self {\n33\t            create_results: Arc::new(Mutex::new(results.into())),\n34\t            ..Self::default()\n35\t        }\n36\t    }\n37\t\n38\t    fn with_get(results: Vec<Result<RemoteSessionSummary, CcrClientError>>) -> Self {\n39\t        Self {\n40\t            get_results: Arc::new(Mutex::new(results.into())),\n41\t            ..Self::default()\n42\t        }\n43\t    }\n44\t\n45\t    fn with_archive(results: Vec<Result<ArchiveResult, CcrClientError>>) -> Self {\n46\t        Self {\n47\t            archive_results: Arc::new(Mutex::new(results.into())),\n48\t            ..Self::default()\n49\t        }\n50\t    }\n51\t\n52\t    fn with_archive_delay(delay: Duration) -> Self {\n53\t        Self {\n54\t            archive_delay: Some(delay),\n55\t            archive_results: Arc::new(Mutex::new(vec![Ok(ArchiveResult::Archived)].into())),\n56\t            ..Self::default()\n57\t        }\n58\t    }\n59\t\n60\t    fn for_happy_path(session_id: &str, state: RemoteSessionState) -> Self {\n61\t        let summary = summary_for(session_id, state);\n62\t        Self {\n63\t            create_results: Arc::new(Mutex::new(vec![Ok(summary.clone())].into())),\n64\t            get_results: Arc::new(Mutex::new(vec![Ok(summary)].into())),\n65\t            archive_results: Arc::new(Mutex::new(vec![Ok(ArchiveResult::Archived)].into())),\n66\t            ..Self::default()\n67\t        }\n68\t    }\n69\t}\n70\t\n71\t#[async_trait::async_trait]\n72\timpl CcrClient for MockCcrClient {\n73\t    async fn create(\n74\t        &self,\n75\t        _req: CreateRemoteSessionRequest,\n76\t    ) -> Result<RemoteSessionSummary, CcrClientError> {\n77\t        self.create_results\n78\t            .lock()\n79\t            .await\n80\t            .pop_front()\n81\t            .expect(\"no create result queued\")\n82\t    }\n83\t\n84\t    async fn get(&self, _session_id: &str) -> Result<RemoteSessionSummary, CcrClientError> {\n85\t        self.get_results\n86\t            .lock()\n87\t            .await\n88\t            .pop_front()\n89\t            .expect(\"no get result queued\")\n90\t    }\n91\t\n92\t    async fn archive(&self, _session_id: &str) -> Result<ArchiveResult, CcrClientError> {\n93\t        if let Some(delay) = self.archive_delay {\n94\t            tokio::time::sleep(delay).await;\n95\t        }\n96\t        self.archive_results\n97\t            .lock()\n98\t            .await\n99\t            .pop_front()\n100\t            .expect(\"no archive result queued\")\n101\t    }\n102\t\n103\t    async fn patch_title(&self, _session_id: &str, _title: &str) -> Result<(), CcrClientError> {\n104\t        self.patch_results\n105\t            .lock()\n106\t            .await\n107\t            .pop_front()\n108\t            .expect(\"no patch result queued\")\n109\t    }\n110\t}\n111\t\n112\tfn summary_for(session_id: &str, state: RemoteSessionState) -> RemoteSessionSummary {\n113\t    RemoteSessionSummary {\n114\t        session_id: session_id.to_string(),\n115\t        title: Some(\"acceptance-test session\".to_string()),\n116\t        environment_id: Some(\"env_test\".to_string()),\n117\t        state,\n118\t    }\n119\t}\n120\t\n121\tfn sample_create_request() -> CreateRemoteSessionRequest {\n122\t    CreateRemoteSessionRequest {\n123\t        environment_id: \"env_test\".to_string(),\n124\t        title: Some(\"acceptance-test\".to_string()),\n125\t        permission_mode: Some(\"default\".to_string()),\n126\t        events: vec![SessionEvent {\n127\t            event_type: \"started\".to_string(),\n128\t            payload_json: serde_json::json!({\"ok\": true}),\n129\t        }],\n130\t    }\n131\t}\n132\t\n133\tfn short_timeout() -> ArchivePolicy {\n134\t    ArchivePolicy {\n135\t        timeout: Duration::from_millis(10),\n136\t        idempotent: true,\n137\t    }\n138\t}\n139\t\n140\t// ── §8.1 Contract tests ────────────────────────────────────────────────────\n141\t\n142\t/// AC: archive(409) maps to success-equivalent result.\n143\t///\n144\t/// HTTP 409 Conflict on an archive call means the session is already\n145\t/// archived; the service must treat this as Ok(()) — never an error.\n146\t#[tokio::test]\n147\tasync fn contract_archive_409_is_success_equivalent() {\n148\t    let client = MockCcrClient::with_archive(vec![Ok(ArchiveResult::AlreadyArchived)]);\n149\t    let svc = ApplicationRemoteSessionService::new(client, true);\n150\t\n151\t    let result = svc.archive_session(\"session_123\", short_timeout()).await;\n152\t\n153\t    assert!(\n154\t        result.is_ok(),\n155\t        \"AlreadyArchived (HTTP 409) must be treated as success; got {result:?}\"\n156\t    );\n157\t}\n158\t\n159\t/// AC: session_ and cse_ IDs round-trip correctly through the compatibility adapter.\n160\t///\n161\t/// The service layer is ID-agnostic: it stores and returns whatever the\n162\t/// transport returned, without performing prefix rewriting itself.\n163\t/// Prefix translation is a remote-runtime concern (see ccr_client_tests.rs).\n164\t#[tokio::test]\n165\tasync fn contract_session_id_is_preserved_opaquely_by_service() {\n166\t    let session_id = \"session_abc123\";\n167\t    let client = MockCcrClient::with_create(vec![Ok(summary_for(\n168\t        session_id,\n169\t        RemoteSessionState::Running,\n170\t    ))]);\n171\t    let svc = ApplicationRemoteSessionService::new(client, true);\n172\t\n173\t    let result = svc.create_session(sample_create_request()).await.unwrap();\n174\t\n175\t    assert_eq!(\n176\t        result.session_id, session_id,\n177\t        \"service must not rewrite session IDs; expected {session_id}, got {}\",\n178\t        result.session_id\n179\t    );\n180\t}\n181\t\n182\t/// Companion: verify that a cse_-prefixed ID is also preserved opaquely.\n183\t#[tokio::test]\n184\tasync fn contract_cse_id_is_preserved_opaquely_by_service() {\n185\t    let cse_id = \"cse_abc123\";\n186\t    let client =\n187\t        MockCcrClient::with_get(vec![Ok(summary_for(cse_id, RemoteSessionState::Running))]);\n188\t    let svc = ApplicationRemoteSessionService::new(client, true);\n189\t\n190\t    let result = svc.fetch_session(cse_id).await.unwrap();\n191\t\n192\t    assert_eq!(\n193\t        result.session_id, cse_id,\n194\t        \"service must not rewrite cse_ IDs; expected {cse_id}, got {}\",\n195\t        result.session_id\n196\t    );\n197\t}\n198\t\n199\t/// AC: missing token produces AuthUnavailable (never panic).\n200\t///\n201\t/// Unauthorized (HTTP 401) from the transport maps to AuthUnavailable at\n202\t/// the service boundary. The call must return Err — not panic.\n203\t#[tokio::test]\n204\tasync fn contract_missing_token_produces_auth_unavailable() {\n205\t    let client = MockCcrClient::with_get(vec![Err(CcrClientError::Unauthorized)]);\n206\t    let svc = ApplicationRemoteSessionService::new(client, true);\n207\t\n208\t    let result = svc.fetch_session(\"session_123\").await;\n209\t\n210\t    assert!(\n211\t        matches!(result, Err(RemoteSessionError::AuthUnavailable)),\n212\t        \"Unauthorized must map to AuthUnavailable; got {result:?}\"\n213\t    );\n214\t}\n215\t\n216\t/// AC: missing org produces EntitlementDenied (never panic).\n217\t///\n218\t/// Forbidden (HTTP 403) — which is returned when the org header is absent or\n219\t/// unrecognised — maps to EntitlementDenied at the service boundary.\n220\t#[tokio::test]\n221\tasync fn contract_missing_org_produces_entitlement_denied() {\n222\t    let client = MockCcrClient {\n223\t        patch_results: Arc::new(Mutex::new(vec![Err(CcrClientError::Forbidden)].into())),\n224\t        ..MockCcrClient::default()\n225\t    };\n226\t    let svc = ApplicationRemoteSessionService::new(client, true);\n227\t\n228\t    let result = svc.update_title(\"session_123\", \"title\").await;\n229\t\n230\t    assert!(\n231\t        matches!(result, Err(RemoteSessionError::EntitlementDenied)),\n232\t        \"Forbidden must map to EntitlementDenied; got {result:?}\"\n233\t    );\n234\t}\n235\t\n236\t// ── §8.2 Integration tests ─────────────────────────────────────────────────\n237\t\n238\t/// AC: create → fetch → archive happy path passes.\n239\t///\n240\t/// Executes the full lifecycle sequentially against a mock transport and\n241\t/// asserts each step succeeds with the expected session ID.\n242\t#[tokio::test]\n243\tasync fn integration_create_fetch_archive_happy_path() {\n244\t    let session_id = \"session_happy\";\n245\t    let client = MockCcrClient::for_happy_path(session_id, RemoteSessionState::Running);\n246\t    let svc = ApplicationRemoteSessionService::new(client, true);\n247\t\n248\t    // Step 1: create\n249\t    let created = svc\n250\t        .create_session(sample_create_request())\n251\t        .await\n252\t        .expect(\"create must succeed\");\n253\t    assert_eq!(created.session_id, session_id);\n254\t    assert_eq!(created.state, RemoteSessionState::Running);\n255\t\n256\t    // Step 2: fetch\n257\t    let fetched = svc\n258\t        .fetch_session(session_id)\n259\t        .await\n260\t        .expect(\"fetch must succeed\");\n261\t    assert_eq!(fetched.session_id, session_id);\n262\t\n263\t    // Step 3: archive\n264\t    svc.archive_session(session_id, short_timeout())\n265\t        .await\n266\t        .expect(\"archive must succeed\");\n267\t}\n268\t\n269\t/// AC: resume with stale/expired session returns deterministic error classification.\n270\t///\n271\t/// Expired sessions are not resumable; the service must return Expired,\n272\t/// not a generic upstream error or a panic.\n273\t#[tokio::test]\n274\tasync fn integration_resume_with_expired_session_returns_deterministic_error() {\n275\t    let client = MockCcrClient::with_get(vec![Ok(summary_for(\n276\t        \"session_stale\",\n277\t        RemoteSessionState::Expired,\n278\t    ))]);\n279\t    let svc = ApplicationRemoteSessionService::new(client, true);\n280\t\n281\t    let result = svc.reconcile_resume(\"session_stale\").await;\n282\t\n283\t    assert!(\n284\t        matches!(result, Err(RemoteSessionError::Expired)),\n285\t        \"expired session must yield RemoteSessionError::Expired; got {result:?}\"\n286\t    );\n287\t}\n288\t\n289\t/// Companion: archived sessions must yield InvalidStateTransition on resume\n290\t/// (Archived is a terminal state — cannot re-enter Running).\n291\t#[tokio::test]\n292\tasync fn integration_resume_with_archived_session_returns_invalid_state_transition() {\n293\t    let client = MockCcrClient::with_get(vec![Ok(summary_for(\n294\t        \"session_archived\",\n295\t        RemoteSessionState::Archived,\n296\t    ))]);\n297\t    let svc = ApplicationRemoteSessionService::new(client, true);\n298\t\n299\t    let result = svc.reconcile_resume(\"session_archived\").await;\n300\t\n301\t    assert!(\n302\t        matches!(result, Err(RemoteSessionError::InvalidStateTransition)),\n303\t        \"archived session resume must yield InvalidStateTransition; got {result:?}\"\n304\t    );\n305\t}\n306\t\n307\t/// AC: shutdown path performs best-effort archive under timeout budget.\n308\t///\n309\t/// When the archive call exceeds the policy timeout the best-effort helper\n310\t/// must return false (degraded) rather than blocking or panicking.\n311\t#[tokio::test]\n312\tasync fn integration_shutdown_best_effort_archive_under_timeout_budget() {\n313\t    let client = MockCcrClient::with_archive_delay(Duration::from_millis(100));\n314\t    let svc = ApplicationRemoteSessionService::new(client, true);\n315\t\n316\t    let archived = svc\n317\t        .archive_on_shutdown_best_effort(\n318\t            \"session_shutdown\",\n319\t            ArchivePolicy {\n320\t                timeout: Duration::from_millis(5),\n321\t                idempotent: true,\n322\t            },\n323\t        )\n324\t        .await;\n325\t\n326\t    assert!(\n327\t        !archived,\n328\t        \"best-effort archive must degrade gracefully when transport exceeds timeout\"\n329\t    );\n330\t}\n331\t\n332\t/// Companion: best-effort archive returns true when transport completes in time.\n333\t#[tokio::test]\n334\tasync fn integration_shutdown_best_effort_archive_succeeds_within_budget() {\n335\t    let client = MockCcrClient::with_archive(vec![Ok(ArchiveResult::Archived)]);\n336\t    let svc = ApplicationRemoteSessionService::new(client, true);\n337\t\n338\t    let archived = svc\n339\t        .archive_on_shutdown_best_effort(\n340\t            \"session_ok\",\n341\t            ArchivePolicy {\n342\t                timeout: Duration::from_millis(200),\n343\t                idempotent: true,\n344\t            },\n345\t        )\n346\t        .await;\n347\t\n348\t    assert!(\n349\t        archived,\n350\t        \"best-effort archive must return true when transport completes within budget\"\n351\t    );\n352\t}\n353\t"}]},"parent_tool_use_id":"toolu_018H4SGR6cdK1dzJcYiwu9aQ","session_id":"6429a853-3cab-4876-b6cc-9209ef0cfb79","uuid":"f060680f-2f2d-43e7-a4a5-1d320acdac45","timestamp":"2026-04-02T14:35:45.931Z"}
