{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PTDhKfCj9TU7z7JqxzsAEd","type":"tool_result","content":"1\tuse crate::{\n2\t    multi_agent_orchestrator_service::{ApplicationMultiAgentOrchestrator, WorkerRuntime},\n3\t    spec_contracts::{\n4\t        MultiAgentOrchestrator, OrchestrationError, TaskCriticality, WorkerResultNotification,\n5\t        WorkerStatus, WorkerTaskSpec,\n6\t    },\n7\t};\n8\tuse std::{\n9\t    collections::{HashMap, HashSet},\n10\t    sync::{\n11\t        Arc,\n12\t        atomic::{AtomicUsize, Ordering},\n13\t    },\n14\t    time::Duration,\n15\t};\n16\tuse tokio::sync::Mutex;\n17\t\n18\t#[derive(Default)]\n19\tstruct MockWorkerRuntime {\n20\t    fail_spawn_for: HashSet<String>,\n21\t    active_spawns: AtomicUsize,\n22\t    max_parallel_spawns: AtomicUsize,\n23\t    stop_calls: Mutex<HashMap<String, usize>>,\n24\t}\n25\t\n26\timpl MockWorkerRuntime {\n27\t    fn with_spawn_failure(task_id: &str) -> Self {\n28\t        Self {\n29\t            fail_spawn_for: HashSet::from([task_id.to_string()]),\n30\t            ..Self::default()\n31\t        }\n32\t    }\n33\t}\n34\t\n35\t#[async_trait::async_trait]\n36\timpl WorkerRuntime for MockWorkerRuntime {\n37\t    async fn spawn_worker(&self, task: &WorkerTaskSpec) -> Result<String, String> {\n38\t        if self.fail_spawn_for.contains(&task.task_id) {\n39\t            return Err(format!(\"spawn failed for {}\", task.task_id));\n40\t        }\n41\t\n42\t        let active = self.active_spawns.fetch_add(1, Ordering::SeqCst) + 1;\n43\t        let _ = self.max_parallel_spawns.fetch_max(active, Ordering::SeqCst);\n44\t        tokio::time::sleep(Duration::from_millis(20)).await;\n45\t        self.active_spawns.fetch_sub(1, Ordering::SeqCst);\n46\t\n47\t        Ok(format!(\"worker-{}\", task.task_id))\n48\t    }\n49\t\n50\t    async fn stop_worker(&self, task_id: &str) -> Result<(), String> {\n51\t        let mut calls = self.stop_calls.lock().await;\n52\t        let entry = calls.entry(task_id.to_string()).or_insert(0);\n53\t        *entry += 1;\n54\t        Ok(())\n55\t    }\n56\t}\n57\t\n58\tfn sidecar_task(task_id: &str, scope: &str) -> WorkerTaskSpec {\n59\t    WorkerTaskSpec {\n60\t        task_id: task_id.to_string(),\n61\t        title: format!(\"title-{task_id}\"),\n62\t        prompt: format!(\"Task {task_id}: only edit {scope}. Ownership boundary: {scope}.\"),\n63\t        criticality: TaskCriticality::Sidecar,\n64\t        owner_scope: scope.to_string(),\n65\t    }\n66\t}\n67\t\n68\t#[tokio::test]\n69\tasync fn spawn_parallel_rejects_overlapping_write_scopes() {\n70\t    let orchestrator =\n71\t        ApplicationMultiAgentOrchestrator::new(true, Arc::new(MockWorkerRuntime::default()));\n72\t\n73\t    let result = orchestrator\n74\t        .spawn_parallel(vec![\n75\t            sidecar_task(\"a\", \"crates/application/src/a.rs\"),\n76\t            sidecar_task(\"b\", \"crates/application/src/a.rs\"),\n77\t        ])\n78\t        .await;\n79\t\n80\t    assert!(matches!(result, Err(OrchestrationError::PolicyViolation)));\n81\t}\n82\t\n83\t#[tokio::test]\n84\tasync fn independent_tasks_are_spawned_in_parallel() {\n85\t    let runtime = Arc::new(MockWorkerRuntime::default());\n86\t    let orchestrator = ApplicationMultiAgentOrchestrator::new(true, runtime.clone());\n87\t\n88\t    let result = orchestrator\n89\t        .spawn_parallel(vec![\n90\t            sidecar_task(\"a\", \"crates/application/src/a.rs\"),\n91\t            sidecar_task(\"b\", \"crates/application/src/b.rs\"),\n92\t            sidecar_task(\"c\", \"crates/application/src/c.rs\"),\n93\t        ])\n94\t        .await\n95\t        .expect(\"spawn should succeed\");\n96\t\n97\t    assert_eq!(result.len(), 3);\n98\t    assert!(runtime.max_parallel_spawns.load(Ordering::SeqCst) > 1);\n99\t}\n100\t\n101\t#[tokio::test]\n102\tasync fn synthesize_summary_aggregates_notifications() {\n103\t    let orchestrator =\n104\t        ApplicationMultiAgentOrchestrator::new(true, Arc::new(MockWorkerRuntime::default()));\n105\t    let task_a = sidecar_task(\"a\", \"scope/a\");\n106\t    let task_b = sidecar_task(\"b\", \"scope/b\");\n107\t    let task_c = sidecar_task(\"c\", \"scope/c\");\n108\t    orchestrator\n109\t        .spawn_parallel(vec![task_a, task_b, task_c])\n110\t        .await\n111\t        .expect(\"spawn should succeed\");\n112\t\n113\t    orchestrator\n114\t        .handle_notification(WorkerResultNotification {\n115\t            task_id: \"a\".to_string(),\n116\t            status: WorkerStatus::Completed,\n117\t            summary: \"implemented output parsing\".to_string(),\n118\t        })\n119\t        .await\n120\t        .expect(\"notification should be accepted\");\n121\t    orchestrator\n122\t        .handle_notification(WorkerResultNotification {\n123\t            task_id: \"b\".to_string(),\n124\t            status: WorkerStatus::Failed,\n125\t            summary: \"tests failed in CI\".to_string(),\n126\t        })\n127\t        .await\n128\t        .expect(\"notification should be accepted\");\n129\t\n130\t    let summary = orchestrator\n131\t        .synthesize_summary(&[\"a\".to_string(), \"b\".to_string(), \"c\".to_string()])\n132\t        .await\n133\t        .expect(\"synthesis should succeed\");\n134\t\n135\t    assert_eq!(summary.completed, 1);\n136\t    assert_eq!(summary.failed, 1);\n137\t    assert_eq!(summary.key_findings.len(), 2);\n138\t    assert!(\n139\t        summary\n140\t            .next_actions\n141\t            .iter()\n142\t            .any(|line| line.contains(\"b\") && line.contains(\"retry\"))\n143\t    );\n144\t}\n145\t\n146\t#[tokio::test]\n147\tasync fn mixed_outcomes_produce_deterministic_summary_and_traceable_actions() {\n148\t    let orchestrator =\n149\t        ApplicationMultiAgentOrchestrator::new(true, Arc::new(MockWorkerRuntime::default()));\n150\t    orchestrator\n151\t        .spawn_parallel(vec![\n152\t            sidecar_task(\"alpha\", \"scope/alpha\"),\n153\t            sidecar_task(\"beta\", \"scope/beta\"),\n154\t            sidecar_task(\"gamma\", \"scope/gamma\"),\n155\t        ])\n156\t        .await\n157\t        .expect(\"spawn should succeed\");\n158\t\n159\t    orchestrator\n160\t        .handle_notification(WorkerResultNotification {\n161\t            task_id: \"alpha\".to_string(),\n162\t            status: WorkerStatus::Completed,\n163\t            summary: \"completed cleanly\".to_string(),\n164\t        })\n165\t        .await\n166\t        .expect(\"notification should be accepted\");\n167\t    orchestrator\n168\t        .handle_notification(WorkerResultNotification {\n169\t            task_id: \"beta\".to_string(),\n170\t            status: WorkerStatus::Failed,\n171\t            summary: \"build failed\".to_string(),\n172\t        })\n173\t        .await\n174\t        .expect(\"notification should be accepted\");\n175\t    orchestrator\n176\t        .handle_notification(WorkerResultNotification {\n177\t            task_id: \"gamma\".to_string(),\n178\t            status: WorkerStatus::Cancelled,\n179\t            summary: \"cancelled by policy\".to_string(),\n180\t        })\n181\t        .await\n182\t        .expect(\"notification should be accepted\");\n183\t\n184\t    let first = orchestrator\n185\t        .synthesize_summary(&[\"alpha\".to_string(), \"beta\".to_string(), \"gamma\".to_string()])\n186\t        .await\n187\t        .expect(\"synthesis should succeed\");\n188\t    let second = orchestrator\n189\t        .synthesize_summary(&[\"alpha\".to_string(), \"beta\".to_string(), \"gamma\".to_string()])\n190\t        .await\n191\t        .expect(\"synthesis should succeed\");\n192\t\n193\t    assert_eq!(first.completed, 1);\n194\t    assert_eq!(first.failed, 1);\n195\t    assert_eq!(first.key_findings, second.key_findings);\n196\t    assert_eq!(first.next_actions, second.next_actions);\n197\t    assert!(\n198\t        first\n199\t            .key_findings\n200\t            .iter()\n201\t            .all(|line| line.contains(\"alpha\") || line.contains(\"beta\") || line.contains(\"gamma\"))\n202\t    );\n203\t    assert!(\n204\t        first\n205\t            .next_actions\n206\t            .iter()\n207\t            .any(|line| line.contains(\"beta\") && line.contains(\"retry\"))\n208\t    );\n209\t    assert!(\n210\t        first\n211\t            .next_actions\n212\t            .iter()\n213\t            .any(|line| line.contains(\"gamma\") && line.contains(\"rescope\"))\n214\t    );\n215\t}\n216\t\n217\t#[tokio::test]\n218\tasync fn stop_is_idempotent_for_terminal_state() {\n219\t    let runtime = Arc::new(MockWorkerRuntime::default());\n220\t    let orchestrator = ApplicationMultiAgentOrchestrator::new(true, runtime.clone());\n221\t    orchestrator\n222\t        .spawn_parallel(vec![sidecar_task(\"a\", \"scope/a\")])\n223\t        .await\n224\t        .expect(\"spawn should succeed\");\n225\t    orchestrator\n226\t        .handle_notification(WorkerResultNotification {\n227\t            task_id: \"a\".to_string(),\n228\t            status: WorkerStatus::Completed,\n229\t            summary: \"done\".to_string(),\n230\t        })\n231\t        .await\n232\t        .expect(\"notification should be accepted\");\n233\t\n234\t    orchestrator.stop_task(\"a\").await.expect(\"idempotent stop\");\n235\t    orchestrator.stop_task(\"a\").await.expect(\"idempotent stop\");\n236\t\n237\t    let calls = runtime.stop_calls.lock().await;\n238\t    assert_eq!(calls.get(\"a\"), None);\n239\t}\n240\t\n241\t#[tokio::test]\n242\tasync fn error_variants_are_reachable() {\n243\t    let disabled =\n244\t        ApplicationMultiAgentOrchestrator::new(false, Arc::new(MockWorkerRuntime::default()));\n245\t    let err = disabled\n246\t        .spawn_parallel(vec![sidecar_task(\"a\", \"scope/a\")])\n247\t        .await\n248\t        .expect_err(\"mode should reject orchestration\");\n249\t    assert!(matches!(err, OrchestrationError::DisabledByMode));\n250\t\n251\t    let orchestrator =\n252\t        ApplicationMultiAgentOrchestrator::new(true, Arc::new(MockWorkerRuntime::default()));\n253\t\n254\t    let invalid = WorkerTaskSpec {\n255\t        task_id: \"bad\".to_string(),\n256\t        title: \"bad\".to_string(),\n257\t        prompt: \"missing boundary marker\".to_string(),\n258\t        criticality: TaskCriticality::Sidecar,\n259\t        owner_scope: \"scope/bad\".to_string(),\n260\t    };\n261\t    let err = orchestrator\n262\t        .spawn_parallel(vec![invalid])\n263\t        .await\n264\t        .expect_err(\"invalid prompt must fail\");\n265\t    assert!(matches!(err, OrchestrationError::InvalidTaskSpec));\n266\t\n267\t    let err = orchestrator\n268\t        .spawn_parallel(vec![WorkerTaskSpec {\n269\t            criticality: TaskCriticality::Blocking,\n270\t            ..sidecar_task(\"blocking\", \"scope/blocking\")\n271\t        }])\n272\t        .await\n273\t        .expect_err(\"blocking work should not be delegated\");\n274\t    assert!(matches!(err, OrchestrationError::PolicyViolation));\n275\t\n276\t    let err = orchestrator\n277\t        .handle_notification(WorkerResultNotification {\n278\t            task_id: \"\".to_string(),\n279\t            status: WorkerStatus::Completed,\n280\t            summary: \"\".to_string(),\n281\t        })\n282\t        .await\n283\t        .expect_err(\"malformed notification\");\n284\t    assert!(matches!(err, OrchestrationError::NotificationMalformed));\n285\t\n286\t    let err = orchestrator\n287\t        .stop_task(\"unknown\")\n288\t        .await\n289\t        .expect_err(\"missing task should return not found\");\n290\t    assert!(matches!(err, OrchestrationError::TaskNotFound));\n291\t\n292\t    let spawn_fail = ApplicationMultiAgentOrchestrator::new(\n293\t        true,\n294\t        Arc::new(MockWorkerRuntime::with_spawn_failure(\"boom\")),\n295\t    );\n296\t    let err = spawn_fail\n297\t        .spawn_parallel(vec![sidecar_task(\"boom\", \"scope/boom\")])\n298\t        .await\n299\t        .expect_err(\"spawn failures must be mapped\");\n300\t    assert!(matches!(err, OrchestrationError::SpawnFailed(_)));\n301\t\n302\t    let err = orchestrator\n303\t        .synthesize_summary(&[])\n304\t        .await\n305\t        .expect_err(\"empty synthesis input should fail\");\n306\t    assert!(matches!(err, OrchestrationError::SynthesisFailed(_)));\n307\t}\n308\t"}]},"parent_tool_use_id":null,"session_id":"6429a853-3cab-4876-b6cc-9209ef0cfb79","uuid":"f199e99c-0b79-4004-aa34-f6b4e3f7bfb2","timestamp":"2026-04-02T14:36:20.378Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/application/src/multi_agent_orchestrator_tests.rs","content":"use crate::{\n    multi_agent_orchestrator_service::{ApplicationMultiAgentOrchestrator, WorkerRuntime},\n    spec_contracts::{\n        MultiAgentOrchestrator, OrchestrationError, TaskCriticality, WorkerResultNotification,\n        WorkerStatus, WorkerTaskSpec,\n    },\n};\nuse std::{\n    collections::{HashMap, HashSet},\n    sync::{\n        Arc,\n        atomic::{AtomicUsize, Ordering},\n    },\n    time::Duration,\n};\nuse tokio::sync::Mutex;\n\n#[derive(Default)]\nstruct MockWorkerRuntime {\n    fail_spawn_for: HashSet<String>,\n    active_spawns: AtomicUsize,\n    max_parallel_spawns: AtomicUsize,\n    stop_calls: Mutex<HashMap<String, usize>>,\n}\n\nimpl MockWorkerRuntime {\n    fn with_spawn_failure(task_id: &str) -> Self {\n        Self {\n            fail_spawn_for: HashSet::from([task_id.to_string()]),\n            ..Self::default()\n        }\n    }\n}\n\n#[async_trait::async_trait]\nimpl WorkerRuntime for MockWorkerRuntime {\n    async fn spawn_worker(&self, task: &WorkerTaskSpec) -> Result<String, String> {\n        if self.fail_spawn_for.contains(&task.task_id) {\n            return Err(format!(\"spawn failed for {}\", task.task_id));\n        }\n\n        let active = self.active_spawns.fetch_add(1, Ordering::SeqCst) + 1;\n        let _ = self.max_parallel_spawns.fetch_max(active, Ordering::SeqCst);\n        tokio::time::sleep(Duration::from_millis(20)).await;\n        self.active_spawns.fetch_sub(1, Ordering::SeqCst);\n\n        Ok(format!(\"worker-{}\", task.task_id))\n    }\n\n    async fn stop_worker(&self, task_id: &str) -> Result<(), String> {\n        let mut calls = self.stop_calls.lock().await;\n        let entry = calls.entry(task_id.to_string()).or_insert(0);\n        *entry += 1;\n        Ok(())\n    }\n}\n\nfn sidecar_task(task_id: &str, scope: &str) -> WorkerTaskSpec {\n    WorkerTaskSpec {\n        task_id: task_id.to_string(),\n        title: format!(\"title-{task_id}\"),\n        prompt: format!(\"Task {task_id}: only edit {scope}. Ownership boundary: {scope}.\"),\n        criticality: TaskCriticality::Sidecar,\n        owner_scope: scope.to_string(),\n    }\n}\n\n#[tokio::test]\nasync fn spawn_parallel_rejects_overlapping_write_scopes() {\n    let orchestrator =\n        ApplicationMultiAgentOrchestrator::new(true, Arc::new(MockWorkerRuntime::default()));\n\n    let result = orchestrator\n        .spawn_parallel(vec![\n            sidecar_task(\"a\", \"crates/application/src/a.rs\"),\n            sidecar_task(\"b\", \"crates/application/src/a.rs\"),\n        ])\n        .await;\n\n    assert!(matches!(result, Err(OrchestrationError::PolicyViolation)));\n}\n\n#[tokio::test]\nasync fn independent_tasks_are_spawned_in_parallel() {\n    let runtime = Arc::new(MockWorkerRuntime::default());\n    let orchestrator = ApplicationMultiAgentOrchestrator::new(true, runtime.clone());\n\n    let result = orchestrator\n        .spawn_parallel(vec![\n            sidecar_task(\"a\", \"crates/application/src/a.rs\"),\n            sidecar_task(\"b\", \"crates/application/src/b.rs\"),\n            sidecar_task(\"c\", \"crates/application/src/c.rs\"),\n        ])\n        .await\n        .expect(\"spawn should succeed\");\n\n    assert_eq!(result.len(), 3);\n    assert!(runtime.max_parallel_spawns.load(Ordering::SeqCst) > 1);\n}\n\n#[tokio::test]\nasync fn synthesize_summary_aggregates_notifications() {\n    let orchestrator =\n        ApplicationMultiAgentOrchestrator::new(true, Arc::new(MockWorkerRuntime::default()));\n    let task_a = sidecar_task(\"a\", \"scope/a\");\n    let task_b = sidecar_task(\"b\", \"scope/b\");\n    let task_c = sidecar_task(\"c\", \"scope/c\");\n    orchestrator\n        .spawn_parallel(vec![task_a, task_b, task_c])\n        .await\n        .expect(\"spawn should succeed\");\n\n    orchestrator\n        .handle_notification(WorkerResultNotification {\n            task_id: \"a\".to_string(),\n            status: WorkerStatus::Completed,\n            summary: \"implemented output parsing\".to_string(),\n        })\n        .await\n        .expect(\"notification should be accepted\");\n    orchestrator\n        .handle_notification(WorkerResultNotification {\n            task_id: \"b\".to_string(),\n            status: WorkerStatus::Failed,\n            summary: \"tests failed in CI\".to_string(),\n        })\n        .await\n        .expect(\"notification should be accepted\");\n\n    let summary = orchestrator\n        .synthesize_summary(&[\"a\".to_string(), \"b\".to_string(), \"c\".to_string()])\n        .await\n        .expect(\"synthesis should succeed\");\n\n    assert_eq!(summary.completed, 1);\n    assert_eq!(summary.failed, 1);\n    assert_eq!(summary.key_findings.len(), 2);\n    assert!(\n        summary\n            .next_actions\n            .iter()\n            .any(|line| line.contains(\"b\") && line.contains(\"retry\"))\n    );\n}\n\n#[tokio::test]\nasync fn mixed_outcomes_produce_deterministic_summary_and_traceable_actions() {\n    let orchestrator =\n        ApplicationMultiAgentOrchestrator::new(true, Arc::new(MockWorkerRuntime::default()));\n    orchestrator\n        .spawn_parallel(vec![\n            sidecar_task(\"alpha\", \"scope/alpha\"),\n            sidecar_task(\"beta\", \"scope/beta\"),\n            sidecar_task(\"gamma\", \"scope/gamma\"),\n        ])\n        .await\n        .expect(\"spawn should succeed\");\n\n    orchestrator\n        .handle_notification(WorkerResultNotification {\n            task_id: \"alpha\".to_string(),\n            status: WorkerStatus::Completed,\n            summary: \"completed cleanly\".to_string(),\n        })\n        .await\n        .expect(\"notification should be accepted\");\n    orchestrator\n        .handle_notification(WorkerResultNotification {\n            task_id: \"beta\".to_string(),\n            status: WorkerStatus::Failed,\n            summary: \"build failed\".to_string(),\n        })\n        .await\n        .expect(\"notification should be accepted\");\n    orchestrator\n        .handle_notification(WorkerResultNotification {\n            task_id: \"gamma\".to_string(),\n            status: WorkerStatus::Cancelled,\n            summary: \"cancelled by policy\".to_string(),\n        })\n        .await\n        .expect(\"notification should be accepted\");\n\n    let first = orchestrator\n        .synthesize_summary(&[\"alpha\".to_string(), \"beta\".to_string(), \"gamma\".to_string()])\n        .await\n        .expect(\"synthesis should succeed\");\n    let second = orchestrator\n        .synthesize_summary(&[\"alpha\".to_string(), \"beta\".to_string(), \"gamma\".to_string()])\n        .await\n        .expect(\"synthesis should succeed\");\n\n    assert_eq!(first.completed, 1);\n    assert_eq!(first.failed, 1);\n    assert_eq!(first.key_findings, second.key_findings);\n    assert_eq!(first.next_actions, second.next_actions);\n    assert!(\n        first\n            .key_findings\n            .iter()\n            .all(|line| line.contains(\"alpha\") || line.contains(\"beta\") || line.contains(\"gamma\"))\n    );\n    assert!(\n        first\n            .next_actions\n            .iter()\n            .any(|line| line.contains(\"beta\") && line.contains(\"retry\"))\n    );\n    assert!(\n        first\n            .next_actions\n            .iter()\n            .any(|line| line.contains(\"gamma\") && line.contains(\"rescope\"))\n    );\n}\n\n#[tokio::test]\nasync fn stop_is_idempotent_for_terminal_state() {\n    let runtime = Arc::new(MockWorkerRuntime::default());\n    let orchestrator = ApplicationMultiAgentOrchestrator::new(true, runtime.clone());\n    orchestrator\n        .spawn_parallel(vec![sidecar_task(\"a\", \"scope/a\")])\n        .await\n        .expect(\"spawn should succeed\");\n    orchestrator\n        .handle_notification(WorkerResultNotification {\n            task_id: \"a\".to_string(),\n            status: WorkerStatus::Completed,\n            summary: \"done\".to_string(),\n        })\n        .await\n        .expect(\"notification should be accepted\");\n\n    orchestrator.stop_task(\"a\").await.expect(\"idempotent stop\");\n    orchestrator.stop_task(\"a\").await.expect(\"idempotent stop\");\n\n    let calls = runtime.stop_calls.lock().await;\n    assert_eq!(calls.get(\"a\"), None);\n}\n\n#[tokio::test]\nasync fn error_variants_are_reachable() {\n    let disabled =\n        ApplicationMultiAgentOrchestrator::new(false, Arc::new(MockWorkerRuntime::default()));\n    let err = disabled\n        .spawn_parallel(vec![sidecar_task(\"a\", \"scope/a\")])\n        .await\n        .expect_err(\"mode should reject orchestration\");\n    assert!(matches!(err, OrchestrationError::DisabledByMode));\n\n    let orchestrator =\n        ApplicationMultiAgentOrchestrator::new(true, Arc::new(MockWorkerRuntime::default()));\n\n    let invalid = WorkerTaskSpec {\n        task_id: \"bad\".to_string(),\n        title: \"bad\".to_string(),\n        prompt: \"missing boundary marker\".to_string(),\n        criticality: TaskCriticality::Sidecar,\n        owner_scope: \"scope/bad\".to_string(),\n    };\n    let err = orchestrator\n        .spawn_parallel(vec![invalid])\n        .await\n        .expect_err(\"invalid prompt must fail\");\n    assert!(matches!(err, OrchestrationError::InvalidTaskSpec));\n\n    let err = orchestrator\n        .spawn_parallel(vec![WorkerTaskSpec {\n            criticality: TaskCriticality::Blocking,\n            ..sidecar_task(\"blocking\", \"scope/blocking\")\n        }])\n        .await\n        .expect_err(\"blocking work should not be delegated\");\n    assert!(matches!(err, OrchestrationError::PolicyViolation));\n\n    let err = orchestrator\n        .handle_notification(WorkerResultNotification {\n            task_id: \"\".to_string(),\n            status: WorkerStatus::Completed,\n            summary: \"\".to_string(),\n        })\n        .await\n        .expect_err(\"malformed notification\");\n    assert!(matches!(err, OrchestrationError::NotificationMalformed));\n\n    let err = orchestrator\n        .stop_task(\"unknown\")\n        .await\n        .expect_err(\"missing task should return not found\");\n    assert!(matches!(err, OrchestrationError::TaskNotFound));\n\n    let spawn_fail = ApplicationMultiAgentOrchestrator::new(\n        true,\n        Arc::new(MockWorkerRuntime::with_spawn_failure(\"boom\")),\n    );\n    let err = spawn_fail\n        .spawn_parallel(vec![sidecar_task(\"boom\", \"scope/boom\")])\n        .await\n        .expect_err(\"spawn failures must be mapped\");\n    assert!(matches!(err, OrchestrationError::SpawnFailed(_)));\n\n    let err = orchestrator\n        .synthesize_summary(&[])\n        .await\n        .expect_err(\"empty synthesis input should fail\");\n    assert!(matches!(err, OrchestrationError::SynthesisFailed(_)));\n}\n","numLines":308,"startLine":1,"totalLines":308}}}
