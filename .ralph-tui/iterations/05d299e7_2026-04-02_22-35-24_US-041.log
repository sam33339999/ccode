{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GfQp8ZV7oEkbVjfNnLpQn3","type":"tool_result","content":"1\tuse crate::spec_contracts::{\n2\t    CoordinatorSummary, MultiAgentOrchestrator, OrchestrationError, TaskCriticality,\n3\t    WorkerResultNotification, WorkerStatus, WorkerTaskSpec,\n4\t};\n5\tuse std::{\n6\t    collections::{HashMap, HashSet},\n7\t    sync::{\n8\t        Arc,\n9\t        atomic::{AtomicU64, Ordering},\n10\t    },\n11\t};\n12\tuse tokio::sync::RwLock;\n13\t\n14\t#[async_trait::async_trait]\n15\tpub trait WorkerRuntime: Send + Sync {\n16\t    async fn spawn_worker(&self, task: &WorkerTaskSpec) -> Result<String, String>;\n17\t    async fn stop_worker(&self, task_id: &str) -> Result<(), String>;\n18\t}\n19\t\n20\t#[derive(Default)]\n21\tpub struct InMemoryWorkerRuntime {\n22\t    seq: AtomicU64,\n23\t}\n24\t\n25\t#[async_trait::async_trait]\n26\timpl WorkerRuntime for InMemoryWorkerRuntime {\n27\t    async fn spawn_worker(&self, task: &WorkerTaskSpec) -> Result<String, String> {\n28\t        let next = self.seq.fetch_add(1, Ordering::SeqCst) + 1;\n29\t        Ok(format!(\"worker-{next}-{}\", task.task_id))\n30\t    }\n31\t\n32\t    async fn stop_worker(&self, _task_id: &str) -> Result<(), String> {\n33\t        Ok(())\n34\t    }\n35\t}\n36\t\n37\t#[derive(Debug, Clone)]\n38\tstruct WorkerTaskState {\n39\t    task: WorkerTaskSpec,\n40\t    status: WorkerStatus,\n41\t    summary: Option<String>,\n42\t}\n43\t\n44\tpub struct ApplicationMultiAgentOrchestrator {\n45\t    enabled_by_mode: bool,\n46\t    runtime: Arc<dyn WorkerRuntime>,\n47\t    tasks: RwLock<HashMap<String, WorkerTaskState>>,\n48\t}\n49\t\n50\timpl ApplicationMultiAgentOrchestrator {\n51\t    pub fn new(enabled_by_mode: bool, runtime: Arc<dyn WorkerRuntime>) -> Self {\n52\t        Self {\n53\t            enabled_by_mode,\n54\t            runtime,\n55\t            tasks: RwLock::new(HashMap::new()),\n56\t        }\n57\t    }\n58\t\n59\t    pub fn with_in_memory_runtime(enabled_by_mode: bool) -> Self {\n60\t        Self::new(enabled_by_mode, Arc::new(InMemoryWorkerRuntime::default()))\n61\t    }\n62\t\n63\t    fn ensure_mode_enabled(&self) -> Result<(), OrchestrationError> {\n64\t        if self.enabled_by_mode {\n65\t            Ok(())\n66\t        } else {\n67\t            Err(OrchestrationError::DisabledByMode)\n68\t        }\n69\t    }\n70\t\n71\t    fn validate_task_specs(tasks: &[WorkerTaskSpec]) -> Result<(), OrchestrationError> {\n72\t        if tasks.is_empty() {\n73\t            return Err(OrchestrationError::InvalidTaskSpec);\n74\t        }\n75\t\n76\t        for task in tasks {\n77\t            if task.task_id.trim().is_empty()\n78\t                || task.title.trim().is_empty()\n79\t                || task.prompt.trim().is_empty()\n80\t                || task.owner_scope.trim().is_empty()\n81\t            {\n82\t                return Err(OrchestrationError::InvalidTaskSpec);\n83\t            }\n84\t\n85\t            if task.criticality == TaskCriticality::Blocking {\n86\t                return Err(OrchestrationError::PolicyViolation);\n87\t            }\n88\t\n89\t            if !task.prompt.contains(&task.owner_scope) {\n90\t                return Err(OrchestrationError::InvalidTaskSpec);\n91\t            }\n92\t        }\n93\t\n94\t        Ok(())\n95\t    }\n96\t\n97\t    fn has_scope_overlap(tasks: &[WorkerTaskSpec]) -> bool {\n98\t        let mut scopes = HashSet::new();\n99\t        for task in tasks {\n100\t            if !scopes.insert(task.owner_scope.trim()) {\n101\t                return true;\n102\t            }\n103\t        }\n104\t        false\n105\t    }\n106\t\n107\t    fn is_terminal(status: WorkerStatus) -> bool {\n108\t        matches!(\n109\t            status,\n110\t            WorkerStatus::Completed | WorkerStatus::Failed | WorkerStatus::Cancelled\n111\t        )\n112\t    }\n113\t}\n114\t\n115\t#[async_trait::async_trait]\n116\timpl MultiAgentOrchestrator for ApplicationMultiAgentOrchestrator {\n117\t    async fn spawn_parallel(\n118\t        &self,\n119\t        tasks: Vec<WorkerTaskSpec>,\n120\t    ) -> Result<Vec<String>, OrchestrationError> {\n121\t        self.ensure_mode_enabled()?;\n122\t        Self::validate_task_specs(&tasks)?;\n123\t\n124\t        if Self::has_scope_overlap(&tasks) {\n125\t            return Err(OrchestrationError::PolicyViolation);\n126\t        }\n127\t\n128\t        {\n129\t            let state = self.tasks.read().await;\n130\t            let active_scopes: HashSet<&str> = state\n131\t                .values()\n132\t                .filter(|task| !Self::is_terminal(task.status))\n133\t                .map(|task| task.task.owner_scope.as_str())\n134\t                .collect();\n135\t\n136\t            for task in &tasks {\n137\t                // Block if the task_id is currently running (not terminal).\n138\t                // Allow re-spawning completed/failed/cancelled tasks for session\n139\t                // resumption.\n140\t                if let Some(existing) = state.get(&task.task_id)\n141\t                    && !Self::is_terminal(existing.status)\n142\t                {\n143\t                    return Err(OrchestrationError::PolicyViolation);\n144\t                }\n145\t                if active_scopes.contains(task.owner_scope.as_str()) {\n146\t                    return Err(OrchestrationError::PolicyViolation);\n147\t                }\n148\t            }\n149\t        }\n150\t\n151\t        let runtime = self.runtime.clone();\n152\t        let spawned = futures::future::join_all(tasks.into_iter().map(|task| {\n153\t            let runtime = runtime.clone();\n154\t            async move {\n155\t                runtime\n156\t                    .spawn_worker(&task)\n157\t                    .await\n158\t                    .map(|worker_id| (task, worker_id))\n159\t            }\n160\t        }))\n161\t        .await;\n162\t\n163\t        let mut created = Vec::new();\n164\t        for result in spawned {\n165\t            match result {\n166\t                Ok(v) => created.push(v),\n167\t                Err(msg) => return Err(OrchestrationError::SpawnFailed(msg)),\n168\t            }\n169\t        }\n170\t\n171\t        let mut worker_ids = Vec::with_capacity(created.len());\n172\t        let mut state = self.tasks.write().await;\n173\t        for (task, worker_id) in created {\n174\t            worker_ids.push(worker_id.clone());\n175\t            state.insert(\n176\t                task.task_id.clone(),\n177\t                WorkerTaskState {\n178\t                    task,\n179\t                    status: WorkerStatus::Running,\n180\t                    summary: None,\n181\t                },\n182\t            );\n183\t        }\n184\t\n185\t        Ok(worker_ids)\n186\t    }\n187\t\n188\t    async fn handle_notification(\n189\t        &self,\n190\t        notification: WorkerResultNotification,\n191\t    ) -> Result<(), OrchestrationError> {\n192\t        self.ensure_mode_enabled()?;\n193\t\n194\t        if notification.task_id.trim().is_empty() || notification.summary.trim().is_empty() {\n195\t            return Err(OrchestrationError::NotificationMalformed);\n196\t        }\n197\t\n198\t        let mut state = self.tasks.write().await;\n199\t        let task = state\n200\t            .get_mut(&notification.task_id)\n201\t            .ok_or(OrchestrationError::TaskNotFound)?;\n202\t        task.status = notification.status;\n203\t        task.summary = Some(notification.summary);\n204\t        Ok(())\n205\t    }\n206\t\n207\t    async fn synthesize_summary(\n208\t        &self,\n209\t        task_ids: &[String],\n210\t    ) -> Result<CoordinatorSummary, OrchestrationError> {\n211\t        self.ensure_mode_enabled()?;\n212\t\n213\t        if task_ids.is_empty() {\n214\t            return Err(OrchestrationError::SynthesisFailed(\n215\t                \"at least one task id is required\".to_string(),\n216\t            ));\n217\t        }\n218\t\n219\t        let state = self.tasks.read().await;\n220\t        let mut completed = 0usize;\n221\t        let mut failed = 0usize;\n222\t        let mut key_findings = Vec::new();\n223\t        let mut next_actions = Vec::new();\n224\t\n225\t        for task_id in task_ids {\n226\t            let task = state.get(task_id).ok_or(OrchestrationError::TaskNotFound)?;\n227\t\n228\t            match task.status {\n229\t                WorkerStatus::Completed => {\n230\t                    completed += 1;\n231\t                    if let Some(summary) = &task.summary {\n232\t                        key_findings.push(format!(\"{}: {}\", task.task.task_id, summary));\n233\t                    }\n234\t                }\n235\t                WorkerStatus::Failed => {\n236\t                    failed += 1;\n237\t                    if let Some(summary) = &task.summary {\n238\t                        key_findings.push(format!(\"{} (failed): {}\", task.task.task_id, summary));\n239\t                    }\n240\t                    next_actions.push(format!(\"retry or debug failed task {}\", task.task.task_id));\n241\t                }\n242\t                WorkerStatus::Cancelled => {\n243\t                    if let Some(summary) = &task.summary {\n244\t                        key_findings\n245\t                            .push(format!(\"{} (cancelled): {}\", task.task.task_id, summary));\n246\t                    }\n247\t                    next_actions.push(format!(\n248\t                        \"rescope or relaunch cancelled task {}\",\n249\t                        task.task.task_id\n250\t                    ));\n251\t                }\n252\t                WorkerStatus::Running => {\n253\t                    next_actions.push(format!(\"wait for running task {}\", task.task.task_id));\n254\t                }\n255\t            }\n256\t        }\n257\t\n258\t        if next_actions.is_empty() {\n259\t            next_actions.push(\"no immediate follow-up actions\".to_string());\n260\t        }\n261\t\n262\t        Ok(CoordinatorSummary {\n263\t            completed,\n264\t            failed,\n265\t            key_findings,\n266\t            next_actions,\n267\t        })\n268\t    }\n269\t\n270\t    async fn stop_task(&self, task_id: &str) -> Result<(), OrchestrationError> {\n271\t        self.ensure_mode_enabled()?;\n272\t\n273\t        let should_stop = {\n274\t            let state = self.tasks.read().await;\n275\t            let task = state.get(task_id).ok_or(OrchestrationError::TaskNotFound)?;\n276\t            !Self::is_terminal(task.status)\n277\t        };\n278\t\n279\t        if !should_stop {\n280\t            return Ok(());\n281\t        }\n282\t\n283\t        self.runtime\n284\t            .stop_worker(task_id)\n285\t            .await\n286\t            .map_err(OrchestrationError::SpawnFailed)?;\n287\t\n288\t        let mut state = self.tasks.write().await;\n289\t        if let Some(task) = state.get_mut(task_id) {\n290\t            task.status = WorkerStatus::Cancelled;\n291\t            if task.summary.is_none() {\n292\t                task.summary = Some(\"stopped by coordinator\".to_string());\n293\t            }\n294\t        }\n295\t\n296\t        Ok(())\n297\t    }\n298\t}\n299\t"}]},"parent_tool_use_id":null,"session_id":"6429a853-3cab-4876-b6cc-9209ef0cfb79","uuid":"52fa064a-de9a-47d5-8302-5f83de6b332d","timestamp":"2026-04-02T14:36:20.408Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/application/src/multi_agent_orchestrator_service.rs","content":"use crate::spec_contracts::{\n    CoordinatorSummary, MultiAgentOrchestrator, OrchestrationError, TaskCriticality,\n    WorkerResultNotification, WorkerStatus, WorkerTaskSpec,\n};\nuse std::{\n    collections::{HashMap, HashSet},\n    sync::{\n        Arc,\n        atomic::{AtomicU64, Ordering},\n    },\n};\nuse tokio::sync::RwLock;\n\n#[async_trait::async_trait]\npub trait WorkerRuntime: Send + Sync {\n    async fn spawn_worker(&self, task: &WorkerTaskSpec) -> Result<String, String>;\n    async fn stop_worker(&self, task_id: &str) -> Result<(), String>;\n}\n\n#[derive(Default)]\npub struct InMemoryWorkerRuntime {\n    seq: AtomicU64,\n}\n\n#[async_trait::async_trait]\nimpl WorkerRuntime for InMemoryWorkerRuntime {\n    async fn spawn_worker(&self, task: &WorkerTaskSpec) -> Result<String, String> {\n        let next = self.seq.fetch_add(1, Ordering::SeqCst) + 1;\n        Ok(format!(\"worker-{next}-{}\", task.task_id))\n    }\n\n    async fn stop_worker(&self, _task_id: &str) -> Result<(), String> {\n        Ok(())\n    }\n}\n\n#[derive(Debug, Clone)]\nstruct WorkerTaskState {\n    task: WorkerTaskSpec,\n    status: WorkerStatus,\n    summary: Option<String>,\n}\n\npub struct ApplicationMultiAgentOrchestrator {\n    enabled_by_mode: bool,\n    runtime: Arc<dyn WorkerRuntime>,\n    tasks: RwLock<HashMap<String, WorkerTaskState>>,\n}\n\nimpl ApplicationMultiAgentOrchestrator {\n    pub fn new(enabled_by_mode: bool, runtime: Arc<dyn WorkerRuntime>) -> Self {\n        Self {\n            enabled_by_mode,\n            runtime,\n            tasks: RwLock::new(HashMap::new()),\n        }\n    }\n\n    pub fn with_in_memory_runtime(enabled_by_mode: bool) -> Self {\n        Self::new(enabled_by_mode, Arc::new(InMemoryWorkerRuntime::default()))\n    }\n\n    fn ensure_mode_enabled(&self) -> Result<(), OrchestrationError> {\n        if self.enabled_by_mode {\n            Ok(())\n        } else {\n            Err(OrchestrationError::DisabledByMode)\n        }\n    }\n\n    fn validate_task_specs(tasks: &[WorkerTaskSpec]) -> Result<(), OrchestrationError> {\n        if tasks.is_empty() {\n            return Err(OrchestrationError::InvalidTaskSpec);\n        }\n\n        for task in tasks {\n            if task.task_id.trim().is_empty()\n                || task.title.trim().is_empty()\n                || task.prompt.trim().is_empty()\n                || task.owner_scope.trim().is_empty()\n            {\n                return Err(OrchestrationError::InvalidTaskSpec);\n            }\n\n            if task.criticality == TaskCriticality::Blocking {\n                return Err(OrchestrationError::PolicyViolation);\n            }\n\n            if !task.prompt.contains(&task.owner_scope) {\n                return Err(OrchestrationError::InvalidTaskSpec);\n            }\n        }\n\n        Ok(())\n    }\n\n    fn has_scope_overlap(tasks: &[WorkerTaskSpec]) -> bool {\n        let mut scopes = HashSet::new();\n        for task in tasks {\n            if !scopes.insert(task.owner_scope.trim()) {\n                return true;\n            }\n        }\n        false\n    }\n\n    fn is_terminal(status: WorkerStatus) -> bool {\n        matches!(\n            status,\n            WorkerStatus::Completed | WorkerStatus::Failed | WorkerStatus::Cancelled\n        )\n    }\n}\n\n#[async_trait::async_trait]\nimpl MultiAgentOrchestrator for ApplicationMultiAgentOrchestrator {\n    async fn spawn_parallel(\n        &self,\n        tasks: Vec<WorkerTaskSpec>,\n    ) -> Result<Vec<String>, OrchestrationError> {\n        self.ensure_mode_enabled()?;\n        Self::validate_task_specs(&tasks)?;\n\n        if Self::has_scope_overlap(&tasks) {\n            return Err(OrchestrationError::PolicyViolation);\n        }\n\n        {\n            let state = self.tasks.read().await;\n            let active_scopes: HashSet<&str> = state\n                .values()\n                .filter(|task| !Self::is_terminal(task.status))\n                .map(|task| task.task.owner_scope.as_str())\n                .collect();\n\n            for task in &tasks {\n                // Block if the task_id is currently running (not terminal).\n                // Allow re-spawning completed/failed/cancelled tasks for session\n                // resumption.\n                if let Some(existing) = state.get(&task.task_id)\n                    && !Self::is_terminal(existing.status)\n                {\n                    return Err(OrchestrationError::PolicyViolation);\n                }\n                if active_scopes.contains(task.owner_scope.as_str()) {\n                    return Err(OrchestrationError::PolicyViolation);\n                }\n            }\n        }\n\n        let runtime = self.runtime.clone();\n        let spawned = futures::future::join_all(tasks.into_iter().map(|task| {\n            let runtime = runtime.clone();\n            async move {\n                runtime\n                    .spawn_worker(&task)\n                    .await\n                    .map(|worker_id| (task, worker_id))\n            }\n        }))\n        .await;\n\n        let mut created = Vec::new();\n        for result in spawned {\n            match result {\n                Ok(v) => created.push(v),\n                Err(msg) => return Err(OrchestrationError::SpawnFailed(msg)),\n            }\n        }\n\n        let mut worker_ids = Vec::with_capacity(created.len());\n        let mut state = self.tasks.write().await;\n        for (task, worker_id) in created {\n            worker_ids.push(worker_id.clone());\n            state.insert(\n                task.task_id.clone(),\n                WorkerTaskState {\n                    task,\n                    status: WorkerStatus::Running,\n                    summary: None,\n                },\n            );\n        }\n\n        Ok(worker_ids)\n    }\n\n    async fn handle_notification(\n        &self,\n        notification: WorkerResultNotification,\n    ) -> Result<(), OrchestrationError> {\n        self.ensure_mode_enabled()?;\n\n        if notification.task_id.trim().is_empty() || notification.summary.trim().is_empty() {\n            return Err(OrchestrationError::NotificationMalformed);\n        }\n\n        let mut state = self.tasks.write().await;\n        let task = state\n            .get_mut(&notification.task_id)\n            .ok_or(OrchestrationError::TaskNotFound)?;\n        task.status = notification.status;\n        task.summary = Some(notification.summary);\n        Ok(())\n    }\n\n    async fn synthesize_summary(\n        &self,\n        task_ids: &[String],\n    ) -> Result<CoordinatorSummary, OrchestrationError> {\n        self.ensure_mode_enabled()?;\n\n        if task_ids.is_empty() {\n            return Err(OrchestrationError::SynthesisFailed(\n                \"at least one task id is required\".to_string(),\n            ));\n        }\n\n        let state = self.tasks.read().await;\n        let mut completed = 0usize;\n        let mut failed = 0usize;\n        let mut key_findings = Vec::new();\n        let mut next_actions = Vec::new();\n\n        for task_id in task_ids {\n            let task = state.get(task_id).ok_or(OrchestrationError::TaskNotFound)?;\n\n            match task.status {\n                WorkerStatus::Completed => {\n                    completed += 1;\n                    if let Some(summary) = &task.summary {\n                        key_findings.push(format!(\"{}: {}\", task.task.task_id, summary));\n                    }\n                }\n                WorkerStatus::Failed => {\n                    failed += 1;\n                    if let Some(summary) = &task.summary {\n                        key_findings.push(format!(\"{} (failed): {}\", task.task.task_id, summary));\n                    }\n                    next_actions.push(format!(\"retry or debug failed task {}\", task.task.task_id));\n                }\n                WorkerStatus::Cancelled => {\n                    if let Some(summary) = &task.summary {\n                        key_findings\n                            .push(format!(\"{} (cancelled): {}\", task.task.task_id, summary));\n                    }\n                    next_actions.push(format!(\n                        \"rescope or relaunch cancelled task {}\",\n                        task.task.task_id\n                    ));\n                }\n                WorkerStatus::Running => {\n                    next_actions.push(format!(\"wait for running task {}\", task.task.task_id));\n                }\n            }\n        }\n\n        if next_actions.is_empty() {\n            next_actions.push(\"no immediate follow-up actions\".to_string());\n        }\n\n        Ok(CoordinatorSummary {\n            completed,\n            failed,\n            key_findings,\n            next_actions,\n        })\n    }\n\n    async fn stop_task(&self, task_id: &str) -> Result<(), OrchestrationError> {\n        self.ensure_mode_enabled()?;\n\n        let should_stop = {\n            let state = self.tasks.read().await;\n            let task = state.get(task_id).ok_or(OrchestrationError::TaskNotFound)?;\n            !Self::is_terminal(task.status)\n        };\n\n        if !should_stop {\n            return Ok(());\n        }\n\n        self.runtime\n            .stop_worker(task_id)\n            .await\n            .map_err(OrchestrationError::SpawnFailed)?;\n\n        let mut state = self.tasks.write().await;\n        if let Some(task) = state.get_mut(task_id) {\n            task.status = WorkerStatus::Cancelled;\n            if task.summary.is_none() {\n                task.summary = Some(\"stopped by coordinator\".to_string());\n            }\n        }\n\n        Ok(())\n    }\n}\n","numLines":299,"startLine":1,"totalLines":299}}}
