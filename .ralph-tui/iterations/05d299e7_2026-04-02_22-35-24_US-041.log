{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RWDJR7wN5JyMossPNaib8N","type":"tool_result","content":"1\t//! Contract tests — llm-compat-contract.md §10.1\n2\t//!\n3\t//! Verifies serialisation round-trips, bijective ToolDefinition mapping,\n4\t//! and correct StopReason translation between Anthropic and OpenAI wire formats.\n5\t//! No HTTP is involved; all tests are pure data-transformation assertions.\n6\t\n7\tuse ccode_provider::compat::convert::{\n8\t    anthropic_response_to_openai_response, anthropic_tool_to_openai_function,\n9\t    openai_function_to_anthropic_tool, openai_response_to_anthropic_response,\n10\t};\n11\tuse ccode_provider::compat::request::{\n12\t    AnthropicRequest, Content, Message, OpenAiMessage, OpenAiRequest, SystemContent,\n13\t};\n14\tuse ccode_provider::compat::response::{\n15\t    AnthropicResponse, OpenAiChoice, OpenAiMessageResponse, OpenAiResponse, TextBlock, Usage,\n16\t};\n17\tuse serde_json::json;\n18\t\n19\t// ── AC1: LlmRequest round-trips through Anthropic wire format ─────────────────\n20\t\n21\t#[test]\n22\tfn anthropic_request_serialises_all_llm_request_fields_without_data_loss() {\n23\t    let req = AnthropicRequest {\n24\t        model: \"claude-3-5-sonnet-20241022\".into(),\n25\t        messages: vec![Message {\n26\t            role: \"user\".into(),\n27\t            content: Content::Text(\"What is 2+2?\".into()),\n28\t        }],\n29\t        max_tokens: Some(512),\n30\t        temperature: Some(0.7),\n31\t        system: Some(SystemContent::Text(\"You are a math tutor.\".into())),\n32\t        stream: None,\n33\t        provider: None,\n34\t    };\n35\t\n36\t    let serialised = serde_json::to_value(&req).expect(\"should serialise\");\n37\t\n38\t    assert_eq!(serialised[\"model\"], \"claude-3-5-sonnet-20241022\");\n39\t    assert_eq!(serialised[\"messages\"][0][\"role\"], \"user\");\n40\t    assert_eq!(serialised[\"messages\"][0][\"content\"], \"What is 2+2?\");\n41\t    assert_eq!(serialised[\"max_tokens\"], 512);\n42\t    assert_eq!(serialised[\"system\"], \"You are a math tutor.\");\n43\t    assert!(\n44\t        serialised[\"temperature\"].is_number(),\n45\t        \"temperature must be present\"\n46\t    );\n47\t\n48\t    // Round-trip: deserialise back and compare\n49\t    let roundtrip: AnthropicRequest =\n50\t        serde_json::from_value(serialised).expect(\"should deserialise\");\n51\t    assert_eq!(roundtrip.model, req.model);\n52\t    assert_eq!(roundtrip.max_tokens, req.max_tokens);\n53\t    assert_eq!(roundtrip.system, req.system);\n54\t    assert_eq!(roundtrip.messages.len(), 1);\n55\t}\n56\t\n57\t#[test]\n58\tfn anthropic_response_deserialises_all_fields_without_data_loss() {\n59\t    let wire = json!({\n60\t        \"id\": \"msg_abc123\",\n61\t        \"type\": \"message\",\n62\t        \"role\": \"assistant\",\n63\t        \"model\": \"claude-3-5-sonnet-20241022\",\n64\t        \"content\": [{\"type\": \"text\", \"text\": \"The answer is 4.\"}],\n65\t        \"stop_reason\": \"end_turn\",\n66\t        \"usage\": {\"input_tokens\": 25, \"output_tokens\": 8}\n67\t    });\n68\t\n69\t    let resp: AnthropicResponse = serde_json::from_value(wire).expect(\"should deserialise\");\n70\t\n71\t    assert_eq!(resp.id, \"msg_abc123\");\n72\t    assert_eq!(resp.model, \"claude-3-5-sonnet-20241022\");\n73\t    assert_eq!(resp.content.len(), 1);\n74\t    assert_eq!(resp.content[0].block_type, \"text\");\n75\t    assert_eq!(resp.content[0].text, \"The answer is 4.\");\n76\t    assert_eq!(resp.stop_reason, Some(\"end_turn\".into()));\n77\t    assert_eq!(resp.usage.input_tokens, 25);\n78\t    assert_eq!(resp.usage.output_tokens, 8);\n79\t}\n80\t"}]},"parent_tool_use_id":"toolu_018H4SGR6cdK1dzJcYiwu9aQ","session_id":"6429a853-3cab-4876-b6cc-9209ef0cfb79","uuid":"c54d04a5-d404-44d1-95b3-57d605b6712a","timestamp":"2026-04-02T14:35:50.820Z"}
