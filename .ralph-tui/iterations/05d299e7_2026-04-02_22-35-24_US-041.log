essionError {\n72\t    #[error(\"remote control is disabled by policy\")]\n73\t    DisabledByPolicy,\n74\t    #[error(\"missing entitlement\")]\n75\t    EntitlementDenied,\n76\t    #[error(\"invalid state transition\")]\n77\t    InvalidStateTransition,\n78\t    #[error(\"session not found\")]\n79\t    NotFound,\n80\t    #[error(\"session expired\")]\n81\t    Expired,\n82\t    #[error(\"auth unavailable\")]\n83\t    AuthUnavailable,\n84\t    #[error(\"upstream error: {0}\")]\n85\t    Upstream(String),\n86\t}\n87\t\n88\t#[async_trait]\n89\tpub trait CcrClient: Send + Sync {\n90\t    async fn create(\n91\t        &self,\n92\t        req: CreateRemoteSessionRequest,\n93\t    ) -> Result<RemoteSessionSummary, CcrClientError>;\n94\t    async fn get(&self, session_id: &str) -> Result<RemoteSessionSummary, CcrClientError>;\n95\t    async fn archive(&self, session_id: &str) -> Result<ArchiveResult, CcrClientError>;\n96\t    async fn patch_title(&self, session_id: &str, title: &str) -> Result<(), CcrClientError>;\n97\t}\n98\t\n99\t#[async_trait]\n100\tpub trait RemoteSessionService: Send + Sync {"}]},"parent_tool_use_id":null,"session_id":"6429a853-3cab-4876-b6cc-9209ef0cfb79","uuid":"3b4819e6-191f-48dd-9eee-d8f3637db651","timestamp":"2026-04-02T14:36:25.981Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/application/src/spec_contracts.rs","content":"use async_trait::async_trait;\nuse ccode_domain::{\n    assistant_mode::{AssistantMode, ModeSwitchTrigger},\n    event::DomainEvent,\n    session::SessionId,\n};\nuse serde::{Deserialize, Serialize};\nuse serde_json::Value;\nuse std::time::Duration;\n\n#[derive(Debug, Clone)]\npub struct CreateRemoteSessionRequest {\n    pub environment_id: String,\n    pub title: Option<String>,\n    pub permission_mode: Option<String>,\n    pub events: Vec<SessionEvent>,\n}\n\n#[derive(Debug, Clone)]\npub struct SessionEvent {\n    pub event_type: String,\n    pub payload_json: Value,\n}\n\n#[derive(Debug, Clone, Copy)]\npub struct ArchivePolicy {\n    pub timeout: Duration,\n    pub idempotent: bool,\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]\npub enum RemoteSessionState {\n    Pending,\n    Running,\n    Idle,\n    RequiresAction,\n    Archived,\n    Expired,\n    Failed,\n}\n\n#[derive(Debug, Clone)]\npub struct RemoteSessionSummary {\n    pub session_id: String,\n    pub title: Option<String>,\n    pub environment_id: Option<String>,\n    pub state: RemoteSessionState,\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub enum ArchiveResult {\n    Archived,\n    AlreadyArchived,\n}\n\n#[derive(Debug, thiserror::Error)]\npub enum CcrClientError {\n    #[error(\"http error: {0}\")]\n    Http(String),\n    #[error(\"timeout\")]\n    Timeout,\n    #[error(\"unauthorized\")]\n    Unauthorized,\n    #[error(\"forbidden\")]\n    Forbidden,\n    #[error(\"invalid payload\")]\n    InvalidPayload,\n}\n\n#[derive(Debug, thiserror::Error)]\npub enum RemoteSessionError {\n    #[error(\"remote control is disabled by policy\")]\n    DisabledByPolicy,\n    #[error(\"missing entitlement\")]\n    EntitlementDenied,\n    #[error(\"invalid state transition\")]\n    InvalidStateTransition,\n    #[error(\"session not found\")]\n    NotFound,\n    #[error(\"session expired\")]\n    Expired,\n    #[error(\"auth unavailable\")]\n    AuthUnavailable,\n    #[error(\"upstream error: {0}\")]\n    Upstream(String),\n}\n\n#[async_trait]\npub trait CcrClient: Send + Sync {\n    async fn create(\n        &self,\n        req: CreateRemoteSessionRequest,\n    ) -> Result<RemoteSessionSummary, CcrClientError>;\n    async fn get(&self, session_id: &str) -> Result<RemoteSessionSummary, CcrClientError>;\n    async fn archive(&self, session_id: &str) -> Result<ArchiveResult, CcrClientError>;\n    async fn patch_title(&self, session_id: &str, title: &str) -> Result<(), CcrClientError>;\n}\n\n#[async_trait]\npub trait RemoteSessionService: Send + Sync {"