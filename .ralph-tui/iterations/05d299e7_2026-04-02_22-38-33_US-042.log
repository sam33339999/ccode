{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UwHBf3ndgpvYcG9GrN8z4h","type":"tool_result","content":"1\t/// Multi-agent orchestration acceptance tests (US-041)\n2\t///\n3\t/// Covers all scenarios from multi-agent-orchestration-contract.md §8 Acceptance Matrix:\n4\t///   §8.1 Contract tests  – policy validation, notification parsing, synthesis requirements\n5\t///   §8.2 Integration tests – parallel spawning, mixed statuses, idempotent stop\n6\t///   §8.3 CLI behaviour tests – coordinator controls, mode blocking, user-visible summary\n7\tuse crate::{\n8\t    multi_agent_orchestrator_service::{ApplicationMultiAgentOrchestrator, WorkerRuntime},\n9\t    spec_contracts::{\n10\t        CoordinatorSummary, MultiAgentOrchestrator, OrchestrationError, TaskCriticality,\n11\t        WorkerResultNotification, WorkerStatus, WorkerTaskSpec,\n12\t    },\n13\t};\n14\tuse std::{\n15\t    collections::{HashMap, HashSet},\n16\t    sync::{\n17\t        Arc,\n18\t        atomic::{AtomicUsize, Ordering},\n19\t    },\n20\t    time::Duration,\n21\t};\n22\tuse tokio::sync::Mutex;\n23\t\n24\t// ── helpers ───────────────────────────────────────────────────────────────\n25\t\n26\t#[derive(Default)]\n27\tstruct MockWorkerRuntime {\n28\t    fail_spawn_for: HashSet<String>,\n29\t    active_spawns: AtomicUsize,\n30\t    max_parallel_spawns: AtomicUsize,\n31\t    stop_calls: Mutex<HashMap<String, usize>>,\n32\t}\n33\t\n34\t#[async_trait::async_trait]\n35\timpl WorkerRuntime for MockWorkerRuntime {\n36\t    async fn spawn_worker(&self, task: &WorkerTaskSpec) -> Result<String, String> {\n37\t        if self.fail_spawn_for.contains(&task.task_id) {\n38\t            return Err(format!(\"spawn failed for {}\", task.task_id));\n39\t        }\n40\t\n41\t        let active = self.active_spawns.fetch_add(1, Ordering::SeqCst) + 1;\n42\t        let _ = self.max_parallel_spawns.fetch_max(active, Ordering::SeqCst);\n43\t        tokio::time::sleep(Duration::from_millis(20)).await;\n44\t        self.active_spawns.fetch_sub(1, Ordering::SeqCst);\n45\t\n46\t        Ok(format!(\"worker-{}\", task.task_id))\n47\t    }\n48\t\n49\t    async fn stop_worker(&self, task_id: &str) -> Result<(), String> {\n50\t        let mut calls = self.stop_calls.lock().await;\n51\t        let entry = calls.entry(task_id.to_string()).or_insert(0);\n52\t        *entry += 1;\n53\t        Ok(())\n54\t    }\n55\t}\n56\t\n57\tfn coordinator_orchestrator() -> ApplicationMultiAgentOrchestrator {\n58\t    ApplicationMultiAgentOrchestrator::new(true, Arc::new(MockWorkerRuntime::default()))\n59\t}\n60\t\n61\tfn coordinator_orchestrator_with_runtime(\n62\t    runtime: Arc<MockWorkerRuntime>,\n63\t) -> ApplicationMultiAgentOrchestrator {\n64\t    ApplicationMultiAgentOrchestrator::new(true, runtime)\n65\t}\n66\t\n67\tfn disabled_orchestrator() -> ApplicationMultiAgentOrchestrator {\n68\t    ApplicationMultiAgentOrchestrator::new(false, Arc::new(MockWorkerRuntime::default()))\n69\t}\n70\t\n71\tfn task(task_id: &str, scope: &str) -> WorkerTaskSpec {\n72\t    WorkerTaskSpec {\n73\t        task_id: task_id.to_string(),\n74\t        title: format!(\"title-{task_id}\"),\n75\t        prompt: format!(\"Task {task_id}: only edit {scope}. Ownership boundary: {scope}.\"),\n76\t        criticality: TaskCriticality::Sidecar,\n77\t        owner_scope: scope.to_string(),\n78\t    }\n79\t}\n80\t\n81\tfn notification(task_id: &str, status: WorkerStatus, summary: &str) -> WorkerResultNotification {\n82\t    WorkerResultNotification {\n83\t        task_id: task_id.to_string(),\n84\t        status,\n85\t        summary: summary.to_string(),\n86\t    }\n87\t}\n88\t\n89\t// ── §8.1 Contract tests ─────────────────────────────────────────────────\n90\t\n91\t/// AC: parallel fan-out rejects overlapping write scopes when policy forbids them.\n92\t///\n93\t/// Two tasks targeting the same owner_scope must be rejected with PolicyViolation.\n94\t#[tokio::test]\n95\tasync fn contract_parallel_fanout_rejects_overlapping_write_scopes() {\n96\t    let orchestrator = coordinator_orchestrator();\n97\t\n98\t    let result = orchestrator\n99\t        .spawn_parallel(vec![\n100\t            task(\"task-1\", \"crates/domain/src/model.rs\"),"}]},"parent_tool_use_id":"toolu_013MtP5ZHyjqKA1pJYvyhzVM","session_id":"b9e339b7-1479-46b1-b285-3ad36d9e4141","uuid":"f1f0cde3-b9c7-45a6-a7f3-bfd0f840bd0e","timestamp":"2026-04-02T14:38:56.279Z"}
