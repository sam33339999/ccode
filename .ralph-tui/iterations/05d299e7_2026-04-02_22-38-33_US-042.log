{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RcDFRTiDvw2uDZ2njAYbqN","type":"tool_result","content":"250\t\n251\t    assert_eq!(worker_ids.len(), 3, \"must return 3 worker ids\");\n252\t\n253\t    // Verify parallel execution occurred\n254\t    assert!(\n255\t        runtime.max_parallel_spawns.load(Ordering::SeqCst) > 1,\n256\t        \"tasks must have been spawned concurrently\"\n257\t    );\n258\t\n259\t    // Deliver 3 notifications\n260\t    for (id, summary) in [\n261\t        (\"w1\", \"refactored module A\"),\n262\t        (\"w2\", \"added tests for B\"),\n263\t        (\"w3\", \"updated docs for C\"),\n264\t    ] {\n265\t        orchestrator\n266\t            .handle_notification(notification(id, WorkerStatus::Completed, summary))\n267\t            .await\n268\t            .expect(&format!(\"notification for {id} must be accepted\"));\n269\t    }\n270\t\n271\t    let summary = orchestrator\n272\t        .synthesize_summary(&[\"w1\".to_string(), \"w2\".to_string(), \"w3\".to_string()])\n273\t        .await\n274\t        .expect(\"synthesis must succeed\");\n275\t\n276\t    assert_eq!(\n277\t        summary.completed, 3,\n278\t        \"all 3 tasks must be counted as completed\"\n279\t    );\n280\t    assert_eq!(summary.failed, 0);\n281\t}\n282\t\n283\t/// AC: mixed result statuses (completed/failed/cancelled) aggregated correctly.\n284\t///\n285\t/// The coordinator summary must reflect exact counts and produce appropriate\n286\t/// next_actions for non-completed statuses.\n287\t#[tokio::test]\n288\tasync fn integration_mixed_result_statuses_aggregated_correctly() {\n289\t    let orchestrator = coordinator_orchestrator();\n290\t    orchestrator\n291\t        .spawn_parallel(vec![\n292\t            task(\"m1\", \"scope/m1\"),\n293\t            task(\"m2\", \"scope/m2\"),\n294\t            task(\"m3\", \"scope/m3\"),\n295\t        ])\n296\t        .await\n297\t        .expect(\"spawn should succeed\");\n298\t\n299\t    orchestrator\n300\t        .handle_notification(notification(\n301\t            \"m1\",\n302\t            WorkerStatus::Completed,\n303\t            \"all tests pass\",\n304\t        ))\n305\t        .await\n306\t        .unwrap();\n307\t    orchestrator\n308\t        .handle_notification(notification(\"m2\", WorkerStatus::Failed, \"compile error\"))\n309\t        .await\n310\t        .unwrap();\n311\t    orchestrator\n312\t        .handle_notification(notification(\n313\t            \"m3\",\n314\t            WorkerStatus::Cancelled,\n315\t            \"user cancelled\",\n316\t        ))\n317\t        .await\n318\t        .unwrap();\n319\t\n320\t    let summary = orchestrator\n321\t        .synthesize_summary(&[\"m1\".to_string(), \"m2\".to_string(), \"m3\".to_string()])\n322\t        .await\n323\t        .expect(\"synthesis should succeed\");\n324\t\n325\t    assert_eq!(summary.completed, 1);\n326\t    assert_eq!(summary.failed, 1);\n327\t\n328\t    // key_findings should mention all tasks\n329\t    assert!(\n330\t        summary.key_findings.iter().any(|f| f.contains(\"m1\")),\n331\t        \"key_findings must include completed task m1\"\n332\t    );\n333\t    assert!(\n334\t        summary.key_findings.iter().any(|f| f.contains(\"m2\")),\n335\t        \"key_findings must include failed task m2\"\n336\t    );\n337\t    assert!(\n338\t        summary.key_findings.iter().any(|f| f.contains(\"m3\")),\n339\t        \"key_findings must include cancelled task m3\"\n340\t    );\n341\t\n342\t    // next_actions for failed → retry, cancelled → rescope\n343\t    assert!(\n344\t        summary\n345\t            .next_actions\n346\t            .iter()\n347\t            .any(|a| a.contains(\"m2\") && a.contains(\"retry\")),\n348\t        \"next_actions must suggest retry for failed task m2\"\n349\t    );"}]},"parent_tool_use_id":"toolu_013MtP5ZHyjqKA1pJYvyhzVM","session_id":"b9e339b7-1479-46b1-b285-3ad36d9e4141","uuid":"e1c0c82c-9e2b-4317-8a1a-09fb7a2347d6","timestamp":"2026-04-02T14:39:12.767Z"}
