{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SMtZEPGt5R5Y4ksZfqMaPS","type":"tool_result","content":"1\t/// Coordinator mode acceptance tests (US-039)\n2\t///\n3\t/// Covers all scenarios from coordinator-mode-contract.md §7 Acceptance Matrix:\n4\t///   §7.1 Contract tests  – precedence and reconcile logic invariants\n5\t///   §7.2 Integration tests – resume path mode consistency\n6\t///   §7.3 CLI behaviour tests – tool visibility, prompt branch, event metadata\n7\tuse crate::{\n8\t    mode_coordinator_service::DefaultModeCoordinatorService,\n9\t    spec_contracts::{\n10\t        CoordinatorMode, CoordinatorModeError, EffectiveModeSource, ModeCoordinatorService,\n11\t        ModeReconcileAction, ModeResolutionInput, ModeSwitchEvent, ModeSwitchReason, SessionMode,\n12\t    },\n13\t};\n14\t\n15\t// ── helpers ───────────────────────────────────────────────────────────────\n16\t\n17\tfn standard_session() -> Option<SessionMode> {\n18\t    Some(SessionMode {\n19\t        mode: CoordinatorMode::Standard,\n20\t    })\n21\t}\n22\t\n23\tfn coordinator_session() -> Option<SessionMode> {\n24\t    Some(SessionMode {\n25\t        mode: CoordinatorMode::Coordinator,\n26\t    })\n27\t}\n28\t\n29\tfn service_with(\n30\t    policy_enabled: bool,\n31\t    env_mode: Option<CoordinatorMode>,\n32\t    current_mode: CoordinatorMode,\n33\t) -> DefaultModeCoordinatorService {\n34\t    DefaultModeCoordinatorService {\n35\t        policy_enabled,\n36\t        env_mode,\n37\t        current_mode,\n38\t    }\n39\t}\n40\t\n41\t// ── §7.1 Contract tests ──────────────────────────────────────────────────\n42\t\n43\t/// AC: mode precedence and reconcile logic is deterministic.\n44\t///\n45\t/// The precedence rule is: session_mode > env_mode > default(Standard).\n46\t/// Given identical inputs the result must never vary.\n47\t#[test]\n48\tfn contract_mode_precedence_is_deterministic() {\n49\t    let svc = DefaultModeCoordinatorService::default();\n50\t\n51\t    // Run resolution twice with same inputs → identical results.\n52\t    let input = ModeResolutionInput {\n53\t        policy_enabled: true,\n54\t        env_mode: Some(CoordinatorMode::Coordinator),\n55\t        session_mode: coordinator_session(),\n56\t        previous_mode: Some(CoordinatorMode::Standard),\n57\t    };\n58\t\n59\t    let a = svc.resolve_effective_mode(input.clone());\n60\t    let b = svc.resolve_effective_mode(input);\n61\t\n62\t    assert_eq!(a.mode, b.mode, \"mode must be deterministic across calls\");\n63\t    assert_eq!(\n64\t        a.source, b.source,\n65\t        \"source must be deterministic across calls\"\n66\t    );\n67\t    assert_eq!(\n68\t        a.switch_event, b.switch_event,\n69\t        \"switch_event must be deterministic across calls\"\n70\t    );\n71\t}\n72\t\n73\t/// AC: session_mode > env_mode in precedence.\n74\t///\n75\t/// When both session and env modes are provided, session wins.\n76\t#[test]\n77\tfn contract_session_mode_takes_precedence_over_env_mode() {\n78\t    let svc = DefaultModeCoordinatorService::default();\n79\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n80\t        policy_enabled: true,\n81\t        env_mode: Some(CoordinatorMode::Standard),\n82\t        session_mode: coordinator_session(),\n83\t        previous_mode: Some(CoordinatorMode::Standard),\n84\t    });\n85\t\n86\t    assert_eq!(result.mode, CoordinatorMode::Coordinator);\n87\t    assert_eq!(result.source, EffectiveModeSource::Session);\n88\t    assert!(result.error.is_none());\n89\t}\n90\t\n91\t/// AC: env_mode > default when no session mode.\n92\t#[test]\n93\tfn contract_env_mode_takes_precedence_over_default() {\n94\t    let svc = DefaultModeCoordinatorService::default();\n95\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n96\t        policy_enabled: true,\n97\t        env_mode: Some(CoordinatorMode::Coordinator),\n98\t        session_mode: None,\n99\t        previous_mode: Some(CoordinatorMode::Standard),\n100\t    });"}]},"parent_tool_use_id":"toolu_013MtP5ZHyjqKA1pJYvyhzVM","session_id":"b9e339b7-1479-46b1-b285-3ad36d9e4141","uuid":"b9ebd8d6-74c5-4694-b624-3e02a15ac1ed","timestamp":"2026-04-02T14:38:55.817Z"}
