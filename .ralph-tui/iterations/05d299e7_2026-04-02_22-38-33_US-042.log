{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01571fDm8PMuindZgckspyej","type":"tool_result","content":"350\t\n351\t/// AC: disabled policy on resume returns Standard with error.\n352\t#[test]\n353\tfn integration_resume_disabled_policy_returns_standard() {\n354\t    let svc = service_with(\n355\t        false,\n356\t        Some(CoordinatorMode::Coordinator),\n357\t        CoordinatorMode::Standard,\n358\t    );\n359\t\n360\t    let result = svc.reconcile_on_resume(coordinator_session());\n361\t\n362\t    assert_eq!(result.mode, CoordinatorMode::Standard);\n363\t    assert_eq!(result.action, ModeReconcileAction::Noop);\n364\t    assert!(matches!(\n365\t        result.error,\n366\t        Some(CoordinatorModeError::DisabledByPolicy)\n367\t    ));\n368\t}\n369\t\n370\t// ── §7.3 CLI behaviour tests ─────────────────────────────────────────────\n371\t\n372\t/// AC: tool visibility and prompt mode branch are correct.\n373\t///\n374\t/// Standard mode produces Default source; Coordinator mode produces Session\n375\t/// source. The source drives the TUI prompt branch selection.\n376\t#[test]\n377\tfn cli_tool_visibility_and_prompt_branch_are_correct() {\n378\t    let svc = DefaultModeCoordinatorService::default();\n379\t\n380\t    // Standard mode → Default source\n381\t    let standard = svc.resolve_effective_mode(ModeResolutionInput {\n382\t        policy_enabled: true,\n383\t        env_mode: None,\n384\t        session_mode: None,\n385\t        previous_mode: None,\n386\t    });\n387\t    assert_eq!(standard.source, EffectiveModeSource::Default);\n388\t\n389\t    // Coordinator via session → Session source\n390\t    let coordinator = svc.resolve_effective_mode(ModeResolutionInput {\n391\t        policy_enabled: true,\n392\t        env_mode: None,\n393\t        session_mode: coordinator_session(),\n394\t        previous_mode: None,\n395\t    });\n396\t    assert_eq!(coordinator.source, EffectiveModeSource::Session);\n397\t\n398\t    // Coordinator via env → Env source\n399\t    let env_coord = svc.resolve_effective_mode(ModeResolutionInput {\n400\t        policy_enabled: true,\n401\t        env_mode: Some(CoordinatorMode::Coordinator),\n402\t        session_mode: None,\n403\t        previous_mode: None,\n404\t    });\n405\t    assert_eq!(env_coord.source, EffectiveModeSource::Env);\n406\t}\n407\t\n408\t/// AC: mode switch event metadata (from, to, reason) is emitted.\n409\t///\n410\t/// Every mode change must produce a ModeSwitchEvent with all three fields\n411\t/// populated so downstream consumers (TUI, telemetry) can react.\n412\t#[test]\n413\tfn cli_mode_switch_event_metadata_is_emitted() {\n414\t    let svc = DefaultModeCoordinatorService::default();\n415\t\n416\t    // Standard → Coordinator via session\n417\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n418\t        policy_enabled: true,\n419\t        env_mode: None,\n420\t        session_mode: coordinator_session(),\n421\t        previous_mode: Some(CoordinatorMode::Standard),\n422\t    });\n423\t\n424\t    let event = result\n425\t        .switch_event\n426\t        .expect(\"mode change must emit a switch event\");\n427\t    assert_eq!(event.from, CoordinatorMode::Standard);\n428\t    assert_eq!(event.to, CoordinatorMode::Coordinator);\n429\t    assert_eq!(event.reason, ModeSwitchReason::SessionPrecedence);\n430\t}\n431\t\n432\t/// AC: mode switch via env emits correct reason.\n433\t#[test]\n434\tfn cli_mode_switch_via_env_emits_env_configured_reason() {\n435\t    let svc = DefaultModeCoordinatorService::default();\n436\t    let result = svc.resolve_effective_mode(ModeResolutionInput {\n437\t        policy_enabled: true,\n438\t        env_mode: Some(CoordinatorMode::Coordinator),\n439\t        session_mode: None,\n440\t        previous_mode: Some(CoordinatorMode::Standard),\n441\t    });\n442\t\n443\t    let event = result.switch_event.expect(\"must emit switch event\");\n444\t    assert_eq!(event.from, CoordinatorMode::Standard);\n445\t    assert_eq!(event.to, CoordinatorMode::Coordinator);\n446\t    assert_eq!(event.reason, ModeSwitchReason::EnvConfigured);\n447\t}\n448\t\n449\t/// AC: reconcile switch emits ResumeReconcile reason."}]},"parent_tool_use_id":"toolu_013MtP5ZHyjqKA1pJYvyhzVM","session_id":"b9e339b7-1479-46b1-b285-3ad36d9e4141","uuid":"0a94e7f8-ab77-4f57-9fe6-f5c4f654ef7c","timestamp":"2026-04-02T14:39:11.967Z"}
