 )),\n627\t            ..MockUltraplanRuntime::default()\n628\t        };\n629\t        let approval_failed_service = DefaultUltraplanService::new(approval_failed_runtime, true);\n630\t        let _ = approval_failed_service\n631\t            .launch(\"prompt\", policy())\n632\t            .await\n633\t            .expect(\"launch succeeds\");\n634\t        let _ = approval_failed_service\n635\t            .poll(\"session_1\")\n636\t            .await\n637\t            .expect(\"awaiting input\");\n638\t        let approval_failed = approval_failed_service.poll(\"session_1\").await;\n639\t        assert!(matches!(\n640\t            approval_failed,\n641\t            Err(UltraplanError::ApprovalFailed)\n642\t        ));\n643\t\n644\t        let archive_failed_runtime = MockUltraplanRuntime {\n645\t            archive_results: Arc::new(Mutex::new(\n646\t                vec![Err(UltraplanError::Transport(\"x\".into()))].into(),\n647\t            )),\n648\t            ..MockUltraplanRuntime::default()\n649\t        };\n650\t        let archive_failed = DefaultUltraplanService::new(archive_failed_runtime, true)\n651\t            .archive_orphan(\"session_2\")\n652\t            .await;\n653\t        assert!(matches!(archive_failed, Err(UltraplanError::ArchiveFailed)));\n654\t\n655\t        let transport_runtime = MockUltraplanRuntime {\n656\t            stop_results: Arc::new(Mutex::new(\n657\t                vec![Err(UltraplanError::Transport(\"stop failed\".to_owned()))].into(),\n658\t            )),\n659\t            ..MockUltraplanRuntime::default()\n660\t        };\n661\t        let transport = DefaultUltraplanService::new(transport_runtime, true)\n662\t            .stop(\"session_3\")\n663\t            .await;\n664\t        assert!(matches!(transport, Err(UltraplanError::Transport(_))));\n665\t    }\n666\t\n667\t    #[tokio::test]\n668\t    async fn archive_failure_during_launch_failure_surfaces_archive_failed() {\n669\t        let runtime = MockUltraplanRuntime {\n