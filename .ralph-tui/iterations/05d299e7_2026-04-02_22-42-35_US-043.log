{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J9WLENidEkWbbuwXiXVKsZ","type":"tool_result","content":"1\tpub mod assistant_mode_service;\n2\tpub mod commands;\n3\tpub mod error;\n4\tpub mod mode_coordinator_service;\n5\tpub mod multi_agent_orchestrator_service;\n6\tpub mod queries;\n7\tpub mod remote_session_service;\n8\tpub mod spec_contracts;\n9\tpub mod teammem_kairos_service;\n10\tpub mod ultraplan_service;\n11\t\n12\t#[cfg(test)]\n13\tmod bridge_mode_acceptance_tests;\n14\t#[cfg(test)]\n15\tmod coordinator_mode_acceptance_tests;\n16\t#[cfg(test)]\n17\tmod kairos_acceptance_tests;\n18\t#[cfg(test)]\n19\tmod multi_agent_orchestration_acceptance_tests;\n20\t#[cfg(test)]\n21\tmod multi_agent_orchestrator_tests;\n22\t#[cfg(test)]\n23\tmod remote_session_service_tests;\n24\t#[cfg(test)]\n25\tmod teammem_acceptance_tests;\n26\t"}]},"parent_tool_use_id":"toolu_01XcwKb2RbRK1ZWthDdBWymB","session_id":"c8641186-7fb9-40c9-80e2-66e2f0b1f59f","uuid":"8b3c44e7-fed4-4e65-9900-6a5d01f908e5","timestamp":"2026-04-02T14:42:57.410Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MnTTsgAQoP8grUJcC1mywg","type":"tool_result","content":"1\tuse crate::spec_contracts::{\n2\t    UltraplanError, UltraplanPhase, UltraplanPolicy, UltraplanService, UltraplanSession,\n3\t};\n4\tuse async_trait::async_trait;\n5\tuse tokio::sync::Mutex;\n6\t\n7\t#[async_trait]\n8\tpub trait UltraplanRuntime: Send + Sync {\n9\t    async fn launch_session(&self, prompt: &str) -> Result<String, UltraplanError>;\n10\t    async fn poll_phase(&self, session_id: &str) -> Result<UltraplanPhase, UltraplanError>;\n11\t    async fn stop_session(&self, session_id: &str) -> Result<(), UltraplanError>;\n12\t    async fn archive_session(&self, session_id: &str) -> Result<(), UltraplanError>;\n13\t}\n14\t\n15\t#[derive(Debug, Clone)]\n16\tstruct ActiveSession {\n17\t    session_id: String,\n18\t    phase: UltraplanPhase,\n19\t}\n20\t\n21\t#[derive(Debug, Default)]\n22\tstruct LocalState {\n23\t    launching: bool,\n24\t    active: Option<ActiveSession>,\n25\t    revision: u64,\n26\t}\n27\t\n28\tpub struct DefaultUltraplanService<R> {\n29\t    runtime: R,\n30\t    policy_enabled: bool,\n31\t    state: Mutex<LocalState>,\n32\t}\n33\t\n34\timpl<R> DefaultUltraplanService<R> {\n35\t    pub fn new(runtime: R, policy_enabled: bool) -> Self {\n36\t        Self {\n37\t            runtime,\n38\t            policy_enabled,\n39\t            state: Mutex::new(LocalState::default()),\n40\t        }\n41\t    }\n42\t\n43\t    fn is_terminal(phase: UltraplanPhase) -> bool {\n44\t        matches!(phase, UltraplanPhase::Completed | UltraplanPhase::Failed)\n45\t    }\n46\t\n47\t    fn transition_allowed(from: UltraplanPhase, to: UltraplanPhase) -> bool {\n48\t        matches!(\n49\t            (from, to),\n50\t            (UltraplanPhase::Idle, UltraplanPhase::Launching)\n51\t                | (UltraplanPhase::Launching, UltraplanPhase::Polling)\n52\t                | (UltraplanPhase::Launching, UltraplanPhase::Failed)\n53\t                | (UltraplanPhase::Polling, UltraplanPhase::AwaitingInput)\n54\t                | (UltraplanPhase::Polling, UltraplanPhase::Approved)\n55\t                | (UltraplanPhase::Polling, UltraplanPhase::Failed)\n56\t                | (UltraplanPhase::Polling, UltraplanPhase::Stopping)\n57\t                | (UltraplanPhase::AwaitingInput, UltraplanPhase::Polling)\n58\t                | (UltraplanPhase::AwaitingInput, UltraplanPhase::Stopping)\n59\t                | (UltraplanPhase::Approved, UltraplanPhase::Completed)\n60\t                | (UltraplanPhase::Stopping, UltraplanPhase::Completed)\n61\t                | (UltraplanPhase::Stopping, UltraplanPhase::Failed)\n62\t        )\n63\t    }\n64\t\n65\t    async fn transition_keyword_guarded(&self) -> bool {\n66\t        let state = self.state.lock().await;\n67\t        if state.launching {\n68\t            return true;\n69\t        }\n70\t\n71\t        state.active.as_ref().is_some_and(|active| {\n72\t            matches!(\n73\t                active.phase,\n74\t                UltraplanPhase::Launching | UltraplanPhase::Polling\n75\t            )\n76\t        })\n77\t    }\n78\t\n79\t    async fn set_launching(&self, launching: bool) {\n80\t        let mut state = self.state.lock().await;\n81\t        state.launching = launching;\n82\t    }\n83\t\n84\t    async fn set_active(&self, active: Option<ActiveSession>) {\n85\t        let mut state = self.state.lock().await;\n86\t        state.active = active;\n87\t        state.revision = state.revision.wrapping_add(1);\n88\t    }\n89\t\n90\t    async fn apply_launch_guard(&self, policy: UltraplanPolicy) -> Result<(), UltraplanError> {\n91\t        let mut state = self.state.lock().await;\n92\t        if !policy.single_active_session {\n93\t            state.launching = true;\n94\t            return Ok(());\n95\t        }\n96\t\n97\t        if state.launching {\n98\t            return Err(UltraplanError::AlreadyActive);\n99\t        }\n100\t        if let Some(active) = state.active.as_ref()\n101\t            && !Self::is_terminal(active.phase)\n102\t        {\n103\t            return Err(UltraplanError::AlreadyActive);\n104\t        }\n105\t\n106\t        state.launching = true;\n107\t        Ok(())\n108\t    }\n109\t\n110\t    async fn try_archive_on_failure(&self, session_id: &str) -> Result<(), UltraplanError>\n111\t    where\n112\t        R: UltraplanRuntime,\n113\t    {\n114\t        self.runtime\n115\t            .archive_session(session_id)\n116\t            .await\n117\t            .map_err(|_| UltraplanError::ArchiveFailed)\n118\t    }\n119\t\n120\t    fn is_ultraplan_keyword(raw: &str) -> bool {\n121\t        let lowered = raw.trim().to_ascii_lowercase();\n122\t        lowered == \"ultraplan\" || lowered == \"/ultraplan\" || lowered.contains(\"ultraplan\")\n123\t    }\n124\t\n125\t    pub async fn route_keyword_launch(\n126\t        &self,\n127\t        raw_input: &str,\n128\t        prompt: &str,\n129\t        policy: UltraplanPolicy,\n130\t    ) -> Result<Option<UltraplanSession>, UltraplanError>\n131\t    where\n132\t        R: UltraplanRuntime + Send + Sync,\n133\t    {\n134\t        if !Self::is_ultraplan_keyword(raw_input) {\n135\t            return Ok(None);\n136\t        }\n137\t        if self.transition_keyword_guarded().await {\n138\t            return Err(UltraplanError::AlreadyActive);\n139\t        }\n140\t\n141\t        self.launch(prompt, policy).await.map(Some)\n142\t    }\n143\t\n144\t    pub async fn active_marker(&self) -> Option<(String, UltraplanPhase)> {\n145\t        let state = self.state.lock().await;\n146\t        state\n147\t            .active\n148\t            .as_ref()\n149\t            .map(|active| (active.session_id.clone(), active.phase))\n150\t    }\n151\t}\n152\t\n153\t#[async_trait]\n154\timpl<R> UltraplanService for DefaultUltraplanService<R>\n155\twhere\n156\t    R: UltraplanRuntime + Send + Sync,\n157\t{\n158\t    async fn launch(\n159\t        &self,\n160\t        prompt: &str,\n161\t        policy: UltraplanPolicy,\n162\t    ) -> Result<UltraplanSession, UltraplanError> {\n163\t        if !self.policy_enabled {\n164\t            return Err(UltraplanError::DisabledByPolicy);\n165\t        }\n166\t\n167\t        self.apply_launch_guard(policy).await?;\n168\t\n169\t        let session_id = match self.runtime.launch_session(prompt).await {\n170\t            Ok(session_id) => session_id,\n171\t            Err(_) => {\n172\t                self.set_launching(false).await;\n173\t                return Err(UltraplanError::LaunchFailed);\n174\t            }\n175\t        };\n176\t\n177\t        let launch_result = self.runtime.poll_phase(&session_id).await;\n178\t        match launch_result {\n179\t            Ok(next_phase) if Self::transition_allowed(UltraplanPhase::Launching, next_phase) => {\n180\t                self.set_launching(false).await;\n181\t                if next_phase == UltraplanPhase::Failed {\n182\t                    self.set_active(None).await;\n183\t                    let _ = self.try_archive_on_failure(&session_id).await;\n184\t                    return Err(UltraplanError::LaunchFailed);\n185\t                }\n186\t                self.set_active(Some(ActiveSession {\n187\t                    session_id: session_id.clone(),\n188\t                    phase: next_phase,\n189\t                }))\n190\t                .await;\n191\t                Ok(UltraplanSession {\n192\t                    session_id,\n193\t                    phase: next_phase,\n194\t                })\n195\t            }\n196\t            Ok(_) | Err(_) => {\n197\t                self.set_launching(false).await;\n198\t                self.set_active(None).await;\n199\t                self.try_archive_on_failure(&session_id).await?;\n200\t                Err(UltraplanError::LaunchFailed)\n201\t            }\n202\t        }\n203\t    }\n204\t\n205\t    async fn poll(&self, session_id: &str) -> Result<UltraplanPhase, UltraplanError> {\n206\t        if !self.policy_enabled {\n207\t            return Err(UltraplanError::DisabledByPolicy);\n208\t        }\n209\t\n210\t        let (from_phase, revision) = {\n211\t            let state = self.state.lock().await;\n212\t            (\n213\t                state\n214\t                    .active\n215\t                    .as_ref()\n216\t                    .filter(|active| active.session_id == session_id)\n217\t                    .map_or(UltraplanPhase::Polling, |active| active.phase),\n218\t                state.revision,\n219\t            )\n220\t        };\n221\t\n222\t        let next_phase = self.runtime.poll_phase(session_id).await?;\n223\t        if !Self::transition_allowed(from_phase, next_phase) {\n224\t            return Err(UltraplanError::ApprovalFailed);\n225\t        }\n226\t\n227\t        let mut resolved_phase = next_phase;\n228\t        if next_phase == UltraplanPhase::Approved {\n229\t            resolved_phase = UltraplanPhase::Completed;\n230\t        }\n231\t\n232\t        if Self::is_terminal(resolved_phase) {\n233\t            self.set_active(None).await;\n234\t        } else {\n235\t            let mut state = self.state.lock().await;\n236\t            if state.revision == revision {\n237\t                state.active = Some(ActiveSession {\n238\t                    session_id: session_id.to_owned(),\n239\t                    phase: resolved_phase,\n240\t                });\n241\t                state.revision = state.revision.wrapping_add(1);\n242\t            }\n243\t        }\n244\t\n245\t        Ok(resolved_phase)\n246\t    }\n247\t\n248\t    async fn stop(&self, session_id: &str) -> Result<(), UltraplanError> {\n249\t        if !self.policy_enabled {\n250\t            return Err(UltraplanError::DisabledByPolicy);\n251\t        }\n252\t\n253\t        {\n254\t            let mut state = self.state.lock().await;\n255\t            state.launching = false;\n256\t            if state\n257\t                .active\n258\t                .as_ref()\n259\t                .is_some_and(|active| active.session_id == session_id)\n260\t            {\n261\t                state.active = None;\n262\t                state.revision = state.revision.wrapping_add(1);\n263\t            }\n264\t        }\n265\t\n266\t        self.runtime.stop_session(session_id).await\n267\t    }\n268\t\n269\t    async fn archive_orphan(&self, session_id: &str) -> Result<(), UltraplanError> {\n270\t        if !self.policy_enabled {\n271\t            return Err(UltraplanError::DisabledByPolicy);\n272\t        }\n273\t\n274\t        self.runtime\n275\t            .archive_session(session_id)\n276\t            .await\n277\t            .map_err(|_| UltraplanError::ArchiveFailed)\n278\t    }\n279\t}\n280\t\n281\t#[cfg(test)]\n282\tmod tests {\n283\t    use super::*;\n284\t    use std::{collections::VecDeque, sync::Arc};\n285\t    use tokio::sync::Notify;\n286\t\n287\t    #[derive(Default)]\n288\t    struct MockUltraplanRuntime {\n289\t        launch_results: Arc<Mutex<VecDeque<Result<String, UltraplanError>>>>,\n290\t        poll_results: Arc<Mutex<VecDeque<Result<UltraplanPhase, UltraplanError>>>>,\n291\t        stop_results: Arc<Mutex<VecDeque<Result<(), UltraplanError>>>>,\n292\t        archive_results: Arc<Mutex<VecDeque<Result<(), UltraplanError>>>>,\n293\t        archive_calls: Arc<Mutex<Vec<String>>>,\n294\t        stop_calls: Arc<Mutex<Vec<String>>>,\n295\t    }\n296\t\n297\t    impl MockUltraplanRuntime {\n298\t        fn with_poll(results: Vec<Result<UltraplanPhase, UltraplanError>>) -> Self {\n299\t            Self {\n300\t                poll_results: Arc::new(Mutex::new(results.into())),\n301\t                ..Self::default()\n302\t            }\n303\t        }\n304\t    }\n305\t\n306\t    #[async_trait]\n307\t    impl UltraplanRuntime for MockUltraplanRuntime {\n308\t        async fn launch_session(&self, _prompt: &str) -> Result<String, UltraplanError> {\n309\t            self.launch_results\n310\t                .lock()\n311\t                .await\n312\t                .pop_front()\n313\t                .expect(\"missing launch result\")\n314\t        }\n315\t\n316\t        async fn poll_phase(&self, _session_id: &str) -> Result<UltraplanPhase, UltraplanError> {\n317\t            self.poll_results\n318\t                .lock()\n319\t                .await\n320\t                .pop_front()\n321\t                .expect(\"missing poll result\")\n322\t        }\n323\t\n324\t        async fn stop_session(&self, session_id: &str) -> Result<(), UltraplanError> {\n325\t            self.stop_calls.lock().await.push(session_id.to_owned());\n326\t            self.stop_results.lock().await.pop_front().unwrap_or(Ok(()))\n327\t        }\n328\t\n329\t        async fn archive_session(&self, session_id: &str) -> Result<(), UltraplanError> {\n330\t            self.archive_calls.lock().await.push(session_id.to_owned());\n331\t            self.archive_results\n332\t                .lock()\n333\t                .await\n334\t                .pop_front()\n335\t                .unwrap_or(Ok(()))\n336\t        }\n337\t    }\n338\t\n339\t    fn policy() -> UltraplanPolicy {\n340\t        UltraplanPolicy {\n341\t            single_active_session: true,\n342\t        }\n343\t    }\n344\t\n345\t    #[test]\n346\t    fn transition_graph_matches_contract() {\n347\t        assert!(\n348\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n349\t                UltraplanPhase::Idle,\n350\t                UltraplanPhase::Launching\n351\t            )\n352\t        );\n353\t        assert!(\n354\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n355\t                UltraplanPhase::Launching,\n356\t                UltraplanPhase::Polling\n357\t            )\n358\t        );\n359\t        assert!(\n360\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n361\t                UltraplanPhase::Launching,\n362\t                UltraplanPhase::Failed\n363\t            )\n364\t        );\n365\t        assert!(\n366\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n367\t                UltraplanPhase::Polling,\n368\t                UltraplanPhase::AwaitingInput\n369\t            )\n370\t        );\n371\t        assert!(\n372\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n373\t                UltraplanPhase::Polling,\n374\t                UltraplanPhase::Approved\n375\t            )\n376\t        );\n377\t        assert!(\n378\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n379\t                UltraplanPhase::Polling,\n380\t                UltraplanPhase::Failed\n381\t            )\n382\t        );\n383\t        assert!(\n384\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n385\t                UltraplanPhase::Polling,\n386\t                UltraplanPhase::Stopping\n387\t            )\n388\t        );\n389\t        assert!(\n390\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n391\t                UltraplanPhase::AwaitingInput,\n392\t                UltraplanPhase::Polling\n393\t            )\n394\t        );\n395\t        assert!(\n396\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n397\t                UltraplanPhase::AwaitingInput,\n398\t                UltraplanPhase::Stopping\n399\t            )\n400\t        );\n401\t        assert!(\n402\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n403\t                UltraplanPhase::Approved,\n404\t                UltraplanPhase::Completed\n405\t            )\n406\t        );\n407\t        assert!(\n408\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n409\t                UltraplanPhase::Stopping,\n410\t                UltraplanPhase::Completed\n411\t            )\n412\t        );