{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01588XPJMutjshU3ap3YtrC5","type":"tool_result","content":"1\tuse crate::spec_contracts::{\n2\t    UltraplanError, UltraplanPhase, UltraplanPolicy, UltraplanService, UltraplanSession,\n3\t};\n4\tuse async_trait::async_trait;\n5\tuse tokio::sync::Mutex;\n6\t\n7\t#[async_trait]\n8\tpub trait UltraplanRuntime: Send + Sync {\n9\t    async fn launch_session(&self, prompt: &str) -> Result<String, UltraplanError>;\n10\t    async fn poll_phase(&self, session_id: &str) -> Result<UltraplanPhase, UltraplanError>;\n11\t    async fn stop_session(&self, session_id: &str) -> Result<(), UltraplanError>;\n12\t    async fn archive_session(&self, session_id: &str) -> Result<(), UltraplanError>;\n13\t}\n14\t\n15\t#[derive(Debug, Clone)]\n16\tstruct ActiveSession {\n17\t    session_id: String,\n18\t    phase: UltraplanPhase,\n19\t}\n20\t\n21\t#[derive(Debug, Default)]\n22\tstruct LocalState {\n23\t    launching: bool,\n24\t    active: Option<ActiveSession>,\n25\t    revision: u64,\n26\t}\n27\t\n28\tpub struct DefaultUltraplanService<R> {\n29\t    runtime: R,\n30\t    policy_enabled: bool,\n31\t    state: Mutex<LocalState>,\n32\t}\n33\t\n34\timpl<R> DefaultUltraplanService<R> {\n35\t    pub fn new(runtime: R, policy_enabled: bool) -> Self {\n36\t        Self {\n37\t            runtime,\n38\t            policy_enabled,\n39\t            state: Mutex::new(LocalState::default()),\n40\t        }\n41\t    }\n42\t\n43\t    fn is_terminal(phase: UltraplanPhase) -> bool {\n44\t        matches!(phase, UltraplanPhase::Completed | UltraplanPhase::Failed)\n45\t    }\n46\t\n47\t    fn transition_allowed(from: UltraplanPhase, to: UltraplanPhase) -> bool {\n48\t        matches!(\n49\t            (from, to),\n50\t            (UltraplanPhase::Idle, UltraplanPhase::Launching)\n51\t                | (UltraplanPhase::Launching, UltraplanPhase::Polling)\n52\t                | (UltraplanPhase::Launching, UltraplanPhase::Failed)\n53\t                | (UltraplanPhase::Polling, UltraplanPhase::AwaitingInput)\n54\t                | (UltraplanPhase::Polling, UltraplanPhase::Approved)\n55\t                | (UltraplanPhase::Polling, UltraplanPhase::Failed)\n56\t                | (UltraplanPhase::Polling, UltraplanPhase::Stopping)\n57\t                | (UltraplanPhase::AwaitingInput, UltraplanPhase::Polling)\n58\t                | (UltraplanPhase::AwaitingInput, UltraplanPhase::Stopping)\n59\t                | (UltraplanPhase::Approved, UltraplanPhase::Completed)\n60\t                | (UltraplanPhase::Stopping, UltraplanPhase::Completed)\n61\t                | (UltraplanPhase::Stopping, UltraplanPhase::Failed)\n62\t        )\n63\t    }\n64\t\n65\t    async fn transition_keyword_guarded(&self) -> bool {\n66\t        let state = self.state.lock().await;\n67\t        if state.launching {\n68\t            return true;\n69\t        }\n70\t\n71\t        state.active.as_ref().is_some_and(|active| {\n72\t            matches!(\n73\t                active.phase,\n74\t                UltraplanPhase::Launching | UltraplanPhase::Polling\n75\t            )\n76\t        })\n77\t    }\n78\t\n79\t    async fn set_launching(&self, launching: bool) {\n80\t        let mut state = self.state.lock().await;\n81\t        state.launching = launching;\n82\t    }\n83\t\n84\t    async fn set_active(&self, active: Option<ActiveSession>) {\n85\t        let mut state = self.state.lock().await;\n86\t        state.active = active;\n87\t        state.revision = state.revision.wrapping_add(1);\n88\t    }\n89\t\n90\t    async fn apply_launch_guard(&self, policy: UltraplanPolicy) -> Result<(), UltraplanError> {\n91\t        let mut state = self.state.lock().await;\n92\t        if !policy.single_active_session {\n93\t            state.launching = true;\n94\t            return Ok(());\n95\t        }\n96\t\n97\t        if state.launching {\n98\t            return Err(UltraplanError::AlreadyActive);\n99\t        }\n100\t        if let Some(active) = state.active.as_ref()\n101\t            && !Self::is_terminal(active.phase)\n102\t        {\n103\t            return Err(UltraplanError::AlreadyActive);\n104\t        }\n105\t\n106\t        state.launching = true;\n107\t        Ok(())\n108\t    }\n109\t\n110\t    async fn try_archive_on_failure(&self, session_id: &str) -> Result<(), UltraplanError>\n111\t    where\n112\t        R: UltraplanRuntime,\n113\t    {\n114\t        self.runtime\n115\t            .archive_session(session_id)\n116\t            .await\n117\t            .map_err(|_| UltraplanError::ArchiveFailed)\n118\t    }\n119\t\n120\t    fn is_ultraplan_keyword(raw: &str) -> bool {\n121\t        let lowered = raw.trim().to_ascii_lowercase();\n122\t        lowered == \"ultraplan\" || lowered == \"/ultraplan\" || lowered.contains(\"ultraplan\")\n123\t    }\n124\t\n125\t    pub async fn route_keyword_launch(\n126\t        &self,\n127\t        raw_input: &str,\n128\t        prompt: &str,\n129\t        policy: UltraplanPolicy,\n130\t    ) -> Result<Option<UltraplanSession>, UltraplanError>\n131\t    where\n132\t        R: UltraplanRuntime + Send + Sync,\n133\t    {\n134\t        if !Self::is_ultraplan_keyword(raw_input) {\n135\t            return Ok(None);\n136\t        }\n137\t        if self.transition_keyword_guarded().await {\n138\t            return Err(UltraplanError::AlreadyActive);\n139\t        }\n140\t\n141\t        self.launch(prompt, policy).await.map(Some)\n142\t    }\n143\t\n144\t    pub async fn active_marker(&self) -> Option<(String, UltraplanPhase)> {\n145\t        let state = self.state.lock().await;\n146\t        state\n147\t            .active\n148\t            .as_ref()\n149\t            .map(|active| (active.session_id.clone(), active.phase))\n150\t    }\n151\t}\n152\t\n153\t#[async_trait]\n154\timpl<R> UltraplanService for DefaultUltraplanService<R>\n155\twhere\n156\t    R: UltraplanRuntime + Send + Sync,\n157\t{\n158\t    async fn launch(\n159\t        &self,\n160\t        prompt: &str,\n161\t        policy: UltraplanPolicy,\n162\t    ) -> Result<UltraplanSession, UltraplanError> {\n163\t        if !self.policy_enabled {\n164\t            return Err(UltraplanError::DisabledByPolicy);\n165\t        }\n166\t\n167\t        self.apply_launch_guard(policy).await?;\n168\t\n169\t        let session_id = match self.runtime.launch_session(prompt).await {\n170\t            Ok(session_id) => session_id,\n171\t            Err(_) => {\n172\t                self.set_launching(false).await;\n173\t                return Err(UltraplanError::LaunchFailed);\n174\t            }\n175\t        };\n176\t\n177\t        let launch_result = self.runtime.poll_phase(&session_id).await;\n178\t        match launch_result {\n179\t            Ok(next_phase) if Self::transition_allowed(UltraplanPhase::Launching, next_phase) => {\n180\t                self.set_launching(false).await;\n181\t                if next_phase == UltraplanPhase::Failed {\n182\t                    self.set_active(None).await;\n183\t                    let _ = self.try_archive_on_failure(&session_id).await;\n184\t                    return Err(UltraplanError::LaunchFailed);\n185\t                }\n186\t                self.set_active(Some(ActiveSession {\n187\t                    session_id: session_id.clone(),\n188\t                    phase: next_phase,\n189\t                }))\n190\t                .await;\n191\t                Ok(UltraplanSession {\n192\t                    session_id,\n193\t                    phase: next_phase,\n194\t                })\n195\t            }\n196\t            Ok(_) | Err(_) => {\n197\t                self.set_launching(false).await;\n198\t                self.set_active(None).await;\n199\t                self.try_archive_on_failure(&session_id).await?;\n200\t                Err(UltraplanError::LaunchFailed)\n201\t            }\n202\t        }\n203\t    }\n204\t\n205\t    async fn poll(&self, session_id: &str) -> Result<UltraplanPhase, UltraplanError> {\n206\t        if !self.policy_enabled {\n207\t            return Err(UltraplanError::DisabledByPolicy);\n208\t        }\n209\t\n210\t        let (from_phase, revision) = {\n211\t            let state = self.state.lock().await;\n212\t            (\n213\t                state\n214\t                    .active\n215\t                    .as_ref()\n216\t                    .filter(|active| active.session_id == session_id)\n217\t                    .map_or(UltraplanPhase::Polling, |active| active.phase),\n218\t                state.revision,\n219\t            )\n220\t        };\n221\t\n222\t        let next_phase = self.runtime.poll_phase(session_id).await?;\n223\t        if !Self::transition_allowed(from_phase, next_phase) {\n224\t            return Err(UltraplanError::ApprovalFailed);\n225\t        }\n226\t\n227\t        let mut resolved_phase = next_phase;\n228\t        if next_phase == UltraplanPhase::Approved {\n229\t            resolved_phase = UltraplanPhase::Completed;\n230\t        }\n231\t\n232\t        if Self::is_terminal(resolved_phase) {\n233\t            self.set_active(None).await;\n234\t        } else {\n235\t            let mut state = self.state.lock().await;\n236\t            if state.revision == revision {\n237\t                state.active = Some(ActiveSession {\n238\t                    session_id: session_id.to_owned(),\n239\t                    phase: resolved_phase,\n240\t                });\n241\t                state.revision = state.revision.wrapping_add(1);\n242\t            }\n243\t        }\n244\t\n245\t        Ok(resolved_phase)\n246\t    }\n247\t\n248\t    async fn stop(&self, session_id: &str) -> Result<(), UltraplanError> {\n249\t        if !self.policy_enabled {\n250\t            return Err(UltraplanError::DisabledByPolicy);\n251\t        }\n252\t\n253\t        {\n254\t            let mut state = self.state.lock().await;\n255\t            state.launching = false;\n256\t            if state\n257\t                .active\n258\t                .as_ref()\n259\t                .is_some_and(|active| active.session_id == session_id)\n260\t            {\n261\t                state.active = None;\n262\t                state.revision = state.revision.wrapping_add(1);\n263\t            }\n264\t        }\n265\t\n266\t        self.runtime.stop_session(session_id).await\n267\t    }\n268\t\n269\t    async fn archive_orphan(&self, session_id: &str) -> Result<(), UltraplanError> {\n270\t        if !self.policy_enabled {\n271\t            return Err(UltraplanError::DisabledByPolicy);\n272\t        }\n273\t\n274\t        self.runtime\n275\t            .archive_session(session_id)\n276\t            .await\n277\t            .map_err(|_| UltraplanError::ArchiveFailed)\n278\t    }\n279\t}\n280\t\n281\t#[cfg(test)]\n282\tmod tests {\n283\t    use super::*;\n284\t    use std::{collections::VecDeque, sync::Arc};\n285\t    use tokio::sync::Notify;\n286\t\n287\t    #[derive(Default)]\n288\t    struct MockUltraplanRuntime {\n289\t        launch_results: Arc<Mutex<VecDeque<Result<String, UltraplanError>>>>,\n290\t        poll_results: Arc<Mutex<VecDeque<Result<UltraplanPhase, UltraplanError>>>>,\n291\t        stop_results: Arc<Mutex<VecDeque<Result<(), UltraplanError>>>>,\n292\t        archive_results: Arc<Mutex<VecDeque<Result<(), UltraplanError>>>>,\n293\t        archive_calls: Arc<Mutex<Vec<String>>>,\n294\t        stop_calls: Arc<Mutex<Vec<String>>>,\n295\t    }\n296\t\n297\t    impl MockUltraplanRuntime {\n298\t        fn with_poll(results: Vec<Result<UltraplanPhase, UltraplanError>>) -> Self {\n299\t            Self {\n300\t                poll_results: Arc::new(Mutex::new(results.into())),\n301\t                ..Self::default()\n302\t            }\n303\t        }\n304\t    }\n305\t\n306\t    #[async_trait]\n307\t    impl UltraplanRuntime for MockUltraplanRuntime {\n308\t        async fn launch_session(&self, _prompt: &str) -> Result<String, UltraplanError> {\n309\t            self.launch_results\n310\t                .lock()\n311\t                .await\n312\t                .pop_front()\n313\t                .expect(\"missing launch result\")\n314\t        }\n315\t\n316\t        async fn poll_phase(&self, _session_id: &str) -> Result<UltraplanPhase, UltraplanError> {\n317\t            self.poll_results\n318\t                .lock()\n319\t                .await\n320\t                .pop_front()\n321\t                .expect(\"missing poll result\")\n322\t        }\n323\t\n324\t        async fn stop_session(&self, session_id: &str) -> Result<(), UltraplanError> {\n325\t            self.stop_calls.lock().await.push(session_id.to_owned());\n326\t            self.stop_results.lock().await.pop_front().unwrap_or(Ok(()))\n327\t        }\n328\t\n329\t        async fn archive_session(&self, session_id: &str) -> Result<(), UltraplanError> {\n330\t            self.archive_calls.lock().await.push(session_id.to_owned());\n331\t            self.archive_results\n332\t                .lock()\n333\t                .await\n334\t                .pop_front()\n335\t                .unwrap_or(Ok(()))\n336\t        }\n337\t    }\n338\t\n339\t    fn policy() -> UltraplanPolicy {\n340\t        UltraplanPolicy {\n341\t            single_active_session: true,\n342\t        }\n343\t    }\n344\t\n345\t    #[test]\n346\t    fn transition_graph_matches_contract() {\n347\t        assert!(\n348\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n349\t                UltraplanPhase::Idle,\n350\t                UltraplanPhase::Launching\n351\t            )\n352\t        );\n353\t        assert!(\n354\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n355\t                UltraplanPhase::Launching,\n356\t                UltraplanPhase::Polling\n357\t            )\n358\t        );\n359\t        assert!(\n360\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n361\t                UltraplanPhase::Launching,\n362\t                UltraplanPhase::Failed\n363\t            )\n364\t        );\n365\t        assert!(\n366\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n367\t                UltraplanPhase::Polling,\n368\t                UltraplanPhase::AwaitingInput\n369\t            )\n370\t        );\n371\t        assert!(\n372\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n373\t                UltraplanPhase::Polling,\n374\t                UltraplanPhase::Approved\n375\t            )\n376\t        );\n377\t        assert!(\n378\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n379\t                UltraplanPhase::Polling,\n380\t                UltraplanPhase::Failed\n381\t            )\n382\t        );\n383\t        assert!(\n384\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n385\t                UltraplanPhase::Polling,\n386\t                UltraplanPhase::Stopping\n387\t            )\n388\t        );\n389\t        assert!(\n390\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n391\t                UltraplanPhase::AwaitingInput,\n392\t                UltraplanPhase::Polling\n393\t            )\n394\t        );\n395\t        assert!(\n396\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n397\t                UltraplanPhase::AwaitingInput,\n398\t                UltraplanPhase::Stopping\n399\t            )\n400\t        );\n401\t        assert!(\n402\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n403\t                UltraplanPhase::Approved,\n404\t                UltraplanPhase::Completed\n405\t            )\n406\t        );\n407\t        assert!(\n408\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n409\t                UltraplanPhase::Stopping,\n410\t                UltraplanPhase::Completed\n411\t            )\n412\t        );\n413\t        assert!(\n414\t            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n415\t                UltraplanPhase::Stopping,\n416\t                UltraplanPhase::Failed\n417\t            )\n418\t        );\n419\t        assert!(\n420\t            !DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n421\t                UltraplanPhase::Completed,\n422\t                UltraplanPhase::Polling\n423\t            )\n424\t        );\n425\t        assert!(\n426\t            !DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n427\t                UltraplanPhase::Failed,\n428\t                UltraplanPhase::Polling\n429\t            )\n430\t        );\n431\t    }\n432\t\n433\t    #[tokio::test]\n434\t    async fn launch_returns_already_active_when_launching_or_polling() {\n435\t        let runtime = MockUltraplanRuntime {\n436\t            launch_results: Arc::new(Mutex::new(vec![Ok(\"s-1\".to_owned())].into())),\n437\t            poll_results: Arc::new(Mutex::new(vec![Ok(UltraplanPhase::Polling)].into())),\n438\t            ..MockUltraplanRuntime::default()\n439\t        };\n440\t        let service = DefaultUltraplanService::new(runtime, true);\n441\t\n442\t        let first = service.launch(\"prompt\", policy()).await;\n443\t        assert!(first.is_ok());\n444\t\n445\t        let second = service.launch(\"prompt\", policy()).await;\n446\t        assert!(matches!(second, Err(UltraplanError::AlreadyActive)));\n447\t    }\n448\t\n449\t    #[tokio::test]\n450\t    async fn concurrent_launch_is_guarded() {\n451\t        let runtime = MockUltraplanRuntime {\n452\t            launch_results: Arc::new(Mutex::new(\n453\t                vec![Ok(\"s-1\".to_owned()), Ok(\"s-2\".to_owned())].into(),\n454\t            )),\n455\t            poll_results: Arc::new(Mutex::new(vec![Ok(UltraplanPhase::Polling)].into())),\n456\t            ..MockUltraplanRuntime::default()\n457\t        };\n458\t        let service = Arc::new(DefaultUltraplanService::new(runtime, true));\n459\t\n460\t        let left = service.launch(\"prompt\", policy());\n461\t        let right = service.launch(\"prompt\", policy());\n462\t        let (a, b) = tokio::join!(left, right);\n463\t\n464\t        assert!(\n465\t            matches!(a, Ok(_)) && matches!(b, Err(UltraplanError::AlreadyActive))\n466\t                || matches!(b, Ok(_)) && matches!(a, Err(UltraplanError::AlreadyActive))\n467\t        );\n468\t    }\n469\t\n470\t    #[tokio::test]\n471\t    async fn keyword_auto_route_respects_launching_and_polling_guard() {\n472\t        let runtime = MockUltraplanRuntime {\n473\t            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_1\".to_owned())].into())),\n474\t            poll_results: Arc::new(Mutex::new(vec![Ok(UltraplanPhase::Polling)].into())),\n475\t            ..MockUltraplanRuntime::default()\n476\t        };\n477\t        let service = DefaultUltraplanService::new(runtime, true);\n478\t        let _ = service\n479\t            .launch(\"boot\", policy())\n480\t            .await\n481\t            .expect(\"launch succeeds\");\n482\t\n483\t        let routed = service\n484\t            .route_keyword_launch(\"please run ultraplan now\", \"second\", policy())\n485\t            .await;\n486\t\n487\t        assert!(matches!(routed, Err(UltraplanError::AlreadyActive)));\n488\t    }\n489\t\n490\t    #[tokio::test]\n491\t    async fn launch_failure_after_remote_creation_attempts_archive() {\n492\t        let runtime = MockUltraplanRuntime {\n493\t            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_123\".to_owned())].into())),\n494\t            poll_results: Arc::new(Mutex::new(\n495\t                vec![Err(UltraplanError::Transport(\"x\".into()))].into(),\n496\t            )),\n497\t            ..MockUltraplanRuntime::default()\n498\t        };\n499\t        let archive_calls = runtime.archive_calls.clone();\n500\t        let service = DefaultUltraplanService::new(runtime, true);\n501\t\n502\t        let result = service.launch(\"prompt\", policy()).await;\n503\t        assert!(matches!(result, Err(UltraplanError::LaunchFailed)));\n504\t\n505\t        let calls = archive_calls.lock().await.clone();\n506\t        assert_eq!(calls, vec![\"session_123\".to_owned()]);\n507\t    }\n508\t\n509\t    #[tokio::test]\n510\t    async fn stop_clears_active_marker_before_returning_error() {\n511\t        let runtime = MockUltraplanRuntime {\n512\t            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_1\".to_owned())].into())),\n513\t            poll_results: Arc::new(Mutex::new(vec![Ok(UltraplanPhase::Polling)].into())),\n514\t            stop_results: Arc::new(Mutex::new(\n515\t                vec![Err(UltraplanError::Transport(\"cannot stop\".to_owned()))].into(),\n516\t            )),\n517\t            ..MockUltraplanRuntime::default()\n518\t        };\n519\t        let service = DefaultUltraplanService::new(runtime, true);\n520\t        let _ = service\n521\t            .launch(\"prompt\", policy())\n522\t            .await\n523\t            .expect(\"launch succeeds\");\n524\t\n525\t        let stop_result = service.stop(\"session_1\").await;\n526\t        assert!(matches!(stop_result, Err(UltraplanError::Transport(_))));\n527\t        assert!(service.active_marker().await.is_none());\n528\t    }\n529\t\n530\t    #[tokio::test]\n531\t    async fn poll_handles_transitions_and_approved_to_completed() {\n532\t        let runtime = MockUltraplanRuntime {\n533\t            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_1\".to_owned())].into())),\n534\t            poll_results: Arc::new(Mutex::new(\n535\t                vec![\n536\t                    Ok(UltraplanPhase::Polling),\n537\t                    Ok(UltraplanPhase::AwaitingInput),\n538\t                    Ok(UltraplanPhase::Polling),\n539\t                    Ok(UltraplanPhase::Stopping),\n540\t                    Ok(UltraplanPhase::Completed),\n541\t                ]\n542\t                .into(),\n543\t            )),\n544\t            ..MockUltraplanRuntime::default()\n545\t        };\n546\t        let service = DefaultUltraplanService::new(runtime, true);\n547\t\n548\t        let _ = service\n549\t            .launch(\"prompt\", policy())\n550\t            .await\n551\t            .expect(\"launch succeeds\");\n552\t        assert_eq!(\n553\t            service.poll(\"session_1\").await.expect(\"awaiting input\"),\n554\t            UltraplanPhase::AwaitingInput\n555\t        );\n556\t        assert_eq!(\n557\t            service.poll(\"session_1\").await.expect(\"back to polling\"),\n558\t            UltraplanPhase::Polling\n559\t        );\n560\t        assert_eq!(\n561\t            service.poll(\"session_1\").await.expect(\"stopping\"),\n562\t            UltraplanPhase::Stopping\n563\t        );\n564\t        assert_eq!(\n565\t            service.poll(\"session_1\").await.expect(\"completed\"),\n566\t            UltraplanPhase::Completed\n567\t        );\n568\t        assert!(service.active_marker().await.is_none());\n569\t    }\n570\t\n571\t    #[tokio::test]\n572\t    async fn poll_maps_each_terminal_and_error_path() {\n573\t        let runtime = MockUltraplanRuntime::with_poll(vec![Err(UltraplanError::PollTimeout)]);\n574\t        let service = DefaultUltraplanService::new(runtime, true);\n575\t        let timeout = service.poll(\"session_1\").await;\n576\t        assert!(matches!(timeout, Err(UltraplanError::PollTimeout)));\n577\t    }\n578\t\n579\t    #[tokio::test]\n580\t    async fn can_emit_each_error_variant() {\n581\t        let disabled = DefaultUltraplanService::new(MockUltraplanRuntime::default(), false)\n582\t            .launch(\"prompt\", policy())\n583\t            .await;\n584\t        assert!(matches!(disabled, Err(UltraplanError::DisabledByPolicy)));\n585\t\n586\t        let already_runtime = MockUltraplanRuntime {\n587\t            launch_results: Arc::new(Mutex::new(vec![Ok(\"s-1\".to_owned())].into())),\n588\t            poll_results: Arc::new(Mutex::new(vec![Ok(UltraplanPhase::Polling)].into())),\n589\t            ..MockUltraplanRuntime::default()\n590\t        };\n591\t        let already_service = DefaultUltraplanService::new(already_runtime, true);\n592\t        let _ = already_service\n593\t            .launch(\"prompt\", policy())\n594\t            .await\n595\t            .expect(\"first launch succeeds\");\n596\t        let already = already_service.launch(\"prompt\", policy()).await;\n597\t        assert!(matches!(already, Err(UltraplanError::AlreadyActive)));\n598\t\n599\t        let launch_failed_runtime = MockUltraplanRuntime {\n600\t            launch_results: Arc::new(Mutex::new(\n601\t                vec![Err(UltraplanError::Transport(\"x\".into()))].into(),\n602\t            )),\n603\t            ..MockUltraplanRuntime::default()\n604\t        };\n605\t        let launch_failed = DefaultUltraplanService::new(launch_failed_runtime, true)\n606\t            .launch(\"prompt\", policy())\n607\t            .await;\n608\t        assert!(matches!(launch_failed, Err(UltraplanError::LaunchFailed)));\n609\t\n610\t        let poll_timeout_runtime =\n611\t            MockUltraplanRuntime::with_poll(vec![Err(UltraplanError::PollTimeout)]);\n612\t        let poll_timeout = DefaultUltraplanService::new(poll_timeout_runtime, true)\n613\t            .poll(\"session\")\n614\t            .await;\n615\t        assert!(matches!(poll_timeout, Err(UltraplanError::PollTimeout)));\n616\t\n617\t        let approval_failed_runtime = MockUltraplanRuntime {\n618\t            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_1\".to_owned())].into())),\n619\t            poll_results: Arc::new(Mutex::new(\n620\t                vec![\n621\t                    Ok(UltraplanPhase::Polling),\n622\t                    Ok(UltraplanPhase::AwaitingInput),\n623\t                    Ok(UltraplanPhase::Failed),\n624\t                ]\n625\t                .into(),\n626\t            )),\n627\t            ..MockUltraplanRuntime::default()\n628\t        };\n629\t        let approval_failed_service = DefaultUltraplanService::new(approval_failed_runtime, true);\n630\t        let _ = approval_failed_service\n631\t            .launch(\"prompt\", policy())\n632\t            .await\n633\t            .expect(\"launch succeeds\");\n634\t        let _ = approval_failed_service\n635\t            .poll(\"session_1\")\n636\t            .await\n637\t            .expect(\"awaiting input\");\n638\t        let approval_failed = approval_failed_service.poll(\"session_1\").await;\n639\t        assert!(matches!(\n640\t            approval_failed,\n641\t            Err(UltraplanError::ApprovalFailed)\n642\t        ));\n643\t\n644\t        let archive_failed_runtime = MockUltraplanRuntime {\n645\t            archive_results: Arc::new(Mutex::new(\n646\t                vec![Err(UltraplanError::Transport(\"x\".into()))].into(),\n647\t            )),\n648\t            ..MockUltraplanRuntime::default()\n649\t        };\n650\t        let archive_failed = DefaultUltraplanService::new(archive_failed_runtime, true)\n651\t            .archive_orphan(\"session_2\")\n652\t            .await;\n653\t        assert!(matches!(archive_failed, Err(UltraplanError::ArchiveFailed)));\n654\t\n655\t        let transport_runtime = MockUltraplanRuntime {\n656\t            stop_results: Arc::new(Mutex::new(\n657\t                vec![Err(UltraplanError::Transport(\"stop failed\".to_owned()))].into(),\n658\t            )),\n659\t            ..MockUltraplanRuntime::default()\n660\t        };\n661\t        let transport = DefaultUltraplanService::new(transport_runtime, true)\n662\t            .stop(\"session_3\")\n663\t            .await;\n664\t        assert!(matches!(transport, Err(UltraplanError::Transport(_))));\n665\t    }\n666\t\n667\t    #[tokio::test]\n668\t    async fn archive_failure_during_launch_failure_surfaces_archive_failed() {\n669\t        let runtime = MockUltraplanRuntime {\n670\t            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_123\".to_owned())].into())),\n671\t            poll_results: Arc::new(Mutex::new(\n672\t                vec![Err(UltraplanError::Transport(\"x\".into()))].into(),\n673\t            )),\n674\t            archive_results: Arc::new(Mutex::new(\n675\t                vec![Err(UltraplanError::Transport(\"bad\".into()))].into(),\n676\t            )),\n677\t            ..MockUltraplanRuntime::default()\n678\t        };\n679\t        let service = DefaultUltraplanService::new(runtime, true);\n680\t\n681\t        let result = service.launch(\"prompt\", policy()).await;\n682\t        assert!(matches!(result, Err(UltraplanError::ArchiveFailed)));\n683\t    }\n684\t\n685\t    #[tokio::test]\n686\t    async fn route_keyword_non_ultraplan_passthroughs_without_launch() {\n687\t        let runtime = MockUltraplanRuntime::default();\n688\t        let service = DefaultUltraplanService::new(runtime, true);\n689\t\n690\t        let routed = service\n691\t            .route_keyword_launch(\"hello world\", \"prompt\", policy())\n692\t            .await\n693\t            .expect(\"routing succeeds\");\n694\t        assert!(routed.is_none());\n695\t    }\n696\t\n697\t    #[tokio::test]\n698\t    async fn concurrent_stop_and_poll_does_not_restore_active_marker() {\n699\t        struct RaceRuntime {\n700\t            poll_release: Arc<Notify>,\n701\t            poll_calls: Arc<Mutex<u8>>,\n702\t        }\n703\t\n704\t        #[async_trait]\n705\t        impl UltraplanRuntime for RaceRuntime {\n706\t            async fn launch_session(&self, _prompt: &str) -> Result<String, UltraplanError> {\n707\t                Ok(\"session-race\".to_string())\n708\t            }\n709\t\n710\t            async fn poll_phase(\n711\t                &self,\n712\t                _session_id: &str,\n713\t            ) -> Result<UltraplanPhase, UltraplanError> {\n714\t                let mut calls = self.poll_calls.lock().await;\n715\t                *calls += 1;\n716\t                let call = *calls;\n717\t                drop(calls);\n718\t\n719\t                if call == 1 {\n720\t                    return Ok(UltraplanPhase::Polling);\n721\t                }\n722\t\n723\t                self.poll_release.notified().await;\n724\t                Ok(UltraplanPhase::AwaitingInput)\n725\t            }\n726\t\n727\t            async fn stop_session(&self, _session_id: &str) -> Result<(), UltraplanError> {\n728\t                self.poll_release.notify_waiters();\n729\t                Ok(())\n730\t            }\n731\t\n732\t            async fn archive_session(&self, _session_id: &str) -> Result<(), UltraplanError> {\n733\t                Ok(())\n734\t            }\n735\t        }\n736\t\n737\t        let runtime = RaceRuntime {\n738\t            poll_release: Arc::new(Notify::new()),\n739\t            poll_calls: Arc::new(Mutex::new(0)),\n740\t        };\n741\t        let service = Arc::new(DefaultUltraplanService::new(runtime, true));\n742\t        service\n743\t            .launch(\"prompt\", policy())\n744\t            .await\n745\t            .expect(\"launch succeeds\");\n746\t\n747\t        let poll = {\n748\t            let service = Arc::clone(&service);\n749\t            tokio::spawn(async move { service.poll(\"session-race\").await })\n750\t        };\n751\t        tokio::task::yield_now().await;\n752\t        let stop = {\n753\t            let service = Arc::clone(&service);\n754\t            tokio::spawn(async move { service.stop(\"session-race\").await })\n755\t        };\n756\t\n757\t        let poll_result = poll.await.expect(\"poll task join\");\n758\t        let stop_result = stop.await.expect(\"stop task join\");\n759\t\n760\t        assert_eq!(\n761\t            poll_result.expect(\"poll result\"),\n762\t            UltraplanPhase::AwaitingInput\n763\t        );\n764\t        stop_result.expect(\"stop result\");\n765\t        assert!(\n766\t            service.active_marker().await.is_none(),\n767\t            \"active marker must remain cleared after stop\"\n768\t        );\n769\t    }\n770\t}\n771\t"}]},"parent_tool_use_id":null,"session_id":"c8641186-7fb9-40c9-80e2-66e2f0b1f59f","uuid":"80d276e9-a316-42a5-8708-a57b9eb1acf3","timestamp":"2026-04-02T14:43:50.792Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/application/src/ultraplan_service.rs","content":"use crate::spec_contracts::{\n    UltraplanError, UltraplanPhase, UltraplanPolicy, UltraplanService, UltraplanSession,\n};\nuse async_trait::async_trait;\nuse tokio::sync::Mutex;\n\n#[async_trait]\npub trait UltraplanRuntime: Send + Sync {\n    async fn launch_session(&self, prompt: &str) -> Result<String, UltraplanError>;\n    async fn poll_phase(&self, session_id: &str) -> Result<UltraplanPhase, UltraplanError>;\n    async fn stop_session(&self, session_id: &str) -> Result<(), UltraplanError>;\n    async fn archive_session(&self, session_id: &str) -> Result<(), UltraplanError>;\n}\n\n#[derive(Debug, Clone)]\nstruct ActiveSession {\n    session_id: String,\n    phase: UltraplanPhase,\n}\n\n#[derive(Debug, Default)]\nstruct LocalState {\n    launching: bool,\n    active: Option<ActiveSession>,\n    revision: u64,\n}\n\npub struct DefaultUltraplanService<R> {\n    runtime: R,\n    policy_enabled: bool,\n    state: Mutex<LocalState>,\n}\n\nimpl<R> DefaultUltraplanService<R> {\n    pub fn new(runtime: R, policy_enabled: bool) -> Self {\n        Self {\n            runtime,\n            policy_enabled,\n            state: Mutex::new(LocalState::default()),\n        }\n    }\n\n    fn is_terminal(phase: UltraplanPhase) -> bool {\n        matches!(phase, UltraplanPhase::Completed | UltraplanPhase::Failed)\n    }\n\n    fn transition_allowed(from: UltraplanPhase, to: UltraplanPhase) -> bool {\n        matches!(\n            (from, to),\n            (UltraplanPhase::Idle, UltraplanPhase::Launching)\n                | (UltraplanPhase::Launching, UltraplanPhase::Polling)\n                | (UltraplanPhase::Launching, UltraplanPhase::Failed)\n                | (UltraplanPhase::Polling, UltraplanPhase::AwaitingInput)\n                | (UltraplanPhase::Polling, UltraplanPhase::Approved)\n                | (UltraplanPhase::Polling, UltraplanPhase::Failed)\n                | (UltraplanPhase::Polling, UltraplanPhase::Stopping)\n                | (UltraplanPhase::AwaitingInput, UltraplanPhase::Polling)\n                | (UltraplanPhase::AwaitingInput, UltraplanPhase::Stopping)\n                | (UltraplanPhase::Approved, UltraplanPhase::Completed)\n                | (UltraplanPhase::Stopping, UltraplanPhase::Completed)\n                | (UltraplanPhase::Stopping, UltraplanPhase::Failed)\n        )\n    }\n\n    async fn transition_keyword_guarded(&self) -> bool {\n        let state = self.state.lock().await;\n        if state.launching {\n            return true;\n        }\n\n        state.active.as_ref().is_some_and(|active| {\n            matches!(\n                active.phase,\n                UltraplanPhase::Launching | UltraplanPhase::Polling\n            )\n        })\n    }\n\n    async fn set_launching(&self, launching: bool) {\n        let mut state = self.state.lock().await;\n        state.launching = launching;\n    }\n\n    async fn set_active(&self, active: Option<ActiveSession>) {\n        let mut state = self.state.lock().await;\n        state.active = active;\n        state.revision = state.revision.wrapping_add(1);\n    }\n\n    async fn apply_launch_guard(&self, policy: UltraplanPolicy) -> Result<(), UltraplanError> {\n        let mut state = self.state.lock().await;\n        if !policy.single_active_session {\n            state.launching = true;\n            return Ok(());\n        }\n\n        if state.launching {\n            return Err(UltraplanError::AlreadyActive);\n        }\n        if let Some(active) = state.active.as_ref()\n            && !Self::is_terminal(active.phase)\n        {\n            return Err(UltraplanError::AlreadyActive);\n        }\n\n        state.launching = true;\n        Ok(())\n    }\n\n    async fn try_archive_on_failure(&self, session_id: &str) -> Result<(), UltraplanError>\n    where\n        R: UltraplanRuntime,\n    {\n        self.runtime\n            .archive_session(session_id)\n            .await\n            .map_err(|_| UltraplanError::ArchiveFailed)\n    }\n\n    fn is_ultraplan_keyword(raw: &str) -> bool {\n        let lowered = raw.trim().to_ascii_lowercase();\n        lowered == \"ultraplan\" || lowered == \"/ultraplan\" || lowered.contains(\"ultraplan\")\n    }\n\n    pub async fn route_keyword_launch(\n        &self,\n        raw_input: &str,\n        prompt: &str,\n        policy: UltraplanPolicy,\n    ) -> Result<Option<UltraplanSession>, UltraplanError>\n    where\n        R: UltraplanRuntime + Send + Sync,\n    {\n        if !Self::is_ultraplan_keyword(raw_input) {\n            return Ok(None);\n        }\n        if self.transition_keyword_guarded().await {\n            return Err(UltraplanError::AlreadyActive);\n        }\n\n        self.launch(prompt, policy).await.map(Some)\n    }\n\n    pub async fn active_marker(&self) -> Option<(String, UltraplanPhase)> {\n        let state = self.state.lock().await;\n        state\n            .active\n            .as_ref()\n            .map(|active| (active.session_id.clone(), active.phase))\n    }\n}\n\n#[async_trait]\nimpl<R> UltraplanService for DefaultUltraplanService<R>\nwhere\n    R: UltraplanRuntime + Send + Sync,\n{\n    async fn launch(\n        &self,\n        prompt: &str,\n        policy: UltraplanPolicy,\n    ) -> Result<UltraplanSession, UltraplanError> {\n        if !self.policy_enabled {\n            return Err(UltraplanError::DisabledByPolicy);\n        }\n\n        self.apply_launch_guard(policy).await?;\n\n        let session_id = match self.runtime.launch_session(prompt).await {\n            Ok(session_id) => session_id,\n            Err(_) => {\n                self.set_launching(false).await;\n                return Err(UltraplanError::LaunchFailed);\n            }\n        };\n\n        let launch_result = self.runtime.poll_phase(&session_id).await;\n        match launch_result {\n            Ok(next_phase) if Self::transition_allowed(UltraplanPhase::Launching, next_phase) => {\n                self.set_launching(false).await;\n                if next_phase == UltraplanPhase::Failed {\n                    self.set_active(None).await;\n                    let _ = self.try_archive_on_failure(&session_id).await;\n                    return Err(UltraplanError::LaunchFailed);\n                }\n                self.set_active(Some(ActiveSession {\n                    session_id: session_id.clone(),\n                    phase: next_phase,\n                }))\n                .await;\n                Ok(UltraplanSession {\n                    session_id,\n                    phase: next_phase,\n                })\n            }\n            Ok(_) | Err(_) => {\n                self.set_launching(false).await;\n                self.set_active(None).await;\n                self.try_archive_on_failure(&session_id).await?;\n                Err(UltraplanError::LaunchFailed)\n            }\n        }\n    }\n\n    async fn poll(&self, session_id: &str) -> Result<UltraplanPhase, UltraplanError> {\n        if !self.policy_enabled {\n            return Err(UltraplanError::DisabledByPolicy);\n        }\n\n        let (from_phase, revision) = {\n            let state = self.state.lock().await;\n            (\n                state\n                    .active\n                    .as_ref()\n                    .filter(|active| active.session_id == session_id)\n                    .map_or(UltraplanPhase::Polling, |active| active.phase),\n                state.revision,\n            )\n        };\n\n        let next_phase = self.runtime.poll_phase(session_id).await?;\n        if !Self::transition_allowed(from_phase, next_phase) {\n            return Err(UltraplanError::ApprovalFailed);\n        }\n\n        let mut resolved_phase = next_phase;\n        if next_phase == UltraplanPhase::Approved {\n            resolved_phase = UltraplanPhase::Completed;\n        }\n\n        if Self::is_terminal(resolved_phase) {\n            self.set_active(None).await;\n        } else {\n            let mut state = self.state.lock().await;\n            if state.revision == revision {\n                state.active = Some(ActiveSession {\n                    session_id: session_id.to_owned(),\n                    phase: resolved_phase,\n                });\n                state.revision = state.revision.wrapping_add(1);\n            }\n        }\n\n        Ok(resolved_phase)\n    }\n\n    async fn stop(&self, session_id: &str) -> Result<(), UltraplanError> {\n        if !self.policy_enabled {\n            return Err(UltraplanError::DisabledByPolicy);\n        }\n\n        {\n            let mut state = self.state.lock().await;\n            state.launching = false;\n            if state\n                .active\n                .as_ref()\n                .is_some_and(|active| active.session_id == session_id)\n            {\n                state.active = None;\n                state.revision = state.revision.wrapping_add(1);\n            }\n        }\n\n        self.runtime.stop_session(session_id).await\n    }\n\n    async fn archive_orphan(&self, session_id: &str) -> Result<(), UltraplanError> {\n        if !self.policy_enabled {\n            return Err(UltraplanError::DisabledByPolicy);\n        }\n\n        self.runtime\n            .archive_session(session_id)\n            .await\n            .map_err(|_| UltraplanError::ArchiveFailed)\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use std::{collections::VecDeque, sync::Arc};\n    use tokio::sync::Notify;\n\n    #[derive(Default)]\n    struct MockUltraplanRuntime {\n        launch_results: Arc<Mutex<VecDeque<Result<String, UltraplanError>>>>,\n        poll_results: Arc<Mutex<VecDeque<Result<UltraplanPhase, UltraplanError>>>>,\n        stop_results: Arc<Mutex<VecDeque<Result<(), UltraplanError>>>>,\n        archive_results: Arc<Mutex<VecDeque<Result<(), UltraplanError>>>>,\n        archive_calls: Arc<Mutex<Vec<String>>>,\n        stop_calls: Arc<Mutex<Vec<String>>>,\n    }\n\n    impl MockUltraplanRuntime {\n        fn with_poll(results: Vec<Result<UltraplanPhase, UltraplanError>>) -> Self {\n            Self {\n                poll_results: Arc::new(Mutex::new(results.into())),\n                ..Self::default()\n            }\n        }\n    }\n\n    #[async_trait]\n    impl UltraplanRuntime for MockUltraplanRuntime {\n        async fn launch_session(&self, _prompt: &str) -> Result<String, UltraplanError> {\n            self.launch_results\n                .lock()\n                .await\n                .pop_front()\n                .expect(\"missing launch result\")\n        }\n\n        async fn poll_phase(&self, _session_id: &str) -> Result<UltraplanPhase, UltraplanError> {\n            self.poll_results\n                .lock()\n                .await\n                .pop_front()\n                .expect(\"missing poll result\")\n        }\n\n        async fn stop_session(&self, session_id: &str) -> Result<(), UltraplanError> {\n            self.stop_calls.lock().await.push(session_id.to_owned());\n            self.stop_results.lock().await.pop_front().unwrap_or(Ok(()))\n        }\n\n        async fn archive_session(&self, session_id: &str) -> Result<(), UltraplanError> {\n            self.archive_calls.lock().await.push(session_id.to_owned());\n            self.archive_results\n                .lock()\n                .await\n                .pop_front()\n                .unwrap_or(Ok(()))\n        }\n    }\n\n    fn policy() -> UltraplanPolicy {\n        UltraplanPolicy {\n            single_active_session: true,\n        }\n    }\n\n    #[test]\n    fn transition_graph_matches_contract() {\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Idle,\n                UltraplanPhase::Launching\n            )\n        );\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Launching,\n                UltraplanPhase::Polling\n            )\n        );\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Launching,\n                UltraplanPhase::Failed\n            )\n        );\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Polling,\n                UltraplanPhase::AwaitingInput\n            )\n        );\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Polling,\n                UltraplanPhase::Approved\n            )\n        );\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Polling,\n                UltraplanPhase::Failed\n            )\n        );\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Polling,\n                UltraplanPhase::Stopping\n            )\n        );\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::AwaitingInput,\n                UltraplanPhase::Polling\n            )\n        );\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::AwaitingInput,\n                UltraplanPhase::Stopping\n            )\n        );\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Approved,\n                UltraplanPhase::Completed\n            )\n        );\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Stopping,\n                UltraplanPhase::Completed\n            )\n        );\n        assert!(\n            DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Stopping,\n                UltraplanPhase::Failed\n            )\n        );\n        assert!(\n            !DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Completed,\n                UltraplanPhase::Polling\n            )\n        );\n        assert!(\n            !DefaultUltraplanService::<MockUltraplanRuntime>::transition_allowed(\n                UltraplanPhase::Failed,\n                UltraplanPhase::Polling\n            )\n        );\n    }\n\n    #[tokio::test]\n    async fn launch_returns_already_active_when_launching_or_polling() {\n        let runtime = MockUltraplanRuntime {\n            launch_results: Arc::new(Mutex::new(vec![Ok(\"s-1\".to_owned())].into())),\n            poll_results: Arc::new(Mutex::new(vec![Ok(UltraplanPhase::Polling)].into())),\n            ..MockUltraplanRuntime::default()\n        };\n        let service = DefaultUltraplanService::new(runtime, true);\n\n        let first = service.launch(\"prompt\", policy()).await;\n        assert!(first.is_ok());\n\n        let second = service.launch(\"prompt\", policy()).await;\n        assert!(matches!(second, Err(UltraplanError::AlreadyActive)));\n    }\n\n    #[tokio::test]\n    async fn concurrent_launch_is_guarded() {\n        let runtime = MockUltraplanRuntime {\n            launch_results: Arc::new(Mutex::new(\n                vec![Ok(\"s-1\".to_owned()), Ok(\"s-2\".to_owned())].into(),\n            )),\n            poll_results: Arc::new(Mutex::new(vec![Ok(UltraplanPhase::Polling)].into())),\n            ..MockUltraplanRuntime::default()\n        };\n        let service = Arc::new(DefaultUltraplanService::new(runtime, true));\n\n        let left = service.launch(\"prompt\", policy());\n        let right = service.launch(\"prompt\", policy());\n        let (a, b) = tokio::join!(left, right);\n\n        assert!(\n            matches!(a, Ok(_)) && matches!(b, Err(UltraplanError::AlreadyActive))\n                || matches!(b, Ok(_)) && matches!(a, Err(UltraplanError::AlreadyActive))\n        );\n    }\n\n    #[tokio::test]\n    async fn keyword_auto_route_respects_launching_and_polling_guard() {\n        let runtime = MockUltraplanRuntime {\n            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_1\".to_owned())].into())),\n            poll_results: Arc::new(Mutex::new(vec![Ok(UltraplanPhase::Polling)].into())),\n            ..MockUltraplanRuntime::default()\n        };\n        let service = DefaultUltraplanService::new(runtime, true);\n        let _ = service\n            .launch(\"boot\", policy())\n            .await\n            .expect(\"launch succeeds\");\n\n        let routed = service\n            .route_keyword_launch(\"please run ultraplan now\", \"second\", policy())\n            .await;\n\n        assert!(matches!(routed, Err(UltraplanError::AlreadyActive)));\n    }\n\n    #[tokio::test]\n    async fn launch_failure_after_remote_creation_attempts_archive() {\n        let runtime = MockUltraplanRuntime {\n            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_123\".to_owned())].into())),\n            poll_results: Arc::new(Mutex::new(\n                vec![Err(UltraplanError::Transport(\"x\".into()))].into(),\n            )),\n            ..MockUltraplanRuntime::default()\n        };\n        let archive_calls = runtime.archive_calls.clone();\n        let service = DefaultUltraplanService::new(runtime, true);\n\n        let result = service.launch(\"prompt\", policy()).await;\n        assert!(matches!(result, Err(UltraplanError::LaunchFailed)));\n\n        let calls = archive_calls.lock().await.clone();\n        assert_eq!(calls, vec![\"session_123\".to_owned()]);\n    }\n\n    #[tokio::test]\n    async fn stop_clears_active_marker_before_returning_error() {\n        let runtime = MockUltraplanRuntime {\n            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_1\".to_owned())].into())),\n            poll_results: Arc::new(Mutex::new(vec![Ok(UltraplanPhase::Polling)].into())),\n            stop_results: Arc::new(Mutex::new(\n                vec![Err(UltraplanError::Transport(\"cannot stop\".to_owned()))].into(),\n            )),\n            ..MockUltraplanRuntime::default()\n        };\n        let service = DefaultUltraplanService::new(runtime, true);\n        let _ = service\n            .launch(\"prompt\", policy())\n            .await\n            .expect(\"launch succeeds\");\n\n        let stop_result = service.stop(\"session_1\").await;\n        assert!(matches!(stop_result, Err(UltraplanError::Transport(_))));\n        assert!(service.active_marker().await.is_none());\n    }\n\n    #[tokio::test]\n    async fn poll_handles_transitions_and_approved_to_completed() {\n        let runtime = MockUltraplanRuntime {\n            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_1\".to_owned())].into())),\n            poll_results: Arc::new(Mutex::new(\n                vec![\n                    Ok(UltraplanPhase::Polling),\n                    Ok(UltraplanPhase::AwaitingInput),\n                    Ok(UltraplanPhase::Polling),\n                    Ok(UltraplanPhase::Stopping),\n                    Ok(UltraplanPhase::Completed),\n                ]\n                .into(),\n            )),\n            ..MockUltraplanRuntime::default()\n        };\n        let service = DefaultUltraplanService::new(runtime, true);\n\n        let _ = service\n            .launch(\"prompt\", policy())\n            .await\n            .expect(\"launch succeeds\");\n        assert_eq!(\n            service.poll(\"session_1\").await.expect(\"awaiting input\"),\n            UltraplanPhase::AwaitingInput\n        );\n        assert_eq!(\n            service.poll(\"session_1\").await.expect(\"back to polling\"),\n            UltraplanPhase::Polling\n        );\n        assert_eq!(\n            service.poll(\"session_1\").await.expect(\"stopping\"),\n            UltraplanPhase::Stopping\n        );\n        assert_eq!(\n            service.poll(\"session_1\").await.expect(\"completed\"),\n            UltraplanPhase::Completed\n        );\n        assert!(service.active_marker().await.is_none());\n    }\n\n    #[tokio::test]\n    async fn poll_maps_each_terminal_and_error_path() {\n        let runtime = MockUltraplanRuntime::with_poll(vec![Err(UltraplanError::PollTimeout)]);\n        let service = DefaultUltraplanService::new(runtime, true);\n        let timeout = service.poll(\"session_1\").await;\n        assert!(matches!(timeout, Err(UltraplanError::PollTimeout)));\n    }\n\n    #[tokio::test]\n    async fn can_emit_each_error_variant() {\n        let disabled = DefaultUltraplanService::new(MockUltraplanRuntime::default(), false)\n            .launch(\"prompt\", policy())\n            .await;\n        assert!(matches!(disabled, Err(UltraplanError::DisabledByPolicy)));\n\n        let already_runtime = MockUltraplanRuntime {\n            launch_results: Arc::new(Mutex::new(vec![Ok(\"s-1\".to_owned())].into())),\n            poll_results: Arc::new(Mutex::new(vec![Ok(UltraplanPhase::Polling)].into())),\n            ..MockUltraplanRuntime::default()\n        };\n        let already_service = DefaultUltraplanService::new(already_runtime, true);\n        let _ = already_service\n            .launch(\"prompt\", policy())\n            .await\n            .expect(\"first launch succeeds\");\n        let already = already_service.launch(\"prompt\", policy()).await;\n        assert!(matches!(already, Err(UltraplanError::AlreadyActive)));\n\n        let launch_failed_runtime = MockUltraplanRuntime {\n            launch_results: Arc::new(Mutex::new(\n                vec![Err(UltraplanError::Transport(\"x\".into()))].into(),\n            )),\n            ..MockUltraplanRuntime::default()\n        };\n        let launch_failed = DefaultUltraplanService::new(launch_failed_runtime, true)\n            .launch(\"prompt\", policy())\n            .await;\n        assert!(matches!(launch_failed, Err(UltraplanError::LaunchFailed)));\n\n        let poll_timeout_runtime =\n            MockUltraplanRuntime::with_poll(vec![Err(UltraplanError::PollTimeout)]);\n        let poll_timeout = DefaultUltraplanService::new(poll_timeout_runtime, true)\n            .poll(\"session\")\n            .await;\n        assert!(matches!(poll_timeout, Err(UltraplanError::PollTimeout)));\n\n        let approval_failed_runtime = MockUltraplanRuntime {\n            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_1\".to_owned())].into())),\n            poll_results: Arc::new(Mutex::new(\n                vec![\n                    Ok(UltraplanPhase::Polling),\n                    Ok(UltraplanPhase::AwaitingInput),\n                    Ok(UltraplanPhase::Failed),\n                ]\n                .into(),\n            )),\n            ..MockUltraplanRuntime::default()\n        };\n        let approval_failed_service = DefaultUltraplanService::new(approval_failed_runtime, true);\n        let _ = approval_failed_service\n            .launch(\"prompt\", policy())\n            .await\n            .expect(\"launch succeeds\");\n        let _ = approval_failed_service\n            .poll(\"session_1\")\n            .await\n            .expect(\"awaiting input\");\n        let approval_failed = approval_failed_service.poll(\"session_1\").await;\n        assert!(matches!(\n            approval_failed,\n            Err(UltraplanError::ApprovalFailed)\n        ));\n\n        let archive_failed_runtime = MockUltraplanRuntime {\n            archive_results: Arc::new(Mutex::new(\n                vec![Err(UltraplanError::Transport(\"x\".into()))].into(),\n            )),\n            ..MockUltraplanRuntime::default()\n        };\n        let archive_failed = DefaultUltraplanService::new(archive_failed_runtime, true)\n            .archive_orphan(\"session_2\")\n            .await;\n        assert!(matches!(archive_failed, Err(UltraplanError::ArchiveFailed)));\n\n        let transport_runtime = MockUltraplanRuntime {\n            stop_results: Arc::new(Mutex::new(\n                vec![Err(UltraplanError::Transport(\"stop failed\".to_owned()))].into(),\n            )),\n            ..MockUltraplanRuntime::default()\n        };\n        let transport = DefaultUltraplanService::new(transport_runtime, true)\n            .stop(\"session_3\")\n            .await;\n        assert!(matches!(transport, Err(UltraplanError::Transport(_))));\n    }\n\n    #[tokio::test]\n    async fn archive_failure_during_launch_failure_surfaces_archive_failed() {\n        let runtime = MockUltraplanRuntime {\n            launch_results: Arc::new(Mutex::new(vec![Ok(\"session_123\".to_owned())].into())),\n            poll_results: Arc::new(Mutex::new(\n                vec![Err(UltraplanError::Transport(\"x\".into()))].into(),\n            )),\n            archive_results: Arc::new(Mutex::new(\n                vec![Err(UltraplanError::Transport(\"bad\".into()))].into(),\n            )),\n            ..MockUltraplanRuntime::default()\n        };\n        let service = DefaultUltraplanService::new(runtime, true);\n\n        let result = service.launch(\"prompt\", policy()).await;\n        assert!(matches!(result, Err(UltraplanError::ArchiveFailed)));\n    }\n\n    #[tokio::test]\n    async fn route_keyword_non_ultraplan_passthroughs_without_launch() {\n        let runtime = MockUltraplanRuntime::default();\n        let service = DefaultUltraplanService::new(runtime, true);\n\n        let routed = service\n            .route_keyword_launch(\"hello world\", \"prompt\", policy())\n            .await\n            .expect(\"routing succeeds\");\n        assert!(routed.is_none());\n    }\n\n    #[tokio::test]\n    async fn concurrent_stop_and_poll_does_not_restore_active_marker() {\n        struct RaceRuntime {\n            poll_release: Arc<Notify>,\n            poll_calls: Arc<Mutex<u8>>,\n        }\n\n        #[async_trait]\n        impl UltraplanRuntime for RaceRuntime {\n            async fn launch_session(&self, _prompt: &str) -> Result<String, UltraplanError> {\n                Ok(\"session-race\".to_string())\n            }\n\n            async fn poll_phase(\n                &self,\n                _session_id: &str,\n            ) -> Result<UltraplanPhase, UltraplanError> {\n                let mut calls = self.poll_calls.lock().await;\n                *calls += 1;\n                let call = *calls;\n                drop(calls);\n\n                if call == 1 {\n                    return Ok(UltraplanPhase::Polling);\n                }\n\n                self.poll_release.notified().await;\n                Ok(UltraplanPhase::AwaitingInput)\n            }\n\n            async fn stop_session(&self, _session_id: &str) -> Result<(), UltraplanError> {\n                self.poll_release.notify_waiters();\n                Ok(())\n            }\n\n            async fn archive_session(&self, _session_id: &str) -> Result<(), UltraplanError> {\n                Ok(())\n            }\n        }\n\n        let runtime = RaceRuntime {\n            poll_release: Arc::new(Notify::new()),\n            poll_calls: Arc::new(Mutex::new(0)),\n        };\n        let service = Arc::new(DefaultUltraplanService::new(runtime, true));\n        service\n            .launch(\"prompt\", policy())\n            .await\n            .expect(\"launch succeeds\");\n\n        let poll = {\n            let service = Arc::clone(&service);\n            tokio::spawn(async move { service.poll(\"session-race\").await })\n        };\n        tokio::task::yield_now().await;\n        let stop = {\n            let service = Arc::clone(&service);\n            tokio::spawn(async move { service.stop(\"session-race\").await })\n        };\n\n        let poll_result = poll.await.expect(\"poll task join\");\n        let stop_result = stop.await.expect(\"stop task join\");\n\n        assert_eq!(\n            poll_result.expect(\"poll result\"),\n            UltraplanPhase::AwaitingInput\n        );\n        stop_result.expect(\"stop result\");\n        assert!(\n            service.active_marker().await.is_none(),\n            \"active marker must remain cleared after stop\"\n        );\n    }\n}\n","numLines":771,"startLine":1,"totalLines":771}}}
