{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AqrrGWSWiHgpoJewZJJgUC","type":"tool_result","content":"1\t#[cfg(test)]\n2\tmod tests {\n3\t    use crate::trigger_scheduler_service::{LocalTriggerSchedulerService, TriggerSchedulerPolicy};\n4\t    use ccode_application::spec_contracts::{\n5\t        TriggerError, TriggerOwner, TriggerSchedulerService, TriggerScope, TriggerTask,\n6\t    };\n7\t    use ccode_state_store::FileTriggerTaskStateStore;\n8\t\n9\t    fn task(id: &str, scope: TriggerScope, owner: TriggerOwner) -> TriggerTask {\n10\t        TriggerTask {\n11\t            id: id.to_string(),\n12\t            cron: \"0 9 * * *\".to_string(),\n13\t            prompt: \"do work\".to_string(),\n14\t            scope,\n15\t            owner,\n16\t            durable_intent: false,\n17\t        }\n18\t    }\n19\t\n20\t    fn unique_temp_dir(label: &str) -> std::path::PathBuf {\n21\t        let ts = std::time::SystemTime::now()\n22\t            .duration_since(std::time::UNIX_EPOCH)\n23\t            .expect(\"time\")\n24\t            .as_nanos();\n25\t        let path = std::env::temp_dir().join(format!(\"ccode-us016-{label}-{ts}\"));\n26\t        std::fs::create_dir_all(&path).expect(\"create temp dir\");\n27\t        path\n28\t    }\n29\t\n30\t    #[tokio::test]\n31\t    async fn durable_persists_and_reloads_on_restart() {\n32\t        let dir = unique_temp_dir(\"durable-reload\");\n33\t        let store = std::sync::Arc::new(FileTriggerTaskStateStore::new(&dir).expect(\"store\"));\n34\t\n35\t        let service =\n36\t            LocalTriggerSchedulerService::new(store.clone(), TriggerSchedulerPolicy::default())\n37\t                .await\n38\t                .expect(\"service\");\n39\t\n40\t        let mut durable = task(\"durable-1\", TriggerScope::Durable, TriggerOwner::MainAgent);\n41\t        durable.durable_intent = true;\n42\t        service\n43\t            .create(durable.clone())\n44\t            .await\n45\t            .expect(\"create durable\");\n46\t\n47\t        let restarted = LocalTriggerSchedulerService::new(store, TriggerSchedulerPolicy::default())\n48\t            .await\n49\t            .expect(\"reload\");\n50\t\n51\t        let tasks = restarted.list().await.expect(\"list\");\n52\t        assert_eq!(tasks.len(), 1);\n53\t        assert_eq!(tasks[0].id, durable.id);\n54\t        assert_eq!(tasks[0].scope, TriggerScope::Durable);\n55\t    }\n56\t\n57\t    #[tokio::test]\n58\t    async fn session_only_survives_runtime_but_not_restart() {\n59\t        let dir = unique_temp_dir(\"session-only\");\n60\t        let store = std::sync::Arc::new(FileTriggerTaskStateStore::new(&dir).expect(\"store\"));\n61\t\n62\t        let service =\n63\t            LocalTriggerSchedulerService::new(store.clone(), TriggerSchedulerPolicy::default())\n64\t                .await\n65\t                .expect(\"service\");\n66\t\n67\t        let session_task = task(\n68\t            \"session-1\",\n69\t            TriggerScope::SessionOnly,\n70\t            TriggerOwner::MainAgent,\n71\t        );\n72\t        service\n73\t            .create(session_task.clone())\n74\t            .await\n75\t            .expect(\"create session-only\");\n76\t\n77\t        let same_runtime = service.list().await.expect(\"list same runtime\");\n78\t        assert_eq!(same_runtime.len(), 1);\n79\t        assert_eq!(same_runtime[0].id, session_task.id);\n80\t\n81\t        let restarted = LocalTriggerSchedulerService::new(store, TriggerSchedulerPolicy::default())\n82\t            .await\n83\t            .expect(\"restart\");\n84\t        let after_restart = restarted.list().await.expect(\"list after restart\");\n85\t        assert!(after_restart.is_empty());\n86\t    }\n87\t\n88\t    #[tokio::test]\n89\t    async fn teammate_cannot_create_durable() {\n90\t        let dir = unique_temp_dir(\"teammate-durable\");\n91\t        let store = std::sync::Arc::new(FileTriggerTaskStateStore::new(&dir).expect(\"store\"));\n92\t        let service = LocalTriggerSchedulerService::new(store, TriggerSchedulerPolicy::default())\n93\t            .await\n94\t            .expect(\"service\");\n95\t\n96\t        let mut durable = task(\n97\t            \"durable-teammate\",\n98\t            TriggerScope::Durable,\n99\t            TriggerOwner::Teammate(\"alice\".to_string()),\n100\t        );\n101\t        durable.durable_intent = true;\n102\t\n103\t        let err = service\n104\t            .create(durable)\n105\t            .await\n106\t            .expect_err(\"durable should be denied\");\n107\t        assert!(matches!(err, TriggerError::DurableNotAllowedForTeammate));\n108\t    }\n109\t\n110\t    #[tokio::test]\n111\t    async fn delete_checks_owner_identity() {\n112\t        let dir = unique_temp_dir(\"owner-delete\");\n113\t        let store = std::sync::Arc::new(FileTriggerTaskStateStore::new(&dir).expect(\"store\"));\n114\t        let service = LocalTriggerSchedulerService::new(store, TriggerSchedulerPolicy::default())\n115\t            .await\n116\t            .expect(\"service\");\n117\t\n118\t        let owned = task(\n119\t            \"owned-1\",\n120\t            TriggerScope::SessionOnly,\n121\t            TriggerOwner::Teammate(\"alice\".to_string()),\n122\t        );\n123\t        service.create(owned).await.expect(\"create\");\n124\t\n125\t        let err = service\n126\t            .delete(\"owned-1\", TriggerOwner::Teammate(\"bob\".to_string()))\n127\t            .await\n128\t            .expect_err(\"owner mismatch should fail\");\n129\t        assert!(matches!(err, TriggerError::OwnershipViolation));\n130\t\n131\t        service\n132\t            .delete(\"owned-1\", TriggerOwner::Teammate(\"alice\".to_string()))\n133\t            .await\n134\t            .expect(\"owner match should delete\");\n135\t    }\n136\t\n137\t    #[tokio::test]\n138\t    async fn invalid_cron_returns_invalid_cron_error() {\n139\t        let dir = unique_temp_dir(\"invalid-cron\");\n140\t        let store = std::sync::Arc::new(FileTriggerTaskStateStore::new(&dir).expect(\"store\"));\n141\t        let service = LocalTriggerSchedulerService::new(store, TriggerSchedulerPolicy::default())\n142\t            .await\n143\t            .expect(\"service\");\n144\t\n145\t        let mut invalid = task(\n146\t            \"invalid-1\",\n147\t            TriggerScope::SessionOnly,\n148\t            TriggerOwner::MainAgent,\n149\t        );\n150\t        invalid.cron = \"this is not cron\".to_string();\n151\t\n152\t        let err = service\n153\t            .create(invalid)\n154\t            .await\n155\t            .expect_err(\"invalid cron should fail\");\n156\t        assert!(matches!(err, TriggerError::InvalidCron));\n157\t    }\n158\t\n159\t    #[tokio::test]\n160\t    async fn durable_requires_explicit_user_intent() {\n161\t        let dir = unique_temp_dir(\"durable-intent\");\n162\t        let store = std::sync::Arc::new(FileTriggerTaskStateStore::new(&dir).expect(\"store\"));\n163\t        let service = LocalTriggerSchedulerService::new(store, TriggerSchedulerPolicy::default())\n164\t            .await\n165\t            .expect(\"service\");\n166\t\n167\t        let durable = task(\n168\t            \"durable-no-intent\",\n169\t            TriggerScope::Durable,\n170\t            TriggerOwner::MainAgent,\n171\t        );\n172\t        let err = service\n173\t            .create(durable)\n174\t            .await\n175\t            .expect_err(\"missing durable intent should fail\");\n176\t        assert!(matches!(err, TriggerError::Unauthorized));\n177\t    }\n178\t\n179\t    #[tokio::test]\n180\t    async fn gate_disabled_returns_gate_disabled() {\n181\t        let dir = unique_temp_dir(\"gate-disabled\");\n182\t        let store = std::sync::Arc::new(FileTriggerTaskStateStore::new(&dir).expect(\"store\"));\n183\t        let service = LocalTriggerSchedulerService::new(\n184\t            store,\n185\t            TriggerSchedulerPolicy {\n186\t                scheduler_enabled: false,\n187\t                durable_enabled: true,\n188\t            },\n189\t        )\n190\t        .await\n191\t        .expect(\"service\");\n192\t\n193\t        let err = service\n194\t            .list()\n195\t            .await\n196\t            .expect_err(\"list should be blocked when gate disabled\");\n197\t        assert!(matches!(err, TriggerError::GateDisabled));\n198\t    }\n199\t\n200\t    #[tokio::test]\n201\t    async fn storage_error_is_mapped_from_store_failures() {\n202\t        struct FailingStore;\n203\t\n204\t        #[async_trait::async_trait]\n205\t        impl ccode_state_store::TriggerTaskStateStore for FailingStore {\n206\t            async fn load_trigger_tasks(\n207\t                &self,\n208\t            ) -> Result<Vec<serde_json::Value>, ccode_state_store::StateStoreError> {\n209\t                Ok(Vec::new())\n210\t            }\n211\t\n212\t            async fn save_trigger_task(\n213\t                &self,\n214\t                _id: &str,\n215\t                _task: &serde_json::Value,\n216\t            ) -> Result<(), ccode_state_store::StateStoreError> {\n217\t                Err(ccode_state_store::StateStoreError::Storage(\n218\t                    \"save boom\".to_string(),\n219\t                ))\n220\t            }\n221\t\n222\t            async fn delete_trigger_task(\n223\t                &self,\n224\t                _id: &str,\n225\t            ) -> Result<(), ccode_state_store::StateStoreError> {\n226\t                Ok(())\n227\t            }\n228\t        }\n229\t\n230\t        let store = std::sync::Arc::new(FailingStore);\n231\t        let service = LocalTriggerSchedulerService::new(store, TriggerSchedulerPolicy::default())\n232\t            .await\n233\t            .expect(\"service\");\n234\t\n235\t        let mut durable = task(\n236\t            \"durable-store\",\n237\t            TriggerScope::Durable,\n238\t            TriggerOwner::MainAgent,\n239\t        );\n240\t        durable.durable_intent = true;\n241\t\n242\t        let err = service\n243\t            .create(durable)\n244\t            .await\n245\t            .expect_err(\"storage failure should bubble up\");\n246\t        assert!(matches!(err, TriggerError::StorageError));\n247\t    }\n248\t\n249\t    #[test]\n250\t    fn upstream_remote_error_variant_exists() {\n251\t        let err = TriggerError::UpstreamRemoteError;\n252\t        assert_eq!(err.to_string(), \"upstream remote error\");\n253\t    }\n254\t}\n255\t"}]},"parent_tool_use_id":"toolu_018v9gKuHTeFVwctEZBEV5Pe","session_id":"f364ad52-4738-45a7-8cb7-9f4703f698a1","uuid":"cfcb10b7-0a36-49d1-bad9-439ba31524dd","timestamp":"2026-04-02T14:47:20.730Z"}
