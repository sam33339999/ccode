{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CwWa8BqfbnjTDp6oWmzvCd","type":"tool_result","content":"1\tuse async_trait::async_trait;\n2\tuse ccode_application::spec_contracts::{RemoteTriggerDispatchService, TriggerError};\n3\tuse ccode_remote_runtime::ccr_client::{AuthContext, AuthContextProvider};\n4\tuse serde_json::Value;\n5\t\n6\t#[derive(Debug, Clone, Copy, Default)]\n7\tpub struct RemoteTriggerDispatchPolicy {\n8\t    pub remote_dispatch_enabled: bool,\n9\t}\n10\t\n11\t#[async_trait]\n12\tpub trait RemoteTriggerTransport: Send + Sync {\n13\t    async fn dispatch(&self, payload: Value, auth: &AuthContext) -> Result<String, String>;\n14\t}\n15\t\n16\tpub struct PlatformRemoteTriggerDispatchService<T, P> {\n17\t    transport: T,\n18\t    auth_provider: P,\n19\t    policy: RemoteTriggerDispatchPolicy,\n20\t}\n21\t\n22\timpl<T, P> PlatformRemoteTriggerDispatchService<T, P>\n23\twhere\n24\t    T: RemoteTriggerTransport,\n25\t    P: AuthContextProvider,\n26\t{\n27\t    pub fn new(transport: T, auth_provider: P, policy: RemoteTriggerDispatchPolicy) -> Self {\n28\t        Self {\n29\t            transport,\n30\t            auth_provider,\n31\t            policy,\n32\t        }\n33\t    }\n34\t\n35\t    fn ensure_enabled(&self) -> Result<(), TriggerError> {\n36\t        if self.policy.remote_dispatch_enabled {\n37\t            Ok(())\n38\t        } else {\n39\t            Err(TriggerError::GateDisabled)\n40\t        }\n41\t    }\n42\t\n43\t    fn validated_auth_context(&self) -> Result<AuthContext, TriggerError> {\n44\t        let auth = self.auth_provider.auth_context();\n45\t\n46\t        let has_token = auth\n47\t            .token\n48\t            .as_ref()\n49\t            .map(|t| !t.trim().is_empty())\n50\t            .unwrap_or(false);\n51\t        let has_org = auth\n52\t            .org_id\n53\t            .as_ref()\n54\t            .map(|o| !o.trim().is_empty())\n55\t            .unwrap_or(false);\n56\t\n57\t        if has_token && has_org {\n58\t            Ok(auth)\n59\t        } else {\n60\t            Err(TriggerError::Unauthorized)\n61\t        }\n62\t    }\n63\t}\n64\t\n65\t#[async_trait]\n66\timpl<T, P> RemoteTriggerDispatchService for PlatformRemoteTriggerDispatchService<T, P>\n67\twhere\n68\t    T: RemoteTriggerTransport,\n69\t    P: AuthContextProvider,\n70\t{\n71\t    async fn dispatch(&self, payload: Value) -> Result<String, TriggerError> {\n72\t        self.ensure_enabled()?;\n73\t        let auth = self.validated_auth_context()?;\n74\t\n75\t        self.transport\n76\t            .dispatch(payload, &auth)\n77\t            .await\n78\t            .map_err(|_| TriggerError::UpstreamRemoteError)\n79\t    }\n80\t}\n81\t"}]},"parent_tool_use_id":"toolu_01KHgqaLUPdKvXjiDKih7urg","session_id":"f364ad52-4738-45a7-8cb7-9f4703f698a1","uuid":"474522e9-e6c2-457d-b382-55a65e9e1029","timestamp":"2026-04-02T14:46:34.193Z"}
