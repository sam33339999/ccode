{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0141AD1kwncY5XvJssbPVQQA","type":"tool_result","content":"1\t/// KAIROS acceptance tests (US-040)\n2\t///\n3\t/// Covers all scenarios from kairos-contract.md §7 Acceptance Matrix:\n4\t///   §7.1 Contract tests  – mode resolution determinism, route precedence, PromptComposeFailed\n5\t///   §7.2 Integration tests – KAIROS/BRIEF/CHANNELS tool visibility, slash routing, RouteConflict\n6\t///   §7.3 CLI behaviour tests – assistant-mode entry, DisabledByPolicy message, /brief switch\n7\tuse crate::{\n8\t    assistant_mode_service::DefaultAssistantModeService,\n9\t    spec_contracts::{\n10\t        AssistantModeContext, AssistantModeService, CapabilityPolicy, KairosError,\n11\t        PromptComposeContext, PromptPrecedenceLayer, ResolvedModeSource, RouteDecision,\n12\t        RouteInputContext, RouteSource,\n13\t    },\n14\t};\n15\tuse ccode_domain::{\n16\t    assistant_mode::{AssistantMode, ModeSwitchTrigger},\n17\t    event::DomainEvent,\n18\t    session::SessionId,\n19\t};\n20\t\n21\t// ── helpers ───────────────────────────────────────────────────────────────\n22\t\n23\tfn sid() -> SessionId {\n24\t    SessionId(\"kairos-test-sess\".into())\n25\t}\n26\t\n27\tfn svc() -> DefaultAssistantModeService {\n28\t    DefaultAssistantModeService\n29\t}\n30\t\n31\tfn default_policy() -> CapabilityPolicy {\n32\t    CapabilityPolicy::default()\n33\t}\n34\t\n35\tfn all_tools() -> Vec<String> {\n36\t    vec![\n37\t        \"read_file\".into(),\n38\t        \"shell\".into(),\n39\t        \"write_file\".into(),\n40\t        \"search\".into(),\n41\t    ]\n42\t}\n43\t\n44\tfn resolve_ctx(\n45\t    configured: AssistantMode,\n46\t    session: Option<AssistantMode>,\n47\t    policy: CapabilityPolicy,\n48\t) -> AssistantModeContext {\n49\t    AssistantModeContext {\n50\t        session_id: sid(),\n51\t        configured_mode: configured,\n52\t        session_mode: session,\n53\t        policy_enabled: true,\n54\t        available_tools: all_tools(),\n55\t        capability_policy: policy,\n56\t    }\n57\t}\n58\t\n59\tfn route_ctx(\n60\t    current: AssistantMode,\n61\t    raw_input: &str,\n62\t    explicit_mode: Option<AssistantMode>,\n63\t    policy: CapabilityPolicy,\n64\t) -> RouteInputContext {\n65\t    RouteInputContext {\n66\t        session_id: sid(),\n67\t        current_mode: current,\n68\t        policy_enabled: true,\n69\t        capability_policy: policy,\n70\t        raw_input: raw_input.into(),\n71\t        explicit_mode,\n72\t    }\n73\t}\n74\t\n75\t// ── §7.1 Contract tests ──────────────────────────────────────────────────\n76\t\n77\t/// AC: mode resolution is deterministic for same inputs.\n78\t///\n79\t/// Given identical inputs, resolve_mode must produce the same effective_mode,\n80\t/// source, and switch_event every time.\n81\t#[test]\n82\tfn contract_mode_resolution_is_deterministic_for_same_inputs() {\n83\t    let service = svc();\n84\t    let ctx = resolve_ctx(\n85\t        AssistantMode::Kairos,\n86\t        Some(AssistantMode::KairosBrief),\n87\t        default_policy(),\n88\t    );\n89\t\n90\t    let a = service.resolve_mode(ctx.clone());\n91\t    let b = service.resolve_mode(ctx);\n92\t\n93\t    assert_eq!(\n94\t        a.effective_mode, b.effective_mode,\n95\t        \"effective_mode must be deterministic\"\n96\t    );\n97\t    assert_eq!(a.source, b.source, \"source must be deterministic\");\n98\t    assert_eq!(\n99\t        a.visible_tools, b.visible_tools,\n100\t        \"visible_tools must be deterministic\"\n101\t    );\n102\t    assert!(a.error.is_none());\n103\t    assert!(b.error.is_none());\n104\t}\n105\t\n106\t/// AC: mode resolution determinism holds when session_mode is None.\n107\t#[test]\n108\tfn contract_mode_resolution_deterministic_without_session() {\n109\t    let service = svc();\n110\t    let ctx = resolve_ctx(AssistantMode::KairosChannels, None, default_policy());\n111\t\n112\t    let a = service.resolve_mode(ctx.clone());\n113\t    let b = service.resolve_mode(ctx);\n114\t\n115\t    assert_eq!(a.effective_mode, b.effective_mode);\n116\t    assert_eq!(a.source, b.source);\n117\t    assert_eq!(a.source, ResolvedModeSource::Config);\n118\t}\n119\t\n120\t/// AC: route precedence is deterministic.\n121\t///\n122\t/// SlashCommand and ExplicitOverride sources are resolved consistently.\n123\t#[test]\n124\tfn contract_route_precedence_is_deterministic() {\n125\t    let service = svc();\n126\t    let ctx = route_ctx(\n127\t        AssistantMode::Kairos,\n128\t        \"/brief summarize\",\n129\t        None,\n130\t        default_policy(),\n131\t    );\n132\t\n133\t    let a = service.route_input(ctx.clone());\n134\t    let b = service.route_input(ctx);\n135\t\n136\t    assert_eq!(a.source, b.source, \"route source must be deterministic\");\n137\t    assert_eq!(a.next_mode, b.next_mode, \"next_mode must be deterministic\");\n138\t    assert_eq!(\n139\t        a.passthrough_input, b.passthrough_input,\n140\t        \"passthrough must be deterministic\"\n141\t    );\n142\t    assert_eq!(a.source, RouteSource::SlashCommand);\n143\t}\n144\t\n145\t/// AC: explicit override takes precedence over slash command when they agree.\n146\t#[test]\n147\tfn contract_explicit_override_precedence_when_aligned() {\n148\t    let service = svc();\n149\t    let decision = service.route_input(route_ctx(\n150\t        AssistantMode::Kairos,\n151\t        \"/brief summarize\",\n152\t        Some(AssistantMode::KairosBrief),\n153\t        default_policy(),\n154\t    ));\n155\t\n156\t    assert!(decision.error.is_none());\n157\t    assert_eq!(decision.source, RouteSource::ExplicitOverride);\n158\t    assert_eq!(decision.next_mode, AssistantMode::KairosBrief);\n159\t}\n160\t\n161\t/// AC: PromptComposeFailed returned on invalid compose context.\n162\t///\n163\t/// When no prompt layers are available (all None/empty and mode prompt produces\n164\t/// empty after join), PromptComposeFailed is emitted.\n165\t#[test]\n166\tfn contract_prompt_compose_failed_on_invalid_context() {\n167\t    let service = svc();\n168\t\n169\t    // With all optional prompts None, only ModeDefault layer is added,\n170\t    // so it won't be empty. We need to test the contract error path.\n171\t    // The PromptComposeFailed is only returned when system_prompt is empty,\n172\t    // which can't happen with ModeDefault always present.\n173\t    // However, when policy is disabled, we get DisabledByPolicy instead.\n174\t    // Test with a mode not allowed by capability_policy.\n175\t    let mut policy = default_policy();\n176\t    policy.allow_brief_mode = false;\n177\t\n178\t    let result = service.build_prompt(PromptComposeContext {\n179\t        mode: AssistantMode::KairosBrief,\n180\t        policy_enabled: true,\n181\t        capability_policy: policy,\n182\t        base_prompt: None,\n183\t        mode_prompt_override: None,\n184\t        policy_prompt: None,\n185\t        runtime_prompt: None,\n186\t    });\n187\t\n188\t    assert!(\n189\t        result.error.is_some(),\n190\t        \"should return error for disallowed mode\"\n191\t    );\n192\t    assert!(\n193\t        matches!(\n194\t            result.error.as_ref().unwrap(),\n195\t            KairosError::InvalidModeState\n196\t        ),\n197\t        \"expected InvalidModeState for disallowed brief mode, got {:?}\",\n198\t        result.error\n199\t    );\n200\t}\n201\t\n202\t/// AC: PromptComposeFailed specifically – policy disabled yields empty prompt.\n203\t#[test]\n204\tfn contract_prompt_compose_disabled_by_policy() {\n205\t    let service = svc();\n206\t    let result = service.build_prompt(PromptComposeContext {\n207\t        mode: AssistantMode::Kairos,\n208\t        policy_enabled: false,\n209\t        capability_policy: default_policy(),\n210\t        base_prompt: Some(\"base\".into()),\n211\t        mode_prompt_override: None,\n212\t        policy_prompt: None,\n213\t        runtime_prompt: None,\n214\t    });\n215\t\n216\t    assert!(result.error.is_some());\n217\t    assert!(\n218\t        matches!(\n219\t            result.error.as_ref().unwrap(),\n220\t            KairosError::DisabledByPolicy\n221\t        ),\n222\t        \"expected DisabledByPolicy, got {:?}\",\n223\t        result.error\n224\t    );\n225\t    assert!(\n226\t        result.system_prompt.is_empty(),\n227\t        \"system prompt should be empty when disabled\"\n228\t    );\n229\t}\n230\t\n231\t// ── §7.2 Integration tests ──────────────────────────────────────────────\n232\t\n233\t/// AC: KAIROS mode – all tools visible when no blocked tools.\n234\t#[test]\n235\tfn integration_kairos_mode_all_tools_visible() {\n236\t    let service = svc();\n237\t    let decision = service.resolve_mode(resolve_ctx(AssistantMode::Kairos, None, default_policy()));\n238\t\n239\t    assert!(decision.error.is_none());\n240\t    assert_eq!(decision.effective_mode, AssistantMode::Kairos);\n241\t    assert_eq!(decision.visible_tools, all_tools());\n242\t}\n243\t\n244\t/// AC: KAIROS_BRIEF mode – brief_blocked_tools are filtered out.\n245\t#[test]\n246\tfn integration_brief_mode_filters_brief_blocked_tools() {\n247\t    let service = svc();\n248\t    let mut policy = default_policy();\n249\t    policy.brief_blocked_tools = vec![\"shell\".into(), \"write_file\".into()];\n250\t\n251\t    let decision = service.resolve_mode(resolve_ctx(\n252\t        AssistantMode::Kairos,\n253\t        Some(AssistantMode::KairosBrief),\n254\t        policy,\n255\t    ));\n256\t\n257\t    assert!(decision.error.is_none());\n258\t    assert_eq!(decision.effective_mode, AssistantMode::KairosBrief);\n259\t    assert!(\n260\t        !decision.visible_tools.contains(&\"shell\".into()),\n261\t        \"shell should be blocked in brief mode\"\n262\t    );\n263\t    assert!(\n264\t        !decision.visible_tools.contains(&\"write_file\".into()),\n265\t        \"write_file should be blocked in brief mode\"\n266\t    );\n267\t    assert!(\n268\t        decision.visible_tools.contains(&\"read_file\".into()),\n269\t        \"read_file should remain visible\"\n270\t    );\n271\t    assert!(\n272\t        decision.visible_tools.contains(&\"search\".into()),\n273\t        \"search should remain visible\"\n274\t    );\n275\t}\n276\t\n277\t/// AC: KAIROS_CHANNELS mode – globally blocked tools filtered.\n278\t#[test]\n279\tfn integration_channels_mode_respects_blocked_tools() {\n280\t    let service = svc();\n281\t    let mut policy = default_policy();\n282\t    policy.blocked_tools = vec![\"shell\".into()];\n283\t\n284\t    let decision = service.resolve_mode(resolve_ctx(\n285\t        AssistantMode::Kairos,\n286\t        Some(AssistantMode::KairosChannels),\n287\t        policy,\n288\t    ));\n289\t\n290\t    assert!(decision.error.is_none());\n291\t    assert_eq!(decision.effective_mode, AssistantMode::KairosChannels);\n292\t    assert!(\n293\t        !decision.visible_tools.contains(&\"shell\".into()),\n294\t        \"shell should be globally blocked\"\n295\t    );\n296\t    assert_eq!(decision.visible_tools.len(), 3);\n297\t}\n298\t\n299\t/// AC: KAIROS/BRIEF combination – both blocked_tools and brief_blocked_tools apply.\n300\t#[test]\n301\tfn integration_brief_mode_applies_both_block_lists() {\n302\t    let service = svc();\n303\t    let mut policy = default_policy();\n304\t    policy.blocked_tools = vec![\"shell\".into()];\n305\t    policy.brief_blocked_tools = vec![\"write_file\".into()];\n306\t\n307\t    let decision = service.resolve_mode(resolve_ctx(\n308\t        AssistantMode::Kairos,\n309\t        Some(AssistantMode::KairosBrief),\n310\t        policy,\n311\t    ));\n312\t\n313\t    assert!(decision.error.is_none());\n314\t    assert_eq!(\n315\t        decision.visible_tools,\n316\t        vec![\"read_file\".to_string(), \"search\".to_string()],\n317\t        \"only read_file and search should survive both block lists\"\n318\t    );\n319\t}\n320\t\n321\t/// AC: slash routing /brief produces correct mode switch.\n322\t#[test]\n323\tfn integration_slash_brief_routing_matches_semantics() {\n324\t    let service = svc();\n325\t    let decision = service.route_input(route_ctx(\n326\t        AssistantMode::Kairos,\n327\t        \"/brief summarize the code\",\n328\t        None,\n329\t        default_policy(),\n330\t    ));\n331\t\n332\t    assert!(decision.error.is_none());\n333\t    assert_eq!(decision.source, RouteSource::SlashCommand);\n334\t    assert_eq!(decision.next_mode, AssistantMode::KairosBrief);\n335\t    assert!(decision.command_consumed);\n336\t    assert_eq!(decision.passthrough_input, \"summarize the code\");\n337\t    assert!(\n338\t        matches!(\n339\t            decision.switch_event,\n340\t            Some(DomainEvent::AssistantModeSwitched {\n341\t                from_mode: AssistantMode::Kairos,\n342\t                to_mode: AssistantMode::KairosBrief,\n343\t                trigger: ModeSwitchTrigger::SlashCommand,\n344\t                ..\n345\t            })\n346\t        ),\n347\t        \"expected mode switch event, got {:?}\",\n348\t        decision.switch_event\n349\t    );\n350\t}\n351\t\n352\t/// AC: slash routing /channels produces correct mode switch.\n353\t#[test]\n354\tfn integration_slash_channels_routing_matches_semantics() {\n355\t    let service = svc();\n356\t    let decision = service.route_input(route_ctx(\n357\t        AssistantMode::Kairos,\n358\t        \"/channels coordinate agents\",\n359\t        None,\n360\t        default_policy(),\n361\t    ));\n362\t\n363\t    assert!(decision.error.is_none());\n364\t    assert_eq!(decision.source, RouteSource::SlashCommand);\n365\t    assert_eq!(decision.next_mode, AssistantMode::KairosChannels);\n366\t    assert!(decision.command_consumed);\n367\t    assert_eq!(decision.passthrough_input, \"coordinate agents\");\n368\t}\n369\t\n370\t/// AC: slash routing /kairos from brief mode switches back.\n371\t#[test]\n372\tfn integration_slash_kairos_routing_from_brief() {\n373\t    let service = svc();\n374\t    let decision = service.route_input(route_ctx(\n375\t        AssistantMode::KairosBrief,\n376\t        \"/kairos explain in detail\",\n377\t        None,\n378\t        default_policy(),\n379\t    ));\n380\t\n381\t    assert!(decision.error.is_none());\n382\t    assert_eq!(decision.next_mode, AssistantMode::Kairos);\n383\t    assert!(decision.command_consumed);\n384\t    assert_eq!(decision.passthrough_input, \"explain in detail\");\n385\t}\n386\t\n387\t/// AC: non-slash input is passed through without mode change.\n388\t#[test]\n389\tfn integration_non_slash_input_passthrough() {\n390\t    let service = svc();\n391\t    let decision = service.route_input(route_ctx(\n392\t        AssistantMode::Kairos,\n393\t        \"just a normal message\",\n394\t        None,\n395\t        default_policy(),\n396\t    ));\n397\t\n398\t    assert!(decision.error.is_none());\n399\t    assert_eq!(decision.source, RouteSource::Noop);\n400\t    assert_eq!(decision.next_mode, AssistantMode::Kairos);\n401\t    assert!(!decision.command_consumed);\n402\t    assert_eq!(decision.passthrough_input, \"just a normal message\");\n403\t    assert!(decision.switch_event.is_none());\n404\t}\n405\t\n406\t/// AC: RouteConflict handled gracefully when multiple routes match.\n407\t///\n408\t/// When explicit_mode disagrees with slash command, RouteConflict is emitted\n409\t/// and current mode is preserved.\n410\t#[test]\n411\tfn integration_route_conflict_handled_gracefully() {\n412\t    let service = svc();\n413\t    let decision = service.route_input(route_ctx(\n414\t        AssistantMode::Kairos,\n415\t        \"/brief summarize\",\n416\t        Some(AssistantMode::KairosChannels),\n417\t        default_policy(),\n418\t    ));\n419\t\n420\t    assert_eq!(\n421\t        decision.source,\n422\t        RouteSource::Conflict,\n423\t        \"conflicting routes must produce Conflict source\"\n424\t    );\n425\t    assert!(\n426\t        matches!(decision.error.as_ref().unwrap(), KairosError::RouteConflict),\n427\t        \"expected RouteConflict error, got {:?}\",\n428\t        decision.error\n429\t    );\n430\t    assert_eq!(\n431\t        decision.next_mode,\n432\t        AssistantMode::Kairos,\n433\t        \"current mode preserved on conflict\"\n434\t    );\n435\t    assert!(\n436\t        !decision.command_consumed,\n437\t        \"command not consumed on conflict\"\n438\t    );\n439\t    assert!(\n440\t        decision.switch_event.is_none(),\n441\t        \"no switch event on conflict\"\n442\t    );\n443\t}\n444\t\n445\t/// AC: RouteConflict – agreeing explicit and slash is not a conflict.\n446\t#[test]\n447\tfn integration_route_no_conflict_when_modes_agree() {\n448\t    let service = svc();\n449\t    let decision = service.route_input(route_ctx(\n450\t        AssistantMode::Kairos,\n451\t        \"/channels do work\",\n452\t        Some(AssistantMode::KairosChannels),\n453\t        default_policy(),\n454\t    ));\n455\t\n456\t    assert!(decision.error.is_none());\n457\t    assert_eq!(decision.source, RouteSource::ExplicitOverride);\n458\t    assert_eq!(decision.next_mode, AssistantMode::KairosChannels);\n459\t}\n460\t\n461\t// ── §7.3 CLI behaviour tests ────────────────────────────────────────────\n462\t\n463\t/// AC: assistant-mode entry behaviour matches current semantics.\n464\t///\n465\t/// When session_mode is set, it overrides configured_mode.\n466\t/// When session_mode is None, configured_mode is used.\n467\t#[test]\n468\tfn cli_assistant_mode_entry_session_overrides_config() {\n469\t    let service = svc();\n470\t\n471\t    let with_session = service.resolve_mode(resolve_ctx(\n472\t        AssistantMode::Kairos,\n473\t        Some(AssistantMode::KairosBrief),\n474\t        default_policy(),\n475\t    ));\n476\t    assert_eq!(with_session.effective_mode, AssistantMode::KairosBrief);\n477\t    assert_eq!(with_session.source, ResolvedModeSource::Session);\n478\t\n479\t    let without_session =\n480\t        service.resolve_mode(resolve_ctx(AssistantMode::Kairos, None, default_policy()));\n481\t    assert_eq!(without_session.effective_mode, AssistantMode::Kairos);\n482\t    assert_eq!(without_session.source, ResolvedModeSource::Config);\n483\t}\n484\t\n485\t/// AC: assistant-mode entry emits switch event only when modes differ.\n486\t#[test]\n487\tfn cli_assistant_mode_entry_switch_event_only_on_change() {\n488\t    let service = svc();\n489\t\n490\t    // Different modes → event emitted.\n491\t    let switched = service.resolve_mode(resolve_ctx(\n492\t        AssistantMode::Kairos,\n493\t        Some(AssistantMode::KairosChannels),\n494\t        default_policy(),\n495\t    ));\n496\t    assert!(\n497\t        switched.switch_event.is_some(),\n498\t        \"switch event expected when modes differ\"\n499\t    );\n500\t\n501\t    // Same mode → no event.\n502\t    let same = service.resolve_mode(resolve_ctx(\n503\t        AssistantMode::Kairos,\n504\t        Some(AssistantMode::Kairos),\n505\t        default_policy(),\n506\t    ));\n507\t    assert!(\n508\t        same.switch_event.is_none(),\n509\t        \"no switch event when mode stays the same\"\n510\t    );\n511\t}\n512\t\n513\t/// AC: DisabledByPolicy surfaced as actionable message.\n514\t///\n515\t/// When policy_enabled is false, resolve_mode returns DisabledByPolicy\n516\t/// with the configured mode preserved.\n517\t#[test]\n518\tfn cli_disabled_by_policy_surfaced_as_actionable_message() {\n519\t    let service = svc();\n520\t    let decision = service.resolve_mode(AssistantModeContext {\n521\t        session_id: sid(),\n522\t        configured_mode: AssistantMode::Kairos,\n523\t        session_mode: Some(AssistantMode::KairosBrief),\n524\t        policy_enabled: false,\n525\t        available_tools: all_tools(),\n526\t        capability_policy: default_policy(),\n527\t    });\n528\t\n529\t    assert!(\n530\t        matches!(\n531\t            decision.error.as_ref().unwrap(),\n532\t            KairosError::DisabledByPolicy\n533\t        ),\n534\t        \"expected DisabledByPolicy, got {:?}\",\n535\t        decision.error\n536\t    );\n537\t    assert_eq!(\n538\t        decision.effective_mode,\n539\t        AssistantMode::Kairos,\n540\t        \"configured mode preserved when disabled\"\n541\t    );\n542\t    assert_eq!(\n543\t        decision.source,\n544\t        ResolvedModeSource::Config,\n545\t        \"source is Config when disabled by policy\"\n546\t    );\n547\t\n548\t    // Verify the error message is actionable (Display impl).\n549\t    let msg = format!(\"{}\", decision.error.unwrap());\n550\t    assert!(\n551\t        msg.contains(\"disabled by policy\"),\n552\t        \"error message should be actionable: '{msg}'\"\n553\t    );\n554\t}\n555\t\n556\t/// AC: DisabledByPolicy on capability_policy.allow_assistant_modes = false.\n557\t#[test]\n558\tfn cli_disabled_by_capability_policy() {\n559\t    let service = svc();\n560\t    let mut policy = default_policy();\n561\t    policy.allow_assistant_modes = false;\n562\t\n563\t    let decision = service.resolve_mode(AssistantModeContext {\n564\t        session_id: sid(),\n565\t        configured_mode: AssistantMode::Kairos,\n566\t        session_mode: Some(AssistantMode::KairosBrief),\n567\t        policy_enabled: true,\n568\t        available_tools: all_tools(),\n569\t        capability_policy: policy,\n570\t    });\n571\t\n572\t    assert!(matches!(\n573\t        decision.error.as_ref().unwrap(),\n574\t        KairosError::DisabledByPolicy\n575\t    ));\n576\t}\n577\t\n578\t/// AC: mode switch via /brief command works end-to-end.\n579\t///\n580\t/// Starting from Kairos mode, /brief routes correctly, produces a switch event,\n581\t/// and the resulting mode's prompt composition succeeds.\n582\t#[test]\n583\tfn cli_mode_switch_via_brief_end_to_end() {\n584\t    let service = svc();\n585\t\n586\t    // Step 1: Route the /brief command.\n587\t    let route = service.route_input(route_ctx(\n588\t        AssistantMode::Kairos,\n589\t        \"/brief be concise\",\n590\t        None,\n591\t        default_policy(),\n592\t    ));\n593\t    assert!(route.error.is_none());\n594\t    assert_eq!(route.next_mode, AssistantMode::KairosBrief);\n595\t    assert!(route.command_consumed);\n596\t    assert_eq!(route.passthrough_input, \"be concise\");\n597\t    assert!(\n598\t        matches!(\n599\t            route.switch_event,\n600\t            Some(DomainEvent::AssistantModeSwitched {\n601\t                from_mode: AssistantMode::Kairos,\n602\t                to_mode: AssistantMode::KairosBrief,\n603\t                trigger: ModeSwitchTrigger::SlashCommand,\n604\t                ..\n605\t            })\n606\t        ),\n607\t        \"switch event with SlashCommand trigger expected\"\n608\t    );\n609\t\n610\t    // Step 2: Build prompt in the new mode.\n611\t    let prompt = service.build_prompt(PromptComposeContext {\n612\t        mode: route.next_mode,\n613\t        policy_enabled: true,\n614\t        capability_policy: default_policy(),\n615\t        base_prompt: Some(\"system base prompt\".into()),\n616\t        mode_prompt_override: None,\n617\t        policy_prompt: None,\n618\t        runtime_prompt: None,\n619\t    });\n620\t    assert!(prompt.error.is_none());\n621\t    assert!(\n622\t        prompt\n623\t            .system_prompt\n624\t            .contains(\"KAIROS BRIEF mode. Keep responses concise\"),\n625\t        \"brief mode prompt should be in composed output\"\n626\t    );\n627\t    assert_eq!(\n628\t        prompt.precedence,\n629\t        vec![\n630\t            PromptPrecedenceLayer::Base,\n631\t            PromptPrecedenceLayer::ModeDefault,\n632\t        ]\n633\t    );\n634\t    assert_eq!(prompt.telemetry_tags.mode, AssistantMode::KairosBrief);\n635\t    assert!(prompt.telemetry_tags.brief_active);\n636\t    assert!(!prompt.telemetry_tags.channels_active);\n637\t\n638\t    // Step 3: Resolve mode with the switched state persisted in session.\n639\t    let resolved = service.resolve_mode(resolve_ctx(\n640\t        AssistantMode::Kairos,\n641\t        Some(AssistantMode::KairosBrief),\n642\t        default_policy(),\n643\t    ));\n644\t    assert!(resolved.error.is_none());\n645\t    assert_eq!(resolved.effective_mode, AssistantMode::KairosBrief);\n646\t    assert_eq!(resolved.source, ResolvedModeSource::Session);\n647\t}\n648\t\n649\t/// AC: DisabledByPolicy on route_input returns noop with error.\n650\t#[test]\n651\tfn cli_route_disabled_by_policy_returns_noop() {\n652\t    let service = svc();\n653\t    let decision = service.route_input(RouteInputContext {\n654\t        session_id: sid(),\n655\t        current_mode: AssistantMode::Kairos,\n656\t        policy_enabled: false,\n657\t        capability_policy: default_policy(),\n658\t        raw_input: \"/brief test\".into(),\n659\t        explicit_mode: None,\n660\t    });\n661\t\n662\t    assert_eq!(decision.source, RouteSource::Noop);\n663\t    assert!(!decision.command_consumed);\n664\t    assert!(matches!(\n665\t        decision.error.as_ref().unwrap(),\n666\t        KairosError::DisabledByPolicy\n667\t    ));\n668\t}\n669\t\n670\t/// AC: telemetry tags reflect correct mode state.\n671\t#[test]\n672\tfn cli_telemetry_tags_reflect_mode_state() {\n673\t    let service = svc();\n674\t\n675\t    let kairos = service.resolve_mode(resolve_ctx(AssistantMode::Kairos, None, default_policy()));\n676\t    assert!(kairos.telemetry_tags.kairos_active);\n677\t    assert!(!kairos.telemetry_tags.brief_active);\n678\t    assert!(!kairos.telemetry_tags.channels_active);\n679\t\n680\t    let brief = service.resolve_mode(resolve_ctx(\n681\t        AssistantMode::Kairos,\n682\t        Some(AssistantMode::KairosBrief),\n683\t        default_policy(),\n684\t    ));\n685\t    assert!(brief.telemetry_tags.kairos_active);\n686\t    assert!(brief.telemetry_tags.brief_active);\n687\t    assert!(!brief.telemetry_tags.channels_active);\n688\t\n689\t    let channels = service.resolve_mode(resolve_ctx(\n690\t        AssistantMode::Kairos,\n691\t        Some(AssistantMode::KairosChannels),\n692\t        default_policy(),\n693\t    ));\n694\t    assert!(channels.telemetry_tags.kairos_active);\n695\t    assert!(!channels.telemetry_tags.brief_active);\n696\t    assert!(channels.telemetry_tags.channels_active);\n697\t}\n698\t"}]},"parent_tool_use_id":"toolu_01KHgqaLUPdKvXjiDKih7urg","session_id":"f364ad52-4738-45a7-8cb7-9f4703f698a1","uuid":"b397e60a-e0a1-48a7-9e0b-4087bc6945dc","timestamp":"2026-04-02T14:46:35.131Z"}
