{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JYzvjyQQz6c9nR59VkqWwm","type":"tool_result","content":"1\t#[cfg(test)]\n2\tmod tests {\n3\t    use crate::{\n4\t        remote_trigger_dispatch_service::{\n5\t            PlatformRemoteTriggerDispatchService, RemoteTriggerDispatchPolicy,\n6\t            RemoteTriggerTransport,\n7\t        },\n8\t        trigger_scheduler_service::{LocalTriggerSchedulerService, TriggerSchedulerPolicy},\n9\t    };\n10\t    use ccode_application::spec_contracts::{\n11\t        RemoteTriggerDispatchService, TriggerError, TriggerOwner, TriggerSchedulerService,\n12\t        TriggerScope, TriggerTask,\n13\t    };\n14\t    use ccode_remote_runtime::ccr_client::{AuthContext, AuthContextProvider};\n15\t    use ccode_state_store::FileTriggerTaskStateStore;\n16\t    use serde_json::{Value, json};\n17\t    use std::{\n18\t        collections::VecDeque,\n19\t        sync::{Arc, Mutex},\n20\t    };\n21\t\n22\t    #[derive(Debug, Clone)]\n23\t    struct TestAuthProvider {\n24\t        ctx: AuthContext,\n25\t    }\n26\t\n27\t    impl AuthContextProvider for TestAuthProvider {\n28\t        fn auth_context(&self) -> AuthContext {\n29\t            self.ctx.clone()\n30\t        }\n31\t    }\n32\t\n33\t    #[derive(Clone)]\n34\t    struct MockRemoteTransport {\n35\t        results: Arc<Mutex<VecDeque<Result<String, String>>>>,\n36\t    }\n37\t\n38\t    impl MockRemoteTransport {\n39\t        fn with_results(results: Vec<Result<String, String>>) -> Self {\n40\t            Self {\n41\t                results: Arc::new(Mutex::new(results.into())),\n42\t            }\n43\t        }\n44\t    }\n45\t\n46\t    #[async_trait::async_trait]\n47\t    impl RemoteTriggerTransport for MockRemoteTransport {\n48\t        async fn dispatch(&self, _payload: Value, _auth: &AuthContext) -> Result<String, String> {\n49\t            self.results\n50\t                .lock()\n51\t                .expect(\"lock\")\n52\t                .pop_front()\n53\t                .expect(\"missing transport result\")\n54\t        }\n55\t    }\n56\t\n57\t    fn unique_temp_dir(label: &str) -> std::path::PathBuf {\n58\t        let ts = std::time::SystemTime::now()\n59\t            .duration_since(std::time::UNIX_EPOCH)\n60\t            .expect(\"time\")\n61\t            .as_nanos();\n62\t        let path = std::env::temp_dir().join(format!(\"ccode-us017-{label}-{ts}\"));\n63\t        std::fs::create_dir_all(&path).expect(\"create temp dir\");\n64\t        path\n65\t    }\n66\t\n67\t    fn task(id: &str) -> TriggerTask {\n68\t        TriggerTask {\n69\t            id: id.to_string(),\n70\t            cron: \"0 9 * * *\".to_string(),\n71\t            prompt: \"do work\".to_string(),\n72\t            scope: TriggerScope::SessionOnly,\n73\t            owner: TriggerOwner::MainAgent,\n74\t            durable_intent: false,\n75\t        }\n76\t    }\n77\t\n78\t    #[tokio::test]\n79\t    async fn gate_off_returns_gate_disabled() {\n80\t        let service = PlatformRemoteTriggerDispatchService::new(\n81\t            MockRemoteTransport::with_results(vec![Ok(\"rid-1\".to_string())]),\n82\t            TestAuthProvider {\n83\t                ctx: AuthContext {\n84\t                    token: Some(\"token\".to_string()),\n85\t                    org_id: Some(\"org\".to_string()),\n86\t                },\n87\t            },\n88\t            RemoteTriggerDispatchPolicy {\n89\t                remote_dispatch_enabled: false,\n90\t            },\n91\t        );\n92\t\n93\t        let err = service\n94\t            .dispatch(json!({\"task_id\": \"t-1\"}))\n95\t            .await\n96\t            .expect_err(\"gate should block dispatch\");\n97\t\n98\t        assert!(matches!(err, TriggerError::GateDisabled));\n99\t    }\n100\t\n101\t    #[tokio::test]\n102\t    async fn missing_auth_or_org_returns_unauthorized() {\n103\t        let missing_token = PlatformRemoteTriggerDispatchService::new(\n104\t            MockRemoteTransport::with_results(vec![Ok(\"rid-1\".to_string())]),\n105\t            TestAuthProvider {\n106\t                ctx: AuthContext {\n107\t                    token: None,\n108\t                    org_id: Some(\"org\".to_string()),\n109\t                },\n110\t            },\n111\t            RemoteTriggerDispatchPolicy {\n112\t                remote_dispatch_enabled: true,\n113\t            },\n114\t        );\n115\t\n116\t        let token_err = missing_token\n117\t            .dispatch(json!({\"task_id\": \"t-1\"}))\n118\t            .await\n119\t            .expect_err(\"missing token should fail\");\n120\t        assert!(matches!(token_err, TriggerError::Unauthorized));\n121\t\n122\t        let missing_org = PlatformRemoteTriggerDispatchService::new(\n123\t            MockRemoteTransport::with_results(vec![Ok(\"rid-2\".to_string())]),\n124\t            TestAuthProvider {\n125\t                ctx: AuthContext {\n126\t                    token: Some(\"token\".to_string()),\n127\t                    org_id: None,\n128\t                },\n129\t            },\n130\t            RemoteTriggerDispatchPolicy {\n131\t                remote_dispatch_enabled: true,\n132\t            },\n133\t        );\n134\t\n135\t        let org_err = missing_org\n136\t            .dispatch(json!({\"task_id\": \"t-1\"}))\n137\t            .await\n138\t            .expect_err(\"missing org should fail\");\n139\t        assert!(matches!(org_err, TriggerError::Unauthorized));\n140\t    }\n141\t\n142\t    #[tokio::test]\n143\t    async fn transport_errors_map_to_non_leaky_upstream_remote_error() {\n144\t        let service = PlatformRemoteTriggerDispatchService::new(\n145\t            MockRemoteTransport::with_results(vec![Err(\"http 500: leaked detail\".to_string())]),\n146\t            TestAuthProvider {\n147\t                ctx: AuthContext {\n148\t                    token: Some(\"token\".to_string()),\n149\t                    org_id: Some(\"org\".to_string()),\n150\t                },\n151\t            },\n152\t            RemoteTriggerDispatchPolicy {\n153\t                remote_dispatch_enabled: true,\n154\t            },\n155\t        );\n156\t\n157\t        let err = service\n158\t            .dispatch(json!({\"task_id\": \"t-1\"}))\n159\t            .await\n160\t            .expect_err(\"transport failure should map to stable upstream error\");\n161\t\n162\t        assert!(matches!(err, TriggerError::UpstreamRemoteError));\n163\t        assert_eq!(err.to_string(), \"upstream remote error\");\n164\t    }\n165\t\n166\t    #[tokio::test]\n167\t    async fn local_scheduler_still_works_when_remote_dispatch_is_disabled() {\n168\t        let dir = unique_temp_dir(\"local-independent\");\n169\t        let store = Arc::new(FileTriggerTaskStateStore::new(&dir).expect(\"store\"));\n170\t        let scheduler = LocalTriggerSchedulerService::new(store, TriggerSchedulerPolicy::default())\n171\t            .await\n172\t            .expect(\"scheduler\");\n173\t\n174\t        scheduler\n175\t            .create(task(\"local-1\"))\n176\t            .await\n177\t            .expect(\"create local\");\n178\t        let local_tasks = scheduler.list().await.expect(\"list local\");\n179\t        assert_eq!(local_tasks.len(), 1);\n180\t\n181\t        let remote = PlatformRemoteTriggerDispatchService::new(\n182\t            MockRemoteTransport::with_results(vec![Ok(\"rid-1\".to_string())]),\n183\t            TestAuthProvider {\n184\t                ctx: AuthContext {\n185\t                    token: Some(\"token\".to_string()),\n186\t                    org_id: Some(\"org\".to_string()),\n187\t                },\n188\t            },\n189\t            RemoteTriggerDispatchPolicy {\n190\t                remote_dispatch_enabled: false,\n191\t            },\n192\t        );\n193\t\n194\t        let err = remote\n195\t            .dispatch(json!({\"task_id\": \"local-1\"}))\n196\t            .await\n197\t            .expect_err(\"remote dispatch should remain disabled\");\n198\t        assert!(matches!(err, TriggerError::GateDisabled));\n199\t\n200\t        let local_tasks_after = scheduler.list().await.expect(\"list local after\");\n201\t        assert_eq!(local_tasks_after.len(), 1);\n202\t        assert_eq!(local_tasks_after[0].id, \"local-1\");\n203\t    }\n204\t}\n205\t"}]},"parent_tool_use_id":null,"session_id":"f364ad52-4738-45a7-8cb7-9f4703f698a1","uuid":"7668af27-53cb-4061-b902-6fad39953194","timestamp":"2026-04-02T14:47:40.815Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/platform/src/remote_trigger_dispatch_service_tests.rs","content":"#[cfg(test)]\nmod tests {\n    use crate::{\n        remote_trigger_dispatch_service::{\n            PlatformRemoteTriggerDispatchService, RemoteTriggerDispatchPolicy,\n            RemoteTriggerTransport,\n        },\n        trigger_scheduler_service::{LocalTriggerSchedulerService, TriggerSchedulerPolicy},\n    };\n    use ccode_application::spec_contracts::{\n        RemoteTriggerDispatchService, TriggerError, TriggerOwner, TriggerSchedulerService,\n        TriggerScope, TriggerTask,\n    };\n    use ccode_remote_runtime::ccr_client::{AuthContext, AuthContextProvider};\n    use ccode_state_store::FileTriggerTaskStateStore;\n    use serde_json::{Value, json};\n    use std::{\n        collections::VecDeque,\n        sync::{Arc, Mutex},\n    };\n\n    #[derive(Debug, Clone)]\n    struct TestAuthProvider {\n        ctx: AuthContext,\n    }\n\n    impl AuthContextProvider for TestAuthProvider {\n        fn auth_context(&self) -> AuthContext {\n            self.ctx.clone()\n        }\n    }\n\n    #[derive(Clone)]\n    struct MockRemoteTransport {\n        results: Arc<Mutex<VecDeque<Result<String, String>>>>,\n    }\n\n    impl MockRemoteTransport {\n        fn with_results(results: Vec<Result<String, String>>) -> Self {\n            Self {\n                results: Arc::new(Mutex::new(results.into())),\n            }\n        }\n    }\n\n    #[async_trait::async_trait]\n    impl RemoteTriggerTransport for MockRemoteTransport {\n        async fn dispatch(&self, _payload: Value, _auth: &AuthContext) -> Result<String, String> {\n            self.results\n                .lock()\n                .expect(\"lock\")\n                .pop_front()\n                .expect(\"missing transport result\")\n        }\n    }\n\n    fn unique_temp_dir(label: &str) -> std::path::PathBuf {\n        let ts = std::time::SystemTime::now()\n            .duration_since(std::time::UNIX_EPOCH)\n            .expect(\"time\")\n            .as_nanos();\n        let path = std::env::temp_dir().join(format!(\"ccode-us017-{label}-{ts}\"));\n        std::fs::create_dir_all(&path).expect(\"create temp dir\");\n        path\n    }\n\n    fn task(id: &str) -> TriggerTask {\n        TriggerTask {\n            id: id.to_string(),\n            cron: \"0 9 * * *\".to_string(),\n            prompt: \"do work\".to_string(),\n            scope: TriggerScope::SessionOnly,\n            owner: TriggerOwner::MainAgent,\n            durable_intent: false,\n        }\n    }\n\n    #[tokio::test]\n    async fn gate_off_returns_gate_disabled() {\n        let service = PlatformRemoteTriggerDispatchService::new(\n            MockRemoteTransport::with_results(vec![Ok(\"rid-1\".to_string())]),\n            TestAuthProvider {\n                ctx: AuthContext {\n                    token: Some(\"token\".to_string()),\n                    org_id: Some(\"org\".to_string()),\n                },\n            },\n            RemoteTriggerDispatchPolicy {\n                remote_dispatch_enabled: false,\n            },\n        );\n\n        let err = service\n            .dispatch(json!({\"task_id\": \"t-1\"}))\n            .await\n            .expect_err(\"gate should block dispatch\");\n\n        assert!(matches!(err, TriggerError::GateDisabled));\n    }\n\n    #[tokio::test]\n    async fn missing_auth_or_org_returns_unauthorized() {\n        let missing_token = PlatformRemoteTriggerDispatchService::new(\n            MockRemoteTransport::with_results(vec![Ok(\"rid-1\".to_string())]),\n            TestAuthProvider {\n                ctx: AuthContext {\n                    token: None,\n                    org_id: Some(\"org\".to_string()),\n                },\n            },\n            RemoteTriggerDispatchPolicy {\n                remote_dispatch_enabled: true,\n            },\n        );\n\n        let token_err = missing_token\n            .dispatch(json!({\"task_id\": \"t-1\"}))\n            .await\n            .expect_err(\"missing token should fail\");\n        assert!(matches!(token_err, TriggerError::Unauthorized));\n\n        let missing_org = PlatformRemoteTriggerDispatchService::new(\n            MockRemoteTransport::with_results(vec![Ok(\"rid-2\".to_string())]),\n            TestAuthProvider {\n                ctx: AuthContext {\n                    token: Some(\"token\".to_string()),\n                    org_id: None,\n                },\n            },\n            RemoteTriggerDispatchPolicy {\n                remote_dispatch_enabled: true,\n            },\n        );\n\n        let org_err = missing_org\n            .dispatch(json!({\"task_id\": \"t-1\"}))\n            .await\n            .expect_err(\"missing org should fail\");\n        assert!(matches!(org_err, TriggerError::Unauthorized));\n    }\n\n    #[tokio::test]\n    async fn transport_errors_map_to_non_leaky_upstream_remote_error() {\n        let service = PlatformRemoteTriggerDispatchService::new(\n            MockRemoteTransport::with_results(vec![Err(\"http 500: leaked detail\".to_string())]),\n            TestAuthProvider {\n                ctx: AuthContext {\n                    token: Some(\"token\".to_string()),\n                    org_id: Some(\"org\".to_string()),\n                },\n            },\n            RemoteTriggerDispatchPolicy {\n                remote_dispatch_enabled: true,\n            },\n        );\n\n        let err = service\n            .dispatch(json!({\"task_id\": \"t-1\"}))\n            .await\n            .expect_err(\"transport failure should map to stable upstream error\");\n\n        assert!(matches!(err, TriggerError::UpstreamRemoteError));\n        assert_eq!(err.to_string(), \"upstream remote error\");\n    }\n\n    #[tokio::test]\n    async fn local_scheduler_still_works_when_remote_dispatch_is_disabled() {\n        let dir = unique_temp_dir(\"local-independent\");\n        let store = Arc::new(FileTriggerTaskStateStore::new(&dir).expect(\"store\"));\n        let scheduler = LocalTriggerSchedulerService::new(store, TriggerSchedulerPolicy::default())\n            .await\n            .expect(\"scheduler\");\n\n        scheduler\n            .create(task(\"local-1\"))\n            .await\n            .expect(\"create local\");\n        let local_tasks = scheduler.list().await.expect(\"list local\");\n        assert_eq!(local_tasks.len(), 1);\n\n        let remote = PlatformRemoteTriggerDispatchService::new(\n            MockRemoteTransport::with_results(vec![Ok(\"rid-1\".to_string())]),\n            TestAuthProvider {\n                ctx: AuthContext {\n                    token: Some(\"token\".to_string()),\n                    org_id: Some(\"org\".to_string()),\n                },\n            },\n            RemoteTriggerDispatchPolicy {\n                remote_dispatch_enabled: false,\n            },\n        );\n\n        let err = remote\n            .dispatch(json!({\"task_id\": \"local-1\"}))\n            .await\n            .expect_err(\"remote dispatch should remain disabled\");\n        assert!(matches!(err, TriggerError::GateDisabled));\n\n        let local_tasks_after = scheduler.list().await.expect(\"list local after\");\n        assert_eq!(local_tasks_after.len(), 1);\n        assert_eq!(local_tasks_after[0].id, \"local-1\");\n    }\n}\n","numLines":205,"startLine":1,"totalLines":205}}}
