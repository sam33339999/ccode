{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RDwFRcsXuLRT5pwWggMCTM","type":"tool_result","content":"1\tuse async_trait::async_trait;\n2\tuse serde_json::Value;\n3\tuse std::path::{Path, PathBuf};\n4\t\n5\t#[derive(Debug, thiserror::Error)]\n6\tpub enum StateStoreError {\n7\t    #[error(\"storage error: {0}\")]\n8\t    Storage(String),\n9\t}\n10\t\n11\t#[async_trait]\n12\tpub trait TriggerTaskStateStore: Send + Sync {\n13\t    async fn load_trigger_tasks(&self) -> Result<Vec<Value>, StateStoreError>;\n14\t    async fn save_trigger_task(&self, id: &str, task: &Value) -> Result<(), StateStoreError>;\n15\t    async fn delete_trigger_task(&self, id: &str) -> Result<(), StateStoreError>;\n16\t}\n17\t\n18\tpub struct FileTriggerTaskStateStore {\n19\t    dir: PathBuf,\n20\t}\n21\t\n22\timpl FileTriggerTaskStateStore {\n23\t    pub fn new(root: impl AsRef<Path>) -> std::io::Result<Self> {\n24\t        let dir = root.as_ref().join(\"trigger-tasks\");\n25\t        std::fs::create_dir_all(&dir)?;\n26\t        Ok(Self { dir })\n27\t    }\n28\t\n29\t    fn path_for(&self, id: &str) -> PathBuf {\n30\t        self.dir.join(format!(\"{id}.json\"))\n31\t    }\n32\t}\n33\t\n34\t#[async_trait]\n35\timpl TriggerTaskStateStore for FileTriggerTaskStateStore {\n36\t    async fn load_trigger_tasks(&self) -> Result<Vec<Value>, StateStoreError> {\n37\t        let entries =\n38\t            std::fs::read_dir(&self.dir).map_err(|e| StateStoreError::Storage(e.to_string()))?;\n39\t        let mut tasks = Vec::new();\n40\t\n41\t        for entry in entries {\n42\t            let entry = entry.map_err(|e| StateStoreError::Storage(e.to_string()))?;\n43\t            let path = entry.path();\n44\t            if path.extension().and_then(|ext| ext.to_str()) != Some(\"json\") {\n45\t                continue;\n46\t            }\n47\t\n48\t            let data = std::fs::read(&path).map_err(|e| StateStoreError::Storage(e.to_string()))?;\n49\t            match serde_json::from_slice::<Value>(&data) {\n50\t                Ok(task) => tasks.push(task),\n51\t                Err(err) => tracing::warn!(\"skipping corrupt trigger task file {:?}: {err}\", path),\n52\t            }\n53\t        }\n54\t\n55\t        tasks.sort_by(|a, b| {\n56\t            let lhs = a.get(\"id\").and_then(Value::as_str).unwrap_or_default();\n57\t            let rhs = b.get(\"id\").and_then(Value::as_str).unwrap_or_default();\n58\t            lhs.cmp(rhs)\n59\t        });\n60\t        Ok(tasks)\n61\t    }\n62\t\n63\t    async fn save_trigger_task(&self, id: &str, task: &Value) -> Result<(), StateStoreError> {\n64\t        let path = self.path_for(id);\n65\t        let tmp = path.with_extension(\"json.tmp\");\n66\t        let data =\n67\t            serde_json::to_vec_pretty(task).map_err(|e| StateStoreError::Storage(e.to_string()))?;\n68\t        std::fs::write(&tmp, data).map_err(|e| StateStoreError::Storage(e.to_string()))?;\n69\t        std::fs::rename(&tmp, &path).map_err(|e| StateStoreError::Storage(e.to_string()))?;\n70\t        Ok(())\n71\t    }\n72\t\n73\t    async fn delete_trigger_task(&self, id: &str) -> Result<(), StateStoreError> {\n74\t        let path = self.path_for(id);\n75\t        match std::fs::remove_file(&path) {\n76\t            Ok(()) => Ok(()),\n77\t            Err(err) if err.kind() == std::io::ErrorKind::NotFound => Ok(()),\n78\t            Err(err) => Err(StateStoreError::Storage(err.to_string())),\n79\t        }\n80\t    }\n81\t}\n82\t"}]},"parent_tool_use_id":"toolu_01KHgqaLUPdKvXjiDKih7urg","session_id":"f364ad52-4738-45a7-8cb7-9f4703f698a1","uuid":"82e99480-c634-42ac-bcb7-6baeba71b660","timestamp":"2026-04-02T14:46:42.431Z"}
