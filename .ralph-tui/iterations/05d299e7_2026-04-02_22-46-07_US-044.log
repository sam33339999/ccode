{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NVa2E4Wbp52L1p7KsPk9MA","type":"tool_result","content":"1\tuse async_trait::async_trait;\n2\tuse ccode_application::spec_contracts::{\n3\t    TriggerError, TriggerOwner, TriggerSchedulerService, TriggerScope, TriggerTask,\n4\t};\n5\tuse ccode_state_store::TriggerTaskStateStore;\n6\tuse std::collections::HashMap;\n7\tuse std::sync::{Arc, Mutex};\n8\t\n9\t#[derive(Debug, Clone, Copy)]\n10\tpub struct TriggerSchedulerPolicy {\n11\t    pub scheduler_enabled: bool,\n12\t    pub durable_enabled: bool,\n13\t}\n14\t\n15\timpl Default for TriggerSchedulerPolicy {\n16\t    fn default() -> Self {\n17\t        Self {\n18\t            scheduler_enabled: true,\n19\t            durable_enabled: true,\n20\t        }\n21\t    }\n22\t}\n23\t\n24\tpub struct LocalTriggerSchedulerService {\n25\t    store: Arc<dyn TriggerTaskStateStore>,\n26\t    policy: TriggerSchedulerPolicy,\n27\t    tasks: Mutex<HashMap<String, TriggerTask>>,\n28\t}\n29\t\n30\timpl LocalTriggerSchedulerService {\n31\t    pub async fn new(\n32\t        store: Arc<dyn TriggerTaskStateStore>,\n33\t        policy: TriggerSchedulerPolicy,\n34\t    ) -> Result<Self, TriggerError> {\n35\t        let mut tasks = HashMap::new();\n36\t        let stored = store\n37\t            .load_trigger_tasks()\n38\t            .await\n39\t            .map_err(|_| TriggerError::StorageError)?;\n40\t\n41\t        for raw in stored {\n42\t            let task: TriggerTask =\n43\t                serde_json::from_value(raw).map_err(|_| TriggerError::StorageError)?;\n44\t            tasks.insert(task.id.clone(), task);\n45\t        }\n46\t\n47\t        Ok(Self {\n48\t            store,\n49\t            policy,\n50\t            tasks: Mutex::new(tasks),\n51\t        })\n52\t    }\n53\t\n54\t    fn ensure_enabled(&self) -> Result<(), TriggerError> {\n55\t        if self.policy.scheduler_enabled {\n56\t            Ok(())\n57\t        } else {\n58\t            Err(TriggerError::GateDisabled)\n59\t        }\n60\t    }\n61\t\n62\t    fn validate_create(&self, task: &TriggerTask) -> Result<(), TriggerError> {\n63\t        if ccode_cron::validate(&task.cron).is_err() {\n64\t            return Err(TriggerError::InvalidCron);\n65\t        }\n66\t\n67\t        if task.scope == TriggerScope::Durable {\n68\t            if !self.policy.durable_enabled {\n69\t                return Err(TriggerError::GateDisabled);\n70\t            }\n71\t            if !task.durable_intent {\n72\t                return Err(TriggerError::Unauthorized);\n73\t            }\n74\t            if matches!(task.owner, TriggerOwner::Teammate(_)) {\n75\t                return Err(TriggerError::DurableNotAllowedForTeammate);\n76\t            }\n77\t        }\n78\t\n79\t        Ok(())\n80\t    }\n81\t}\n82\t\n83\t#[async_trait]\n84\timpl TriggerSchedulerService for LocalTriggerSchedulerService {\n85\t    async fn create(&self, task: TriggerTask) -> Result<TriggerTask, TriggerError> {\n86\t        self.ensure_enabled()?;\n87\t        self.validate_create(&task)?;\n88\t\n89\t        if task.scope == TriggerScope::Durable {\n90\t            let data = serde_json::to_value(&task).map_err(|_| TriggerError::StorageError)?;\n91\t            self.store\n92\t                .save_trigger_task(&task.id, &data)\n93\t                .await\n94\t                .map_err(|_| TriggerError::StorageError)?;\n95\t        }\n96\t\n97\t        self.tasks\n98\t            .lock()\n99\t            .map_err(|_| TriggerError::StorageError)?\n100\t            .insert(task.id.clone(), task.clone());\n101\t\n102\t        Ok(task)\n103\t    }\n104\t\n105\t    async fn list(&self) -> Result<Vec<TriggerTask>, TriggerError> {\n106\t        self.ensure_enabled()?;\n107\t        let tasks = self.tasks.lock().map_err(|_| TriggerError::StorageError)?;\n108\t        let mut listed: Vec<TriggerTask> = tasks.values().cloned().collect();\n109\t        listed.sort_by(|a, b| a.id.cmp(&b.id));\n110\t        Ok(listed)\n111\t    }\n112\t\n113\t    async fn delete(&self, id: &str, actor: TriggerOwner) -> Result<(), TriggerError> {\n114\t        self.ensure_enabled()?;\n115\t        let found = {\n116\t            let tasks = self.tasks.lock().map_err(|_| TriggerError::StorageError)?;\n117\t            tasks.get(id).cloned()\n118\t        };\n119\t\n120\t        let task = match found {\n121\t            Some(task) => task,\n122\t            None => return Err(TriggerError::Unauthorized),\n123\t        };\n124\t\n125\t        if task.owner != actor {\n126\t            return Err(TriggerError::OwnershipViolation);\n127\t        }\n128\t\n129\t        if task.scope == TriggerScope::Durable {\n130\t            self.store\n131\t                .delete_trigger_task(id)\n132\t                .await\n133\t                .map_err(|_| TriggerError::StorageError)?;\n134\t        }\n135\t\n136\t        self.tasks\n137\t            .lock()\n138\t            .map_err(|_| TriggerError::StorageError)?\n139\t            .remove(id);\n140\t        Ok(())\n141\t    }\n142\t}\n143\t"}]},"parent_tool_use_id":"toolu_01KHgqaLUPdKvXjiDKih7urg","session_id":"f364ad52-4738-45a7-8cb7-9f4703f698a1","uuid":"ff2b4b8b-e426-4939-83a9-ca2b61132cb6","timestamp":"2026-04-02T14:46:33.979Z"}
