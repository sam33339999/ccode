}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct McpServerConfig {\n    pub name: String,\n    pub command: String,\n    #[serde(default)]\n    pub args: Vec<String>,\n    #[serde(default)]\n    pub declared_capabilities: Vec<String>,\n    #[serde(default)]\n    pub enable_computer_use: bool,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct RemoteRuntimeConfig {\n    #[serde(default)]\n    pub ccr_http: CcrHttpConfig,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct CcrHttpConfig {\n    #[serde(default = \"default_ccr_timeout_ms\")]\n    pub timeout_ms: u64,\n    #[serde(default = \"default_ccr_retry_count\")]\n    pub max_retries: u32,\n    #[serde(default = \"default_ccr_retry_delay_ms\")]\n    pub retry_delay_ms: u64,\n}\n\nimpl Default for CcrHttpConfig {\n    fn default() -> Self {\n        Self {\n            timeout_ms: default_ccr_timeout_ms(),\n            max_retries: default_ccr_retry_count(),\n            retry_delay_ms: default_ccr_retry_delay_ms(),\n        }\n    }\n}\n\nfn default_ccr_timeout_ms() -> u64 {\n    10_000\n}\n\nfn default_ccr_retry_count() -> u32 {\n    2\n}\n\nfn default_ccr_retry_delay_ms() -> u64 {\n    200\n}\n\n// ── Context / compression ─────────────────────────────────────────────────────\n\n/// Controls the agentic loop's context window management.\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct ContextConfig {\n    /// Model max context tokens, used with `compress_threshold_ratio`.\n    /// Example: `200_000`.\n    pub max_context_tokens: Option<usize>,\n    /// Compression trigger ratio against `max_context_tokens`.\n    /// Example: `0.8` means compress when estimated context reaches 80%.\n    pub compress_threshold_ratio: Option<f32>,\n    /// Trigger compression when total context exceeds this many characters\n    /// (rough estimate: 4 chars ≈ 1 token). Default: 600_000 (~150k tokens).\n    /// If set, this value overrides `max_context_tokens * compress_threshold_ratio`.\n    pub compress_chars_threshold: Option<usize>,\n    /// Number of most-recent messages to keep verbatim after compression.\n    /// Default: 8.\n    pub keep_recent_messages: Option<usize>,\n    /// Truncate a single tool result that exceeds this many characters.\n    /// Default: 40_000.\n    pub tool_result_max_chars: Option<usize>,\n    /// Maximum iterations for the agentic loop (tool-call rounds).\n    /// Default: 50.\n    pub max_agent_iterations: Option<usize>,\n    /// Default `max_tokens` sent to the LLM per request.\n    /// If unset, the provider's built-in default applies (e.g. 4096 for Anthropic).\n    pub default_max_tokens: Option<u32>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct SandboxConfig {\n    pub cwd: Option<String>,\n    /// \"any\" | \"cwd\" | \"none\"\n    pub fs_read: Option<String>,\n    /// \"any\" | \"cwd\" | \"none\"\n    pub fs_write: Option<String>,\n    /// \"any\" | \"none\" | comma-separated allowlist\n    pub shell: Option<String>,\n    pub web_fetch: Option<bool>,\n    pub browser: Option<bool>,\n}\n\n// ── Providers ─────────────────────────────────────────────────────────────────\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct ProvidersConfig {\n    pub openrouter: Option<OpenRouterConfig>,\n    pub zhipu: Option<ZhipuConfig>,\n    pub openai: Option<OpenAiConfig>,\n    pub anthropic: Option<AnthropicConfig>,\n    pub llamacpp: Option<LlamaCppConfig>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct OpenRouterConfig {\n    /// Bearer token. Falls back to `OPENROUTER_API_KEY` env var.\n    pub api_key: Option<String>,\n    /// Default model slug, e.g. `\"anthropic/claude-3-5-sonnet\"`.\n    pub default_model: Option<String>,\n    /// Override base URL (useful for local proxies).\n    pub base_url: Option<String>,\n    /// Optional HTTP `Referer` header sent to OpenRouter for attribution.\n    pub site_url: Option<St