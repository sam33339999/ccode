{"type":"item.completed","item":{"id":"item_9","type":"command_execution","command":"/bin/zsh -lc 'cat crates/config/src/schema.rs'","aggregated_output":"use serde::{Deserialize, Serialize};\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct Config {\n    #[serde(default)]\n    pub providers: ProvidersConfig,\n    #[serde(default)]\n    pub routing: RoutingConfig,\n    #[serde(default)]\n    pub mcp: McpConfig,\n    pub sandbox: Option<SandboxConfig>,\n    pub memory: Option<MemoryConfig>,\n    #[serde(default)]\n    pub context: ContextConfig,\n    #[serde(default)]\n    pub image: ImageConfig,\n    #[serde(default)]\n    pub remote_runtime: RemoteRuntimeConfig,\n    #[serde(default)]\n    pub tui: TuiConfig,\n    pub gateway: Option<GatewayConfig>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]\n#[serde(rename_all = \"snake_case\")]\npub enum ImageStrategy {\n    Resize,\n    Quantize,\n    None,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct ImageConfig {\n    #[serde(default = \"default_image_strategy\")]\n    pub strategy: Option<ImageStrategy>,\n    #[serde(default = \"default_image_max_dimension\")]\n    pub max_dimension: Option<u32>,\n}\n\nimpl Default for ImageConfig {\n    fn default() -> Self {\n        Self {\n            strategy: default_image_strategy(),\n            max_dimension: default_image_max_dimension(),\n        }\n    }\n}\n\nfn default_image_strategy() -> Option<ImageStrategy> {\n    Some(ImageStrategy::Resize)\n}\n\nfn default_image_max_dimension() -> Option<u32> {\n    Some(2048)\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct GatewayConfig {\n    pub port: Option<u16>,\n    pub workdir: Option<String>,\n    pub telegram: Option<TelegramConfig>,\n    pub discord: Option<DiscordConfig>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct TelegramConfig {\n    pub bot_token: String,\n    /// \"webhook\" (default) or \"long_polling\".\n    /// Note: Telegram does not allow both modes on the same bot token simultaneously.\n    /// Switch modes by calling deleteWebhook first if moving from webhook to long_polling.\n    pub mode: Option<String>,\n    /// Only used in webhook mode. Validates the X-Telegram-Bot-Api-Secret-Token header.\n    pub webhook_secret: Option<String>,\n}\n\nimpl TelegramConfig {\n    pub fn is_long_polling(&self) -> bool {\n        self.mode.as_deref() == Some(\"long_polling\")\n    }\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct DiscordConfig {\n    pub application_public_key: String,\n    pub bot_token: Option<String>,\n}\n\n/// TUI display and accessibility settings.\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct TuiConfig {\n    /// Color theme for the terminal UI.\n    /// Accepted values: `\"default\"` (16-color), `\"high_contrast\"` (bold+bright),\n    /// `\"no_color\"` (modifiers only).\n    /// Overridden automatically when `NO_COLOR` env var is set or `TERM=dumb`.\n    pub theme: Option<String>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct McpConfig {\n    #[serde(default)]\n    pub enable_chicago_mcp_feature_gate: bool,\n    #[serde(default)]\n    pub allow_privileged_computer_use: bool,\n    #[serde(default)]\n    pub servers: Vec<McpServerConfig>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct McpServerConfig {\n    pub name: String,\n    pub command: String,\n    #[serde(default)]\n    pub args: Vec<String>,\n    #[serde(default)]\n    pub declared_capabilities: Vec<String>,\n    #[serde(default)]\n    pub enable_computer_use: bool,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct RemoteRuntimeConfig {\n    #[serde(default)]\n    pub ccr_http: CcrHttpConfig,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct CcrHttpConfig {\n    #[serde(default = \"default_ccr_timeout_ms\")]\n    pub timeout_ms: u64,\n    #[serde(default = \"default_ccr_retry_count\")]\n    pub max_retries: u32,\n    #[serde(default = \"default_ccr_retry_delay_ms\")]\n    pub retry_delay_ms: u64,\n}\n\nimpl Default for CcrHttpConfig {\n    fn default() -> Self {\n        Self {\n            timeout_ms: default_ccr_timeout_ms(),\n            max_retries: default_ccr_retry_count(),\n            retry_delay_ms: default_ccr_retry_delay_ms(),\n        }\n    }\n}\n\nfn default_ccr_timeout_ms() -> u64 {\n    10_000\n}\n\nfn default_ccr_retry_count() -> u32 {\n    2\n}\n\nfn default_ccr_retry_delay_ms() -> u64 {\n    200\n}\n\n// ── Context / compression ─────────────────────────────────────────────────────\n\n/// Controls the agentic loop's context window management.\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct ContextConfig {\n    /// Model max context tokens, used with `compress_threshold_ratio`.\n    /// Example: `200_000`.\n    pub max_context_tokens: Option<usize>,\n    /// Compression trigger ratio against `max_context_tokens`.\n    /// Example: `0.8` means compress when estimated context reaches 80%.\n    pub compress_threshold_ratio: Option<f32>,\n    /// Trigger compression when total context exceeds this many characters\n    /// (rough estimate: 4 chars ≈ 1 token). Default: 600_000 (~150k tokens).\n    /// If set, this value overrides `max_context_tokens * compress_threshold_ratio`.\n    pub compress_chars_threshold: Option<usize>,\n    /// Number of most-recent messages to keep verbatim after compression.\n    /// Default: 8.\n    pub keep_recent_messages: Option<usize>,\n    /// Truncate a single tool result that exceeds this many characters.\n    /// Default: 40_000.\n    pub tool_result_max_chars: Option<usize>,\n    /// Maximum iterations for the agentic loop (tool-call rounds).\n    /// Default: 50.\n    pub max_agent_iterations: Option<usize>,\n    /// Default `max_tokens` sent to the LLM per request.\n    /// If unset, the provider's built-in default applies (e.g. 4096 for Anthropic).\n    pub default_max_tokens: Option<u32>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct SandboxConfig {\n    pub cwd: Option<String>,\n    /// \"any\" | \"cwd\" | \"none\"\n    pub fs_read: Option<String>,\n    /// \"any\" | \"cwd\" | \"none\"\n    pub fs_write: Option<String>,\n    /// \"any\" | \"none\" | comma-separated allowlist\n    pub shell: Option<String>,\n    pub web_fetch: Option<bool>,\n    pub browser: Option<bool>,\n}\n\n// ── Providers ─────────────────────────────────────────────────────────────────\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct ProvidersConfig {\n    pub openrouter: Option<OpenRouterConfig>,\n    pub zhipu: Option<ZhipuConfig>,\n    pub openai: Option<OpenAiConfig>,\n    pub anthropic: Option<AnthropicConfig>,\n    pub llamacpp: Option<LlamaCppConfig>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct OpenRouterConfig {\n    /// Bearer token. Falls back to `OPENROUTER_API_KEY` env var.\n    pub api_key: Option<String>,\n    /// Default model slug, e.g. `\"anthropic/claude-3-5-sonnet\"`.\n    pub default_model: Option<String>,\n    /// Override base URL (useful for local proxies).\n    pub base_url: Option<String>,\n    /// Optional HTTP `Referer` header sent to OpenRouter for attribution.\n    pub site_url: Option<String>,\n    /// Optional `X-Title` header sent to OpenRouter.\n    pub site_name: Option<String>,\n    /// Whether this provider endpoint supports vision inputs.\n    pub vision: Option<bool>,\n    /// Maximum supported model context window (tokens).\n    pub context_window: Option<usize>,\n}\n\nimpl OpenRouterConfig {\n    pub fn resolved_api_key(&self) -> Option<String> {\n        self.api_key\n            .clone()\n            .or_else(|| std::env::var(\"OPENROUTER_API_KEY\").ok())\n    }\n\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"OPENROUTER_BASE_URL\").ok())\n            .unwrap_or_else(|| \"https://openrouter.ai/api/v1\".into())\n    }\n\n    pub fn resolved_default_model(&self) -> String {\n        self.default_model\n            .clone()\n            .or_else(|| std::env::var(\"OPENROUTER_DEFAULT_MODEL\").ok())\n            .unwrap_or_else(|| \"openai/gpt-4o-mini\".into())\n    }\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct ZhipuConfig {\n    /// Bearer token. Falls back to `ZHIPU_API_KEY` env var.\n    pub api_key: Option<String>,\n    /// Default model slug, e.g. `\"glm-4-plus\"`.\n    pub default_model: Option<String>,\n    /// Override base URL (defaults to `https://api.z.ai/api/paas/v4`).\n    pub base_url: Option<String>,\n    /// Value for the `X-Title` header (required by the coding plan).\n    pub title: Option<String>,\n    /// Whether this provider endpoint supports vision inputs.\n    pub vision: Option<bool>,\n    /// Maximum supported model context window (tokens).\n    pub context_window: Option<usize>,\n}\n\nimpl ZhipuConfig {\n    pub fn resolved_api_key(&self) -> Option<String> {\n        self.api_key\n            .clone()\n            .or_else(|| std::env::var(\"ZHIPU_API_KEY\").ok())\n    }\n\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"ZHIPU_BASE_URL\").ok())\n            .unwrap_or_else(|| \"https://api.z.ai/api/paas/v4\".into())\n    }\n\n    pub fn resolved_default_model(&self) -> String {\n        self.default_model\n            .clone()\n            .or_else(|| std::env::var(\"ZHIPU_DEFAULT_MODEL\").ok())\n            .unwrap_or_else(|| \"glm-4-plus\".into())\n    }\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct OpenAiConfig {\n    pub api_key: Option<String>,\n    pub default_model: Option<String>,\n    /// Whether this provider endpoint supports vision inputs.\n    pub vision: Option<bool>,\n    /// Maximum supported model context window (tokens).\n    pub context_window: Option<usize>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct AnthropicConfig {\n    /// Bearer token. Falls back to `ANTHROPIC_API_KEY` env var.\n    pub api_key: Option<String>,\n    /// Default model slug, e.g. `\"claude-opus-4-5\"`.\n    pub default_model: Option<String>,\n    /// Override base URL. Defaults to `https://api.anthropic.com/v1`.\n    pub base_url: Option<String>,\n    /// Whether this provider endpoint supports vision inputs.\n    pub vision: Option<bool>,\n    /// Maximum supported model context window (tokens).\n    pub context_window: Option<usize>,\n}\n\nimpl AnthropicConfig {\n    pub fn resolved_api_key(&self) -> Option<String> {\n        self.api_key\n            .clone()\n            .or_else(|| std::env::var(\"ANTHROPIC_API_KEY\").ok())\n    }\n\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"ANTHROPIC_BASE_URL\").ok())\n            .unwrap_or_else(|| \"https://api.anthropic.com/v1\".into())\n    }\n\n    pub fn resolved_default_model(&self) -> String {\n        self.default_model\n            .clone()\n            .or_else(|| std::env::var(\"ANTHROPIC_DEFAULT_MODEL\").ok())\n            .unwrap_or_else(|| \"claude-opus-4-5\".into())\n    }\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct LlamaCppConfig {\n    /// Optional auth key (some llama.cpp setups enable simple auth).\n    /// Falls back to `LLAMACPP_API_KEY`. Defaults to `\"\"`.\n    pub api_key: Option<String>,\n    /// Falls back to `LLAMACPP_BASE_URL`. Defaults to `http://127.0.0.1:8080/v1`.\n    pub base_url: Option<String>,\n    /// Falls back to `LLAMACPP_DEFAULT_MODEL`. Defaults to `\"default\"` (ignored by server).\n    pub default_model: Option<String>,\n    /// Whether this provider endpoint supports vision inputs.\n    pub vision: Option<bool>,\n    /// Maximum supported model context window (tokens).\n    pub context_window: Option<usize>,\n}\n\nimpl LlamaCppConfig {\n    pub fn resolved_api_key(&self) -> String {\n        self.api_key\n            .clone()\n            .or_else(|| std::env::var(\"LLAMACPP_API_KEY\").ok())\n            .unwrap_or_default()\n    }\n\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"LLAMACPP_BASE_URL\").ok())\n            .unwrap_or_else(|| \"http://127.0.0.1:8080/v1\".into())\n    }\n\n    pub fn resolved_default_model(&self) -> String {\n        self.default_model\n            .clone()\n            .or_else(|| std::env::var(\"LLAMACPP_DEFAULT_MODEL\").ok())\n            .unwrap_or_else(|| \"default\".into())\n    }\n}\n\n// ── Routing ───────────────────────────────────────────────────────────────────\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct RoutingConfig {\n    /// `manual` | `failover` | `round_robin` | `cost_optimized`\n    #[serde(default = \"default_strategy\")]\n    pub strategy: String,\n    /// Provider name used when strategy = \"manual\" or as primary for failover.\n    pub default_provider: Option<String>,\n}\n\nfn default_strategy() -> String {\n    \"manual\".into()\n}\n\nimpl Default for RoutingConfig {\n    fn default() -> Self {\n        Self {\n            strategy: default_strategy(),\n            default_provider: None,\n        }\n    }\n}\n\n// ── Memory ────────────────────────────────────────────────────────────────────\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct MemoryConfig {\n    /// \"fts5\"（預設，不需 embedding）| \"vector\"（需設定 embedding provider）\n    #[serde(default = \"default_memory_backend\")]\n    pub backend: String,\n    /// SQLite 資料庫路徑。None = ~/.ccode/memory.db\n    pub db_path: Option<String>,\n    /// Embedding provider 設定（backend = \"vector\" 時需要）\n    pub embedding: Option<EmbeddingConfig>,\n}\n\nfn default_memory_backend() -> String {\n    \"fts5\".into()\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct EmbeddingConfig {\n    /// \"openai\" | \"llamacpp\" | \"zhipu\"\n    pub provider: Option<String>,\n    pub openai: Option<EmbeddingOpenAiConfig>,\n    pub llamacpp: Option<EmbeddingLlamaCppConfig>,\n    pub zhipu: Option<EmbeddingZhipuConfig>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct EmbeddingOpenAiConfig {\n    /// env: OPENAI_API_KEY\n    pub api_key: Option<String>,\n    /// env: OPENAI_EMBEDDING_MODEL，預設 \"text-embedding-3-small\"\n    pub model: Option<String>,\n    /// env: OPENAI_BASE_URL，預設 \"https://api.openai.com/v1\"\n    pub base_url: Option<String>,\n}\n\nimpl EmbeddingOpenAiConfig {\n    pub fn resolved_api_key(&self) -> Option<String> {\n        self.api_key\n            .clone()\n            .or_else(|| std::env::var(\"OPENAI_API_KEY\").ok())\n    }\n    pub fn resolved_model(&self) -> String {\n        self.model\n            .clone()\n            .or_else(|| std::env::var(\"OPENAI_EMBEDDING_MODEL\").ok())\n            .unwrap_or_else(|| \"text-embedding-3-small\".into())\n    }\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"OPENAI_BASE_URL\").ok())\n            .unwrap_or_else(|| \"https://api.openai.com/v1\".into())\n    }\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct EmbeddingLlamaCppConfig {\n    /// env: LLAMACPP_BASE_URL，預設 \"http://127.0.0.1:8080/v1\"\n    pub base_url: Option<String>,\n    /// env: LLAMACPP_EMBEDDING_MODEL，預設 \"default\"\n    pub model: Option<String>,\n    /// env: LLAMACPP_API_KEY，預設 \"\"\n    pub api_key: Option<String>,\n}\n\nimpl EmbeddingLlamaCppConfig {\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"LLAMACPP_BASE_URL\").ok())\n            .unwrap_or_else(|| \"http://127.0.0.1:8080/v1\".into())\n    }\n    pub