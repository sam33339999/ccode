{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' crates/provider/src/openrouter/adapter.rs\"","aggregated_output":"use crate::openai_compat::OpenAiCompatAdapter;\nuse async_trait::async_trait;\nuse ccode_ports::provider::{\n    LlmClient, LlmError, LlmRequest, LlmResponse, LlmStream, ProviderCapabilities,\n};\n\npub struct OpenRouterAdapter {\n    adapter: OpenAiCompatAdapter,\n}\n\nimpl OpenRouterAdapter {\n    pub fn new(\n        api_key: impl Into<String>,\n        base_url: impl Into<String>,\n        default_model: impl Into<String>,\n        site_url: Option<String>,\n        site_name: Option<String>,\n        vision: bool,\n        context_window: Option<usize>,\n    ) -> Self {\n        let mut extra_headers = Vec::new();\n        if let Some(url) = site_url {\n            extra_headers.push((\"HTTP-Referer\".into(), url));\n        }\n        if let Some(name) = site_name {\n            extra_headers.push((\"X-Title\".into(), name));\n        }\n        Self {\n            adapter: OpenAiCompatAdapter::new(\n                \"openrouter\",\n                api_key,\n                base_url,\n                default_model,\n                extra_headers,\n                ProviderCapabilities {\n                    vision,\n                    context_window,\n                },\n            ),\n        }\n    }\n}\n\n#[async_trait]\nimpl LlmClient for OpenRouterAdapter {\n    fn name(&self) -> &str {\n        self.adapter.name()\n    }\n\n    fn default_model(&self) -> &str {\n        self.adapter.default_model()\n    }\n\n    fn capabilities(&self) -> ProviderCapabilities {\n        self.adapter.capabilities()\n    }\n\n    async fn health_check(&self) -> Result<(), LlmError> {\n        self.adapter.health_check().await\n    }\n\n    async fn complete(&self, req: LlmRequest) -> Result<LlmResponse, LlmError> {\n        self.adapter.complete(req).await\n    }\n\n    async fn stream(&self, req: LlmRequest) -> Result<LlmStream, LlmError> {\n        self.adapter.stream(req).await\n    }\n}\n","exit_code":0,"status":"completed"}}
