e(\"Review command arguments and configuration values.\".to_string()),\n            ctx,\n        ),\n        ErrorCategory::State => {\n            if lower.contains(\"not found\") {\n                ErrorEnvelope::new(\n                    ErrorCategory::State,\n                    \"Requested resource was not found.\",\n                    None,\n                    ctx,\n                )\n            } else if lower.contains(\"invalid state\") {\n                ErrorEnvelope::new(\n                    ErrorCategory::State,\n","exit_code":0,"status":"completed"}}
