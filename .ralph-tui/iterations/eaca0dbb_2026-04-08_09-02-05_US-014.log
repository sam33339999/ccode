geData::Base64(\"aGVsbG8=\".to_string()),\ncrates/application/src/commands/agent_run.rs:950:    async fn run_with_images_attaches_to_first_user_message() {\ncrates/application/src/commands/agent_run.rs:966:                \"describe image\".to_string(),\ncrates/application/src/commands/agent_run.rs:967:                vec![ImageSource {\ncrates/application/src/commands/agent_run.rs:968:                    media_type: ImageMediaType::Png,\ncrates/application/src/commands/agent_run.rs:969:                    data: ImageData::Base64(\"aGVsbG8=\".to_string()),\ncrates/application/src/commands/agent_run.rs:989:        assert_eq!(user.content, \"describe image\");\ncrates/application/src/commands/agent_run.rs:990:        let attachments = user.attachments.as_ref().expect(\"attachments exist\");\ncrates/application/src/commands/agent_run.rs:991:        assert_eq!(attachments.len(), 1);\n","exit_code":0,"status":"completed"}}
