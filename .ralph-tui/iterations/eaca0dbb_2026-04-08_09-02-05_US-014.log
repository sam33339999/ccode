on/src/commands/agent_run.rs:88:type ExecuteToolFn = dyn Fn(String, serde_json::Value) -> Pin<Box<dyn Future<Output = Result<String, String>> + Send>>\ncrates/application/src/commands/agent_run.rs:89:    + Send\ncrates/application/src/commands/agent_run.rs:103:pub trait ComputerUseLifecycle: Send + Sync {\ncrates/application/src/commands/agent_run.rs:174:        images: Vec<ImageSource>,\ncrates/application/src/commands/agent_run.rs:176:        on_delta: &(dyn Fn(String) + Send + Sync),\ncrates/application/src/commands/agent_run.rs:184:                images,\ncrates/application/src/commands/agent_run.rs:199:        images: Vec<ImageSource>,\ncrates/application/src/commands/agent_run.rs:201:        on_delta: &(dyn Fn(String) + Send + Sync),\ncrates/application/src/commands/agent_run.rs:229:        if !images.is_empty() && !self.provider.capabilities().vision {\ncrates/application/src/commands/agent_run.rs:238:        if !images.is_empty() {\ncrates/application/src/commands/agent_run.rs:239:            user_message.attachments = Some(\ncrates/application/src/commands/agent_run.rs:240:                images\ncrates/application/src/commands/agent_run.rs:242:                    .map(image_source_to_attachment)\ncrates/application/src/commands/agent_run.rs:576:pub fn estimate_image_context_tokens(provider_name: &str) -> usize {\ncrates/application/src/commands/agent_run.rs:578:        ANTHROPIC_IMAGE_CONTEXT_TOKENS\ncrates/application/src/commands/agent_run.rs:580:        DEFAULT_IMAGE_CONTEXT_TOKENS\ncrates/application/src/commands/agent_run.rs:586:    let image_chars = message\ncrates/application/src/commands/agent_run.rs:587:        .attachments\ncrates/application/src/commands/agent_run.rs:589:        .map(|attachments| {\ncrates/application/src/commands/agent_run.rs:590:            attachments.len()\ncrates/application/src/commands/agent_run.rs:591:                * estimate_image_context_tokens(provider_name)\ncrates/application/src/commands/agent_run.rs:595:    te