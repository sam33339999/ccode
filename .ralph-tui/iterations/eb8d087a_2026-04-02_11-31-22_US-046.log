{"type":"item.completed","item":{"id":"item_17","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' crates/ports/src/lib.rs && sed -n '1,260p' crates/ports/src/provider.rs && sed -n '1,260p' crates/ports/src/cron.rs && sed -n '1,260p' crates/ports/src/memory.rs && sed -n '1,260p' crates/ports/src/tool.rs && sed -n '1,260p' crates/ports/src/event_bus.rs && sed -n '1,260p' crates/ports/src/repositories.rs\"","aggregated_output":"pub mod cron;\npub mod embedding;\npub mod event_bus;\npub mod memory;\npub mod provider;\npub mod repositories;\npub mod tool;\n\nuse thiserror::Error;\n\n#[derive(Debug, Error)]\npub enum PortError {\n    #[error(\"not found\")]\n    NotFound,\n    #[error(\"storage error: {0}\")]\n    Storage(String),\n    #[error(\"provider error: {0}\")]\n    Provider(String),\n    #[error(\"channel error: {0}\")]\n    Channel(String),\n    #[error(\"tool error: {0}\")]\n    Tool(String),\n    #[error(\"permission denied: {0}\")]\n    PermissionDenied(String),\n}\nuse crate::PortError;\nuse async_trait::async_trait;\nuse ccode_domain::message::Message;\nuse futures_core::Stream;\nuse std::pin::Pin;\n\n// ── Tool definitions ───────────────────────────────────────────────────────────\n\n#[derive(Debug, Clone)]\npub struct ToolDefinition {\n    pub name: String,\n    pub description: String,\n    pub parameters: serde_json::Value,\n}\n\n// ── Request / Response types ───────────────────────────────────────────────────\n\n#[derive(Debug, Clone)]\npub struct CompletionRequest {\n    pub messages: Vec<Message>,\n    pub model: Option<String>, // None → use provider's default_model\n    pub max_tokens: Option<u32>,\n    pub temperature: Option<f32>,\n    pub tools: Vec<ToolDefinition>,\n}\n\n#[derive(Debug, Clone)]\npub struct CompletionResponse {\n    pub content: String,\n    pub model: String,\n    pub usage: Option<TokenUsage>,\n}\n\n#[derive(Debug, Clone)]\npub struct TokenUsage {\n    pub prompt_tokens: u32,\n    pub completion_tokens: u32,\n    pub total_tokens: u32,\n}\n\n#[derive(Debug, Clone)]\npub enum StreamEvent {\n    /// Incremental content delta from the model.\n    Delta { content: String },\n    /// One or more tool calls produced by the model.\n    ToolCallDone {\n        tool_calls: Vec<ccode_domain::message::ToolCall>,\n    },\n    /// Stream finished. May include final usage stats.\n    Done { usage: Option<TokenUsage> },\n}\n\npub type ProviderStream = Pin<Box<dyn Stream<Item = Result<StreamEvent, PortError>> + Send>>;\n\n// ── Provider port trait ────────────────────────────────────────────────────────\n\n#[async_trait]\npub trait ProviderPort: Send + Sync {\n    /// Provider identifier used in routing and logging.\n    fn name(&self) -> &str;\n\n    /// Default model for this provider.\n    fn default_model(&self) -> &str;\n\n    /// Liveness check.\n    async fn health_check(&self) -> Result<(), PortError>;\n\n    /// Single-shot completion (waits for full response).\n    async fn complete(&self, req: CompletionRequest) -> Result<CompletionResponse, PortError>;\n\n    /// Streaming completion — returns a stream of incremental events.\n    async fn stream_complete(&self, req: CompletionRequest) -> Result<ProviderStream, PortError>;\n}\nuse crate::PortError;\nuse async_trait::async_trait;\nuse ccode_domain::cron::{CronJob, CronJobId};\nuse std::sync::Arc;\n\n#[async_trait]\npub trait CronRepository: Send + Sync {\n    async fn list(&self) -> Result<Vec<CronJob>, PortError>;\n    async fn find_by_id(&self, id: &CronJobId) -> Result<Option<CronJob>, PortError>;\n    async fn save(&self, job: &CronJob) -> Result<(), PortError>;\n    async fn delete(&self, id: &CronJobId) -> Result<(), PortError>;\n}\n\n#[async_trait]\nimpl<T: CronRepository + ?Sized> CronRepository for Arc<T> {\n    async fn list(&self) -> Result<Vec<CronJob>, PortError> {\n        (**self).list().await\n    }\n    async fn find_by_id(&self, id: &CronJobId) -> Result<Option<CronJob>, PortError> {\n        (**self).find_by_id(id).await\n    }\n    async fn save(&self, job: &CronJob) -> Result<(), PortError> {\n        (**self).save(job).await\n    }\n    async fn delete(&self, id: &CronJobId) -> Result<(), PortError> {\n        (**self).delete(id).await\n    }\n}\nuse crate::PortError;\nuse async_trait::async_trait;\nuse serde::{Deserialize, Serialize};\nuse std::sync::Arc;\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct MemoryEntry {\n    pub id: String,\n    pub content: String,\n    pub tags: Vec<String>,\n    pub session_id: Option<String>,\n    pub created_at: u64,\n    /// 任意附加資料（JSON object）\n    pub metadata: serde_json::Value,\n}\n\n#[async_trait]\npub trait MemoryPort: Send + Sync {\n    /// 儲存一筆記憶，回傳其 id（由實作自行生成 uuid 或自定格式）\n    async fn store(&self, entry: MemoryEntry) -> Result<String, PortError>;\n    /// 全文搜尋，回傳最相關的 limit 筆\n    async fn search(&self, query: &str, limit: usize) -> Result<Vec<MemoryEntry>, PortError>;\n    /// 刪除指定 id\n    async fn delete(&self, id: &str) -> Result<(), PortError>;\n    /// 列出（可依 session_id 篩選），回傳最新的 limit 筆\n    async fn list(\n        &self,\n        session_id: Option<&str>,\n        limit: usize,\n    ) -> Result<Vec<MemoryEntry>, PortError>;\n}\n\n// Arc blanket impl\n#[async_trait]\nimpl<T: MemoryPort + ?Sized> MemoryPort for Arc<T> {\n    async fn store(&self, entry: MemoryEntry) -> Result<String, PortError> {\n        (**self).store(entry).await\n    }\n    async fn search(&self, query: &str, limit: usize) -> Result<Vec<MemoryEntry>, PortError> {\n        (**self).search(query, limit).await\n    }\n    async fn delete(&self, id: &str) -> Result<(), PortError> {\n        (**self).delete(id).await\n    }\n    async fn list(\n        &self,\n        session_id: Option<&str>,\n        limit: usize,\n    ) -> Result<Vec<MemoryEntry>, PortError> {\n        (**self).list(session_id, limit).await\n    }\n}\nuse crate::{PortError, provider::ToolDefinition};\nuse async_trait::async_trait;\nuse serde_json::Value;\nuse std::path::PathBuf;\nuse std::sync::Arc;\n\n#[derive(Debug, Clone)]\npub struct ToolContext {\n    pub cwd: PathBuf,\n    pub permission: Permission,\n}\n\n#[derive(Debug, Clone)]\npub struct Permission {\n    pub fs_read: FsPolicy,\n    pub fs_write: FsPolicy,\n    pub shell: ShellPolicy,\n    pub web_fetch: bool,\n    pub browser: bool,\n}\n\n#[derive(Debug, Clone)]\npub enum FsPolicy {\n    None,\n    Cwd,\n    Any,\n    Paths(Vec<PathBuf>),\n}\n\n#[derive(Debug, Clone)]\npub enum ShellPolicy {\n    None,\n    Any,\n    Allowlist(Vec<String>),\n}\n\nimpl Default for Permission {\n    fn default() -> Self {\n        Self {\n            fs_read: FsPolicy::Any,\n            fs_write: FsPolicy::Any,\n            shell: ShellPolicy::Any,\n            web_fetch: true,\n            browser: true,\n        }\n    }\n}\n\nimpl ToolContext {\n    pub fn new(cwd: PathBuf) -> Self {\n        Self {\n            cwd,\n            permission: Permission::default(),\n        }\n    }\n}\n\n#[async_trait]\npub trait ToolPort: Send + Sync {\n    fn name(&self) -> &str;\n    fn description(&self) -> &str;\n    fn parameters_schema(&self) -> Value;\n    fn definition(&self) -> ToolDefinition {\n        ToolDefinition {\n            name: self.name().to_string(),\n            description: self.description().to_string(),\n            parameters: self.parameters_schema(),\n        }\n    }\n    async fn execute(&self, args: Value, ctx: &ToolContext) -> Result<String, PortError>;\n}\n\n#[async_trait]\nimpl<T: ToolPort + ?Sized> ToolPort for Arc<T> {\n    fn name(&self) -> &str {\n        (**self).name()\n    }\n    fn description(&self) -> &str {\n        (**self).description()\n    }\n    fn parameters_schema(&self) -> Value {\n        (**self).parameters_schema()\n    }\n    async fn execute(&self, args: Value, ctx: &ToolContext) -> Result<String, PortError> {\n        (**self).execute(args, ctx).await\n    }\n}\nuse crate::PortError;\nuse async_trait::async_trait;\nuse ccode_domain::event::DomainEvent;\n\n#[async_trait]\npub trait EventBusPort: Send + Sync {\n    async fn publish(&self, event: DomainEvent) -> Result<(), PortError>;\n}\nuse crate::PortError;\nuse async_trait::async_trait;\nuse ccode_domain::session::{Session, SessionId, SessionSummary};\nuse std::sync::Arc;\n\n#[async_trait]\npub trait SessionRepository: Send + Sync {\n    async fn list(&self, limit: usize) -> Result<Vec<SessionSummary>, PortError>;\n    async fn find_by_id(&self, id: &SessionId) -> Result<Option<Session>, PortError>;\n    async fn save(&self, session: &Session) -> Result<(), PortError>;\n    async fn delete(&self, id: &SessionId) -> Result<(), PortError>;\n}\n\n/// Blanket impl so `Arc<dyn SessionRepository>` can be passed as a concrete `R: SessionRepository`.\n#[async_trait]\nimpl<T: SessionRepository + ?Sized> SessionRepository for Arc<T> {\n    async fn list(&self, limit: usize) -> Result<Vec<SessionSummary>, PortError> {\n        (**self).list(limit).await\n    }\n    async fn find_by_id(&self, id: &SessionId) -> Result<Option<Session>, PortError> {\n        (**self).find_by_id(id).await\n    }\n    async fn save(&self, session: &Session) -> Result<(), PortError> {\n        (**self).save(session).await\n    }\n    async fn delete(&self, id: &SessionId) -> Result<(), PortError> {\n        (**self).delete(id).await\n    }\n}\n","exit_code":0,"status":"completed"}}
