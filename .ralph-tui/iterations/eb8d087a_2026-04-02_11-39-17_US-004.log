pub async fn run(action: Action) -> anyhow::Result<()> {
    let state = wire_from_config_with_cwd(std::env::current_dir().ok())
        .map_err(|e| anyhow::anyhow!("bootstrap error: {e}"))?;

    match action {
        Action::List { limit } => list(Arc::clone(&state.session_repo), limit).await,
        Action::Show { id } => show(Arc::clone(&state.session_repo), id).await,
        Action::Delete { id } => delete(Arc::clone(&state.session_repo), id).await,
        Action::Clear => clear(Arc::clone(&state.session_repo)).await,
    }
}

