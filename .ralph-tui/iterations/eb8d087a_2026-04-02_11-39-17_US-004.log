{"type":"item.completed","item":{"id":"item_60","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,280p' crates/cli/src/cmd/sessions.rs\"","aggregated_output":"use ccode_application::queries::sessions_list::SessionsListQuery;\nuse ccode_bootstrap::wire_from_config_with_cwd;\nuse ccode_domain::message::Role;\nuse ccode_domain::session::{Session, SessionId, SessionSummary};\nuse clap::Subcommand;\nuse std::io::{self, Write};\nuse std::sync::Arc;\n\n#[derive(Subcommand)]\npub enum Action {\n    /// List recent sessions\n    List {\n        /// Maximum number of sessions to show\n        #[arg(long, default_value_t = 20)]\n        limit: usize,\n    },\n    /// Show full content of a session\n    Show {\n        /// Session ID\n        id: String,\n    },\n    /// Delete a session by ID\n    Delete {\n        /// Session ID\n        id: String,\n    },\n    /// Delete all sessions (with confirmation prompt)\n    Clear,\n}\n\npub async fn run(action: Action) -> anyhow::Result<()> {\n    let state = wire_from_config_with_cwd(std::env::current_dir().ok())\n        .map_err(|e| anyhow::anyhow!(\"bootstrap error: {e}\"))?;\n\n    match action {\n        Action::List { limit } => list(Arc::clone(&state.session_repo), limit).await,\n        Action::Show { id } => show(Arc::clone(&state.session_repo), id).await,\n        Action::Delete { id } => delete(Arc::clone(&state.session_repo), id).await,\n        Action::Clear => clear(Arc::clone(&state.session_repo)).await,\n    }\n}\n\nasync fn list(repo: Arc<dyn ccode_ports::repositories::SessionRepository>, limit: usize) -> anyhow::Result<()> {\n    let sessions = SessionsListQuery::new(repo)\n        .execute(limit)\n        .await?;\n\n    if sessions.is_empty() {\n        println!(\"No sessions.\");\n        return Ok(());\n    }\n\n    println!(\"{:<36}  {:>4}  timestamp\", \"id\", \"msgs\");\n    println!(\"{}\", \"─\".repeat(66));\n    for s in &sessions {\n        println!(\"{}\", render_session_summary_line(s));\n    }\n    Ok(())\n}\n\nasync fn show(\n    repo: Arc<dyn ccode_ports::repositories::SessionRepository>,\n    id: String,\n) -> anyhow::Result<()> {\n    let session_id = SessionId(id.clone());\n    let session = repo\n        .find_by_id(&session_id)\n        .await?\n        .ok_or_else(|| anyhow::anyhow!(\"session not found: {id}\"))?;\n    println!(\"{}\", render_session_detail(&session));\n    Ok(())\n}\n\nasync fn delete(\n    repo: Arc<dyn ccode_ports::repositories::SessionRepository>,\n    id: String,\n) -> anyhow::Result<()> {\n    let session_id = SessionId(id.clone());\n    let exists = repo.find_by_id(&session_id).await?.is_some();\n    if !exists {\n        return Err(anyhow::anyhow!(\"session not found: {id}\"));\n    }\n    repo.delete(&session_id).await?;\n    println!(\"Deleted session: {id}\");\n    Ok(())\n}\n\nasync fn clear(repo: Arc<dyn ccode_ports::repositories::SessionRepository>) -> anyhow::Result<()> {\n    print!(\"Delete ALL sessions? Type 'yes' to continue: \");\n    io::stdout().flush()?;\n\n    let mut input = String::new();\n    io::stdin().read_line(&mut input)?;\n    if !is_clear_confirmed(&input) {\n        println!(\"Aborted.\");\n        return Ok(());\n    }\n\n    let sessions = repo.list(usize::MAX).await?;\n    for summary in sessions {\n        repo.delete(&summary.id).await?;\n    }\n    println!(\"Deleted all sessions.\");\n    Ok(())\n}\n\nfn render_session_summary_line(s: &SessionSummary) -> String {\n    format!(\n        \"{:<36}  {:>4}  {}\",\n        s.id,\n        s.message_count,\n        format_timestamp(s.updated_at)\n    )\n}\n\nfn render_session_detail(session: &Session) -> String {\n    let mut out = String::new();\n    out.push_str(&format!(\"id: {}\\n\", session.id));\n    out.push_str(&format!(\"created_at: {}\\n\", format_timestamp(session.created_at)));\n    out.push_str(&format!(\"updated_at: {}\\n\", format_timestamp(session.updated_at)));\n    out.push_str(&format!(\"messages: {}\\n\", session.messages.len()));\n    out.push('\\n');\n\n    for m in &session.messages {\n        out.push_str(&format!(\n            \"[{}] {} ({})\\n{}\\n\\n\",\n            m.id.0,\n            role_label(&m.role),\n            format_timestamp(m.created_at),\n            m.content\n        ));\n    }\n    out\n}\n\nfn format_timestamp(ms: u64) -> String {\n    let seconds = (ms / 1000) as i64;\n    let nanos = ((ms % 1000) * 1_000_000) as u32;\n    match chrono::DateTime::<chrono::Utc>::from_timestamp(seconds, nanos) {\n        Some(ts) => ts.to_rfc3339(),\n        None => ms.to_string(),\n    }\n}\n\nfn is_clear_confirmed(input: &str) -> bool {\n    input.trim() == \"yes\"\n}\n\nfn role_label(role: &Role) -> &'static str {\n    match role {\n        Role::System => \"system\",\n        Role::User => \"user\",\n        Role::Assistant => \"assistant\",\n        Role::Tool => \"tool\",\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use ccode_domain::message::{Message, Role};\n\n    #[test]\n    fn clear_confirmation_requires_exact_yes() {\n        assert!(is_clear_confirmed(\"yes\\n\"));\n        assert!(!is_clear_confirmed(\"y\\n\"));\n        assert!(!is_clear_confirmed(\"YES\\n\"));\n    }\n\n    #[test]\n    fn summary_line_contains_id_message_count_and_rfc3339_timestamp() {\n        let summary = SessionSummary {\n            id: SessionId(\"s-1\".into()),\n            message_count: 3,\n            created_at: 1_700_000_000_000,\n            updated_at: 1_700_000_000_000,\n        };\n        let line = render_session_summary_line(&summary);\n        assert!(line.contains(\"s-1\"));\n        assert!(line.contains(\"3\"));\n        assert!(line.contains(\"2023-11-14T22:13:20+00:00\"));\n    }\n\n    #[test]\n    fn session_detail_contains_all_messages() {\n        let mut session = Session::new(\"s-1\", 1_700_000_000_000);\n        session.add_message(\n            Message::new(\"m1\", Role::User, \"hello\", 1_700_000_001_000),\n            1_700_000_001_000,\n        );\n        session.add_message(\n            Message::new(\"m2\", Role::Assistant, \"hi there\", 1_700_000_002_000),\n            1_700_000_002_000,\n        );\n\n        let out = render_session_detail(&session);\n        assert!(out.contains(\"id: s-1\"));\n        assert!(out.contains(\"messages: 2\"));\n        assert!(out.contains(\"[m1] user\"));\n        assert!(out.contains(\"hello\"));\n        assert!(out.contains(\"[m2] assistant\"));\n        assert!(out.contains(\"hi there\"));\n    }\n}\n","exit_code":0,"status":"completed"}}
