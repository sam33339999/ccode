{"type":"item.completed","item":{"id":"item_52","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' crates/provider/src/llamacpp/adapter.rs\"","aggregated_output":"use crate::openai_compat::OpenAiCompatClient;\nuse async_trait::async_trait;\nuse ccode_ports::{\n    PortError,\n    provider::{LlmRequest, LlmResponse, LlmClient, LlmStream},\n};\n\npub struct LlamaCppAdapter {\n    client: OpenAiCompatClient,\n}\n\nimpl LlamaCppAdapter {\n    pub fn new(\n        api_key: impl Into<String>,\n        base_url: impl Into<String>,\n        default_model: impl Into<String>,\n    ) -> Self {\n        Self {\n            client: OpenAiCompatClient::new(api_key, base_url, default_model, vec![]),\n        }\n    }\n}\n\n#[async_trait]\nimpl LlmClient for LlamaCppAdapter {\n    fn name(&self) -> &str {\n        \"llamacpp\"\n    }\n\n    fn default_model(&self) -> &str {\n        &self.client.default_model\n    }\n\n    async fn health_check(&self) -> Result<(), PortError> {\n        self.client.health_check().await\n    }\n\n    async fn complete(&self, req: LlmRequest) -> Result<LlmResponse, PortError> {\n        self.client.complete(req).await\n    }\n\n    async fn stream(&self, req: LlmRequest) -> Result<LlmStream, PortError> {\n        self.client.stream(req).await\n    }\n}\n","exit_code":0,"status":"completed"}}
