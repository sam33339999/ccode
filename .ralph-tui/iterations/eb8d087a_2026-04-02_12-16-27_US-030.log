{"type":"item.completed","item":{"id":"item_19","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,320p' crates/tools/src/registry.rs\"","aggregated_output":"use ccode_ports::{\n    provider::ToolDefinition,\n    tool::{ToolContext, ToolPort},\n    PortError,\n};\nuse serde_json::Value;\nuse std::sync::Arc;\n\npub struct ToolRegistry {\n    tools: Vec<Arc<dyn ToolPort>>,\n}\n\nimpl ToolRegistry {\n    pub fn new() -> Self {\n        Self { tools: Vec::new() }\n    }\n\n    pub fn register(&mut self, tool: Arc<dyn ToolPort>) {\n        self.tools.push(tool);\n    }\n\n    pub fn definitions(&self) -> Vec<ToolDefinition> {\n        self.tools.iter().map(|t| t.definition()).collect()\n    }\n\n    pub async fn execute(\n        &self,\n        name: &str,\n        args: Value,\n        ctx: &ToolContext,\n    ) -> Result<String, PortError> {\n        let tool = self\n            .tools\n            .iter()\n            .find(|t| t.name() == name)\n            .ok_or_else(|| PortError::Tool(format!(\"unknown tool: {name}\")))?;\n        tool.execute(args, ctx).await\n    }\n}\n\nimpl Default for ToolRegistry {\n    fn default() -> Self {\n        Self::new()\n    }\n}\n","exit_code":0,"status":"completed"}}
