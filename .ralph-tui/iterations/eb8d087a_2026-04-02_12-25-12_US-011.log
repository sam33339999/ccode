{"type":"item.completed","item":{"id":"item_52","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' config.example.toml\"","aggregated_output":"# Clawler 設定範例\n# 複製到 ~/.clawler/config.toml 後修改\n#\n# 所有 api_key / base_url / default_model 欄位均可省略，\n# 改用環境變數替代（各欄位旁有標注對應的 env var）。\n\n# ── Routing ────────────────────────────────────────────────────────────────────\n\n[routing]\n# 選擇使用哪個服務商\n# strategy: \"manual\" | \"failover\" | \"round_robin\" | \"cost_optimized\"\nstrategy = \"manual\"\n\n# 當 strategy = \"manual\" 時，固定使用此服務商\n# 可選值: \"openrouter\" | \"zhipu\" | \"anthropic\" | \"llamacpp\"\ndefault_provider = \"openrouter\"\n\n# ── Providers ──────────────────────────────────────────────────────────────────\n\n# OpenRouter（預設啟用，可路由到多個模型）\n# env: OPENROUTER_API_KEY / OPENROUTER_BASE_URL / OPENROUTER_DEFAULT_MODEL\n[providers.openrouter]\napi_key      = \"sk-or-v1-...\"\ndefault_model = \"openai/gpt-4o-mini\"\n# base_url   = \"https://openrouter.ai/api/v1\"   # 通常不需改\n# site_url   = \"https://yourapp.com\"             # HTTP-Referer header（選填）\n# site_name  = \"My App\"                          # X-Title header（選填）\n\n# 智谱 AI（z.ai 國際站，OpenAI-compatible）\n# env: ZHIPU_API_KEY / ZHIPU_BASE_URL / ZHIPU_DEFAULT_MODEL\n[providers.zhipu]\napi_key      = \"your-zhipu-api-key\"\ndefault_model = \"glm-4-plus\"\n# base_url   = \"https://api.z.ai/api/paas/v4\"   # 通常不需改\n# title      = \"My App\"                          # X-Title header（coding 方案必填）\n\n# Anthropic（原生 Messages API，非 OpenAI-compat）\n# env: ANTHROPIC_API_KEY / ANTHROPIC_BASE_URL / ANTHROPIC_DEFAULT_MODEL\n[providers.anthropic]\napi_key      = \"sk-ant-api03-...\"\ndefault_model = \"claude-opus-4-5\"\n# base_url   = \"https://api.anthropic.com/v1\"    # 通常不需改\n\n# llama.cpp 本地推理伺服器\n# 啟動方式: llama-server -m your-model.gguf --port 8080\n# env: LLAMACPP_API_KEY / LLAMACPP_BASE_URL / LLAMACPP_DEFAULT_MODEL\n[providers.llamacpp]\n# api_key    = \"\"                                # 通常不需要（部分 auth 設定除外）\n# base_url   = \"http://127.0.0.1:8080/v1\"        # 通常不需改\n# default_model = \"default\"                      # llama.cpp 忽略此欄位\n\n# ── Sandbox ────────────────────────────────────────────────────────────────────\n# 控制 agent 可執行哪些本地操作\n\n# [sandbox]\n# cwd      = \"~/projects/my-app\"   # agent 預設工作目錄（None = 啟動時 cwd）\n# fs_read  = \"any\"                 # \"any\" | \"cwd\" | \"none\"\n# fs_write = \"any\"                 # \"any\" | \"cwd\" | \"none\"\n# shell    = \"any\"                 # \"any\" | \"none\" | \"git,cargo,ls\"（逗號分隔 allowlist）\n# web_fetch = true\n# browser  = true\n\n# ── Memory ─────────────────────────────────────────────────────────────────────\n# Agent 記憶系統設定\n\n[memory]\n# backend: \"fts5\"（預設，純本地全文索引，不需 embedding）\n#        | \"vector\"（語意搜尋，需設定 embedding provider）\nbackend = \"fts5\"\n\n# SQLite 資料庫儲存路徑（預設 ~/.clawler/memory.db）\n# db_path = \"~/.clawler/memory.db\"\n\n# ── Embedding（backend = \"vector\" 時需設定）───────────────────────────────────\n\n# [memory.embedding]\n# provider = \"openai\"   # \"openai\" | \"llamacpp\" | \"zhipu\"\n\n# OpenAI embedding（text-embedding-3-small 最具 CP 值）\n# env: OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_EMBEDDING_MODEL\n# [memory.embedding.openai]\n# api_key  = \"sk-...\"\n# model    = \"text-embedding-3-small\"   # 或 \"text-embedding-3-large\"\n# base_url = \"https://api.openai.com/v1\"\n\n# llama.cpp 本地 embedding（使用 /v1/embeddings，OpenAI-compat）\n# 啟動方式: llama-server -m nomic-embed-text.gguf --port 8080 --embedding\n# env: LLAMACPP_BASE_URL / LLAMACPP_EMBEDDING_MODEL\n# [memory.embedding.llamacpp]\n# base_url = \"http://127.0.0.1:8080/v1\"\n# model    = \"default\"\n\n# 智谱 AI embedding\n# env: ZHIPU_API_KEY / ZHIPU_EMBEDDING_MODEL\n# [memory.embedding.zhipu]\n# api_key = \"your-zhipu-api-key\"\n# model   = \"embedding-3\"\n","exit_code":0,"status":"completed"}}
