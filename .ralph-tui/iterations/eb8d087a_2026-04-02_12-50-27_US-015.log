 ),\n   134\t                error: conflict.then_some(CoordinatorModeError::SessionModeMismatch),\n   135\t            };\n   136\t        }\n   137\t\n   138\t        let target_mode = self.env_mode.unwrap_or(CoordinatorMode::Standard);\n   139\t        if !Self::transition_allowed(self.current_mode, target_mode) {\n   140\t            return ModeReconcileResult {\n   141\t                mode: self.current_mode,\n   142\t                action: ModeReconcileAction::Noop,\n   143\t                switch_event: None,\n   144\t                error: Some(CoordinatorModeError::InvalidModeTransition),\n   145\t            };\n   146\t        }\n   147\t\n   148\t        ModeReconcileResult {\n   149\t            mode: target_mode,\n   150\t            action: ModeReconcileAction::EnvAdopted,\n   151\t            switch_event: Self::mode_event(\n   152\t                self.current_mode,\n   153\t                target_mode,\n   154\t                ModeSwitchReason::ResumeReconcile,\n   155\t            ),\n   156\t            error: None,\n   157\t        }\n   158\t    }\n   159\t}\n   160\t\n   161\t#[cfg(test)]\n   162\tmod tests {\n   163\t    use super::*;\n   164\t    use crate::spec_contracts::ModeCoordinatorService;\n   165\t\n   166\t    #[test]\n   167\t    fn resolve_effective_mode_prefers_session_over_env_mode() {\n   168\t        let service = DefaultModeCoordinatorService::default();\n   169\t        let result = service.resolve_effective_mode(ModeResolutionInput {\n   170\t            policy_enabled: true,\n   171\t            env_mode: Some(CoordinatorMode::Standard),\n   172\t            session_mode: Some(SessionMode {\n   173\t                mode: CoordinatorMode::Coordinator,\n   174\t            }),\n   175\t            previous_mode: Some(CoordinatorMode::Standard),\n   176\t        });\n   177\t\n   178\t        assert_eq!(result.mode, CoordinatorMode::Coordinator);\n   179\t        assert_eq!(result.source, EffectiveModeSource::Session);\n   180\t        assert!(result.error.is_none());\n   181\t        assert!(matches!(\n   182\t            result.switch_event,\n   183\t            Some(ModeSwitchEvent {\n   184\t                from: CoordinatorMode::Standard,\n   185\t                to: CoordinatorMode::Coordinator,\n   186\t                reason: ModeSwitchReason::SessionPrecedence,\n   187\t            })\n   188\t        ));\n   189\t    }\n   190\t\n   191\t    #[test]\n   192\t    fn reconcile_on_resume_uses_session_mode_and_marks_conflict_deterministically() {\n   193\t        let service = DefaultModeCoordinatorService {\n   194\t            policy_enabled: true,\n   195\t            env_mode: Some(CoordinatorMode::Standard),\n   196\t            current_mode: CoordinatorMode::Standard,\n   197\t        };\n   198\t\n   199\t        let result = service.reconcile_on_resume(Some(SessionMode {\n   200\t            mode: CoordinatorMode::Coordinator,\n   201\t        }));\n   202\t\n   203\t        assert_eq!(result.mode, CoordinatorMode::Coordinator);\n   204\t        assert_eq!(result.action, ModeReconcileAction::SessionWins);\n   205\t        assert!(matches!(\n   206\t            result.error,\n   207\t            Some(CoordinatorModeError::SessionModeMismatch)\n   208\t        ));\n   209\t        assert!(matches!(\n   210\t            result.switch_event,\n   211\t            Some(ModeSwitchEvent {\n   212\t                from: CoordinatorMode::Standard,\n   213\t                to: CoordinatorMode::Coordinator,\n   214\t                reason: ModeSwitchReason::ResumeReconcile,\n   215\t            })\n   216\t        ));\n   217\t    }\n   218\t\n   219\t    #[test]\n   220\t    fn resolve_effective_mode_reports_disabled_by_policy() {\n   221\t        let service = DefaultModeCoordinatorService::default();\n   222\t        let result = service.resolve_effective_mode(ModeResolutionInput {\n   223\t            policy_enabled: false,\n   224\t            env_mode: Some(CoordinatorMode::Co