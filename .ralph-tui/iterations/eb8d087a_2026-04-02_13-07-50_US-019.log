{"type":"item.completed","item":{"id":"item_25","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' config.example.toml\"","aggregated_output":"# Clawler 設定範例\n# 複製到 ~/.clawler/config.toml 後修改\n#\n# 所有 api_key / base_url / default_model 欄位均可省略，\n# 改用環境變數替代（各欄位旁有標注對應的 env var）。\n\n# ── Routing ────────────────────────────────────────────────────────────────────\n\n[routing]\n# 選擇使用哪個服務商\n# strategy: \"manual\" | \"failover\" | \"round_robin\" | \"cost_optimized\"\nstrategy = \"manual\"\n\n# 當 strategy = \"manual\" 時，固定使用此服務商\n# 可選值: \"openrouter\" | \"zhipu\" | \"anthropic\" | \"llamacpp\"\ndefault_provider = \"openrouter\"\n\n# ── Providers ──────────────────────────────────────────────────────────────────\n\n# OpenRouter（預設啟用，可路由到多個模型）\n# env: OPENROUTER_API_KEY / OPENROUTER_BASE_URL / OPENROUTER_DEFAULT_MODEL\n[providers.openrouter]\napi_key      = \"sk-or-v1-...\"\ndefault_model = \"openai/gpt-4o-mini\"\n# base_url   = \"https://openrouter.ai/api/v1\"   # 通常不需改\n# site_url   = \"https://yourapp.com\"             # HTTP-Referer header（選填）\n# site_name  = \"My App\"                          # X-Title header（選填）\n\n# 智谱 AI（z.ai 國際站，OpenAI-compatible）\n# env: ZHIPU_API_KEY / ZHIPU_BASE_URL / ZHIPU_DEFAULT_MODEL\n[providers.zhipu]\napi_key      = \"your-zhipu-api-key\"\ndefault_model = \"glm-4-plus\"\n# base_url   = \"https://api.z.ai/api/paas/v4\"   # 通常不需改\n# title      = \"My App\"                          # X-Title header（coding 方案必填）\n\n# Anthropic（原生 Messages API，非 OpenAI-compat）\n# env: ANTHROPIC_API_KEY / ANTHROPIC_BASE_URL / ANTHROPIC_DEFAULT_MODEL\n[providers.anthropic]\napi_key      = \"sk-ant-api03-...\"\ndefault_model = \"claude-opus-4-5\"\n# base_url   = \"https://api.anthropic.com/v1\"    # 通常不需改\n\n# llama.cpp 本地推理伺服器\n# 啟動方式: llama-server -m your-model.gguf --port 8080\n# env: LLAMACPP_API_KEY / LLAMACPP_BASE_URL / LLAMACPP_DEFAULT_MODEL\n[providers.llamacpp]\n# api_key    = \"\"                                # 通常不需要（部分 auth 設定除外）\n# base_url   = \"http://127.0.0.1:8080/v1\"        # 通常不需改\n# default_model = \"default\"                      # llama.cpp 忽略此欄位\n\n# ── Sandbox ────────────────────────────────────────────────────────────────────\n# 控制 agent 可執行哪些本地操作\n\n# [sandbox]\n# cwd      = \"~/projects/my-app\"   # agent 預設工作目錄（None = 啟動時 cwd）\n# fs_read  = \"any\"                 # \"any\" | \"cwd\" | \"none\"\n# fs_write = \"any\"                 # \"any\" | \"cwd\" | \"none\"\n# shell    = \"any\"                 # \"any\" | \"none\" | \"git,cargo,ls\"（逗號分隔 allowlist）\n# web_fetch = true\n# browser  = true\n\n# ── MCP Servers ────────────────────────────────────────────────────────────────\n# 啟動後會對每個 server 呼叫 tools/list，並把回傳工具註冊到工具表中。\n\n[mcp]\n# Chicago MCP 高權限能力總開關（預設 false）\nenable_chicago_mcp_feature_gate = false\n# Policy 是否允許高權限 computer-use（預設 false）\nallow_privileged_computer_use = false\n\n# [[mcp.servers]]\n# name = \"filesystem\"\n# command = \"node\"\n# args = [\"./mcp-filesystem-server.js\", \"--stdio\"]\n# declared_capabilities = [\"standard\"] # 可選: \"privileged_computer_use\"\n# enable_computer_use = false\n\n# ── Memory ─────────────────────────────────────────────────────────────────────\n# Agent 記憶系統設定\n\n[memory]\n# backend: \"fts5\"（預設，純本地全文索引，不需 embedding）\n#        | \"vector\"（語意搜尋，需設定 embedding provider）\nbackend = \"fts5\"\n\n# SQLite 資料庫儲存路徑（預設 ~/.clawler/memory.db）\n# db_path = \"~/.clawler/memory.db\"\n\n# ── Embedding（backend = \"vector\" 時需設定）───────────────────────────────────\n\n# [memory.embedding]\n# provider = \"openai\"   # \"openai\" | \"llamacpp\" | \"zhipu\"\n\n# OpenAI embedding（text-embedding-3-small 最具 CP 值）\n# env: OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_EMBEDDING_MODEL\n# [memory.embedding.openai]\n# api_key  = \"sk-...\"\n# model    = \"text-embedding-3-small\"   # 或 \"text-embedding-3-large\"\n# base_url = \"https://api.openai.com/v1\"\n\n# llama.cpp 本地 embedding（使用 /v1/embeddings，OpenAI-compat）\n# 啟動方式: llama-server -m nomic-embed-text.gguf --port 8080 --embedding\n# env: LLAMACPP_BASE_URL / LLAMACPP_EMBEDDING_MODEL\n# [memory.embedding.llamacpp]\n# base_url = \"http://127.0.0.1:8080/v1\"\n# model    = \"default\"\n\n# 智谱 AI embedding\n# env: ZHIPU_API_KEY / ZHIPU_EMBEDDING_MODEL\n# [memory.embedding.zhipu]\n# api_key = \"your-zhipu-api-key\"\n# model   = \"embedding-3\"\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_27","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,320p' crates/config/src/schema.rs\"","aggregated_output":"use serde::{Deserialize, Serialize};\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct Config {\n    #[serde(default)]\n    pub providers: ProvidersConfig,\n    #[serde(default)]\n    pub routing: RoutingConfig,\n    #[serde(default)]\n    pub mcp: McpConfig,\n    pub sandbox: Option<SandboxConfig>,\n    pub memory: Option<MemoryConfig>,\n    #[serde(default)]\n    pub context: ContextConfig,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct McpConfig {\n    #[serde(default)]\n    pub enable_chicago_mcp_feature_gate: bool,\n    #[serde(default)]\n    pub allow_privileged_computer_use: bool,\n    #[serde(default)]\n    pub servers: Vec<McpServerConfig>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct McpServerConfig {\n    pub name: String,\n    pub command: String,\n    #[serde(default)]\n    pub args: Vec<String>,\n    #[serde(default)]\n    pub declared_capabilities: Vec<String>,\n    #[serde(default)]\n    pub enable_computer_use: bool,\n}\n\n// ── Context / compression ─────────────────────────────────────────────────────\n\n/// Controls the agentic loop's context window management.\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct ContextConfig {\n    /// Trigger compression when total context exceeds this many characters\n    /// (rough estimate: 4 chars ≈ 1 token). Default: 600_000 (~150k tokens).\n    pub compress_chars_threshold: Option<usize>,\n    /// Number of most-recent messages to keep verbatim after compression.\n    /// Default: 8.\n    pub keep_recent_messages: Option<usize>,\n    /// Truncate a single tool result that exceeds this many characters.\n    /// Default: 40_000.\n    pub tool_result_max_chars: Option<usize>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct SandboxConfig {\n    pub cwd: Option<String>,\n    /// \"any\" | \"cwd\" | \"none\"\n    pub fs_read: Option<String>,\n    /// \"any\" | \"cwd\" | \"none\"\n    pub fs_write: Option<String>,\n    /// \"any\" | \"none\" | comma-separated allowlist\n    pub shell: Option<String>,\n    pub web_fetch: Option<bool>,\n    pub browser: Option<bool>,\n}\n\n// ── Providers ─────────────────────────────────────────────────────────────────\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct ProvidersConfig {\n    pub openrouter: Option<OpenRouterConfig>,\n    pub zhipu: Option<ZhipuConfig>,\n    pub openai: Option<OpenAiConfig>,\n    pub anthropic: Option<AnthropicConfig>,\n    pub llamacpp: Option<LlamaCppConfig>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct OpenRouterConfig {\n    /// Bearer token. Falls back to `OPENROUTER_API_KEY` env var.\n    pub api_key: Option<String>,\n    /// Default model slug, e.g. `\"anthropic/claude-3-5-sonnet\"`.\n    pub default_model: Option<String>,\n    /// Override base URL (useful for local proxies).\n    pub base_url: Option<String>,\n    /// Optional HTTP `Referer` header sent to OpenRouter for attribution.\n    pub site_url: Option<String>,\n    /// Optional `X-Title` header sent to OpenRouter.\n    pub site_name: Option<String>,\n}\n\nimpl OpenRouterConfig {\n    pub fn resolved_api_key(&self) -> Option<String> {\n        self.api_key\n            .clone()\n            .or_else(|| std::env::var(\"OPENROUTER_API_KEY\").ok())\n    }\n\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"OPENROUTER_BASE_URL\").ok())\n            .unwrap_or_else(|| \"https://openrouter.ai/api/v1\".into())\n    }\n\n    pub fn resolved_default_model(&self) -> String {\n        self.default_model\n            .clone()\n            .or_else(|| std::env::var(\"OPENROUTER_DEFAULT_MODEL\").ok())\n            .unwrap_or_else(|| \"openai/gpt-4o-mini\".into())\n    }\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct ZhipuConfig {\n    /// Bearer token. Falls back to `ZHIPU_API_KEY` env var.\n    pub api_key: Option<String>,\n    /// Default model slug, e.g. `\"glm-4-plus\"`.\n    pub default_model: Option<String>,\n    /// Override base URL (defaults to `https://api.z.ai/api/paas/v4`).\n    pub base_url: Option<String>,\n    /// Value for the `X-Title` header (required by the coding plan).\n    pub title: Option<String>,\n}\n\nimpl ZhipuConfig {\n    pub fn resolved_api_key(&self) -> Option<String> {\n        self.api_key\n            .clone()\n            .or_else(|| std::env::var(\"ZHIPU_API_KEY\").ok())\n    }\n\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"ZHIPU_BASE_URL\").ok())\n            .unwrap_or_else(|| \"https://api.z.ai/api/paas/v4\".into())\n    }\n\n    pub fn resolved_default_model(&self) -> String {\n        self.default_model\n            .clone()\n            .or_else(|| std::env::var(\"ZHIPU_DEFAULT_MODEL\").ok())\n            .unwrap_or_else(|| \"glm-4-plus\".into())\n    }\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct OpenAiConfig {\n    pub api_key: Option<String>,\n    pub default_model: Option<String>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct AnthropicConfig {\n    /// Bearer token. Falls back to `ANTHROPIC_API_KEY` env var.\n    pub api_key: Option<String>,\n    /// Default model slug, e.g. `\"claude-opus-4-5\"`.\n    pub default_model: Option<String>,\n    /// Override base URL. Defaults to `https://api.anthropic.com/v1`.\n    pub base_url: Option<String>,\n}\n\nimpl AnthropicConfig {\n    pub fn resolved_api_key(&self) -> Option<String> {\n        self.api_key\n            .clone()\n            .or_else(|| std::env::var(\"ANTHROPIC_API_KEY\").ok())\n    }\n\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"ANTHROPIC_BASE_URL\").ok())\n            .unwrap_or_else(|| \"https://api.anthropic.com/v1\".into())\n    }\n\n    pub fn resolved_default_model(&self) -> String {\n        self.default_model\n            .clone()\n            .or_else(|| std::env::var(\"ANTHROPIC_DEFAULT_MODEL\").ok())\n            .unwrap_or_else(|| \"claude-opus-4-5\".into())\n    }\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct LlamaCppConfig {\n    /// Optional auth key (some llama.cpp setups enable simple auth).\n    /// Falls back to `LLAMACPP_API_KEY`. Defaults to `\"\"`.\n    pub api_key: Option<String>,\n    /// Falls back to `LLAMACPP_BASE_URL`. Defaults to `http://127.0.0.1:8080/v1`.\n    pub base_url: Option<String>,\n    /// Falls back to `LLAMACPP_DEFAULT_MODEL`. Defaults to `\"default\"` (ignored by server).\n    pub default_model: Option<String>,\n}\n\nimpl LlamaCppConfig {\n    pub fn resolved_api_key(&self) -> String {\n        self.api_key\n            .clone()\n            .or_else(|| std::env::var(\"LLAMACPP_API_KEY\").ok())\n            .unwrap_or_default()\n    }\n\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"LLAMACPP_BASE_URL\").ok())\n            .unwrap_or_else(|| \"http://127.0.0.1:8080/v1\".into())\n    }\n\n    pub fn resolved_default_model(&self) -> String {\n        self.default_model\n            .clone()\n            .or_else(|| std::env::var(\"LLAMACPP_DEFAULT_MODEL\").ok())\n            .unwrap_or_else(|| \"default\".into())\n    }\n}\n\n// ── Routing ───────────────────────────────────────────────────────────────────\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct RoutingConfig {\n    /// `manual` | `failover` | `round_robin` | `cost_optimized`\n    #[serde(default = \"default_strategy\")]\n    pub strategy: String,\n    /// Provider name used when strategy = \"manual\" or as primary for failover.\n    pub default_provider: Option<String>,\n}\n\nfn default_strategy() -> String {\n    \"manual\".into()\n}\n\nimpl Default for RoutingConfig {\n    fn default() -> Self {\n        Self {\n            strategy: default_strategy(),\n            default_provider: None,\n        }\n    }\n}\n\n// ── Memory ────────────────────────────────────────────────────────────────────\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct MemoryConfig {\n    /// \"fts5\"（預設，不需 embedding）| \"vector\"（需設定 embedding provider）\n    #[serde(default = \"default_memory_backend\")]\n    pub backend: String,\n    /// SQLite 資料庫路徑。None = ~/.ccode/memory.db\n    pub db_path: Option<String>,\n    /// Embedding provider 設定（backend = \"vector\" 時需要）\n    pub embedding: Option<EmbeddingConfig>,\n}\n\nfn default_memory_backend() -> String {\n    \"fts5\".into()\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct EmbeddingConfig {\n    /// \"openai\" | \"llamacpp\" | \"zhipu\"\n    pub provider: Option<String>,\n    pub openai: Option<EmbeddingOpenAiConfig>,\n    pub llamacpp: Option<EmbeddingLlamaCppConfig>,\n    pub zhipu: Option<EmbeddingZhipuConfig>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct EmbeddingOpenAiConfig {\n    /// env: OPENAI_API_KEY\n    pub api_key: Option<String>,\n    /// env: OPENAI_EMBEDDING_MODEL，預設 \"text-embedding-3-small\"\n    pub model: Option<String>,\n    /// env: OPENAI_BASE_URL，預設 \"https://api.openai.com/v1\"\n    pub base_url: Option<String>,\n}\n\nimpl EmbeddingOpenAiConfig {\n    pub fn resolved_api_key(&self) -> Option<String> {\n        self.api_key\n            .clone()\n            .or_else(|| std::env::var(\"OPENAI_API_KEY\").ok())\n    }\n    pub fn resolved_model(&self) -> String {\n        self.model\n            .clone()\n            .or_else(|| std::env::var(\"OPENAI_EMBEDDING_MODEL\").ok())\n            .unwrap_or_else(|| \"text-embedding-3-small\".into())\n    }\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"OPENAI_BASE_URL\").ok())\n            .unwrap_or_else(|| \"https://api.openai.com/v1\".into())\n    }\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize, Default)]\npub struct EmbeddingLlamaCppConfig {\n    /// env: LLAMACPP_BASE_URL，預設 \"http://127.0.0.1:8080/v1\"\n    pub base_url: Option<String>,\n    /// env: LLAMACPP_EMBEDDING_MODEL，預設 \"default\"\n    pub model: Option<String>,\n    /// env: LLAMACPP_API_KEY，預設 \"\"\n    pub api_key: Option<String>,\n}\n\nimpl EmbeddingLlamaCppConfig {\n    pub fn resolved_base_url(&self) -> String {\n        self.base_url\n            .clone()\n            .or_else(|| std::env::var(\"LLAMACPP_BASE_URL\").ok())\n            .unwrap_or_else(|| \"http://127.0.0.1:8080/v1\".into())\n    }\n    pub fn resolved_model(&self) -> String {\n        self.model\n            .clone()\n","exit_code":0,"status":"completed"}}
