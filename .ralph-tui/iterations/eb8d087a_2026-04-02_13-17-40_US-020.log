ses\": false,\n      \"notes\": \"Per teammem-contract.md. This is a prerequisite for TEAMMEM sync. Invariant ordering: validate → scan → write/push is critical.\",\n      \"dependsOn\": [\n        \"US-009\"\n      ]\n    },\n    {\n      \"id\": \"US-022\",\n      \"title\": \"TeamMemorySyncService implementation\",\n      \"description\": \"As a user, I want to sync team memory with remote storage with security guarantees.\",\n      \"acceptanceCriteria\": [\n        \"TeamMemorySyncService trait with: pull() -> Result<SyncResult, TeamMemError>\",\n        \"TeamMemorySyncService trait with: push() -> Result<SyncResult, TeamMemError>\",\n        \"TeamMemorySyncService trait with: sync() -> Result<SyncResult, TeamMemError>\",\n        \"Pull → merge → push with ETag / 412 conflict retry (bounded at configured max_retries)\",\n        \"All remote writes pass secret scan first\",\n        \"All local writes pass canonical path validation first\",\n        \"Path traversal / symlink escape returns PathValidationFailed\",\n        \"Secret detected skips file with audit metadata (never returns raw secret content)\",\n        \"File over max-size skipped with explicit classification\",\n        \"Entry count over max-entry has deterministic truncation/skip policy\",\n        \"Retry exhausted returns ConflictExhausted\",\n        \"TeamMemError variants: AuthUnavailable, Unauthorized, ConflictExhausted, PathValidationFailed, SecretDetected, FileTooLarge, EntryLimitExceeded, StorageWriteError, UpstreamTimeout\",\n        \"Unit tests for security invariants (path validation, secret scan)\",\n        \"Unit tests for conflict retry exhaustion\",\n        \"Unit tests for oversized file handling\",\n        \"Unit tests for each error variant\",\n        \"cargo fmt --check passes\",\n        \"cargo clippy --workspace -- -D warnings passes\",\n        \"cargo test --workspace passes\"\n      ],\n      \"priority\": 13,\n      \"passes\": false,\n      \"notes\": \"Per 