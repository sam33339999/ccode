{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,320p' crates/tools/src/registry.rs\"","aggregated_output":"use ccode_domain::assistant_mode::AssistantMode;\nuse ccode_ports::{\n    provider::ToolDefinition,\n    tool::{ToolContext, ToolPort},\n    PortError,\n};\nuse serde_json::Value;\nuse std::sync::{Arc, RwLock};\n\npub(crate) const MCP_DISCONNECTED_MARKER: &str = \"__MCP_DISCONNECTED__:\";\nconst BRIEF_MODE_TOOL_ALLOWLIST: &[&str] =\n    &[\"fs_glob\", \"fs_grep\", \"fs_list\", \"fs_read\", \"web_fetch\"];\n\nenum ModeAllowlist {\n    All,\n    Names(&'static [&'static str]),\n}\n\nimpl ModeAllowlist {\n    fn includes(&self, tool_name: &str) -> bool {\n        match self {\n            Self::All => true,\n            Self::Names(names) => names.contains(&tool_name),\n        }\n    }\n}\n\nstruct ToolEntry {\n    source: String,\n    tool: Arc<dyn ToolPort>,\n}\n\npub struct ToolRegistry {\n    tools: RwLock<Vec<ToolEntry>>,\n}\n\nimpl ToolRegistry {\n    pub fn new() -> Self {\n        Self {\n            tools: RwLock::new(Vec::new()),\n        }\n    }\n\n    pub fn register(&mut self, tool: Arc<dyn ToolPort>) {\n        self.register_with_source(\"local\", tool);\n    }\n\n    pub fn register_with_source(&self, source: impl Into<String>, tool: Arc<dyn ToolPort>) {\n        let mut tools = self.tools.write().expect(\"tool registry poisoned\");\n        tools.push(ToolEntry {\n            source: source.into(),\n            tool,\n        });\n    }\n\n    pub fn remove_by_source(&self, source: &str) {\n        let mut tools = self.tools.write().expect(\"tool registry poisoned\");\n        tools.retain(|entry| entry.source != source);\n    }\n\n    pub fn definitions(&self) -> Vec<ToolDefinition> {\n        self.definitions_for_mode(AssistantMode::Kairos)\n    }\n\n    pub fn definitions_for_mode(&self, mode: AssistantMode) -> Vec<ToolDefinition> {\n        let allowlist = Self::allowlist_for_mode(mode);\n        let tools = self.tools.read().expect(\"tool registry poisoned\");\n        tools\n            .iter()\n            .filter(|entry| allowlist.includes(entry.tool.name()))\n            .map(|entry| entry.tool.definition())\n            .collect()\n    }\n\n    pub async fn execute(\n        &self,\n        name: &str,\n        args: Value,\n        ctx: &ToolContext,\n    ) -> Result<String, PortError> {\n        let entry = self\n            .tools\n            .read()\n            .expect(\"tool registry poisoned\")\n            .iter()\n            .find(|entry| entry.tool.name() == name)\n            .map(|entry| (entry.source.clone(), Arc::clone(&entry.tool)))\n            .ok_or_else(|| PortError::Tool(format!(\"unknown tool: {name}\")))?;\n\n        let (source, tool) = entry;\n        let result = tool.execute(args, ctx).await;\n\n        if source.starts_with(\"mcp:\")\n            && matches!(\n                &result,\n                Err(PortError::Tool(message)) if message.starts_with(MCP_DISCONNECTED_MARKER)\n            )\n        {\n            self.remove_by_source(source.as_str());\n        }\n\n        result\n    }\n\n    const fn allowlist_for_mode(mode: AssistantMode) -> ModeAllowlist {\n        match mode {\n            AssistantMode::Kairos => ModeAllowlist::All,\n            AssistantMode::KairosBrief => ModeAllowlist::Names(BRIEF_MODE_TOOL_ALLOWLIST),\n            AssistantMode::KairosChannels => ModeAllowlist::All,\n        }\n    }\n}\n\nimpl Default for ToolRegistry {\n    fn default() -> Self {\n        Self::new()\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use async_trait::async_trait;\n    use ccode_domain::assistant_mode::AssistantMode;\n    use ccode_ports::tool::Permission;\n    use std::path::PathBuf;\n\n    struct DisconnectingTool;\n    struct NamedTool(&'static str);\n\n    #[async_trait]\n    impl ToolPort for DisconnectingTool {\n        fn name(&self) -> &str {\n            \"mcp_echo\"\n        }\n\n        fn description(&self) -> &str {\n            \"mock mcp tool\"\n        }\n\n        fn parameters_schema(&self) -> Value {\n            serde_json::json!({\"type\":\"object\"})\n        }\n\n        async fn execute(&self, _args: Value, _ctx: &ToolContext) -> Result<String, PortError> {\n            Err(PortError::Tool(\n                \"__MCP_DISCONNECTED__:server=demo\".to_string(),\n            ))\n        }\n    }\n\n    #[async_trait]\n    impl ToolPort for NamedTool {\n        fn name(&self) -> &str {\n            self.0\n        }\n\n        fn description(&self) -> &str {\n            \"named tool\"\n        }\n\n        fn parameters_schema(&self) -> Value {\n            serde_json::json!({\"type\":\"object\"})\n        }\n\n        async fn execute(&self, _args: Value, _ctx: &ToolContext) -> Result<String, PortError> {\n            Ok(\"ok\".to_string())\n        }\n    }\n\n    #[tokio::test]\n    async fn disconnect_error_removes_tools_from_same_source() {\n        let registry = ToolRegistry::new();\n        registry.register_with_source(\"mcp:demo\", Arc::new(DisconnectingTool));\n        registry.register_with_source(\"mcp:demo\", Arc::new(DisconnectingTool));\n        assert_eq!(registry.definitions().len(), 2);\n\n        let ctx = ToolContext {\n            cwd: PathBuf::from(\".\"),\n            permission: Permission::default(),\n        };\n        let _ = registry\n            .execute(\"mcp_echo\", serde_json::json!({}), &ctx)\n            .await;\n\n        assert!(\n            registry.definitions().is_empty(),\n            \"disconnect should remove all server tools\"\n        );\n    }\n\n    #[test]\n    fn definitions_for_mode_hides_high_risk_tools_in_brief_mode() {\n        let mut registry = ToolRegistry::new();\n        registry.register(Arc::new(NamedTool(\"fs_read\")));\n        registry.register(Arc::new(NamedTool(\"shell\")));\n        registry.register(Arc::new(NamedTool(\"spawn_agent\")));\n        registry.register(Arc::new(NamedTool(\"web_fetch\")));\n        registry.register(Arc::new(NamedTool(\"mcp_custom_tool\")));\n\n        let names: Vec<String> = registry\n            .definitions_for_mode(AssistantMode::KairosBrief)\n            .into_iter()\n            .map(|def| def.name)\n            .collect();\n\n        assert_eq!(names, vec![\"fs_read\", \"web_fetch\"]);\n    }\n\n    #[test]\n    fn definitions_for_mode_is_deterministic_and_updates_immediately() {\n        let mut registry = ToolRegistry::new();\n        registry.register(Arc::new(NamedTool(\"fs_read\")));\n        registry.register(Arc::new(NamedTool(\"fs_write\")));\n        registry.register(Arc::new(NamedTool(\"shell\")));\n        registry.register(Arc::new(NamedTool(\"web_fetch\")));\n\n        let kairos_names: Vec<String> = registry\n            .definitions_for_mode(AssistantMode::Kairos)\n            .into_iter()\n            .map(|def| def.name)\n            .collect();\n        let brief_names: Vec<String> = registry\n            .definitions_for_mode(AssistantMode::KairosBrief)\n            .into_iter()\n            .map(|def| def.name)\n            .collect();\n        let channels_names: Vec<String> = registry\n            .definitions_for_mode(AssistantMode::KairosChannels)\n            .into_iter()\n            .map(|def| def.name)\n            .collect();\n\n        assert_eq!(\n            kairos_names,\n            vec![\"fs_read\", \"fs_write\", \"shell\", \"web_fetch\"]\n        );\n        assert_eq!(brief_names, vec![\"fs_read\", \"web_fetch\"]);\n        assert_eq!(\n            channels_names,\n            vec![\"fs_read\", \"fs_write\", \"shell\", \"web_fetch\"]\n        );\n    }\n}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_19","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,320p' crates/tools/src/spawn_agent.rs\"","aggregated_output":"use crate::ToolRegistry;\nuse async_trait::async_trait;\nuse ccode_application::commands::agent_run::{AgentRunCommand, ContextPolicy};\nuse ccode_ports::{\n    provider::LlmClient,\n    repositories::SessionRepository,\n    tool::{ToolContext, ToolPort},\n    PortError,\n};\nuse serde_json::{json, Value};\nuse std::sync::{Arc, OnceLock};\n\n/// Tool that lets the agent delegate a sub-task to a child agent.\n///\n/// The sub-agent runs with full tool access (same registry) in its own session.\n/// All tool calls made by the sub-agent are auto-approved (no stdin prompt).\n/// Returns the sub-agent's final response and its session ID.\n///\n/// The registry is wired via a `OnceLock` to break the circular dependency:\n/// the registry must exist before `SpawnAgentTool` can run, but the tool must\n/// be registered before the registry is finalised. Bootstrap sets the cell after\n/// `Arc<ToolRegistry>` is created.\npub struct SpawnAgentTool {\n    provider: Arc<dyn LlmClient>,\n    session_repo: Arc<dyn SessionRepository>,\n    /// Filled in by bootstrap after the registry `Arc` is finalized.\n    registry_cell: Arc<OnceLock<Arc<ToolRegistry>>>,\n    context_policy: ContextPolicy,\n}\n\nimpl SpawnAgentTool {\n    /// Create the tool and return a shared cell that bootstrap must fill with\n    /// the completed `Arc<ToolRegistry>` before the tool is first called.\n    pub fn new(\n        provider: Arc<dyn LlmClient>,\n        session_repo: Arc<dyn SessionRepository>,\n        context_policy: ContextPolicy,\n    ) -> (Self, Arc<OnceLock<Arc<ToolRegistry>>>) {\n        let cell = Arc::new(OnceLock::new());\n        let tool = Self {\n            provider,\n            session_repo,\n            registry_cell: Arc::clone(&cell),\n            context_policy,\n        };\n        (tool, cell)\n    }\n}\n\n#[async_trait]\nimpl ToolPort for SpawnAgentTool {\n    fn name(&self) -> &str {\n        \"spawn_agent\"\n    }\n\n    fn description(&self) -> &str {\n        \"Spawn a sub-agent to handle a delegated sub-task independently. \\\n         The sub-agent has access to all tools and runs in its own session. \\\n         Returns the sub-agent's final response text and its session ID.\\n\\\n         Parameters:\\n\\\n         - message: The task/prompt for the sub-agent (required)\\n\\\n         - persona: Optional system prompt that defines the sub-agent's role \\\n           (e.g. \\\"You are an expert in data analysis\\\")\"\n    }\n\n    fn parameters_schema(&self) -> Value {\n        json!({\n            \"type\": \"object\",\n            \"properties\": {\n                \"message\": {\n                    \"type\": \"string\",\n                    \"description\": \"Task for the sub-agent to perform\"\n                },\n                \"persona\": {\n                    \"type\": \"string\",\n                    \"description\": \"Optional system prompt / role for the sub-agent\"\n                }\n            },\n            \"required\": [\"message\"]\n        })\n    }\n\n    async fn execute(&self, args: Value, ctx: &ToolContext) -> Result<String, PortError> {\n        let message = args[\"message\"]\n            .as_str()\n            .ok_or_else(|| PortError::Tool(\"missing: message\".into()))?\n            .to_string();\n        let persona = args[\"persona\"].as_str().map(|s| s.to_string());\n\n        let registry = self.registry_cell.get().ok_or_else(|| {\n            PortError::Tool(\"spawn_agent: tool registry not yet initialized\".into())\n        })?;\n\n        let cmd = AgentRunCommand::new(Arc::clone(&self.session_repo), Arc::clone(&self.provider))\n            .with_context(self.context_policy.clone());\n\n        let tool_definitions = registry.definitions();\n        let registry = Arc::clone(registry);\n        let tool_ctx = Arc::new(ctx.clone());\n\n        // Collect the sub-agent's streamed response\n        let reply = Arc::new(std::sync::Mutex::new(String::new()));\n        let reply_clone = reply.clone();\n\n        let on_delta = move |content: String| {\n            reply_clone.lock().unwrap().push_str(&content);\n        };\n\n        // Sub-agent auto-approves all tool calls — no interactive stdin\n        let execute_tool = move |name: String,\n                                 tool_args: Value|\n              -> std::pin::Pin<\n            Box<dyn std::future::Future<Output = Result<String, String>> + Send>,\n        > {\n            let registry = registry.clone();\n            let tool_ctx = tool_ctx.clone();\n            Box::pin(async move {\n                registry\n                    .execute(&name, tool_args, &tool_ctx)\n                    .await\n                    .map_err(|e| e.to_string())\n            })\n        };\n\n        let session_id = cmd\n            .run(\n                None,\n                persona,\n                message,\n                tool_definitions,\n                &on_delta,\n                &execute_tool,\n            )\n            .await\n            .map_err(|e| PortError::Tool(e.to_string()))?;\n\n        let response = reply.lock().unwrap().clone();\n        Ok(json!({\n            \"session_id\": session_id.0,\n            \"response\": response,\n        })\n        .to_string())\n    }\n}\n","exit_code":0,"status":"completed"}}
