          } else {\n   494\t                    self.input.move_to_end();\n   495\t                }\n   496\t                AppAction::None\n   497\t            }\n   498\t            KeyCode::Char(c)\n   499\t                if !key.modifiers.contains(KeyModifiers::CONTROL)\n   500\t                    && !key.modifiers.contains(KeyModifiers::ALT) =>\n   501\t            {\n   502\t                self.clear_preedit_state();\n   503\t                self.input.insert_char(c);\n   504\t                self.clear_history_navigation();\n   505\t                AppAction::None\n   506\t            }\n   507\t            _ => AppAction::None,\n   508\t        }\n   509\t    }\n   510\t\n   511\t    fn submit_input(&mut self) -> AppAction {\n   512\t        let raw_input = self.input.as_str().to_string();\n   513\t        let normalized = raw_input.trim().to_string();\n   514\t        if normalized.is_empty() {\n   515\t            return AppAction::None;\n   516\t        }\n   517\t        if matches!(normalized.as_str(), \"q\" | \"quit\" | \"exit\") {\n   518\t            return AppAction::Quit;\n   519\t        }\n   520\t        self.push_history(raw_input.clone());\n   521\t\n   522\t        self.conversation\n   523\t            .push(ConversationLine::User(raw_input.clone()));\n   524\t        self.active_assistant_idx = None;\n   525\t        self.input.clear();\n   526\t        self.clear_history_navigation();\n   527\t        self.ime_preedit = None;\n   528\t        AppAction::Submit(raw_input)\n   529\t    }\n   530\t\n   531\t    fn clear_preedit_state(&mut self) {\n   532\t        self.ime_preedit = None;\n   533\t        self.suppress_enter_submit_once = false;\n   534\t    }\n   535\t\n   536\t    fn clear_history_navigation(&mut self) {\n   537\t        self.history_cursor = None;\n   538\t        self.history_draft = None;\n   539\t    }\n   540\t\n   541\t    fn push_history(&mut self, item: String) {\n   542\t        const MAX_HISTORY: usize = 100;\