eight.saturating_sub(2).max(1);\n   739\t\n   740\t        let (mut row, mut col) = self.input.cursor_display_offset();\n   741\t        row = row.saturating_add(col / inner_width);\n   742\t        col %= inner_width;\n   743\t\n   744\t        (\n   745\t            inner_x.saturating_add(col.min(inner_width.saturating_sub(1))),\n   746\t            inner_y.saturating_add(row.min(inner_height.saturating_sub(1))),\n   747\t        )\n   748\t    }\n   749\t}\n   750\t\n   751\tfn prev_grapheme_boundary(text: &str, cursor: usize) -> usize {\n   752\t    let mut prev = 0usize;\n   753\t    for (idx, _) in text.grapheme_indices(true) {\n   754\t        if idx >= cursor {\n   755\t            break;\n   756\t        }\n   757\t        prev = idx;\n   758\t    }\n   759\t    prev\n   760\t}\n","exit_code":0,"status":"completed"}}
