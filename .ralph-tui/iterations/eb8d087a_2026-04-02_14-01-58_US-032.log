SessionReady(String),\n   875\t}\n   876\t\n   877\t#[derive(Clone, Copy)]\n   878\tstruct DrawLimiter;\n   879\t\n   880\timpl DrawLimiter {\n   881\t    const fn interval() -> Duration {\n   882\t        Duration::from_millis(16)\n   883\t    }\n   884\t\n   885\t    fn should_draw(last_draw: Instant) -> bool {\n   886\t        last_draw.elapsed() >= Self::interval()\n   887\t    }\n   888\t\n   889\t    fn next_timeout(last_draw: Instant, dirty: bool) -> Duration {\n   890\t        if !dirty {\n   891\t            return Duration::from_millis(10);\n   892\t        }\n   893\t        let elapsed = last_draw.elapsed();\n   894\t        if elapsed >= Self::interval() {\n   895\t            Duration::ZERO\n   896\t        } else {\n   897\t            Self::interval() - elapsed\n   898\t        }\n   899\t    }\n   900\t}\n   901\t\n   902\tfn drain_ui_events(\n   903\t    app: &mut AppState,\n   904\t    runtime: &mut RuntimeState,\n   905\t    ui_rx: &mut tokio::sync::mpsc::UnboundedReceiver<UiEvent>,\n   906\t    dirty: &mut bool,\n   907\t) {\n   908\t    while let Ok(evt) = ui_rx.try_recv() {\n   909\t        match evt {\n   910\t            UiEvent::AssistantDelta(delta) => app.apply_delta(&delta),\n   911\t            UiEvent::AssistantDone => {\n   912\t                runtime.in_flight = false;\n   913\t                app.close_active_assistant();\n   914\t            }\n   915\t            UiEvent::ToolStart { name, args } => app.push_tool_start(name, args),\n   916\t            UiEvent::ToolDone { name, success } => app.push_tool_done(name, success),\n   917\t            UiEvent::WorkerStatus { task_id, status } => app.push_worker_status(task_id, status),\n   918\t            UiEvent::Error(message) => {\n   919\t                runtime.in_flight = false;\n   920\t                app.push_error_status(message);\n   921\t            }\n   922\t            UiEvent::SessionReady(sid) => {\n   923\t                runtime.session_id = Some(sid.clone());\n   924\t                app.push_info_status(format!(\"session: {sid}\"));\n   925\t            }\n   926\t        }\n   927\t        *dirty = true;\n   928\t    }\n   929\t}\n   930\t\n   931\tfn spawn_agent_turn(\n   932\t    bootstrap_state: Arc<BootstrapState>,\n   933\t    session_id: Option<String>,\n   934\t    user_content: String,\n   935\t    ui_tx: tokio::sync::mpsc::UnboundedSender<UiEvent>,\n   936\t) {\n   937\t    tokio::spawn(async move {\n   938\t        let Some(provider) = bootstrap_state.provider.clone() else {\n   939\t            let _ = ui_tx.send(UiEvent::Error(\"provider unavailable\".to_string()));\n   940\t            return;\n   941\t        };\n   942\t        let cmd = AgentRunCommand::new(Arc::clone(&bootstrap_state.session_repo), provider)\n   943\t            .with_context(bootstrap_state.context_policy.clone());\n   944\t        let tool_registry = Arc::clone(&bootstrap_state.tool_registry);\n   945\t        let tool_ctx = Arc::new(bootstrap_state.tool_ctx());\n   946\t        let tool_definitions = tool_registry.definitions();\n   947\t        let tool_event_tx = ui_tx.clone();\n   948\t\n   949\t        let on_delta = {\n   950\t            let tx = ui_tx.clone();\n   951\t            move |content: String| {\n   952\t                let _ = tx.send(UiEvent::AssistantDelta(content));\n   953\t            }\n   954\t        };\n   955\t\n   956\t        let execute_tool = move |name: String,\n   957\t                                 args: Value|\n   958\t              -> std::pin::Pin<\n   959\t            Box<dyn std::future::Future<Output = Result<String, String>> + Send>,\n   960\t        > {\n   961\t            let registry = Arc::clone(&tool_registry);\n   962\t            let tool_ctx = Arc::clone(&tool_ctx);\n   963\t            let tx = tool_event_tx.clone();\n   964\t            Box::pin(async move {\n   965\t                let _ = tx.send(UiEvent::ToolStart {\n   966\t                    name: name.clone(),\n   967\t                    args: args.clone(),\n   968\t                });\n   969\t                let result = registry\n   970\t                    .execute(&name, args, &tool_ctx)\n   971\t                    .await\n   972\t                    .map_err(|e| e.to_string());\n   973\t                if let Ok(payload) = &result\n   974\t                    && let Ok(value) = serde_json::from_str::<Value>(payload)\n   975\t                    && let (Some(task_id), Some(status_raw)) = (\n   976\t                        value.get(\"task_id\").and_then(Value::as_str),\n   977\t                        value.get(\"status\").and_then(Value::as_str),\n   978\t                    )\n   979\t                    && let Some(status) = worker_status_label(status_raw)\n   980\t                {\n","exit_code":0,"status":"completed"}}
