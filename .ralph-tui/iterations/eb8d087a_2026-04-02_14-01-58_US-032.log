                   } else if let RuntimeDeps::Ready { bootstrap_state } = &runtime_deps {\n    85\t                        runtime.in_flight = true;\n    86\t                        spawn_agent_turn(\n    87\t                            Arc::clone(bootstrap_state),\n    88\t                            runtime.session_id.clone(),\n    89\t                            prompt,\n    90\t                            ui_tx.clone(),\n    91\t                        );\n    92\t                    } else {\n    93\t                        app.push_error_status(\"provider unavailable\".to_string());\n    94\t                    }\n    95\t                    dirty = true;\n    96\t                }\n    97\t            }\n    98\t        }\n    99\t\n   100\t        if dirty && DrawLimiter::should_draw(last_draw) {\n   101\t            terminal.draw(|frame| draw_ui(frame, &app))?;\n   102\t            last_draw = Instant::now();\n   103\t            dirty = false;\n   104\t        } else if timeout > Duration::ZERO {\n   105\t            std::thread::sleep(timeout.min(Duration::from_millis(10)));\n   106\t        }\n   107\t    }\n   108\t\n   109\t    terminal.show_cursor()?;\n   110\t    drop(terminal);\n   111\t    drop(terminal_guard);\n   112\t    Ok(())\n   113\t}\n   114\t\n   115\tfn draw_ui(frame: &mut Frame<'_>, app: &AppState) {\n   116\t    let [conversation_pane, status_pane, input_pane] = split_layout(frame.area());\n   117\t\n   118\t    let conversation = Paragraph::new(app.render_conversation())\n   119\t        .block(\n   120\t            Block::default()\n   121\t                .title(\"Conversation\")\n   122\t                .borders(Borders::ALL)\n   123\t                .title_style(Style::default().add_modifier(Modifier::BOLD)),\n   124\t        )\n   125\t        .scroll((app.conversation_scroll, 0))\n   126\t        .wrap(Wrap { trim: false });\n   127\t    frame.render_widget(conversation, conversation_pane);\n   128\t\n   129\t    let status = Paragraph::new(app.render_status()).block(\n   130\t        Block::default()\n   131\t            .title(\"Status\")\n   132\t            .borders(Borders::ALL)\n   133\t            .title_style(Style::default().add_modifier(Modifier::BOLD)),\n   134\t    );\n   135\t    frame.render_widget(status, status_pane);\n   136\t\n   137\t    let input = Paragraph::new(app.render_input())\n   138\t        .wrap(Wrap { trim: false })\n   139\t        .block(\n   140\t            Block::default()\n   141\t                .title(\"Input\")\n   142\t                .borders(Borders::ALL)\n   143\t                .title_style(Style::default().add_modifier(Modifier::BOLD)),\n   144\t        );\n   145\t    frame.render_widget(input, input_pane);\n   146\t    frame.set_cursor_position(app.input_cursor_position(input_pane));\n   147\t}\n   148\t\n   149\tfn split_layout(area: Rect) -> [Rect; 3] {\n   150\t    Layout::vertical([\n   151\t        Constraint::Min(5),\n   152\t        Constraint::Length(5),\n   153\t        Constraint::Length(3),\n   154\t    ])\n   155\t    .areas(area)\n   156\t}\n   157\t\n   158\t#[derive(Default)]\n   159\tstruct RuntimeState {\n   160\t    in_flight: bool,\n   161\t    session_id: Option<String>,\n   162\t}\n   163\t\n   164\tenum RuntimeDeps {\n   165\t    Ready {\n   166\t        bootstrap_state: Arc<BootstrapState>,\n   167\t    },\n   168\t    Unavailable,\n   169\t}\n   170\t\n   171\t#[derive(Clone, Debug)]\n   172\tenum StatusKind {\n   173\t    Info,\n   174\t    Error(ErrorCategory),\n   175\t}\n   176\t\n   177\t#[derive(Clone, Debug)]\n   178\tstruct StatusLine {\n   179\t    kind: StatusKind,\n   180\t    message: String,\n   181\t}\n   182\t\n   183\t#[derive(Clone, Debug)]\n   184\tenum ConversationLine {\n   185\t    User(String),\n   186\t    Assistant(String),\n   187\t    ToolStart { name: String, args_summary: String },\n   188\t    ToolDone { name: String, success: bool },\n   189\t    WorkerStatus { task_id: String, status: String },\n   190\t}\n   191\t\n   192\t#[derive(Default)]\n   193\tstruct AppState {\n   194\t    conversation: Vec<ConversationLine>,\n   195\t    status: VecDeque<StatusLine>,\n   196\t    input: InputBuffer,\n   197\t    input_history: VecDeque<String>,\n   198\t    history_cursor: Option<usize>,\n   199\t    history_draft: Option<String>,\n   200\t    ime_preedit: Option<String>,\n   201\t    suppress_enter_submit_once: bool,\n   202\t    active_assistant_idx: Option<usize>,\n   203\t    conversation_scroll: u16,\n   204\t    should_quit: bool,\n   205\t}\n   206\t\n   207\tenum AppAction {\n   208\t    None,\n   209\t    Submit(String),\n   210\t    Quit,\n   211\t}\n   212\t\n   213\t#[derive(Clone, Debug)]\n   214\tenum AppInputEvent {\n   215\t    Key(KeyEvent),\n   216\t    Paste(String),\n   217\t}\n   218\t\n   219\t#[derive(Default)]\n   220\tstruct InputBuffer {\n","exit_code":0,"status":"completed"}}
