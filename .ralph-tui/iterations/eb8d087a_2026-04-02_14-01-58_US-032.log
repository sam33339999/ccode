ext = text;\n   349\t    }\n   350\t\n   351\t    fn insert_char(&mut self, c: char) {\n   352\t        let mut buf = [0; 4];\n   353\t        self.insert_str(c.encode_utf8(&mut buf));\n   354\t    }\n   355\t\n   356\t    fn insert_str(&mut self, s: &str) {\n   357\t        if s.is_empty() {\n   358\t            return;\n   359\t        }\n   360\t        self.text.insert_str(self.cursor, s);\n   361\t        self.cursor += s.len();\n   362\t    }\n   363\t\n   364\t    fn move_left(&mut self) {\n   365\t        self.cursor = prev_grapheme_boundary(self.text.as_str(), self.cursor);\n   366\t    }\n   367\t\n   368\t    fn move_right(&mut self) {\n   369\t        self.cursor = next_grapheme_boundary(self.text.as_str(), self.cursor);\n   370\t    }\n   371\t\n   372\t    fn move_to_start(&mut self) {\n   373\t        self.cursor = 0;\n   374\t    }\n   375\t\n   376\t    fn move_to_end(&mut self) {\n   377\t        self.cursor = self.text.len();\n   378\t    }\n   379\t\n   380\t    fn backspace_grapheme(&mut self) {\n   381\t        if self.cursor == 0 {\n   382\t            return;\n   383\t        }\n   384\t        let start = prev_grapheme_boundary(self.text.as_str(), self.cursor);\n   385\t        self.text.drain(start..self.cursor);\n   386\t        self.cursor = start;\n   387\t    }\n   388\t\n   389\t    fn cursor_display_offset(&self) -> (u16, u16) {\n   390\t        let before = &self.text[..self.cursor];\n   391\t        let mut row = 0usize;\n   392\t        let mut col = 0usize;\n   393\t        for (idx, line) in before.split('\\n').enumerate() {\n   394\t            if idx > 0 {\n   395\t                row += 1;\n   396\t            }\n   397\t            col = UnicodeWidthStr::width(line);\n   398\t        }\n   399\t        (row as u16, col as u16)\n   400\t    }\n   401\t}\n   402\t\n   403\timpl AppState {\n   404\t    fn handle_input_event(&mut self, event: AppInputEvent) -> AppAction {\n   405\t        match event {\n   406\t            AppInputEvent::Key(key) => self.handle_key(key),\n   407\t            AppInputEvent::Paste(text) => {\n   408\t                self.clear_preedit_state();\n   409\t                self.input.insert_str(text.as_str());\n   410\t                self.clear_history_navigation();\n   411\t                AppAction::None\n   412\t            }\n   413\t        }\n   414\t    }\n   415\t\n   416\t    #[cfg(test)]\n   417\t    fn ime_preedit_for_test(&mut self, text: String) {\n   418\t        self.ime_preedit = if text.is_empty() { None } else { Some(text) };\n   419\t    }\n   420\t\n   421\t    #[cfg(test)]\n   422\t    fn ime_commit_for_test(&mut self, text: String) {\n   423\t        if !text.is_empty() {\n   424\t            self.input.insert_str(text.as_str());\n   425\t            self.suppress_enter_submit_once = true;\n   426\t        }\n   427\t        self.ime_preedit = None;\n   428\t        self.clear_history_navigation();\n   429\t    }\n   430\t\n   431\t    fn handle_key(&mut self, key: KeyEvent) -> AppAction {\n   432\t        if key.kind == KeyEventKind::Release {\n   433\t            return AppAction::None;\n   434\t        }\n   435\t        if key.modifiers.contains(KeyModifiers::CONTROL) && key.code == KeyCode::Char('c') {\n   436\t            return AppAction::Quit;\n   437\t        }\n   438\t\n   439\t        match key.code {\n   440\t            KeyCode::Esc => {\n   441\t                self.ime_preedit = None;\n   442\t                AppAction::Quit\n   443\t            }\n   444\t            KeyCode::Char('q') if self.input.is_empty() => AppAction::Quit,\n   445\t            KeyCode::Enter if key.modifiers.contains(KeyModifiers::SHIFT) => {\n   446\t                self.clear_preedit_state();\n   447\t                self.input.insert_char('\\n');\n   448\t                self.clear_history_navigation();\n   449\t                AppAction::None\n   450\t            }\n   451\t            KeyCode::Enter if self.ime_preedit.is_some() || self.suppress_