iArgs) -> anyhow::Result<()> {","+    if !terminal_supports_tui() {","+        eprintln!(\"[tui] terminal does not support raw mode — falling back to REPL\");","+        return super::repl::run(super::repl::ReplArgs {","+            session: None,","+            persona: None,","+            no_confirm: false,","+        })","+        .await;","+    }","     run_ui_loop().await"," }"," "," async fn run_ui_loop() -> anyhow::Result<()> {","+    // Load config to resolve the user's preferred theme (best-effort; ignore errors).","+    let tui_theme_name = ccode_config::load()","+        .ok()","+        .and_then(|cfg| cfg.tui.theme)","+        .unwrap_or_default();","+    let color_support = detect_color_support();","+    let theme = Theme::build(","+        ThemeName::from_str(tui_theme_name.as_str()),","+        color_support,","+    );","+","     install_panic_restoration_hook();","     enable_raw_mode()?;","     execute!(io::stdout(), EnterAlternateScreen)?;"]}],"userModified":false,"replaceAll":false}}
