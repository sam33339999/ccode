{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PP5M8WBus79x9FPCWcSvhP","type":"tool_result","content":"600\t            .push(ConversationLine::User(raw_input.clone()));\n601\t        self.active_assistant_idx = None;\n602\t        self.input.clear();\n603\t        self.clear_history_navigation();\n604\t        self.ime_preedit = None;\n605\t        AppAction::Submit(raw_input)\n606\t    }\n607\t\n608\t    fn clear_preedit_state(&mut self) {\n609\t        self.ime_preedit = None;\n610\t        self.suppress_enter_submit_once = false;\n611\t    }\n612\t\n613\t    fn clear_history_navigation(&mut self) {\n614\t        self.history_cursor = None;\n615\t        self.history_draft = None;\n616\t    }\n617\t\n618\t    fn push_history(&mut self, item: String) {\n619\t        const MAX_HISTORY: usize = 100;\n620\t        if self\n621\t            .input_history\n622\t            .back()\n623\t            .is_some_and(|last| last.as_str() == item.as_str())\n624\t        {\n625\t            return;\n626\t        }\n627\t        if self.input_history.len() >= MAX_HISTORY {\n628\t            self.input_history.pop_front();\n629\t        }\n630\t        self.input_history.push_back(item);\n631\t    }\n632\t\n633\t    fn recall_history_prev(&mut self) {\n634\t        if self.input_history.is_empty() {\n635\t            return;\n636\t        }\n637\t\n638\t        let next_idx = match self.history_cursor {\n639\t            Some(current) => current.saturating_sub(1),\n640\t            None => {\n641\t                self.history_draft = Some(self.input.as_str().to_string());\n642\t                self.input_history.len() - 1\n643\t            }\n644\t        };\n645\t        self.history_cursor = Some(next_idx);\n646\t        if let Some(entry) = self.input_history.get(next_idx) {\n647\t            self.input.set_text(entry.clone());\n648\t        }\n649\t        self.clear_preedit_state();\n650\t    }\n651\t\n652\t    fn recall_history_next(&mut self) {\n653\t        let Some(current) = self.history_cursor else {\n654\t            return;\n655\t        };\n656\t\n657\t        if current + 1 < self.input_history.len() {\n658\t            let next_idx = current + 1;\n659\t            self.history_cursor = Some(next_idx);\n660\t            if let Some(entry) = self.input_history.get(next_idx) {\n661\t                self.input.set_text(entry.clone());\n662\t            }\n663\t        } else {\n664\t            self.history_cursor = None;\n665\t            let draft = self.history_draft.take().unwrap_or_default();\n666\t            self.input.set_text(draft);\n667\t        }\n668\t        self.clear_preedit_state();\n669\t    }\n670\t\n671\t    fn apply_delta(&mut self, delta: &str) {\n672\t        if delta.is_empty() {\n673\t            return;\n674\t        }\n675\t        let idx = if let Some(idx) = self.active_assistant_idx {\n676\t            idx\n677\t        } else {\n678\t            self.conversation\n679\t                .push(ConversationLine::Assistant(String::new()));\n680\t            let idx = self.conversation.len() - 1;\n681\t            self.active_assistant_idx = Some(idx);\n682\t            idx\n683\t        };\n684\t        if let Some(ConversationLine::Assistant(content)) = self.conversation.get_mut(idx) {\n685\t            content.push_str(delta);\n686\t        }\n687\t    }\n688\t\n689\t    fn close_active_assistant(&mut self) {\n690\t        self.active_assistant_idx = None;\n691\t    }\n692\t\n693\t    fn open_tool_approval(\n694\t        &mut self,\n695\t        name: String,\n696\t        args: Value,\n697\t        response_tx: tokio::sync::oneshot::Sender<ToolConfirmationDecision>,\n698\t    ) {\n699\t        self.tool_approval = Some(ToolApprovalModal {\n700\t            risk_level: classify_tool_risk(name.as_str()).label().to_string(),\n701\t            tool_name: name,\n702\t            params_summary: summarize_tool_args(&args),\n703\t            selected: 0,\n704\t            response_tx: Some(response_tx),\n705\t        });\n706\t    }\n707\t\n708\t    #[cfg(test)]\n709\t    fn open_tool_approval_for_test(&mut self, name: String, args: Value) {\n710\t        self.tool_approval = Some(ToolApprovalModal {\n711\t            risk_level: classify_tool_risk(name.as_str()).label().to_string(),\n712\t            tool_name: name,\n713\t            params_summary: summarize_tool_args(&args),\n714\t            selected: 0,\n715\t            response_tx: None,\n716\t        });\n717\t    }\n718\t\n719\t    fn has_pending_tool_approval(&self) -> bool {\n720\t        self.tool_approval.is_some()\n721\t    }\n722\t\n723\t    fn handle_approval_key(&mut self, key: KeyEvent) -> AppAction {\n724\t        match key.code {\n725\t            KeyCode::Char('y') | KeyCode::Char('Y') => {\n726\t                self.resolve_tool_approval(ToolApprovalAction::AllowOnce)\n727\t            }\n728\t            KeyCode::Char('n') | KeyCode::Char('N') | KeyCode::Esc => {\n729\t                self.resolve_tool_approval(ToolApprovalAction::Deny)\n730\t            }\n731\t            KeyCode::Char('a') | KeyCode::Char('A') => {\n732\t                self.resolve_tool_approval(ToolApprovalAction::AllowAlways)\n733\t            }\n734\t            KeyCode::Tab | KeyCode::Right => {\n735\t                if let Some(modal) = self.tool_approval.as_mut() {\n736\t                    modal.selected = (modal.selected + 1) % 3;\n737\t                }\n738\t                AppAction::None\n739\t            }\n740\t            KeyCode::BackTab | KeyCode::Left => {\n741\t                if let Some(modal) = self.tool_approval.as_mut() {\n742\t                    modal.selected = if modal.selected == 0 {\n743\t                        2\n744\t                    } else {\n745\t                        modal.selected - 1\n746\t                    };\n747\t                }\n748\t                AppAction::None\n749\t            }\n750\t            KeyCode::Enter => {\n751\t                let selected = self\n752\t                    .tool_approval\n753\t                    .as_ref()\n754\t                    .map(|modal| modal.selected)\n755\t                    .unwrap_or(0);\n756\t                self.resolve_tool_approval(ToolApprovalAction::from_selection(selected))\n757\t            }\n758\t            _ => AppAction::None,\n759\t        }\n760\t    }\n761\t\n762\t    fn resolve_tool_approval(&mut self, decision: ToolApprovalAction) -> AppAction {\n763\t        let Some(mut modal) = self.tool_approval.take() else {\n764\t            return AppAction::None;\n765\t        };\n766\t        if let Some(response_tx) = modal.response_tx.take() {\n767\t            let _ = response_tx.send(decision.to_confirmation_decision());\n768\t        }\n769\t        self.conversation.push(ConversationLine::ToolDecision {\n770\t            name: modal.tool_name.clone(),\n771\t            decision,\n772\t        });\n773\t        AppAction::ToolApprovalResolved {\n774\t            name: modal.tool_name,\n775\t            decision,\n776\t        }\n777\t    }\n778\t\n779\t    fn push_tool_start(&mut self, name: String, args: Value) {\n780\t        self.conversation.push(ConversationLine::ToolStart {\n781\t            name,\n782\t            args_summary: summarize_tool_args(&args),\n783\t        });\n784\t    }\n785\t\n786\t    fn push_tool_done(&mut self, name: String, success: bool) {\n787\t        self.conversation\n788\t            .push(ConversationLine::ToolDone { name, success });\n789\t    }\n790\t\n791\t    fn push_worker_status_with_details(\n792\t        &mut self,\n793\t        task_id: String,\n794\t        status: String,\n795\t        summary: Option<String>,\n796\t        timestamp: SystemTime,\n797\t    ) {\n798\t        self.conversation.push(ConversationLine::WorkerStatus {\n799\t            task_id: task_id.clone(),\n800\t            status: status.clone(),\n801\t        });\n802\t        self.record_worker_event(WorkerUiEvent {\n803\t          