  Self {\n60\t            timeout_ms: default_ccr_timeout_ms(),\n61\t            max_retries: default_ccr_retry_count(),\n62\t            retry_delay_ms: default_ccr_retry_delay_ms(),\n63\t        }\n64\t    }\n65\t}\n66\t\n67\tfn default_ccr_timeout_ms() -> u64 {\n68\t    10_000\n69\t}\n70\t\n71\tfn default_ccr_retry_count() -> u32 {\n72\t    2\n73\t}\n74\t\n75\tfn default_ccr_retry_delay_ms() -> u64 {\n76\t    200\n77\t}\n78\t\n79\t// ── Context / compression ─────────────────────────────────────────────────────\n80\t\n81\t/// Controls the agentic loop's context window management.\n82\t#[derive(Debug, Clone, Serialize, Deserialize, Default)]\n83\tpub struct ContextConfig {\n84\t    /// Trigger compression when total context exceeds this many characters\n85\t    /// (rough estimate: 4 chars ≈ 1 token). Default: 600_000 (~150k tokens).\n86\t    pub compress_chars_threshold: Option<usize>,\n87\t    /// Number of most-recent messages to keep verbatim after compression.\n88\t    /// Default: 8.\n89\t    pub keep_recent_messages: Option<usize>,\n90\t    /// Truncate a single tool result that exceeds this many characters.\n91\t    /// Default: 40_000.\n92\t    pub tool_result_max_chars: Option<usize>,\n93\t}\n94\t\n95\t#[derive(Debug, Clone, Serialize, Deserialize, Default)]\n96\tpub struct SandboxConfig {\n97\t    pub cwd: Option<String>,\n98\t    /// \"any\" | \"cwd\" | \"none\"\n99\t    pub fs_read: Option<String>,\n100\t    /// \"any\" | \"cwd\" | \"none\"\n101\t    pub fs_write: Option<String>,\n102\t    /// \"any\" | \"none\" | comma-separated allowlist\n103\t    pub shell: Option<String>,\n104\t    pub web_fetch: Option<bool>,\n105\t    pub browser: Option<bool>,\n106\t}\n107\t\n108\t// ── Providers ─────────────────────────────────────────────────────────────────\n109\t\n110\t#[derive(Debug, Clone, Serialize, Deserialize, Default)]\n111\tpub struct ProvidersConfig {\n112\t    pub openrouter: Option<OpenRouterConfig>,\n113\t    pub zhipu: Option<ZhipuConfig>,\n114\t    pub openai: Option<OpenAiConfig>,\n115\t    pub anthropic: Option<AnthropicConfig>,\n116\t    pub llamacpp: Option<LlamaCppConfig>,\n117\t}\n118\t\n119\t#[derive(Debug, Clone, Serialize, Deserialize, Default)]\n120\tpub struct OpenRouterConfig {\n121\t    /// Bearer token. Falls back to `OPENROUTER_API_KEY` env var.\n122\t    pub api_key: Option<String>,\n123\t    /// Default model slug, e.g. `\"anthropic/claude-3-5-sonnet\"`.\n124\t    pub default_model: Option<String>,\n125\t    /// Override base URL (useful for local proxies).\n126\t    pub base_url: Option<String>,\n127\t    /// Optional HTTP `Referer` header sent to OpenRouter for attribution.\n128\t    pub site_url: Option<String>,\n129\t    /// Optional `X-Title` header sent to OpenRouter.\n130\t    pub site_name: Option<String>,\n131\t}\n132\t\n133\timpl OpenRouterConfig {\n134\t    pub fn resolved_api_key(&self) -> Option<String> {\n135\t        self.api_key\n136\t            .clone()\n137\t            .or_else(|| std::env::var(\"OPENROUTER_API_KEY\").ok())\n138\t    }\n139\t\n140\t    pub fn resolved_base_url(&self) -> String {\n141\t        self.base_url\n142\t            .clone()\n143\t            .or_else(|| std::env::var(\"OPENROUTER_BASE_URL\").ok())\n144\t            .unwrap_or_else(|| \"https://openrouter.ai/api/v1\".into())\n145\t    }\n146\t\n147\t    pub fn resolved_default_model(&self) -> String {\n148\t        self.default_model\n149\t            .clone()\n150\t            .or_else(|| std::env::var(\"OPENROUTER_DEFAULT_MODEL\").ok())\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01WZqWFGu49DUSvyMsDxFM7U","session_id":"b35f4001-d232-4171-b853-fb6a26d102e1","uuid":"