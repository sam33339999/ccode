{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016ubFYyL6PgAbU54JxicBX8","type":"tool_result","content":"1\tuse ccode_application::commands::agent_run::AgentRunCommand;\n2\tuse ccode_bootstrap::AppState as BootstrapState;\n3\tuse ccode_bootstrap::worker_monitor;\n4\tuse chrono::{DateTime, Local};\n5\tuse clap::Args;\n6\tuse crossterm::event::{self, Event, KeyCode, KeyEvent, KeyEventKind, KeyModifiers};\n7\tuse crossterm::execute;\n8\tuse crossterm::terminal::{\n9\t    EnterAlternateScreen, LeaveAlternateScreen, disable_raw_mode, enable_raw_mode,\n10\t};\n11\tuse ratatui::backend::CrosstermBackend;\n12\tuse ratatui::layout::{Constraint, Layout, Rect};\n13\tuse ratatui::style::{Modifier, Style};\n14\tuse ratatui::text::Line;\n15\tuse ratatui::widgets::{Block, Borders, Clear, Paragraph, Wrap};\n16\tuse ratatui::{Frame, Terminal};\n17\tuse serde_json::Value;\n18\tuse std::collections::{HashSet, VecDeque};\n19\tuse std::io;\n20\tuse std::sync::{Arc, Mutex};\n21\tuse std::time::{Duration, Instant, SystemTime};\n22\tuse unicode_segmentation::UnicodeSegmentation;\n23\tuse unicode_width::UnicodeWidthStr;\n24\t\n25\tuse super::output::{\n26\t    ErrorCategory, ToolConfirmationDecision, classify_error, classify_tool_risk,\n27\t    error_category_label, summarize_tool_args, worker_status_label,\n28\t};\n29\t\n30\t#[derive(Args, Default)]\n31\tpub struct TuiArgs {}\n32\t\n33\tpub async fn run(_args: TuiArgs) -> anyhow::Result<()> {\n34\t    run_ui_loop().await\n35\t}\n36\t\n37\tasync fn run_ui_loop() -> anyhow::Result<()> {\n38\t    install_panic_restoration_hook();\n39\t    enable_raw_mode()?;\n40\t    execute!(io::stdout(), EnterAlternateScreen)?;\n41\t\n42\t    let terminal_guard = TerminalGuard;\n43\t    let backend = CrosstermBackend::new(io::stdout());\n44\t    let mut terminal = Terminal::new(backend)?;\n45\t    terminal.clear()?;\n46\t\n47\t    let state = ccode_bootstrap::wire_from_config_with_cwd(std::env::current_dir().ok());\n48\t    let mut app = AppState::default();\n49\t    let (ui_tx, mut ui_rx) = tokio::sync::mpsc::unbounded_channel::<UiEvent>();\n50\t    let mut worker_monitor_rx = worker_monitor::subscribe_worker_events();\n51\t    let mut runtime = RuntimeState::default();\n52\t    let always_allowed_tools: Arc<Mutex<HashSet<String>>> = Arc::new(Mutex::new(HashSet::new()));\n53\t\n54\t    let runtime_deps = match state {\n55\t        Ok(bootstrap_state) => {\n56\t            if bootstrap_state.provider.is_none() {\n57\t                app.push_error_status(\"no LLM provider configured\".to_string());\n58\t                RuntimeDeps::Unavailable\n59\t            } else {\n60\t                RuntimeDeps::Ready {\n61\t                    bootstrap_state: Arc::new(bootstrap_state),\n62\t                }\n63\t            }\n64\t        }\n65\t        Err(e) => {\n66\t            app.push_error_status(e.to_string());\n67\t            RuntimeDeps::Unavailable\n68\t        }\n69\t    };\n70\t\n71\t    let mut last_draw = Instant::now() - DrawLimiter::interval();\n72\t    let mut dirty = true;\n73\t    while !app.should_quit {\n74\t        drain_ui_events(\n75\t            &mut app,\n76\t            &mut runtime,\n77\t            &mut ui_rx,\n78\t            &mut worker_monitor_rx,\n79\t            &mut dirty,\n80\t        );\n81\t        let timeout = DrawLimiter::next_timeout(last_draw, dirty);\n82\t        if event::poll(Duration::from_millis(50))? {\n83\t            let action = match event::read()? {\n84\t                Event::Key(key) => app.handle_input_event(AppInputEvent::Key(key)),\n85\t                Event::Paste(text) => app.handle_input_event(AppInputEvent::Paste(text)),\n86\t                _ => AppAction::None,\n87\t            };\n88\t\n89\t            match action {\n90\t                AppAction::None => {}\n91\t                AppAction::Quit => app.should_quit = true,\n92\t                AppAction::Submit(prompt) => {\n93\t                    if runtime.in_flight {\n94\t                        app.push_info_status(\"request already in progress\".to_string());\n95\t                    } else if let RuntimeDeps::Ready { bootstrap_state } = &runtime_deps {\n96\t                        runtime.in_flight = true;\n97\t                        spawn_agent_turn(\n98\t                            Arc::clone(bootstrap_state),\n99\t                            runtime.session_id.clone(),\n100\t                            prompt,\n101\t                            ui_tx.clone(),\n102\t                            Arc::clone(&always_allowed_tools),\n103\t                        );\n104\t                    } else {\n105\t                        app.push_error_status(\"provider unavailable\".to_string());\n106\t                    }\n107\t                    dirty = true;\n108\t                }\n109\t                AppAction::ToolApprovalResolved { name, decision } => {\n110\t                    app.push_info_status(format!(\"tool decision: {} {}\", name, decision.label()));\n111\t                    dirty = true;\n112\t                }\n113\t                AppAction::StopSelectedTask(task_id) => {\n114\t                    if let RuntimeDeps::Ready { bootstrap_state } = &runtime_deps {\n115\t                        spawn_task_stop(Arc::clone(bootstrap_state), task_id, ui_tx.clone());\n116\t                    } else {\n117\t                        app.push_error_status(\"provider unavailable\".to_string());\n118\t                    }\n119\t                    dirty = true;\n120\t                }\n121\t            }\n122\t        }\n123\t\n124\t        if dirty && DrawLimiter::should_draw(last_draw) {\n125\t            terminal.draw(|frame| draw_ui(frame, &app))?;\n126\t            last_draw = Instant::now();\n127\t            dirty = false;\n128\t        } else if timeout > Duration::ZERO {\n129\t            std::thread::sleep(timeout.min(Duration::from_millis(10)));\n130\t        }\n131\t    }\n132\t\n133\t    terminal.show_cursor()?;\n134\t    drop