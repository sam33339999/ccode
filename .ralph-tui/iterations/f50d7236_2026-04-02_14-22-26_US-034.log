nput(&mut self) -> AppAction {\n589\t        let raw_input = self.input.as_str().to_string();\n590\t        let normalized = raw_input.trim().to_string();\n591\t        if normalized.is_empty() {\n592\t            return AppAction::None;\n593\t        }\n594\t        if matches!(normalized.as_str(), \"q\" | \"quit\" | \"exit\") {\n595\t            return AppAction::Quit;\n596\t        }\n597\t        self.push_history(raw_input.clone());\n598\t\n599\t        self.conversation\n600\t            .push(ConversationLine::User(raw_input.clone()));\n601\t        self.active_assistant_idx = None;\n602\t        self.input.clear();\n603\t        self.clear_history_navigation();\n604\t        self.ime_preedit = None;\n605\t        AppAction::Submit(raw_input)\n606\t    }\n607\t\n608\t    fn clear_preedit_state(&mut self) {\n609\t        self.ime_preedit = None;\n610\t        self.suppress_enter_submit_once = false;\n611\t    }\n612\t\n613\t    fn clear_history_navigation(&mut self) {\n614\t        self.history_cursor = None;\n615\t        self.history_draft = None;\n616\t    }\n617\t\n618\t    fn push_history(&mut self, item: String) {\n619\t        const MAX_HISTORY: usize = 100;\n620\t        if self\n621\t            .input_history\n622\t            .back()\n623\t            .is_some_and(|last| last.as_str() == item.as_str())\n624\t        {\n625\t            return;\n626\t        }\n627\t        if self.input_history.len() >= MAX_HISTORY {\n628\t            self.input_history.pop_front();\n629\t        }\n630\t        self.input_history.push_back(item);\n631\t    }\n632\t\n633\t    fn recall_history_prev(&mut self) {\n634\t        if self.input_history.is_empty() {\n635\t            return;\n636\t        }\n637\t\n638\t        let next_idx = match self.history_cursor {\n639\t            Some(current) => current.saturating_sub(1),\n640\t            None => {\n641\t                self.history_draft = Some(self.input.as_str().to_string());\n642\t                self.input_h