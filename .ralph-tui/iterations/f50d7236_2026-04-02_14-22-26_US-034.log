{\n857\t                                lines.push(Line::from(format!(\"Assistant: {line}\")));\n858\t                            } else {\n859\t                                lines.push(Line::from(format!(\"  {line}\")));\n860\t                            }\n861\t                        }\n862\t                        if text.ends_with('\\n') {\n863\t                            lines.push(Line::from(\"  \"));\n864\t                        }\n865\t                        lines\n866\t                    }\n867\t                }\n868\t                ConversationLine::ToolStart { name, args_summary } => {\n869\t                    vec![Line::from(format!(\"[tool:start] {name} ({args_summary})\"))]\n870\t                }\n871\t                ConversationLine::ToolDone { name, success } => {\n872\t                    let marker = if *success { \"[ok]\" } else { \"[fail]\" };\n873\t                    vec![Line::from(format!(\"[tool:done] {name} {marker}\"))]\n874\t                }\n875\t                ConversationLine::ToolDecision { name, decision } => {\n876\t                    vec![Line::from(format!(\n877\t                        \"[tool:decision] {} {}\",\n878\t                        name,\n879\t                        decision.label()\n880\t                    ))]\n881\t                }\n882\t                ConversationLine::WorkerStatus { task_id, status } => {\n883\t                    vec![Line::from(format!(\"[worker] {task_id} {status}\"))]\n884\t                }\n885\t            })\n886\t            .collect()\n887\t    }\n888\t\n889\t    fn render_status(&self) -> String {\n890\t        self.status\n891\t            .iter()\n892\t            .rev()\n893\t            .take(4)\n894\t            .map(|line| match &line.kind {\n895\t                StatusKind::Info => format!(\"[info] {}\", line.message),\n896\t                StatusKind::Error(category) => {\n897\t                    format!(\"[{}] {}\", error_category_label(*category), line.message)\n898\t                }\n899\t            })\n900\t            .collect::<Vec<_>>()\n901\t            .join(\"\\n\")\n902\t    }\n903\t\n904\t    fn render_input(&self) -> String {\n905\t        let Some(preedit) = &self.ime_preedit else {\n906\t            return self.input.as_str().to_string();\n907\t        };\n908\t        if preedit.is_empty() {\n909\t            return self.input.as_str().to_string();\n910\t        }\n911\t\n912\t        let cursor = self.input.cursor;\n913\t        let mut rendered = self.input.as_str().to_string();\n914\t        rendered.insert_str(cursor, preedit.as_str());\n915\t        rendered\n916\t    }\n917\t\n918\t    fn record_worker_event(&mut self, event: WorkerUiEvent) {\n919\t        const MAX_WORKER_TASKS: usize = 500;\n920\t        let selected_id = if self.worker_panel.manual_selection {\n921\t            self.worker_panel\n922\t                .tasks\n923\t                .get(self.worker_panel.selected)\n924\t                .map(|task| task.task_id.clone())\n925\t        } else {\n926\t            None\n927\t        };\n928\t\n929\t        if let Some(existing_idx) = self\n930\t            .worker_panel\n931\t            .tasks\n932\t            .iter()\n933\t            .position(|task| task.task_id == event.task_id)\n934\t        {\n935\t            let mut existing = self.worker_panel.tasks.remove(existing_idx);\n936\t            existing.status = event.status;\n937\t            if event.summary.is_some() {\n938\t                existing.summary = event.summary;\n939\t            }\n940\t            existing.updated_at = event.timestamp;\n941\t            self.worker_panel.tasks.insert(0, existing);\n942\t        } else {\n943\t            self.worker_panel.tasks.insert(\n944\t                0,\n945\t                WorkerTaskEntry {\n946\t                    task_id: event.task_id,\n947\t                    status: event.status,\n948\t                    summary: event.summary,\n949\t                    started_at: