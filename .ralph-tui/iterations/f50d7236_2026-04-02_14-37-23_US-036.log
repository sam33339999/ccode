{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017nKkXLoUpgCdLEoAG4BctV","type":"tool_result","content":"1\tuse super::types::*;\n2\tuse async_stream::stream;\n3\tuse ccode_domain::message::{Role, ToolCall};\n4\tuse ccode_ports::provider::{\n5\t    LlmError, LlmRequest, LlmResponse, LlmStream, StreamEvent, TokenUsage,\n6\t};\n7\tuse futures::StreamExt;\n8\tuse reqwest::header::HeaderMap;\n9\tuse std::collections::HashMap;\n10\tuse std::time::Duration;\n11\t\n12\tconst ANTHROPIC_VERSION: &str = \"2023-06-01\";\n13\tconst DEFAULT_MAX_TOKENS: u32 = 4096;\n14\ttype ToolUseBuffer = HashMap<usize, (String, String, String)>;\n15\t\n16\t/// HTTP client for the Anthropic Messages API.\n17\t///\n18\t/// Wire format differences from OpenAI-compat:\n19\t/// - Auth: `x-api-key` header (not Bearer)\n20\t/// - Required header: `anthropic-version`\n21\t/// - `system` prompt is a top-level field, not in the messages array\n22\t/// - `max_tokens` is required\n23\t/// - SSE ends with `event: message_stop`, no `[DONE]` sentinel\n24\tpub struct AnthropicCompatClient {\n25\t    client: reqwest::Client,\n26\t    pub api_key: String,\n27\t    pub base_url: String,\n28\t    pub default_model: String,\n29\t}\n30\t\n31\timpl AnthropicCompatClient {\n32\t    pub fn new(\n33\t        api_key: impl Into<String>,\n34\t        base_url: impl Into<String>,\n35\t        default_model: impl Into<String>,\n36\t    ) -> Self {\n37\t        Self {\n38\t            client: reqwest::Client::new(),\n39\t            api_key: api_key.into(),\n40\t            base_url: base_url.into(),\n41\t            default_model: default_model.into(),\n42\t        }\n43\t    }\n44\t\n45\t    fn messages_endpoint(&self) -> String {\n46\t        format!(\"{}/messages\", self.base_url)\n47\t    }\n48\t\n49\t    fn models_endpoint(&self) -> String {\n50\t        format!(\"{}/models\", self.base_url)\n51\t    }\n52\t\n53\t    fn add_headers(&self, builder: reqwest::RequestBuilder) -> reqwest::RequestBuilder {\n54\t        builder\n55\t            .header(\"x-api-key\", &self.api_key)\n56\t            .header(\"anthropic-version\", ANTHROPIC_VERSION)\n57\t    }\n58\t\n59\t    /// 將 LlmRequest 的 messages 轉換為 Anthropic 格式。\n60\t    ///\n61\t    /// 三種轉換規則：\n62\t    /// 1. System → 抽出，合併為頂層 `system` 欄位\n63\t    /// 2. Assistant + tool_calls → content 為 block 陣列（text block + tool_use blocks）\n64\t    /// 3. Tool（工具結果）→ role=\"user\"，content 為 tool_result block 陣列；\n65\t    ///    **連續多個 Tool 訊息必須合併成同一個 user 訊息**（Anthropic 禁止連續同 role）\n66\t    fn split_system(&self, req: &LlmRequest) -> (Option<String>, Vec<AnthropicMessage>) {\n67\t        use serde_json::{Value, json};\n68\t\n69\t        let mut system_parts: Vec<String> = Vec::new();\n70\t        let mut messages: Vec<AnthropicMessage> = Vec::new();\n71\t\n72\t        // 先過濾 System，並把其餘訊息逐一轉換\n73\t        let non_system: Vec<_> = req\n74\t            .messages\n75\t            .iter()\n76\t            .filter(|m| {\n77\t                if m.role == Role::System {\n78\t                    system_parts.push(m.content.clone());\n79\t                    false\n80\t                } else {\n81\t                    true\n82\t                }\n83\t            })\n84\t            .collect();\n85\t\n86\t        let mut i = 0;\n87\t        while i < non_system.len() {\n88\t            let m = non_system[i];\n89\t\n90\t            match m.role {\n91\t                Role::Tool => {\n92\t                    // 收集所有連續的 Tool 訊息，合併成一個 user message\n93\t                    let mut tool_result_blocks: Vec<Value> = Vec::new();\n94\t                    while i < non_system.len() && non_system[i].role == Role::Tool {\n95\t                        let tm = non_system[i];\n96\t                        tool_result_blocks.push(json!({\n97\t                            \"type\": \"tool_result\",\n98\t                            \"tool_use_id\": tm.tool_call_id.as_deref().unwrap_or(\"\"),\n99\t                            \"content\": tm.content,\n100\t                        }));\n101\t                        i += 1;\n102\t                    }\n103\t                    messages.push(AnthropicMessage {\n104\t                        role: \"user\".into(),\n105\t                        content: Value::Array(tool_result_blocks),\n106\t                    });\n107\t                }\n108\t                Role::Assistant => {\n109\t                    // 若 assistant 訊息有 tool_calls，建立 content block 陣列\n110\t                    if let Some(tool_calls) = &m.tool_calls {\n111\t                        let mut blocks: Vec<Value> = Vec::new();\n112\t                        // 文字內容（可能為空）\n113\t                        if !m.content.is_empty() {\n114\t                            blocks.push(json!({\"type\": \"text\", \"text\": m.content}));\n115\t                        }\n116\t                        // tool_use blocks\n117\t                        for tc in tool_calls {\n118\t                            let input: Value = serde_json::from_str(&tc.arguments)\n119\t                                .unwrap_or(Value::Object(Default::default()));\n120\t                            blocks.push(json!({\n121\t                                \"type\": \"tool_use\",\n122\t                                \"id\": tc.id,\n123\t                                \"name\": tc.name,\n124\t                                \"input\": input,\n125\t                            }));\n126\t                        }\n127\t                        messages.push(AnthropicMessage {\n128\t                            role: \"assistant\".into(),\n129\t                            content: Value::Array(blocks),\n130\t                        });\n131\t                    } else {\n132\t                        // 純文字回應\n133\t                        messages.push(AnthropicMessage {\n134\t                            role: \"assistant\".into(),\n135\t                            content: Value::String(m.content.clone()),\n136\t                        });\n137\t                    }\n138\t                    i += 1;\n139\t                }\n140\t                Role::User => {\n141\t                    messages.push(AnthropicMessage {\n142\t                        role: \"user\".into(),\n143\t                        content: Value::String(m.content.clone()),\n144\t                    });\n145\t                    i += 1;\n146\t                }\n147\t                Role::System => unreachable!(\"already filtered above\"),\n148\t            }\n149\t        }\n150\t\n151\t        let system = if system_parts.is_empty() {\n152\t            None\n153\t        } else {\n154\t            Some(system_parts.join(\"\\n\"))\n155\t        };\n156\t\n157\t        (system, messages)\n158\t    }\n159\t\n160\t    fn build_body(&self, req: &LlmRequest, stream: bool) -> AnthropicRequest {\n161\t        let model = req\n162\t            .model\n163\t            .clone()\n164\t            .unwrap_or_else(|| self.default_model.clone());\n165\t        let (system, messages) = self.split_system(req);\n166\t        let tools: Vec<AnthropicTool> = req\n167\t            .tools\n168\t            .iter()\n169\t            .map(|t| AnthropicTool {\n170\t                name: t.name.clone(),\n171\t                description: t.description.clone(),\n172\t                input_schema: t.parameters.clone(),\n173\t            })\n174\t            .collect();\n175\t        AnthropicRequest {\n176\t            model,\n177\t            max_tokens: req.max_tokens.unwrap_or(DEFAULT_MAX_TOKENS),\n178\t            system,\n179\t            messages,\n180\t            stream,\n181\t            temperature: req.temperature,\n182\t            tools,\n183\t        }\n184\t    }\n185\t\n186\t    pub async fn health_check(&self) -> Result<(), LlmError> {\n187\t        let resp = self\n188\t            .add_headers(self.client.get(self.models_endpoint()))\n189\t            .send()\n190\t            .await\n191\t            .map_err(map_reqwest_error)?;\n192\t\n193\t        if resp.status().is_success() {\n194\t            Ok(())\n195\t        } else {\n196\t            Err(LlmError::ProviderError {\n197\t                status: resp.status().as_u16(),\n198\t                message: \"health check failed\".into(),\n199\t            })\n200\t        }\n201\t    }\n202\t\n203\t    pub async fn complete(&self, req: LlmRequest) -> Result<LlmResponse, LlmError> {\n204\t        let body = self.build_body(&req, false);\n205\t        let resp = self\n206\t            .add_headers(self.client.post(self.messages_endpoint()).json(&body))\n207\t            .send()\n208\t            .await\n209\t            .map_err(map_reqwest_error)?;\n210\t\n211\t        if !resp.status().is_success() {\n212\t            let status = resp.status();\n213\t            let headers = resp.headers().clone();\n214\t            let text = resp.text().await.unwrap_or_default();\n215\t            return Err(map_http_status_error(status.as_u16(), &headers, text));\n216\t        }\n217\t\n218\t        let ar: AnthropicResponse = resp\n219\t            .json()\n220\t            .await\n221\t            .map_err(|e| LlmError::InvalidResponse(e.to_string()))?;\n222\t\n223\t        let content = ar\n224\t            .content\n225\t            .into_iter()\n226\t            .filter(|c| c.content_type == \"text\")\n227\t            .filter_map(|c| c.text)\n228\t            .collect::<Vec<_>>()\n229\t            .join(\"\");\n230\t\n231\t        Ok(LlmResponse {\n232\t            content,\n233\t            model: ar.model,\n234\t            usage: Some(TokenUsage {\n235\t                prompt_tokens: ar.usage.input_tokens,\n236\t                completion_tokens: ar.usage.output_tokens,\n237\t                total_tokens: ar.usage.input_tokens + ar.usage.output_tokens,\n238\t            }),\n239\t        })\n240\t    }\n241\t\n242\t    pub async fn stream(&self, req: LlmRequest) -> Result<LlmStream, LlmError> {\n243\t        let body = self.build_body(&req, true);\n244\t        let resp = self\n245\t            .add_headers(self.client.post(self.messages_endpoint()).json(&body))\n246\t            .send()\n247\t            .await\n248\t            .map_err(map_reqwest_error)?;\n249\t\n250\t        if !resp.status().is_success() {\n251\t            let status = resp.status();\n252\t            let headers = resp.headers().clone();\n253\t            let text = resp.text().await.unwrap_or_default();\n254\t            return Err(map_http_status_error(status.as_u16(), &headers, text));\n255\t        }\n256\t\n257\t        let bytes_stream = resp.bytes_stream();\n258\t\n259\t        let s = stream! {\n260\t            tokio::pin!(bytes_stream);\n261\t            let mut buf = String::new();\n262\t            let mut state = AnthropicStreamState::default();\n263\t\n264\t            while let Some(chunk) = bytes_stream.next().await {\n265\t                match chunk {\n266\t                    Err(e) => {\n267\t                        yield Err(LlmError::StreamInterrupted(e.to_string()));\n268\t                        return;\n269\t                    }\n270\t                    Ok(bytes) => {\n271\t                        buf.push_str(&String::from_utf8_lossy(&bytes));\n272\t\n273\t                        loop {\n274\t                            match buf.find('\\n') {\n275\t                                None => break,\n276\t                                Some(pos) => {\n277\t                                    let line = buf[..pos].trim().to_string();\n278\t                                    buf = buf[pos + 1..].to_string();\n279\t\n280\t                                    // Skip blank lines and \"event:\" lines —\n281\t                                    // all needed info is in the \"data:\" payload.\n282\t                                    if line.is_empty() || line.starts_with(\"event:\") {\n283\t                                        continue;\n284\t                                    }\n285\t                                    if !line.starts_with(\"data:\") {\n286\t                                        continue;\n287\t                                    }\n288\t\n289\t                                    let data = line[\"data:\".len()..].trim();\n290\t\n291\t                                    match serde_json::from_str::<AnthropicEvent>(data) {\n292\t                                        Err(e) => {\n293\t                                            tracing::debug!(\"skip unparseable Anthropic SSE: {e}\");\n294\t                                        }\n295\t                                        Ok(event) => {\n296\t                                            let (events, done) = convert_anthropic_event_to_events(event, &mut state);\n297\t                                            for event in events {\n298\t                                                yield Ok(event);\n299\t                                            }\n300\t                                            if done {\n301\t                                                return;\n302\t                                            }\n303\t                                        }\n304\t                                    }\n305\t                                }\n306\t                            }\n307\t                        }\n308\t                    }\n309\t                }\n310\t            }\n311\t        };\n312\t\n313\t        Ok(Box::pin(s))\n314\t    }\n315\t}\n316\t\n317\tfn map_reqwest_error(e: reqwest::Error) -> LlmError {\n318\t    if e.is_timeout() {\n319\t        return LlmError::Timeout(Duration::from_secs(30));\n320\t    }\n321\t    LlmError::Network(e.to_string())\n322\t}\n323\t\n324\tfn map_http_status_error(status: u16, headers: &HeaderMap, message: String) -> LlmError {\n325\t    match status {\n326\t        401 | 403 => LlmError::AuthError(message),\n327\t        413 => LlmError::RequestTooLarge(message),\n328\t        400 if is_request_too_large_message(&message) => LlmError::RequestTooLarge(message),\n329\t        429 => LlmError::RateLimited {\n330\t            retry_after_ms: retry_after_ms(headers),\n331\t        },\n332\t        404 => LlmError::ModelNotAvailable(message),\n333\t        _ => LlmError::ProviderError { status, message },\n334\t    }\n335\t}\n336\t\n337\tfn is_request_too_large_message(message: &str) -> bool {\n338\t    let lower = message.to_ascii_lowercase();\n339\t    [\n340\t        \"too large\",\n341\t        \"request_too_large\",\n342\t        \"maximum context length\",\n343\t        \"context length\",\n344\t        \"token limit\",\n345\t        \"prompt is too long\",\n346\t    ]\n347\t    .iter()\n348\t    .any(|needle| lower.contains(needle))\n349\t}\n350\t\n351\tfn retry_after_ms(headers: &HeaderMap) -> Option<u64> {\n352\t    let secs = headers\n353\t        .get(\"retry-after\")\n354\t        .and_then(|v| v.to_str().ok())\n355\t        .and_then(|raw| raw.trim().parse::<u64>().ok())?;\n356\t    secs.checked_mul(1000)\n357\t}\n358\t\n359\t#[derive(Default)]\n360\tstruct AnthropicStreamState {\n361\t    input_tokens: u32,\n362\t    tool_use_buf: ToolUseBuffer,\n363\t    tool_use_indices: std::collections::HashSet<usize>,\n364\t}\n365\t\n366\tfn convert_anthropic_event_to_events(\n367\t    event: AnthropicEvent,\n368\t    state: &mut AnthropicStreamState,\n369\t) -> (Vec<StreamEvent>, bool) {\n370\t    let mut events = Vec::new();\n371\t    let mut done = false;\n372\t\n373\t    match event.event_type.as_str() {\n374\t        \"message_start\" => {\n375\t            if let Some(msg) = event.message\n376\t                && let Some(u) = msg.usage\n377\t            {\n378\t                state.input_tokens = u.input_tokens;\n379\t            }\n380\t        }\n381\t        \"content_block_start\" => {\n382\t            if let (Some(block), Some(idx)) = (event.content_block, event.index)\n383\t                && block.block_type == \"tool_use\"\n384\t            {\n385\t                state.tool_use_indices.insert(idx);\n386\t                state.tool_use_buf.insert(\n387\t                    idx,\n388\t                    (\n389\t                        block.id.unwrap_or_default(),\n390\t                        block.name.unwrap_or_default(),\n391\t                        String::new(),\n392\t                    ),\n393\t                );\n394\t            }\n395\t        }\n396\t        \"content_block_delta\" => {\n397\t            if let Some(delta) = event.delta {\n398\t                if delta.delta_type == \"text_delta\" {\n399\t                    if let Some(text) = delta.text\n400\t                        && !text.is_empty()\n401\t                    {\n402\t                        events.push(StreamEvent::Delta { content: text });\n403\t                    }\n404\t                } else if delta.delta_type == \"input_json_delta\"\n405\t                    && let (Some(partial), Some(idx)) = (delta.partial_json, event.index)\n406\t                    && let Some(entry) = state.tool_use_buf.get_mut(&idx)\n407\t                {\n408\t                    entry.2.push_str(&partial);\n409\t                }\n410\t            }\n411\t        }\n412\t        \"content_block_stop\" => {\n413\t            if let Some(idx) = event.index\n414\t                && state.tool_use_indices.remove(&idx)\n415\t                && let Some((id, name, args)) = state.tool_use_buf.remove(&idx)\n416\t            {\n417\t                events.push(StreamEvent::ToolCallDone {\n418\t                    tool_calls: vec![ToolCall {\n419\t                        id,\n420\t                        name,\n421\t                        arguments: args,\n422\t                    }],\n423\t                });\n424\t            }\n425\t        }\n426\t        \"message_delta\" => {\n427\t            let output_tokens = event.usage.map(|u| u.output_tokens).unwrap_or(0);\n428\t            let usage = TokenUsage {\n429\t                prompt_tokens: state.input_tokens,\n430\t                completion_tokens: output_tokens,\n431\t                total_tokens: state.input_tokens + output_tokens,\n432\t            };\n433\t            events.push(StreamEvent::Done { usage: Some(usage) });\n434\t            done = true;\n435\t        }\n436\t        \"message_stop\" => {\n437\t            events.push(StreamEvent::Done { usage: None });\n438\t            done = true;\n439\t        }\n440\t        _ => {}\n441\t    }\n442\t\n443\t    (events, done)\n444\t}\n445\t\n446\t#[cfg(test)]\n447\tmod tests {\n448\t    use super::*;\n449\t\n450\t    #[test]\n451\t    fn maps_400_too_large_to_request_too_large() {\n452\t        let err = map_http_status_error(\n453\t            400,\n454\t            &HeaderMap::new(),\n455\t            \"request too large for model\".to_string(),\n456\t        );\n457\t        match err {\n458\t            LlmError::RequestTooLarge(msg) => assert!(msg.contains(\"too large\")),\n459\t            other => panic!(\"expected RequestTooLarge, got {other:?}\"),\n460\t        }\n461\t    }\n462\t\n463\t    #[test]\n464\t    fn extracts_retry_after_on_429() {\n465\t        let mut headers = HeaderMap::new();\n466\t        headers.insert(\"retry-after\", \"3\".parse().expect(\"valid header value\"));\n467\t        let err = map_http_status_error(429, &headers, \"rate limit\".to_string());\n468\t        match err {\n469\t            LlmError::RateLimited { retry_after_ms } => assert_eq!(retry_after_ms, Some(3_000)),\n470\t            other => panic!(\"expected RateLimited, got {other:?}\"),\n471\t        }\n472\t    }\n473\t\n474\t    #[test]\n475\t    fn anthropic_stream_event_order_is_preserved() {\n476\t        let mut state = AnthropicStreamState::default();\n477\t\n478\t        let _ = convert_anthropic_event_to_events(\n479\t            AnthropicEvent {\n480\t                event_type: \"message_start\".to_string(),\n481\t                delta: None,\n482\t                message: Some(AnthropicEventMessage {\n483\t                    usage: Some(AnthropicUsage {\n484\t                        input_tokens: 10,\n485\t                        output_tokens: 0,\n486\t                    }),\n487\t                }),\n488\t                usage: None,\n489\t                content_block: None,\n490\t                index: None,\n491\t            },\n492\t            &mut state,\n493\t        );\n494\t\n495\t        let _ = convert_anthropic_event_to_events(\n496\t            AnthropicEvent {\n497\t                event_type: \"content_block_start\".to_string(),\n498\t                delta: None,\n499\t                message: None,\n500\t                usage: None,\n501\t                content_block: Some(AnthropicContentBlock {\n502\t                    block_type: \"tool_use\".to_string(),\n503\t                    id: Some(\"tool_1\".to_string()),\n504\t                    name: Some(\"search_docs\".to_string()),\n505\t                }),\n506\t                index: Some(0),\n507\t            },\n508\t            &mut state,\n509\t        );\n510\t\n511\t        let _ = convert_anthropic_event_to_events(\n512\t            AnthropicEvent {\n513\t                event_type: \"content_block_delta\".to_string(),\n514\t                delta: Some(AnthropicEventDelta {\n515\t                    delta_type: \"input_json_delta\".to_string(),\n516\t                    text: None,\n517\t                    partial_json: Some(\"{\\\"q\\\":\\\"\".to_string()),\n518\t                }),\n519\t                message: None,\n520\t                usage: None,\n521\t                content_block: None,\n522\t                index: Some(0),\n523\t            },\n524\t            &mut state,\n525\t        );\n526\t\n527\t        let _ = convert_anthropic_event_to_events(\n528\t            AnthropicEvent {\n529\t                event_type: \"content_block_delta\".to_string(),\n530\t                delta: Some(AnthropicEventDelta {\n531\t                    delta_type: \"input_json_delta\".to_string(),\n532\t                    text: None,\n533\t                    partial_json: Some(\"rust\\\"}\".to_string()),\n534\t                }),\n535\t                message: None,\n536\t                usage: None,\n537\t                content_block: None,\n538\t                index: Some(0),\n539\t            },\n540\t            &mut state,\n541\t        );\n542\t\n543\t        let (events_tool, done_tool) = convert_anthropic_event_to_events(\n544\t            AnthropicEvent {\n545\t                event_type: \"content_block_stop\".to_string(),\n546\t                delta: None,\n547\t                message: None,\n548\t                usage: None,\n549\t                content_block: None,\n550\t                index: Some(0),\n551\t            },\n552\t            &mut state,\n553\t        );\n554\t        assert!(!done_tool);\n555\t        assert!(\n556\t            matches!(&events_tool[0], StreamEvent::ToolCallDone { tool_calls } if tool_calls.len() == 1 && tool_calls[0].arguments == \"{\\\"q\\\":\\\"rust\\\"}\")\n557\t        );\n558\t\n559\t        let (events_text, done_text) = convert_anthropic_event_to_events(\n560\t            AnthropicEvent {\n561\t                event_type: \"content_block_delta\".to_string(),\n562\t                delta: Some(AnthropicEventDelta {\n563\t                    delta_type: \"text_delta\".to_string(),\n564\t                    text: Some(\"done\".to_string()),\n565\t                    partial_json: None,\n566\t                }),\n567\t                message: None,\n568\t                usage: None,\n569\t                content_block: None,\n570\t                index: Some(1),\n571\t            },\n572\t            &mut state,\n573\t        );\n574\t        assert!(!done_text);\n575\t        assert!(matches!(&events_text[0], StreamEvent::Delta { content } if content == \"done\"));\n576\t\n577\t        let (events_done, done_done) = convert_anthropic_event_to_events(\n578\t            AnthropicEvent {\n579\t                event_type: \"message_delta\".to_string(),\n580\t                delta: None,\n581\t                message: None,\n582\t                usage: Some(AnthropicDeltaUsage { output_tokens: 4 }),\n583\t                content_block: None,\n584\t                index: None,\n585\t            },\n586\t            &mut state,\n587\t        );\n588\t        assert!(done_done);\n589\t        assert!(matches!(\n590\t            &events_done[0],\n591\t            StreamEvent::Done { usage: Some(_) }\n592\t        ));\n593\t    }\n594\t}\n595\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"33623158-75cc-4f67-b2ef-8a696211d978","uuid":"7aded253-7749-472b-8230-1bc6e4ac8d72","timestamp":"2026-04-02T06:39:24.773Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/provider/src/anthropic_compat/client.rs","content":"use super::types::*;\nuse async_stream::stream;\nuse ccode_domain::message::{Role, ToolCall};\nuse ccode_ports::provider::{\n    LlmError, LlmRequest, LlmResponse, LlmStream, StreamEvent, TokenUsage,\n};\nuse futures::StreamExt;\nuse reqwest::header::HeaderMap;\nuse std::collections::HashMap;\nuse std::time::Duration;\n\nconst ANTHROPIC_VERSION: &str = \"2023-06-01\";\nconst DEFAULT_MAX_TOKENS: u32 = 4096;\ntype ToolUseBuffer = HashMap<usize, (String, String, String)>;\n\n/// HTTP client for the Anthropic Messages API.\n///\n/// Wire format differences from OpenAI-compat:\n/// - Auth: `x-api-key` header (not Bearer)\n/// - Required header: `anthropic-version`\n/// - `system` prompt is a top-level field, not in the messages array\n/// - `max_tokens` is required\n/// - SSE ends with `event: message_stop`, no `[DONE]` sentinel\npub struct AnthropicCompatClient {\n    client: reqwest::Client,\n    pub api_key: String,\n    pub base_url: String,\n    pub default_model: String,\n}\n\nimpl AnthropicCompatClient {\n    pub fn new(\n        api_key: impl Into<String>,\n        base_url: impl Into<String>,\n        default_model: impl Into<String>,\n    ) -> Self {\n        Self {\n            client: reqwest::Client::new(),\n            api_key: api_key.into(),\n            base_url: base_url.into(),\n            default_model: default_model.into(),\n        }\n    }\n\n    fn messages_endpoint(&self) -> String {\n        format!(\"{}/messages\", self.base_url)\n    }\n\n    fn models_endpoint(&self) -> String {\n        format!(\"{}/models\", self.base_url)\n    }\n\n    fn add_headers(&self, builder: reqwest::RequestBuilder) -> reqwest::RequestBuilder {\n        builder\n            .header(\"x-api-key\", &self.api_key)\n            .header(\"anthropic-version\", ANTHROPIC_VERSION)\n    }\n\n    /// 將 LlmRequest 的 messages 轉換為 Anthropic 格式。\n    ///\n    /// 三種轉換規則：\n    /// 1. System → 抽出，合併為頂層 `system` 欄位\n    /// 2. Assistant + tool_calls → content 為 block 陣列（text block + tool_use blocks）\n    /// 3. Tool（工具結果）→ role=\"user\"，content 為 tool_result block 陣列；\n    ///    **連續多個 Tool 訊息必須合併成同一個 user 訊息**（Anthropic 禁止連續同 role）\n    fn split_system(&self, req: &LlmRequest) -> (Option<String>, Vec<AnthropicMessage>) {\n        use serde_json::{Value, json};\n\n        let mut system_parts: Vec<String> = Vec::new();\n        let mut messages: Vec<AnthropicMessage> = Vec::new();\n\n        // 先過濾 System，並把其餘訊息逐一轉換\n        let non_system: Vec<_> = req\n            .messages\n            .iter()\n            .filter(|m| {\n                if m.role == Role::System {\n                    system_parts.push(m.content.clone());\n                    false\n                } else {\n                    true\n                }\n            })\n            .collect();\n\n        let mut i = 0;\n        while i < non_system.len() {\n            let m = non_system[i];\n\n            match m.role {\n                Role::Tool => {\n                    // 收集所有連續的 Tool 訊息，合併成一個 user message\n                    let mut tool_result_blocks: Vec<Value> = Vec::new();\n                    while i < non_system.len() && non_system[i].role == Role::Tool {\n                        let tm = non_system[i];\n                        tool_result_blocks.push(json!({\n                            \"type\": \"tool_result\",\n                            \"tool_use_id\": tm.tool_call_id.as_deref().unwrap_or(\"\"),\n                            \"content\": tm.content,\n                        }));\n                        i += 1;\n                    }\n                    messages.push(AnthropicMessage {\n                        role: \"user\".into(),\n                        content: Value::Array(tool_result_blocks),\n                    });\n                }\n                Role::Assistant => {\n                    // 若 assistant 訊息有 tool_calls，建立 content block 陣列\n                    if let Some(tool_calls) = &m.tool_calls {\n                        let mut blocks: Vec<Value> = Vec::new();\n                        // 文字內容（可能為空）\n                        if !m.content.is_empty() {\n                            blocks.push(json!({\"type\": \"text\", \"text\": m.content}));\n                        }\n                        // tool_use blocks\n                        for tc in tool_calls {\n                            let input: Value = serde_json::from_str(&tc.arguments)\n                                .unwrap_or(Value::Object(Default::default()));\n                            blocks.push(json!({\n                                \"type\": \"tool_use\",\n                                \"id\": tc.id,\n                                \"name\": tc.name,\n                                \"input\": input,\n                            }));\n                        }\n                        messages.push(AnthropicMessage {\n                            role: \"assistant\".into(),\n                            content: Value::Array(blocks),\n                        });\n                    } else {\n                        // 純文字回應\n                        messages.push(AnthropicMessage {\n                            role: \"assistant\".into(),\n                            content: Value::String(m.content.clone()),\n                        });\n                    }\n                    i += 1;\n                }\n                Role::User => {\n                    messages.push(AnthropicMessage {\n                        role: \"user\".into(),\n                        content: Value::String(m.content.clone()),\n                    });\n                    i += 1;\n                }\n                Role::System => unreachable!(\"already filtered above\"),\n            }\n        }\n\n        let system = if system_parts.is_empty() {\n            None\n        } else {\n            Some(system_parts.join(\"\\n\"))\n        };\n\n        (system, messages)\n    }\n\n    fn build_body(&self, req: &LlmRequest, stream: bool) -> AnthropicRequest {\n        let model = req\n            .model\n            .clone()\n            .unwrap_or_else(|| self.default_model.clone());\n        let (system, messages) = self.split_system(req);\n        let tools: Vec<AnthropicTool> = req\n            .tools\n            .iter()\n            .map(|t| AnthropicTool {\n                name: t.name.clone(),\n                description: t.description.clone(),\n                input_schema: t.parameters.clone(),\n            })\n            .collect();\n        AnthropicRequest {\n            model,\n            max_tokens: req.max_tokens.unwrap_or(DEFAULT_MAX_TOKENS),\n            system,\n            messages,\n            stream,\n            temperature: req.temperature,\n            tools,\n        }\n    }\n\n    pub async fn health_check(&self) -> Result<(), LlmError> {\n        let resp = self\n            .add_headers(self.client.get(self.models_endpoint()))\n            .send()\n            .await\n            .map_err(map_reqwest_error)?;\n\n        if resp.status().is_success() {\n            Ok(())\n        } else {\n            Err(LlmError::ProviderError {\n                status: resp.status().as_u16(),\n                message: \"health check failed\".into(),\n            })\n        }\n    }\n\n    pub async fn complete(&self, req: LlmRequest) -> Result<LlmResponse, LlmError> {\n        let body = self.build_body(&req, false);\n        let resp = self\n            .add_headers(self.client.post(self.messages_endpoint()).json(&body))\n            .send()\n            .await\n            .map_err(map_reqwest_error)?;\n\n        if !resp.status().is_success() {\n            let status = resp.status();\n            let headers = resp.headers().clone();\n            let text = resp.text().await.unwrap_or_default();\n            return Err(map_http_status_error(status.as_u16(), &headers, text));\n        }\n\n        let ar: AnthropicResponse = resp\n            .json()\n            .await\n            .map_err(|e| LlmError::InvalidResponse(e.to_string()))?;\n\n        let content = ar\n            .content\n            .into_iter()\n            .filter(|c| c.content_type == \"text\")\n            .filter_map(|c| c.text)\n            .collect::<Vec<_>>()\n            .join(\"\");\n\n        Ok(LlmResponse {\n            content,\n            model: ar.model,\n            usage: Some(TokenUsage {\n                prompt_tokens: ar.usage.input_tokens,\n                completion_tokens: ar.usage.output_tokens,\n                total_tokens: ar.usage.input_tokens + ar.usage.output_tokens,\n            }),\n        })\n    }\n\n    pub async fn stream(&self, req: LlmRequest) -> Result<LlmStream, LlmError> {\n        let body = self.build_body(&req, true);\n        let resp = self\n            .add_headers(self.client.post(self.messages_endpoint()).json(&body))\n            .send()\n            .await\n            .map_err(map_reqwest_error)?;\n\n        if !resp.status().is_success() {\n            let status = resp.status();\n            let headers = resp.headers().clone();\n            let text = resp.text().await.unwrap_or_default();\n            return Err(map_http_status_error(status.as_u16(), &headers, text));\n        }\n\n        let bytes_stream = resp.bytes_stream();\n\n        let s = stream! {\n            tokio::pin!(bytes_stream);\n            let mut buf = String::new();\n            let mut state = AnthropicStreamState::default();\n\n            while let Some(chunk) = bytes_stream.next().await {\n                match chunk {\n                    Err(e) => {\n                        yield Err(LlmError::StreamInterrupted(e.to_string()));\n                        return;\n                    }\n                    Ok(bytes) => {\n                        buf.push_str(&String::from_utf8_lossy(&bytes));\n\n                        loop {\n                            match buf.find('\\n') {\n                                None => break,\n                                Some(pos) => {\n                                    let line = buf[..pos].trim().to_string();\n                                    buf = buf[pos + 1..].to_string();\n\n                                    // Skip blank lines and \"event:\" lines —\n                                    // all needed info is in the \"data:\" payload.\n                                    if line.is_empty() || line.starts_with(\"event:\") {\n                                        continue;\n                                    }\n                                    if !line.starts_with(\"data:\") {\n                                        continue;\n                                    }\n\n                                    let data = line[\"data:\".len()..].trim();\n\n                                    match serde_json::from_str::<AnthropicEvent>(data) {\n                                        Err(e) => {\n                                            tracing::debug!(\"skip unparseable Anthropic SSE: {e}\");\n                                        }\n                                        Ok(event) => {\n                                            let (events, done) = convert_anthropic_event_to_events(event, &mut state);\n                                            for event in events {\n                                                yield Ok(event);\n                                            }\n                                            if done {\n                                                return;\n                                            }\n                                        }\n                                    }\n                                }\n                            }\n                        }\n                    }\n                }\n            }\n        };\n\n        Ok(Box::pin(s))\n    }\n}\n\nfn map_reqwest_error(e: reqwest::Error) -> LlmError {\n    if e.is_timeout() {\n        return LlmError::Timeout(Duration::from_secs(30));\n    }\n    LlmError::Network(e.to_string())\n}\n\nfn map_http_status_error(status: u16, headers: &HeaderMap, message: String) -> LlmError {\n    match status {\n        401 | 403 => LlmError::AuthError(message),\n        413 => LlmError::RequestTooLarge(message),\n        400 if is_request_too_large_message(&message) => LlmError::RequestTooLarge(message),\n        429 => LlmError::RateLimited {\n            retry_after_ms: retry_after_ms(headers),\n        },\n        404 => LlmError::ModelNotAvailable(message),\n        _ => LlmError::ProviderError { status, message },\n    }\n}\n\nfn is_request_too_large_message(message: &str) -> bool {\n    let lower = message.to_ascii_lowercase();\n    [\n        \"too large\",\n        \"request_too_large\",\n        \"maximum context length\",\n        \"context length\",\n        \"token limit\",\n        \"prompt is too long\",\n    ]\n    .iter()\n    .any(|needle| lower.contains(needle))\n}\n\nfn retry_after_ms(headers: &HeaderMap) -> Option<u64> {\n    let secs = headers\n        .get(\"retry-after\")\n        .and_then(|v| v.to_str().ok())\n        .and_then(|raw| raw.trim().parse::<u64>().ok())?;\n    secs.checked_mul(1000)\n}\n\n#[derive(Default)]\nstruct AnthropicStreamState {\n    input_tokens: u32,\n    tool_use_buf: ToolUseBuffer,\n    tool_use_indices: std::collections::HashSet<usize>,\n}\n\nfn convert_anthropic_event_to_events(\n    event: AnthropicEvent,\n    state: &mut AnthropicStreamState,\n) -> (Vec<StreamEvent>, bool) {\n    let mut events = Vec::new();\n    let mut done = false;\n\n    match event.event_type.as_str() {\n        \"message_start\" => {\n            if let Some(msg) = event.message\n                && let Some(u) = msg.usage\n            {\n                state.input_tokens = u.input_tokens;\n            }\n        }\n        \"content_block_start\" => {\n            if let (Some(block), Some(idx)) = (event.content_block, event.index)\n                && block.block_type == \"tool_use\"\n            {\n                state.tool_use_indices.insert(idx);\n                state.tool_use_buf.insert(\n                    idx,\n                    (\n                        block.id.unwrap_or_default(),\n                        block.name.unwrap_or_default(),\n                        String::new(),\n                    ),\n                );\n            }\n        }\n        \"content_block_delta\" => {\n            if let Some(delta) = event.delta {\n                if delta.delta_type == \"text_delta\" {\n                    if let Some(text) = delta.text\n                        && !text.is_empty()\n                    {\n                        events.push(StreamEvent::Delta { content: text });\n                    }\n                } else if delta.delta_type == \"input_json_delta\"\n                    && let (Some(partial), Some(idx)) = (delta.partial_json, event.index)\n                    && let Some(entry) = state.tool_use_buf.get_mut(&idx)\n                {\n                    entry.2.push_str(&partial);\n                }\n            }\n        }\n        \"content_block_stop\" => {\n            if let Some(idx) = event.index\n                && state.tool_use_indices.remove(&idx)\n                && let Some((id, name, args)) = state.tool_use_buf.remove(&idx)\n            {\n                events.push(StreamEvent::ToolCallDone {\n                    tool_calls: vec![ToolCall {\n                        id,\n                        name,\n                        arguments: args,\n                    }],\n                });\n            }\n        }\n        \"message_delta\" => {\n            let output_tokens = event.usage.map(|u| u.output_tokens).unwrap_or(0);\n            let usage = TokenUsage {\n                prompt_tokens: state.input_tokens,\n                completion_tokens: output_tokens,\n                total_tokens: state.input_tokens + output_tokens,\n            };\n            events.push(StreamEvent::Done { usage: Some(usage) });\n            done = true;\n        }\n        \"message_stop\" => {\n            events.push(StreamEvent::Done { usage: None });\n            done = true;\n        }\n        _ => {}\n    }\n\n    (events, done)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn maps_400_too_large_to_request_too_large() {\n        let err = map_http_status_error(\n            400,\n            &HeaderMap::new(),\n            \"request too large for model\".to_string(),\n        );\n        match err {\n            LlmError::RequestTooLarge(msg) => assert!(msg.contains(\"too large\")),\n            other => panic!(\"expected RequestTooLarge, got {other:?}\"),\n        }\n    }\n\n    #[test]\n    fn extracts_retry_after_on_429() {\n        let mut headers = HeaderMap::new();\n        headers.insert(\"retry-after\", \"3\".parse().expect(\"valid header value\"));\n        let err = map_http_status_error(429, &headers, \"rate limit\".to_string());\n        match err {\n            LlmError::RateLimited { retry_after_ms } => assert_eq!(retry_after_ms, Some(3_000)),\n            other => panic!(\"expected RateLimited, got {other:?}\"),\n        }\n    }\n\n    #[test]\n    fn anthropic_stream_event_order_is_preserved() {\n        let mut state = AnthropicStreamState::default();\n\n        let _ = convert_anthropic_event_to_events(\n            AnthropicEvent {\n                event_type: \"message_start\".to_string(),\n                delta: None,\n                message: Some(AnthropicEventMessage {\n                    usage: Some(AnthropicUsage {\n                        input_tokens: 10,\n                        output_tokens: 0,\n                    }),\n                }),\n                usage: None,\n                content_block: None,\n                index: None,\n            },\n            &mut state,\n        );\n\n        let _ = convert_anthropic_event_to_events(\n            AnthropicEvent {\n                event_type: \"content_block_start\".to_string(),\n                delta: None,\n                message: None,\n                usage: None,\n                content_block: Some(AnthropicContentBlock {\n                    block_type: \"tool_use\".to_string(),\n                    id: Some(\"tool_1\".to_string()),\n                    name: Some(\"search_docs\".to_string()),\n                }),\n                index: Some(0),\n            },\n            &mut state,\n        );\n\n        let _ = convert_anthropic_event_to_events(\n            AnthropicEvent {\n                event_type: \"content_block_delta\".to_string(),\n                delta: Some(AnthropicEventDelta {\n                    delta_type: \"input_json_delta\".to_string(),\n                    text: None,\n                    partial_json: Some(\"{\\\"q\\\":\\\"\".to_string()),\n                }),\n                message: None,\n                usage: None,\n                content_block: None,\n                index: Some(0),\n            },\n            &mut state,\n        );\n\n        let _ = convert_anthropic_event_to_events(\n            AnthropicEvent {\n                event_type: \"content_block_delta\".to_string(),\n                delta: Some(AnthropicEventDelta {\n                    delta_type: \"input_json_delta\".to_string(),\n                    text: None,\n                    partial_json: Some(\"rust\\\"}\".to_string()),\n                }),\n                message: None,\n                usage: None,\n                content_block: None,\n                index: Some(0),\n            },\n            &mut state,\n        );\n\n        let (events_tool, done_tool) = convert_anthropic_event_to_events(\n            AnthropicEvent {\n                event_type: \"content_block_stop\".to_string(),\n                delta: None,\n                message: None,\n                usage: None,\n                content_block: None,\n                index: Some(0),\n            },\n            &mut state,\n        );\n        assert!(!done_tool);\n        assert!(\n            matches!(&events_tool[0], StreamEvent::ToolCallDone { tool_calls } if tool_calls.len() == 1 && tool_calls[0].arguments == \"{\\\"q\\\":\\\"rust\\\"}\")\n        );\n\n        let (events_text, done_text) = convert_anthropic_event_to_events(\n            AnthropicEvent {\n                event_type: \"content_block_delta\".to_string(),\n                delta: Some(AnthropicEventDelta {\n                    delta_type: \"text_delta\".to_string(),\n                    text: Some(\"done\".to_string()),\n                    partial_json: None,\n                }),\n                message: None,\n                usage: None,\n                content_block: None,\n                index: Some(1),\n            },\n            &mut state,\n        );\n        assert!(!done_text);\n        assert!(matches!(&events_text[0], StreamEvent::Delta { content } if content == \"done\"));\n\n        let (events_done, done_done) = convert_anthropic_event_to_events(\n            AnthropicEvent {\n                event_type: \"message_delta\".to_string(),\n                delta: None,\n                message: None,\n                usage: Some(AnthropicDeltaUsage { output_tokens: 4 }),\n                content_block: None,\n                index: None,\n            },\n            &mut state,\n        );\n        assert!(done_done);\n        assert!(matches!(\n            &events_done[0],\n            StreamEvent::Done { usage: Some(_) }\n        ));\n    }\n}\n","numLines":595,"startLine":1,"totalLines":595}}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01J2y4YNmEMAzf9or3dW85rW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RBKEGDiNwNp2hamEj4z5TK","name":"Read","input":{"file_path":"/Users/yaxin/Projects/rust_projects/ccode/crates/provider/src/openai_compat/client.rs"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4113,"cache_read_input_tokens":25622,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4113},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"33623158-75cc-4f67-b2ef-8a696211d978","uuid":"95276d2e-8fed-4038-b29a-6ca87b15d09e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RBKEGDiNwNp2hamEj4z5TK","type":"tool_result","content":"1\tuse super::types::*;\n2\tuse async_stream::stream;\n3\tuse ccode_domain::message::{Role, ToolCall};\n4\tuse ccode_ports::provider::{\n5\t    LlmError, LlmRequest, LlmResponse, LlmStream, StreamEvent, TokenUsage,\n6\t};\n7\tuse futures::StreamExt;\n8\tuse reqwest::header::HeaderMap;\n9\tuse std::collections::HashMap;\n10\tuse std::time::Duration;\n11\t\n12\ttype ToolCallBuffer = HashMap<usize, (String, String, String)>;\n13\t\n14\t/// Shared HTTP client for OpenAI-compatible APIs.\n15\t///\n16\t/// Pass `extra_headers` to inject provider-specific headers (e.g. `X-Title`).\n17\tpub struct OpenAiCompatClient {\n18\t    client: reqwest::Client,\n19\t    pub api_key: String,\n20\t    pub base_url: String,\n21\t    pub default_model: String,\n22\t    extra_headers: Vec<(String, String)>,\n23\t}\n24\t\n25\timpl OpenAiCompatClient {\n26\t    pub fn new(\n27\t        api_key: impl Into<String>,\n28\t        base_url: impl Into<String>,\n29\t        default_model: impl Into<String>,\n30\t        extra_headers: Vec<(String, String)>,\n31\t    ) -> Self {\n32\t        Self {\n33\t            client: reqwest::Client::new(),\n34\t            api_key: api_key.into(),\n35\t            base_url: base_url.into(),\n36\t            default_model: default_model.into(),\n37\t            extra_headers,\n38\t        }\n39\t    }\n40\t\n41\t    fn endpoint(&self) -> String {\n42\t        format!(\"{}/chat/completions\", self.base_url)\n43\t    }\n44\t\n45\t    fn build_body(&self, req: &LlmRequest, stream: bool) -> ChatRequest {\n46\t        let model = req\n47\t            .model\n48\t            .clone()\n49\t            .unwrap_or_else(|| self.default_model.clone());\n50\t        let messages = req\n51\t            .messages\n52\t            .iter()\n53\t            .map(|m| {\n54\t                // tool role：帶 tool_call_id，content 為結果\n55\t                if m.role == Role::Tool {\n56\t                    return ChatMessage {\n57\t                        role: \"tool\".into(),\n58\t                        content: Some(m.content.clone()),\n59\t                        tool_calls: None,\n60\t                        tool_call_id: m.tool_call_id.clone(),\n61\t                    };\n62\t                }\n63\t                // assistant role：可能帶 tool_calls（純工具呼叫時 content 為 null）\n64\t                if m.role == Role::Assistant {\n65\t                    let tool_calls = m.tool_calls.as_ref().map(|tcs| {\n66\t                        tcs.iter()\n67\t                            .map(|tc| OpenAiToolCall {\n68\t                                id: tc.id.clone(),\n69\t                                r#type: \"function\".into(),\n70\t                                function: OpenAiToolCallFunction {\n71\t                                    name: tc.name.clone(),\n72\t                                    arguments: tc.arguments.clone(),\n73\t                                },\n74\t                            })\n75\t                            .collect::<Vec<_>>()\n76\t                    });\n77\t                    let content = if m.content.is_empty() && tool_calls.is_some() {\n78\t                        None // 純工具呼叫，content 送 null\n79\t                    } else {\n80\t                        Some(m.content.clone())\n81\t                    };\n82\t                    return ChatMessage {\n83\t                        role: \"assistant\".into(),\n84\t                        content,\n85\t                        tool_calls,\n86\t                        tool_call_id: None,\n87\t                    };\n88\t                }\n89\t                // user / system\n90\t                ChatMessage {\n91\t                    role: role_str(&m.role).into(),\n92\t                    content: Some(m.content.clone()),\n93\t                    tool_calls: None,\n94\t                    tool_call_id: None,\n95\t                }\n96\t            })\n97\t            .collect();\n98\t        let tools: Vec<OpenAiTool> = req\n99\t            .tools\n100\t            .iter()\n101\t            .map(|t| OpenAiTool {\n102\t                r#type: \"function\".to_string(),\n103\t                function: OpenAiToolFunction {\n104\t                    name: t.name.clone(),\n105\t                    description: t.description.clone(),\n106\t                    parameters: t.parameters.clone(),\n107\t                },\n108\t            })\n109\t            .collect();\n110\t        let tool_choice = if tools.is_empty() {\n111\t            None\n112\t        } else {\n113\t            Some(\"auto\".into())\n114\t        };\n115\t        ChatRequest {\n116\t            model,\n117\t            messages,\n118\t            stream,\n119\t            max_tokens: req.max_tokens,\n120\t            temperature: req.temperature,\n121\t            tools,\n122\t            tool_choice,\n123\t        }\n124\t    }\n125\t\n126\t    fn add_headers(&self, builder: reqwest::RequestBuilder) -> reqwest::RequestBuilder {\n127\t        let mut b = builder.bearer_auth(&self.api_key);\n128\t        for (name, value) in &self.extra_headers {\n129\t            b = b.header(name.as_str(), value.as_str());\n130\t        }\n131\t        b\n132\t    }\n133\t\n134\t    pub async fn health_check(&self) -> Result<(), LlmError> {\n135\t        let url = format!(\"{}/models\", self.base_url);\n136\t        let resp = self\n137\t            .add_headers(self.client.get(&url))\n138\t            .send()\n139\t            .await\n140\t            .map_err(map_reqwest_error)?;\n141\t\n142\t        if resp.status().is_success() {\n143\t            Ok(())\n144\t        } else {\n145\t            Err(LlmError::ProviderError {\n146\t                status: resp.status().as_u16(),\n147\t                message: \"health check failed\".into(),\n148\t            })\n149\t        }\n150\t    }\n151\t\n152\t    pub async fn complete(&self, req: LlmRequest) -> Result<LlmResponse, LlmError> {\n153\t        let body = self.build_body(&req, false);\n154\t        let resp = self\n155\t            .add_headers(self.client.post(self.endpoint()).json(&body))\n156\t            .send()\n157\t            .await\n158\t            .map_err(map_reqwest_error)?;\n159\t\n160\t        if !resp.status().is_success() {\n161\t            let status = resp.status();\n162\t            let headers = resp.headers().clone();\n163\t            let text = resp.text().await.unwrap_or_default();\n164\t            return Err(map_http_status_error(status.as_u16(), &headers, text));\n165\t        }\n166\t\n167\t        let chat: ChatResponse = resp\n168\t            .json()\n169\t            .await\n170\t            .map_err(|e| LlmError::InvalidResponse(e.to_string()))?;\n171\t\n172\t        let content = chat\n173\t            .choices\n174\t            .into_iter()\n175\t            .next()\n176\t            .and_then(|c| c.message)\n177\t            .and_then(|m| m.content)\n178\t            .unwrap_or_default();\n179\t\n180\t        Ok(LlmResponse {\n181\t            content,\n182\t            model: chat.model,\n183\t            usage: chat.usage.map(map_usage),\n184\t        })\n185\t    }\n186\t\n187\t    pub async fn stream(&self, req: LlmRequest) -> Result<LlmStream, LlmError> {\n188\t        let body = self.build_body(&req, true);\n189\t\n190\t        // debug: 印出送出的完整 request body（RUST_LOG=debug 時可見）\n191\t        tracing::debug!(\n192\t            endpoint = %self.endpoint(),\n193\t            request_body = %serde_json::to_string_pretty(&body).unwrap_or_default(),\n194\t            \"openai_compat → stream_complete request\"\n195\t        );\n196\t\n197\t        let resp = self\n198\t            .add_headers(self.client.post(self.endpoint()).json(&body))\n199\t            .send()\n200\t            .await\n201\t            .map_err(map_reqwest_error)?;\n202\t\n203\t        if !resp.status().is_success() {\n204\t            let status = resp.status();\n205\t            let headers = resp.headers().clone();\n206\t            let text = resp.text().await.unwrap_or_default();\n207\t            return Err(map_http_status_error(status.as_u16(), &headers, text));\n208\t        }\n209\t\n210\t        let bytes_stream = resp.bytes_stream();\n211\t\n212\t        let s = stream! {\n213\t            tokio::pin!(bytes_stream);\n214\t            let mut buf = String::new();\n215\t            // Map from tool_call index -> (id, name, accumulated_arguments)\n216\t            let mut tool_call_buf: ToolCallBuffer = HashMap::new();\n217\t\n218\t            while let Some(chunk) = bytes_stream.next().await {\n219\t                match chunk {\n220\t                    Err(e) => {\n221\t                        yield Err(LlmError::StreamInterrupted(e.to_string()));\n222\t                        return;\n223\t                    }\n224\t                    Ok(bytes) => {\n225\t                        buf.push_str(&String::from_utf8_lossy(&bytes));\n226\t\n227\t                        loop {\n228\t                            match buf.find('\\n') {\n229\t                                None => break,\n230\t                                Some(pos) => {\n231\t                                    let line = buf[..pos].trim().to_string();\n232\t                                    buf = buf[pos + 1..].to_string();\n233\t\n234\t                                    tracing::trace!(raw_sse_line = %line, \"openai_compat SSE\");\n235\t\n236\t                                    if !line.starts_with(\"data:\") {\n237\t                                        continue;\n238\t                                    }\n239\t                                    let data = line[\"data:\".len()..].trim();\n240\t\n241\t                                    if data == \"[DONE]\" {\n242\t                                        // Emit tool calls if any were buffered\n243\t                                        if !tool_call_buf.is_empty() {\n244\t                                            let mut indices: Vec<usize> = tool_call_buf.keys().cloned().collect();\n245\t                                            indices.sort();\n246\t                                            let tool_calls: Vec<ToolCall> = indices.iter().filter_map(|idx| {\n247\t                                                let (id, name, args) = tool_call_buf.get(idx)?;\n248\t                                                Some(ToolCall {\n249\t                                                    id: id.clone(),\n250\t                                                    name: name.clone(),\n251\t                                                    arguments: args.clone(),\n252\t                                                })\n253\t                                            }).collect();\n254\t                                            if !tool_calls.is_empty() {\n255\t                                                yield Ok(StreamEvent::ToolCallDone { tool_calls });\n256\t                                            }\n257\t                                        }\n258\t                                        yield Ok(StreamEvent::Done { usage: None });\n259\t                                        return;\n260\t                                    }\n261\t\n262\t                                    match serde_json::from_str::<StreamChunk>(data) {\n263\t                                        Err(e) => {\n264\t                                            tracing::debug!(\"skip unparseable SSE chunk: {e}\");\n265\t                                        }\n266\t                                        Ok(chunk) => {\n267\t                                            let (events, done) = convert_chunk_to_events(chunk, &mut tool_call_buf);\n268\t                                            for event in events {\n269\t                                                yield Ok(event);\n270\t                                            }\n271\t                                            if done {\n272\t                                                return;\n273\t                                            }\n274\t                                        }\n275\t                                    }\n276\t                                }\n277\t                            }\n278\t                        }\n279\t                    }\n280\t                }\n281\t            }\n282\t        };\n283\t\n284\t        Ok(Box::pin(s))\n285\t    }\n286\t}\n287\t\n288\tfn map_reqwest_error(e: reqwest::Error) -> LlmError {\n289\t    if e.is_timeout() {\n290\t        return LlmError::Timeout(Duration::from_secs(30));\n291\t    }\n292\t    LlmError::Network(e.to_string())\n293\t}\n294\t\n295\tfn map_http_status_error(status: u16, headers: &HeaderMap, message: String) -> LlmError {\n296\t    match status {\n297\t        401 | 403 => LlmError::AuthError(message),\n298\t        413 => LlmError::RequestTooLarge(message),\n299\t        400 if is_request_too_large_message(&message) => LlmError::RequestTooLarge(message),\n300\t        429 => LlmError::RateLimited {\n301\t            retry_after_ms: retry_after_ms(headers),\n302\t        },\n303\t        404 => LlmError::ModelNotAvailable(message),\n304\t        _ => LlmError::ProviderError { status, message },\n305\t    }\n306\t}\n307\t\n308\tfn is_request_too_large_message(message: &str) -> bool {\n309\t    let lower = message.to_ascii_lowercase();\n310\t    [\n311\t        \"too large\",\n312\t        \"request_too_large\",\n313\t        \"maximum context length\",\n314\t        \"context length\",\n315\t        \"token limit\",\n316\t        \"prompt is too long\",\n317\t    ]\n318\t    .iter()\n319\t    .any(|needle| lower.contains(needle))\n320\t}\n321\t\n322\tfn retry_after_ms(headers: &HeaderMap) -> Option<u64> {\n323\t    let secs = headers\n324\t        .get(\"retry-after\")\n325\t        .and_then(|v| v.to_str().ok())\n326\t        .and_then(|raw| raw.trim().parse::<u64>().ok())?;\n327\t    secs.checked_mul(1000)\n328\t}\n329\t\n330\tfn role_str(role: &Role) -> &'static str {\n331\t    match role {\n332\t        Role::System => \"system\",\n333\t        Role::User => \"user\",\n334\t        Role::Assistant => \"assistant\",\n335\t        Role::Tool => \"tool\",\n336\t    }\n337\t}\n338\t\n339\tfn map_usage(u: UsageStats) -> TokenUsage {\n340\t    TokenUsage {\n341\t        prompt_tokens: u.prompt_tokens,\n342\t        completion_tokens: u.completion_tokens,\n343\t        total_tokens: u.total_tokens,\n344\t    }\n345\t}\n346\t\n347\tfn flush_tool_calls(tool_call_buf: &mut ToolCallBuffer) -> Option<Vec<ToolCall>> {\n348\t    if tool_call_buf.is_empty() {\n349\t        return None;\n350\t    }\n351\t    let mut indices: Vec<usize> = tool_call_buf.keys().cloned().collect();\n352\t    indices.sort();\n353\t    let tool_calls: Vec<ToolCall> = indices\n354\t        .iter()\n355\t        .filter_map(|idx| {\n356\t            let (id, name, args) = tool_call_buf.get(idx)?;\n357\t            Some(ToolCall {\n358\t                id: id.clone(),\n359\t                name: name.clone(),\n360\t                arguments: args.clone(),\n361\t            })\n362\t        })\n363\t        .collect();\n364\t    tool_call_buf.clear();\n365\t    if tool_calls.is_empty() {\n366\t        None\n367\t    } else {\n368\t        Some(tool_calls)\n369\t    }\n370\t}\n371\t\n372\tfn convert_chunk_to_events(\n373\t    chunk: StreamChunk,\n374\t    tool_call_buf: &mut ToolCallBuffer,\n375\t) -> (Vec<StreamEvent>, bool) {\n376\t    let mut events = Vec::new();\n377\t    let usage = chunk.usage.map(map_usage);\n378\t    let mut done = false;\n379\t\n380\t    for choice in chunk.choices {\n381\t        if let Some(content) = choice.delta.content\n382\t            && !content.is_empty()\n383\t        {\n384\t            events.push(StreamEvent::Delta { content });\n385\t        }\n386\t\n387\t        if let Some(tc_deltas) = choice.delta.tool_calls {\n388\t            for tc_delta in tc_deltas {\n389\t                let entry = tool_call_buf\n390\t                    .entry(tc_delta.index)\n391\t                    .or_insert_with(|| (String::new(), String::new(), String::new()));\n392\t                if let Some(id) = tc_delta.id {\n393\t                    entry.0 = id;\n394\t                }\n395\t                if let Some(func) = tc_delta.function {\n396\t                    if let Some(name) = func.name {\n397\t                        entry.1 = name;\n398\t                    }\n399\t                    if let Some(args) = func.arguments {\n400\t                        entry.2.push_str(&args);\n401\t                    }\n402\t                }\n403\t            }\n404\t        }\n405\t\n406\t        if choice.finish_reason.is_some() {\n407\t            if let Some(tool_calls) = flush_tool_calls(tool_call_buf) {\n408\t                events.push(StreamEvent::ToolCallDone { tool_calls });\n409\t            }\n410\t            if usage.is_some() {\n411\t                events.push(StreamEvent::Done {\n412\t                    usage: usage.clone(),\n413\t                });\n414\t                done = true;\n415\t            }\n416\t        }\n417\t    }\n418\t\n419\t    (events, done)\n420\t}\n421\t\n422\t#[cfg(test)]\n423\tmod tests {\n424\t    use super::*;\n425\t\n426\t    #[test]\n427\t    fn maps_400_too_large_to_request_too_large() {\n428\t        let err = map_http_status_error(\n429\t            400,\n430\t            &HeaderMap::new(),\n431\t            \"maximum context length exceeded\".to_string(),\n432\t        );\n433\t        match err {\n434\t            LlmError::RequestTooLarge(msg) => assert!(msg.contains(\"context length\")),\n435\t            other => panic!(\"expected RequestTooLarge, got {other:?}\"),\n436\t        }\n437\t    }\n438\t\n439\t    #[test]\n440\t    fn extracts_retry_after_on_429() {\n441\t        let mut headers = HeaderMap::new();\n442\t        headers.insert(\"retry-after\", \"12\".parse().expect(\"valid header value\"));\n443\t        let err = map_http_status_error(429, &headers, \"slow down\".to_string());\n444\t        match err {\n445\t            LlmError::RateLimited { retry_after_ms } => assert_eq!(retry_after_ms, Some(12_000)),\n446\t            other => panic!(\"expected RateLimited, got {other:?}\"),\n447\t        }\n448\t    }\n449\t\n450\t    #[test]\n451\t    fn openai_stream_chunk_preserves_delta_then_tool_then_done_order() {\n452\t        let mut buf = ToolCallBuffer::new();\n453\t\n454\t        let first = StreamChunk {\n455\t            choices: vec![StreamChoice {\n456\t                delta: DeltaContent {\n457\t                    content: Some(\"hello \".to_string()),\n458\t                    tool_calls: Some(vec![StreamToolCallDelta {\n459\t                        index: 0,\n460\t                        id: Some(\"call_1\".to_string()),\n461\t                        function: Some(StreamToolCallFunctionDelta {\n462\t                            name: Some(\"lookup\".to_string()),\n463\t                            arguments: Some(\"{\\\"q\\\":\\\"\".to_string()),\n464\t                        }),\n465\t                    }]),\n466\t                },\n467\t                finish_reason: None,\n468\t            }],\n469\t            usage: None,\n470\t        };\n471\t\n472\t        let second = StreamChunk {\n473\t            choices: vec![StreamChoice {\n474\t                delta: DeltaContent {\n475\t                    content: Some(\"world\".to_string()),\n476\t                    tool_calls: Some(vec![StreamToolCallDelta {\n477\t                        index: 0,\n478\t                        id: None,\n479\t                        function: Some(StreamToolCallFunctionDelta {\n480\t                            name: None,\n481\t                            arguments: Some(\"rust\\\"}\".to_string()),\n482\t                        }),\n483\t                    }]),\n484\t                },\n485\t                finish_reason: Some(\"tool_calls\".to_string()),\n486\t            }],\n487\t            usage: Some(UsageStats {\n488\t                prompt_tokens: 5,\n489\t                completion_tokens: 7,\n490\t                total_tokens: 12,\n491\t            }),\n492\t        };\n493\t\n494\t        let (events_1, done_1) = convert_chunk_to_events(first, &mut buf);\n495\t        let (events_2, done_2) = convert_chunk_to_events(second, &mut buf);\n496\t\n497\t        assert!(!done_1);\n498\t        assert!(done_2);\n499\t        assert!(matches!(&events_1[0], StreamEvent::Delta { content } if content == \"hello \"));\n500\t        assert!(matches!(&events_2[0], StreamEvent::Delta { content } if content == \"world\"));\n501\t        assert!(\n502\t            matches!(&events_2[1], StreamEvent::ToolCallDone { tool_calls } if tool_calls.len() == 1 && tool_calls[0].arguments == \"{\\\"q\\\":\\\"rust\\\"}\")\n503\t        );\n504\t        assert!(matches!(&events_2[2], StreamEvent::Done { usage: Some(_) }));\n505\t    }\n506\t}\n507\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"33623158-75cc-4f67-b2ef-8a696211d978","uuid":"a1c62d69-b035-40b5-94e8-540a9373509c","timestamp":"2026-04-02T06:39:25.139Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/provider/src/openai_compat/client.rs","content":"use super::types::*;\nuse async_stream::stream;\nuse ccode_domain::message::{Role, ToolCall};\nuse ccode_ports::provider::{\n    LlmError, LlmRequest, LlmResponse, LlmStream, StreamEvent, TokenUsage,\n};\nuse futures::StreamExt;\nuse reqwest::header::HeaderMap;\nuse std::collections::HashMap;\nuse std::time::Duration;\n\ntype ToolCallBuffer = HashMap<usize, (String, String, String)>;\n\n/// Shared HTTP client for OpenAI-compatible APIs.\n///\n/// Pass `extra_headers` to inject provider-specific headers (e.g. `X-Title`).\npub struct OpenAiCompatClient {\n    client: reqwest::Client,\n    pub api_key: String,\n    pub base_url: String,\n    pub default_model: String,\n    extra_headers: Vec<(String, String)>,\n}\n\nimpl OpenAiCompatClient {\n    pub fn new(\n        api_key: impl Into<String>,\n        base_url: impl Into<String>,\n        default_model: impl Into<String>,\n        extra_headers: Vec<(String, String)>,\n    ) -> Self {\n        Self {\n            client: reqwest::Client::new(),\n            api_key: api_key.into(),\n            base_url: base_url.into(),\n            default_model: default_model.into(),\n            extra_headers,\n        }\n    }\n\n    fn endpoint(&self) -> String {\n        format!(\"{}/chat/completions\", self.base_url)\n    }\n\n    fn build_body(&self, req: &LlmRequest, stream: bool) -> ChatRequest {\n        let model = req\n            .model\n            .clone()\n            .unwrap_or_else(|| self.default_model.clone());\n        let messages = req\n            .messages\n            .iter()\n            .map(|m| {\n                // tool role：帶 tool_call_id，content 為結果\n                if m.role == Role::Tool {\n                    return ChatMessage {\n                        role: \"tool\".into(),\n                        content: Some(m.content.clone()),\n                        tool_calls: None,\n                        tool_call_id: m.tool_call_id.clone(),\n                    };\n                }\n                // assistant role：可能帶 tool_calls（純工具呼叫時 content 為 null）\n                if m.role == Role::Assistant {\n                    let tool_calls = m.tool_calls.as_ref().map(|tcs| {\n                        tcs.iter()\n                            .map(|tc| OpenAiToolCall {\n                                id: tc.id.clone(),\n                                r#type: \"function\".into(),\n                                function: OpenAiToolCallFunction {\n                                    name: tc.name.clone(),\n                                    arguments: tc.arguments.clone(),\n                                },\n                            })\n                            .collect::<Vec<_>>()\n                    });\n                    let content = if m.content.is_empty() && tool_calls.is_some() {\n                        None // 純工具呼叫，content 送 null\n                    } else {\n                        Some(m.content.clone())\n                    };\n                    return ChatMessage {\n                        role: \"assistant\".into(),\n                        content,\n                        tool_calls,\n                        tool_call_id: None,\n                    };\n                }\n                // user / system\n                ChatMessage {\n                    role: role_str(&m.role).into(),\n                    content: Some(m.content.clone()),\n                    tool_calls: None,\n                    tool_call_id: None,\n                }\n            })\n            .collect();\n        let tools: Vec<OpenAiTool> = req\n            .tools\n            .iter()\n            .map(|t| OpenAiTool {\n                r#type: \"function\".to_string(),\n                function: OpenAiToolFunction {\n                    name: t.name.clone(),\n                    description: t.description.clone(),\n                    parameters: t.parameters.clone(),\n                },\n            })\n            .collect();\n        let tool_choice = if tools.is_empty() {\n            None\n        } else {\n            Some(\"auto\".into())\n        };\n        ChatRequest {\n            model,\n            messages,\n            stream,\n            max_tokens: req.max_tokens,\n            temperature: req.temperature,\n            tools,\n            tool_choice,\n        }\n    }\n\n    fn add_headers(&self, builder: reqwest::RequestBuilder) -> reqwest::RequestBuilder {\n        let mut b = builder.bearer_auth(&self.api_key);\n        for (name, value) in &self.extra_headers {\n            b = b.header(name.as_str(), value.as_str());\n        }\n        b\n    }\n\n    pub async fn health_check(&self) -> Result<(), LlmError> {\n        let url = format!(\"{}/models\", self.base_url);\n        let resp = self\n            .add_headers(self.client.get(&url))\n            .send()\n            .await\n            .map_err(map_reqwest_error)?;\n\n        if resp.status().is_success() {\n            Ok(())\n        } else {\n            Err(LlmError::ProviderError {\n                status: resp.status().as_u16(),\n                message: \"health check failed\".into(),\n            })\n        }\n    }\n\n    pub async fn complete(&self, req: LlmRequest) -> Result<LlmResponse, LlmError> {\n        let body = self.build_body(&req, false);\n        let resp = self\n            .add_headers(self.client.post(self.endpoint()).json(&body))\n            .send()\n            .await\n            .map_err(map_reqwest_error)?;\n\n        if !resp.status().is_success() {\n            let status = resp.status();\n            let headers = resp.headers().clone();\n            let text = resp.text().await.unwrap_or_default();\n            return Err(map_http_status_error(status.as_u16(), &headers, text));\n        }\n\n        let chat: ChatResponse = resp\n            .json()\n            .await\n            .map_err(|e| LlmError::InvalidResponse(e.to_string()))?;\n\n        let content = chat\n            .choices\n            .into_iter()\n            .next()\n            .and_then(|c| c.message)\n            .and_then(|m| m.content)\n            .unwrap_or_default();\n\n        Ok(LlmResponse {\n            content,\n            model: chat.model,\n            usage: chat.usage.map(map_usage),\n        })\n    }\n\n    pub async fn stream(&self, req: LlmRequest) -> Result<LlmStream, LlmError> {\n        let body = self.build_body(&req, true);\n\n        // debug: 印出送出的完整 request body（RUST_LOG=debug 時可見）\n        tracing::debug!(\n            endpoint = %self.endpoint(),\n            request_body = %serde_json::to_string_pretty(&body).unwrap_or_default(),\n            \"openai_compat → stream_complete request\"\n        );\n\n        let resp = self\n            .add_headers(self.client.post(self.endpoint()).json(&body))\n            .send()\n            .await\n            .map_err(map_reqwest_error)?;\n\n        if !resp.status().is_success() {\n            let status = resp.status();\n            let headers = resp.headers().clone();\n            let text = resp.text().await.unwrap_or_default();\n            return Err(map_http_status_error(status.as_u16(), &headers, text));\n        }\n\n        let bytes_stream = resp.bytes_stream();\n\n        let s = stream! {\n            tokio::pin!(bytes_stream);\n            let mut buf = String::new();\n            // Map from tool_call index -> (id, name, accumulated_arguments)\n            let mut tool_call_buf: ToolCallBuffer = HashMap::new();\n\n            while let Some(chunk) = bytes_stream.next().await {\n                match chunk {\n                    Err(e) => {\n                        yield Err(LlmError::StreamInterrupted(e.to_string()));\n                        return;\n                    }\n                    Ok(bytes) => {\n                        buf.push_str(&String::from_utf8_lossy(&bytes));\n\n                        loop {\n                            match buf.find('\\n') {\n                                None => break,\n                                Some(pos) => {\n                                    let line = buf[..pos].trim().to_string();\n                                    buf = buf[pos + 1..].to_string();\n\n                                    tracing::trace!(raw_sse_line = %line, \"openai_compat SSE\");\n\n                                    if !line.starts_with(\"data:\") {\n                                        continue;\n                                    }\n                                    let data = line[\"data:\".len()..].trim();\n\n                                    if data == \"[DONE]\" {\n                                        // Emit tool calls if any were buffered\n                                        if !tool_call_buf.is_empty() {\n                                            let mut indices: Vec<usize> = tool_call_buf.keys().cloned().collect();\n                                            indices.sort();\n                                            let tool_calls: Vec<ToolCall> = indices.iter().filter_map(|idx| {\n                                                let (id, name, args) = tool_call_buf.get(idx)?;\n                                                Some(ToolCall {\n                                                    id: id.clone(),\n                                                    name: name.clone(),\n                                                    arguments: args.clone(),\n                                                })\n                                            }).collect();\n                                            if !tool_calls.is_empty() {\n                                                yield Ok(StreamEvent::ToolCallDone { tool_calls });\n                                            }\n                                        }\n                                        yield Ok(StreamEvent::Done { usage: None });\n                                        return;\n                                    }\n\n                                    match serde_json::from_str::<StreamChunk>(data) {\n                                        Err(e) => {\n                                            tracing::debug!(\"skip unparseable SSE chunk: {e}\");\n                                        }\n                                        Ok(chunk) => {\n                                            let (events, done) = convert_chunk_to_events(chunk, &mut tool_call_buf);\n                                            for event in events {\n                                                yield Ok(event);\n                                            }\n                                            if done {\n                                                return;\n                                            }\n                                        }\n                                    }\n                                }\n                            }\n                        }\n                    }\n                }\n            }\n        };\n\n        Ok(Box::pin(s))\n    }\n}\n\nfn map_reqwest_error(e: reqwest::Error) -> LlmError {\n    if e.is_timeout() {\n        return LlmError::Timeout(Duration::from_secs(30));\n    }\n    LlmError::Network(e.to_string())\n}\n\nfn map_http_status_error(status: u16, headers: &HeaderMap, message: String) -> LlmError {\n    match status {\n        401 | 403 => LlmError::AuthError(message),\n        413 => LlmError::RequestTooLarge(message),\n        400 if is_request_too_large_message(&message) => LlmError::RequestTooLarge(message),\n        429 => LlmError::RateLimited {\n            retry_after_ms: retry_after_ms(headers),\n        },\n        404 => LlmError::ModelNotAvailable(message),\n        _ => LlmError::ProviderError { status, message },\n    }\n}\n\nfn is_request_too_large_message(message: &str) -> bool {\n    let lower = message.to_ascii_lowercase();\n    [\n        \"too large\",\n        \"request_too_large\",\n        \"maximum context length\",\n        \"context length\",\n        \"token limit\",\n        \"prompt is too long\",\n    ]\n    .iter()\n    .any(|needle| lower.contains(needle))\n}\n\nfn retry_after_ms(headers: &HeaderMap) -> Option<u64> {\n    let secs = headers\n        .get(\"retry-after\")\n        .and_then(|v| v.to_str().ok())\n        .and_then(|raw| raw.trim().parse::<u64>().ok())?;\n    secs.checked_mul(1000)\n}\n\nfn role_str(role: &Role) -> &'static str {\n    match role {\n        Role::System => \"system\",\n        Role::User => \"user\",\n        Role::Assistant => \"assistant\",\n        Role::Tool => \"tool\",\n    }\n}\n\nfn map_usage(u: UsageStats) -> TokenUsage {\n    TokenUsage {\n        prompt_tokens: u.prompt_tokens,\n        completion_tokens: u.completion_tokens,\n        total_tokens: u.total_tokens,\n    }\n}\n\nfn flush_tool_calls(tool_call_buf: &mut ToolCallBuffer) -> Option<Vec<ToolCall>> {\n    if tool_call_buf.is_empty() {\n        return None;\n    }\n    let mut indices: Vec<usize> = tool_call_buf.keys().cloned().collect();\n    indices.sort();\n    let tool_calls: Vec<ToolCall> = indices\n        .iter()\n        .filter_map(|idx| {\n            let (id, name, args) = tool_call_buf.get(idx)?;\n            Some(ToolCall {\n                id: id.clone(),\n                name: name.clone(),\n                arguments: args.clone(),\n            })\n        })\n        .collect();\n    tool_call_buf.clear();\n    if tool_calls.is_empty() {\n        None\n    } else {\n        Some(tool_calls)\n    }\n}\n\nfn convert_chunk_to_events(\n    chunk: StreamChunk,\n    tool_call_buf: &mut ToolCallBuffer,\n) -> (Vec<StreamEvent>, bool) {\n    let mut events = Vec::new();\n    let usage = chunk.usage.map(map_usage);\n    let mut done = false;\n\n    for choice in chunk.choices {\n        if let Some(content) = choice.delta.content\n            && !content.is_empty()\n        {\n            events.push(StreamEvent::Delta { content });\n        }\n\n        if let Some(tc_deltas) = choice.delta.tool_calls {\n            for tc_delta in tc_deltas {\n                let entry = tool_call_buf\n                    .entry(tc_delta.index)\n                    .or_insert_with(|| (String::new(), String::new(), String::new()));\n                if let Some(id) = tc_delta.id {\n                    entry.0 = id;\n                }\n                if let Some(func) = tc_delta.function {\n                    if let Some(name) = func.name {\n                        entry.1 = name;\n                    }\n                    if let Some(args) = func.arguments {\n                        entry.2.push_str(&args);\n                    }\n                }\n            }\n        }\n\n        if choice.finish_reason.is_some() {\n            if let Some(tool_calls) = flush_tool_calls(tool_call_buf) {\n                events.push(StreamEvent::ToolCallDone { tool_calls });\n            }\n            if usage.is_some() {\n                events.push(StreamEvent::Done {\n                    usage: usage.clone(),\n                });\n                done = true;\n            }\n        }\n    }\n\n    (events, done)\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn maps_400_too_large_to_request_too_large() {\n        let err = map_http_status_error(\n            400,\n            &HeaderMap::new(),\n            \"maximum context length exceeded\".to_string(),\n        );\n        match err {\n            LlmError::RequestTooLarge(msg) => assert!(msg.contains(\"context length\")),\n            other => panic!(\"expected RequestTooLarge, got {other:?}\"),\n        }\n    }\n\n    #[test]\n    fn extracts_retry_after_on_429() {\n        let mut headers = HeaderMap::new();\n        headers.insert(\"retry-after\", \"12\".parse().expect(\"valid header value\"));\n        let err = map_http_status_error(429, &headers, \"slow down\".to_string());\n        match err {\n            LlmError::RateLimited { retry_after_ms } => assert_eq!(retry_after_ms, Some(12_000)),\n            other => panic!(\"expected RateLimited, got {other:?}\"),\n        }\n    }\n\n    #[test]\n    fn openai_stream_chunk_preserves_delta_then_tool_then_done_order() {\n        let mut buf = ToolCallBuffer::new();\n\n        let first = StreamChunk {\n            choices: vec![StreamChoice {\n                delta: DeltaContent {\n                    content: Some(\"hello \".to_string()),\n                    tool_calls: Some(vec![StreamToolCallDelta {\n                        index: 0,\n                        id: Some(\"call_1\".to_string()),\n                        function: Some(StreamToolCallFunctionDelta {\n                            name: Some(\"lookup\".to_string()),\n                            arguments: Some(\"{\\\"q\\\":\\\"\".to_string()),\n                        }),\n                    }]),\n                },\n                finish_reason: None,\n            }],\n            usage: None,\n        };\n\n        let second = StreamChunk {\n            choices: vec![StreamChoice {\n                delta: DeltaContent {\n                    content: Some(\"world\".to_string()),\n                    tool_calls: Some(vec![StreamToolCallDelta {\n                        index: 0,\n                        id: None,\n                        function: Some(StreamToolCallFunctionDelta {\n                            name: None,\n                            arguments: Some(\"rust\\\"}\".to_string()),\n                        }),\n                    }]),\n                },\n                finish_reason: Some(\"tool_calls\".to_string()),\n            }],\n            usage: Some(UsageStats {\n                prompt_tokens: 5,\n                completion_tokens: 7,\n                total_tokens: 12,\n            }),\n        };\n\n        let (events_1, done_1) = convert_chunk_to_events(first, &mut buf);\n        let (events_2, done_2) = convert_chunk_to_events(second, &mut buf);\n\n        assert!(!done_1);\n        assert!(done_2);\n        assert!(matches!(&events_1[0], StreamEvent::Delta { content } if content == \"hello \"));\n        assert!(matches!(&events_2[0], StreamEvent::Delta { content } if content == \"world\"));\n        assert!(\n            matches!(&events_2[1], StreamEvent::ToolCallDone { tool_calls } if tool_calls.len() == 1 && tool_calls[0].arguments == \"{\\\"q\\\":\\\"rust\\\"}\")\n        );\n        assert!(matches!(&events_2[2], StreamEvent::Done { usage: Some(_) }));\n    }\n}\n","numLines":507,"startLine":1,"totalLines":507}}}
