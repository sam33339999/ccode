{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HCNGYFmBe9GtZaiqTamXCC","type":"tool_result","content":"1\tuse serde::{Deserialize, Serialize};\n2\t\n3\t// ── Tool types ─────────────────────────────────────────────────────────────────\n4\t\n5\t#[derive(Serialize, Deserialize, Debug, Clone)]\n6\tpub(super) struct AnthropicTool {\n7\t    pub name: String,\n8\t    pub description: String,\n9\t    pub input_schema: serde_json::Value,\n10\t}\n11\t\n12\t// ── Outgoing request ───────────────────────────────────────────────────────────\n13\t\n14\t#[derive(Serialize)]\n15\tpub(super) struct AnthropicRequest {\n16\t    pub model: String,\n17\t    /// Required by Anthropic API.\n18\t    pub max_tokens: u32,\n19\t    #[serde(skip_serializing_if = \"Option::is_none\")]\n20\t    pub system: Option<String>,\n21\t    pub messages: Vec<AnthropicMessage>,\n22\t    pub stream: bool,\n23\t    #[serde(skip_serializing_if = \"Option::is_none\")]\n24\t    pub temperature: Option<f32>,\n25\t    #[serde(skip_serializing_if = \"Vec::is_empty\")]\n26\t    pub tools: Vec<AnthropicTool>,\n27\t}\n28\t\n29\t/// Anthropic message — content 可為純字串或 content block 陣列。\n30\t/// 純文字訊息用字串（較簡潔），含 tool_use / tool_result 的訊息用陣列。\n31\t#[derive(Serialize, Deserialize)]\n32\tpub(super) struct AnthropicMessage {\n33\t    pub role: String,\n34\t    pub content: serde_json::Value,\n35\t}\n36\t\n37\t// ── Non-streaming response ─────────────────────────────────────────────────────\n38\t\n39\t#[derive(Deserialize)]\n40\tpub(super) struct AnthropicResponse {\n41\t    pub model: String,\n42\t    pub content: Vec<AnthropicContent>,\n43\t    pub usage: AnthropicUsage,\n44\t}\n45\t\n46\t#[derive(Deserialize)]\n47\tpub(super) struct AnthropicContent {\n48\t    #[serde(rename = \"type\")]\n49\t    pub content_type: String,\n50\t    pub text: Option<String>,\n51\t}\n52\t\n53\t// ── Streaming events ───────────────────────────────────────────────────────────\n54\t\n55\t/// Single envelope for all Anthropic SSE event payloads.\n56\t/// Unknown fields are ignored — only the relevant variants populate their fields.\n57\t#[derive(Deserialize)]\n58\tpub(super) struct AnthropicEvent {\n59\t    #[serde(rename = \"type\")]\n60\t    pub event_type: String,\n61\t    /// Present on `content_block_delta`.\n62\t    pub delta: Option<AnthropicEventDelta>,\n63\t    /// Present on `message_start`.\n64\t    pub message: Option<AnthropicEventMessage>,\n65\t    /// Present on `message_delta` (contains output token count).\n66\t    pub usage: Option<AnthropicDeltaUsage>,\n67\t    /// Present on `content_block_start`.\n68\t    pub content_block: Option<AnthropicContentBlock>,\n69\t    /// Present on `content_block_start` / `content_block_stop` / `content_block_delta`.\n70\t    pub index: Option<usize>,\n71\t}\n72\t\n73\t#[derive(Deserialize)]\n74\tpub(super) struct AnthropicContentBlock {\n75\t    #[serde(rename = \"type\")]\n76\t    pub block_type: String,\n77\t    /// Present when block_type == \"tool_use\"\n78\t    pub id: Option<String>,\n79\t    pub name: Option<String>,\n80\t}\n81\t\n82\t#[derive(Deserialize)]\n83\tpub(super) struct AnthropicEventDelta {\n84\t    #[serde(rename = \"type\")]\n85\t    pub delta_type: String,\n86\t    /// Populated when `delta_type == \"text_delta\"`.\n87\t    pub text: Option<String>,\n88\t    /// Populated when `delta_type == \"input_json_delta\"`.\n89\t    pub partial_json: Option<String>,\n90\t}\n91\t\n92\t#[derive(Deserialize)]\n93\tpub(super) struct AnthropicEventMessage {\n94\t    pub usage: Option<AnthropicUsage>,\n95\t}\n96\t\n97\t// ── Shared ─────────────────────────────────────────────────────────────────────\n98\t\n99\t#[derive(Deserialize, Clone)]\n100\tpub(super) struct AnthropicUsage {\n101\t    pub input_tokens: u32,\n102\t    pub output_tokens: u32,\n103\t}\n104\t\n105\t#[derive(Deserialize)]\n106\tpub(super) struct AnthropicDeltaUsage {\n107\t    pub output_tokens: u32,\n108\t}\n109\t\n\n<system-reminder>\nWhenever you re