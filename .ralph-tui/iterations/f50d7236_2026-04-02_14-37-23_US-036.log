{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CxRnGybrL4NR6mcv4fcDH9","type":"tool_result","content":"1\tuse ccode_config::schema::Config;\n2\tuse ccode_ports::provider::LlmClient;\n3\tuse std::sync::Arc;\n4\t\n5\t#[derive(Debug, thiserror::Error)]\n6\tpub enum FactoryError {\n7\t    #[error(\"provider '{0}' is not configured (missing api_key)\")]\n8\t    NotConfigured(&'static str),\n9\t    #[error(\"unknown provider: {0}\")]\n10\t    Unknown(String),\n11\t}\n12\t\n13\t/// Build a provider adapter from config.\n14\t/// `name` must match a key in `config.providers` (e.g. `\"openrouter\"`).\n15\tpub fn build(name: &str, config: &Config) -> Result<Arc<dyn LlmClient>, FactoryError> {\n16\t    match name {\n17\t        #[cfg(feature = \"provider-openrouter\")]\n18\t        \"openrouter\" => {\n19\t            use crate::openrouter::OpenRouterAdapter;\n20\t            let cfg = config\n21\t                .providers\n22\t                .openrouter\n23\t                .as_ref()\n24\t                .cloned()\n25\t                .unwrap_or_default();\n26\t            let api_key = cfg\n27\t                .resolved_api_key()\n28\t                .ok_or(FactoryError::NotConfigured(\"openrouter\"))?;\n29\t            Ok(Arc::new(OpenRouterAdapter::new(\n30\t                api_key,\n31\t                cfg.resolved_base_url(),\n32\t                cfg.resolved_default_model(),\n33\t                cfg.site_url.clone(),\n34\t                cfg.site_name.clone(),\n35\t            )))\n36\t        }\n37\t        #[cfg(feature = \"provider-zhipu\")]\n38\t        \"zhipu\" => {\n39\t            use crate::zhipu::ZhipuAdapter;\n40\t            let cfg = config.providers.zhipu.as_ref().cloned().unwrap_or_default();\n41\t            let api_key = cfg\n42\t                .resolved_api_key()\n43\t                .ok_or(FactoryError::NotConfigured(\"zhipu\"))?;\n44\t            Ok(Arc::new(ZhipuAdapter::new(\n45\t                api_key,\n46\t                cfg.resolved_base_url(),\n47\t                cfg.resolved_default_model(),\n48\t                cfg.title.clone(),\n49\t            )))\n50\t        }\n51\t        #[cfg(feature = \"provider-llamacpp\")]\n52\t        \"llamacpp\" => {\n53\t            use crate::llamacpp::LlamaCppAdapter;\n54\t            let cfg = config\n55\t                .providers\n56\t                .llamacpp\n57\t                .as_ref()\n58\t                .cloned()\n59\t                .unwrap_or_default();\n60\t            Ok(Arc::new(LlamaCppAdapter::new(\n61\t                cfg.resolved_api_key(),\n62\t                cfg.resolved_base_url(),\n63\t                cfg.resolved_default_model(),\n64\t            )))\n65\t        }\n66\t        #[cfg(feature = \"provider-anthropic\")]\n67\t        \"anthropic\" => {\n68\t            use crate::anthropic::AnthropicAdapter;\n69\t            let cfg = config\n70\t                .providers\n71\t                .anthropic\n72\t                .as_ref()\n73\t                .cloned()\n74\t                .unwrap_or_default();\n75\t            let api_key = cfg\n76\t                .resolved_api_key()\n77\t                .ok_or(FactoryError::NotConfigured(\"anthropic\"))?;\n78\t            Ok(Arc::new(AnthropicAdapter::new(\n79\t                api_key,\n80\t                cfg.resolved_base_url(),\n81\t                cfg.resolved_default_model(),\n82\t            )))\n83\t        }\n84\t        other => Err(FactoryError::Unknown(other.into())),\n85\t    }\n86\t}\n87\t\n88\t/// Build the active provider from config.\n89\t///\n90\t/// - `manual`      → single provider named by `routing.default_provider`\n91\t/// - `failover`    → all configured providers in config order, try each on error\n92\t/// - `round_robin` → all configured providers, rotated per request\n93\tpub fn build_default(config: &Config) -> Result<Arc<dyn LlmClient>, FactoryError> {\n94\t    use crate::router::{ProviderRouter, RoutingStrategy};\n95\t\n96\t    let strategy = RoutingStrategy::from_config_value(&config.routing.strategy);\n97\t\n98\t    if strategy == RoutingStrategy::Manual {\n99\t        let name = config\n100\t            .routing\n101\t            .default_provider\n102\t            .as_deref()\n103\t            .unwrap_or(\"openrouter\");\n104\t        return build(name, config);\n105\t    }\n106\t\n107\t    // Build all providers that are configured\n108\t    let candidates = [\"openrouter\", \"anthropic\", \"zhipu\", \"llamacpp\"];\n109\t    let mut providers: Vec<Arc<dyn LlmClient>> = Vec::new();\n110\t\n111\t    // Put default_provider first if specified\n112\t    if let Some(default) = config.routing.default_provider.as_deref()\n113\t        && let Ok(p) = build(default, config)\n114\t    {\n115\t        providers.push(p);\n116\t    }\n117\t    for name in candidates {\n118\t        if Some(name) == config.routing.default_provider.as_deref() {\n119\t            continue; // already added\n120\t        }\n121\t        if let Ok(p) = build(name, config) {\n122\t            providers.push(p);\n123\t        }\n124\t    }\n125\t\n126\t    if providers.is_empty() {\n127\t        return Err(FactoryError::NotConfigured(\"no providers available\"));\n128\t    }\n129\t\n130\t    Ok(Arc::new(ProviderRouter::new(providers, strategy)))\n131\t}\n132\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_015ehycsq2bes8m9vz6JSD8h","session_id":"33623158-75cc-4f67-b2ef-8a696211d978","uuid":"6faf0b98-75f0-4e80-b96a-2d4f71d9548f","timestamp":"2026-04-02T06:38:18.855Z"}
