sync fn health_check(&self) -> Result<(), LlmError> {\n        self.client.health_check().await\n    }\n\n    async fn complete(&self, req: LlmRequest) -> Result<LlmResponse, LlmError> {\n        self.client.complete(req).await\n    }\n\n    async fn stream(&self, req: LlmRequest) -> Result<LlmStream, LlmError> {\n        self.client.stream(req).await\n    }\n}\n","structuredPatch":[{"oldStart":17,"oldLines":8,"newStart":17,"newLines":7,"lines":["         }","     }"," ","-    /// Inject a custom `reqwest::Client` — used in tests to set short timeouts.","-    #[cfg(test)]","+    /// Inject a custom `reqwest::Client` — used in acceptance tests to set short timeouts.","     pub fn new_for_test(","         http: reqwest::Client,","         api_key: impl Into<String>,"]}],"userModified":false,"replaceAll":false}}
