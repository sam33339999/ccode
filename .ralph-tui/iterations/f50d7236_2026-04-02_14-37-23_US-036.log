{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GbDfCsfWQ2Lm1Yo3zjaUoV","type":"tool_result","content":"1\tuse async_trait::async_trait;\n2\tuse ccode_domain::message::Message;\n3\tuse futures_core::Stream;\n4\tuse std::pin::Pin;\n5\tuse std::time::Duration;\n6\t\n7\t// ── Tool definitions ───────────────────────────────────────────────────────────\n8\t\n9\t#[derive(Debug, Clone)]\n10\tpub struct ToolDefinition {\n11\t    pub name: String,\n12\t    pub description: String,\n13\t    pub parameters: serde_json::Value,\n14\t}\n15\t\n16\t// ── Request / Response types ───────────────────────────────────────────────────\n17\t\n18\t#[derive(Debug, Clone)]\n19\tpub struct LlmRequest {\n20\t    pub messages: Vec<Message>,\n21\t    pub model: Option<String>, // None → use provider's default_model\n22\t    pub max_tokens: Option<u32>,\n23\t    pub temperature: Option<f32>,\n24\t    pub tools: Vec<ToolDefinition>,\n25\t}\n26\t\n27\t#[derive(Debug, Clone)]\n28\tpub struct LlmResponse {\n29\t    pub content: String,\n30\t    pub model: String,\n31\t    pub usage: Option<TokenUsage>,\n32\t}\n33\t\n34\t#[derive(Debug, Clone)]\n35\tpub struct TokenUsage {\n36\t    pub prompt_tokens: u32,\n37\t    pub completion_tokens: u32,\n38\t    pub total_tokens: u32,\n39\t}\n40\t\n41\t#[derive(Debug, Clone)]\n42\tpub enum StreamEvent {\n43\t    /// Incremental content delta from the model.\n44\t    Delta { content: String },\n45\t    /// One or more tool calls produced by the model.\n46\t    ToolCallDone {\n47\t        tool_calls: Vec<ccode_domain::message::ToolCall>,\n48\t    },\n49\t    /// Stream finished. May include final usage stats.\n50\t    Done { usage: Option<TokenUsage> },\n51\t}\n52\t\n53\tpub type LlmStream = Pin<Box<dyn Stream<Item = Result<StreamEvent, LlmError>> + Send>>;\n54\t\n55\t#[derive(Debug, thiserror::Error)]\n56\tpub enum LlmError {\n57\t    #[error(\"authentication failed: {0}\")]\n58\t    AuthError(String),\n59\t    #[error(\"rate limited\")]\n60\t    RateLimited { retry_after_ms: Option<u64> },\n61\t    #[error(\"model not available: {0}\")]\n62\t    ModelNotAvailable(String),\n63\t    #[error(\"request too large: {0}\")]\n64\t    RequestTooLarge(String),\n65\t    #[error(\"provider returned invalid response: {0}\")]\n66\t    InvalidResponse(String),\n67\t    #[error(\"stream interrupted: {0}\")]\n68\t    StreamInterrupted(String),\n69\t    #[error(\"network error: {0}\")]\n70\t    Network(String),\n71\t    #[error(\"timeout after {0:?}\")]\n72\t    Timeout(Duration),\n73\t    #[error(\"provider error ({status}): {message}\")]\n74\t    ProviderError { status: u16, message: String },\n75\t}\n76\t\n77\t// ── Provider port trait ────────────────────────────────────────────────────────\n78\t\n79\t#[async_trait]\n80\tpub trait LlmClient: Send + Sync {\n81\t    /// Provider identifier used in routing and logging.\n82\t    fn name(&self) -> &str;\n83\t\n84\t    /// Default model for this provider.\n85\t    fn default_model(&self) -> &str;\n86\t\n87\t    /// Liveness check.\n88\t    async fn health_check(&self) -> Result<(), LlmError>;\n89\t\n90\t    /// Single-shot completion (waits for full response).\n91\t    async fn complete(&self, req: LlmRequest) -> Result<LlmResponse, LlmError>;\n92\t\n93\t    /// Streaming completion — returns a stream of incremental events.\n94\t    async fn stream(&self, req: LlmRequest) -> Result<LlmStream, LlmError>;\n95\t}\n96\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_015ehycsq2bes8m9vz6JSD8h","session_id":"33623158-75cc-4f67-b2ef-8a696211d978","uuid":"7077e49f-ab69-4d53-8a7e-fc5dfb4bbd23","timestamp":"2026-04-02T06:38:12.317Z"}
