{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EgZUj82GzchcKMx5UowDfK","type":"tool_result","content":"1\tuse super::request::{\n2\t    AnthropicRequest, Content, Message, OpenAiMessage, OpenAiRequest, SystemContent,\n3\t};\n4\tuse super::response::{\n5\t    AnthropicResponse, OpenAiChoice, OpenAiMessageResponse, OpenAiResponse, OpenAiUsage, TextBlock,\n6\t    Usage,\n7\t};\n8\t\n9\t#[derive(Debug, Clone, Copy, Default)]\n10\tpub struct AnthropicToOpenAiOptions {\n11\t    pub enable_thinking: Option<bool>,\n12\t}\n13\t\n14\tpub fn anthropic_request_to_openai_request(\n15\t    anthropic_req: AnthropicRequest,\n16\t    options: AnthropicToOpenAiOptions,\n17\t) -> OpenAiRequest {\n18\t    let mut messages: Vec<OpenAiMessage> = anthropic_req\n19\t        .messages\n20\t        .into_iter()\n21\t        .map(|msg| OpenAiMessage {\n22\t            role: msg.role,\n23\t            content: content_to_text(msg.content),\n24\t        })\n25\t        .collect();\n26\t\n27\t    if let Some(system) = &anthropic_req.system {\n28\t        messages.insert(\n29\t            0,\n30\t            OpenAiMessage {\n31\t                role: \"system\".to_string(),\n32\t                content: system.to_text(),\n33\t            },\n34\t        );\n35\t    }\n36\t\n37\t    OpenAiRequest {\n38\t        model: anthropic_req.model,\n39\t        messages,\n40\t        max_tokens: anthropic_req.max_tokens,\n41\t        temperature: anthropic_req.temperature,\n42\t        stream: None,\n43\t        enable_thinking: options.enable_thinking,\n44\t    }\n45\t}\n46\t\n47\tpub fn openai_request_to_anthropic_request(openai_req: OpenAiRequest) -> AnthropicRequest {\n48\t    let mut system: Option<SystemContent> = None;\n49\t    let mut messages = Vec::with_capacity(openai_req.messages.len());\n50\t\n51\t    for message in openai_req.messages {\n52\t        if message.role == \"system\" && system.is_none() {\n53\t            system = Some(SystemContent::Text(message.content));\n54\t            continue;\n55\t        }\n56\t\n57\t        messages.push(Message {\n58\t            role: message.role,\n59\t            content: Content::Text(message.content),\n60\t        });\n61\t    }\n62\t\n63\t    AnthropicRequest {\n64\t        model: openai_req.model,\n65\t        messages,\n66\t        max_tokens: openai_req.max_tokens,\n67\t        temperature: openai_req.temperature,\n68\t        system,\n69\t        stream: openai_req.stream,\n70\t        provider: None,\n71\t    }\n72\t}\n73\t\n74\tpub fn openai_response_to_anthropic_response(\n75\t    openai_resp: OpenAiResponse,\n76\t    original_model: impl Into<String>,\n77\t) -> AnthropicResponse {\n78\t    let stop_reason = openai_resp\n79\t        .choices\n80\t        .first()\n81\t        .and_then(|choice| choice.finish_reason.clone());\n82\t\n83\t    let content = openai_resp\n84\t        .choices\n85\t        .into_iter()\n86\t        .filter_map(|choice| {\n87\t            let text = choice.message.content.filter(|s| !s.is_empty());\n88\t            if text.is_none() {\n89\t                if choice.message.reasoning_content.is_some() {\n90\t                    tracing::warn!(\n91\t                        \"thinking model returned empty content (all tokens consumed by reasoning)\"\n92\t                    );\n93\t                }\n94\t                return None;\n95\t            }\n96\t\n97\t            Some(TextBlock {\n98\t                block_type: \"text\".to_string(),\n99\t                text: text.expect(\"content checked is_some\"),\n100\t            })\n101\t        })\n102\t        .collect();\n103\t\n104\t    let usage = openai_resp\n105\t        .usage\n106\t        .map(|usage| Usage {\n107\t            input_tokens: usage.prompt_tokens,\n108\t            output_tokens: usage.completion_tokens,\n109\t        })\n110\t        .unwrap_or(Usage {\n111\t            input_tokens: 0,\n112\t            output_tokens: 0,\n113\t        });\n114\t\n115\t    AnthropicResponse {\n116\t        id: openai_resp.id,\n117\t        response_type: \"message\".to_string(),\n118\t        role: \"assistant\".to_string(),\n119\t        content,\n120\t        model: original_model.into(),\n121\t        stop_reason: stop_reason.map(|r| map_stop_reason_openai_to_anthropic(&r)),\n122\t        usage,\n123\t    }\n124\t}\n125\t\n126\tpub fn anthropic_response_to_openai_response(\n127\t    anthropic_resp: AnthropicResponse,\n128\t    target_model: impl Into<String>,\n129\t) -> OpenAiResponse {\n130\t    let text = anthropic_resp\n131\t        .content\n132\t        .into_iter()\n133\t        .filter(|block| block.block_type == \"text\")\n134\t        .map(|block| block.text)\n135\t        .collect::<Vec<_>>()\n136\t        .join(\"\\n\");\n137\t\n138\t    OpenAiResponse {\n139\t        id: anthropic_resp.id,\n140\t        object: \"chat.completion\".to_string(),\n141\t        created: 0,\n142\t        model: target_model.into(),\n143\t        choices: vec![OpenAiChoice {\n144\t            index: 0,\n145\t            message: OpenAiMessageResponse {\n146\t                role: anthropic_resp.role,\n147\t                content: Some(text),\n148\t                reasoning_content: None,\n149\t            },\n150\t            finish_reason: anthropic_resp\n151\t                .stop_reason\n152\t                .map(|r| map_stop_reason_anthropic_to_openai(&r)),\n153\t        }],\n154\t        usage: Some(OpenAiUsage {\n155\t            prompt_tokens: anthropic_resp.usage.input_tokens,\n156\t            completion_tokens: anthropic_resp.usage.output_tokens,\n157\t            total_tokens: anthropic_resp.usage.input_tokens + anthropic_resp.usage.output_tokens,\n158\t        }),\n159\t    }\n160\t}\n161\t\n162\tpub fn anthropic_tool_to_openai_function(\n163\t    anthropic_tool: serde_json::Value,\n164\t) -> Result<serde_json::Value, String> {\n165\t    let name = anthropic_tool\n166\t        .get(\"name\")\n167\t        .and_then(serde_json::Value::as_str)\n168\t        .ok_or(\"anthropic tool missing string field: name\")?;\n169\t    let description = anthropic_tool\n170\t        .get(\"description\")\n171\t        .and_then(serde_json::Value::as_str)\n172\t        .ok_or(\"anthropic tool missing string field: description\")?;\n173\t    let parameters = anthropic_tool\n174\t        .get(\"input_schema\")\n175\t        .cloned()\n176\t        .ok_or(\"anthropic tool missing field: input_schema\")?;\n177\t\n178\t    Ok(serde_json::json!({\n179\t        \"name\": name,\n180\t        \"description\": description,\n181\t        \"parameters\": parameters\n182\t    }))\n183\t}\n184\t\n185\tpub fn openai_function_to_anthropic_tool(\n186\t    openai_function: serde_json::Value,\n187\t) -> Result<serde_json::Value, String> {\n188\t    let name = openai_function\n189\t        .get(\"name\")\n190\t        .and_then(serde_json::Value::as_str)\n191\t        .ok_or(\"openai function missing string field: name\")?;\n192\t    let description = openai_function\n193\t        .get(\"description\")\n194\t        .and_then(serde_json::Value::as_str)\n195\t        .ok_or(\"openai function missing string field: description\")?;\n196\t    let input_schema = openai_function\n197\t        .get(\"parameters\")\n198\t        .cloned()\n199\t        .ok_or(\"openai function missing field: parameters\")?;\n200\t\n201\t    Ok(serde_json::json!({\n202\t        \"name\": name,\n203\t        \"description\": description,\n204\t        \"input_schema\": input_schema\n205\t    }))\n206\t}\n207\t\n208\tfn map_stop_reason_openai_to_anthropic(reason: &str) -> String {\n209\t    match reason {\n210\t        \"tool_calls\" => \"tool_use\".to_string(),\n211\t        other => other.to_string(),\n212\t    }\n213\t}\n214\t\n215\tfn map_stop_reason_anthropic_to_openai(reason: &str) -> String {\n216\t    match reason {\n217\t        \"tool_use\" => \"tool_calls\".to_string(),\n218\t        other => other.to_string(),\n219\t    }\n220\t}\n221\t\n222\tfn content_to_text(content: Content) -> String {\n223\t    match content {\n224\t        Content::Text(text) => text,\n225\t        Content::Blocks(blocks) => blocks\n226\t            .into_iter()\n227\t            .filter_map(|block| block.text)\n228\t            .collect::<Vec<_>>()\n229\t            .join(\"\\n\"),\n230\t    }\n231\t}\n232\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"33623158-75cc-4f67-b2ef-8a696211d978","uuid":"c0020559-43f4-4895-8734-e55ca106a081","timestamp":"2026-04-02T06:39:32.748Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/provider/src/compat/convert.rs","content":"use super::request::{\n    AnthropicRequest, Content, Message, OpenAiMessage, OpenAiRequest, SystemContent,\n};\nuse super::response::{\n    AnthropicResponse, OpenAiChoice, OpenAiMessageResponse, OpenAiResponse, OpenAiUsage, TextBlock,\n    Usage,\n};\n\n#[derive(Debug, Clone, Copy, Default)]\npub struct AnthropicToOpenAiOptions {\n    pub enable_thinking: Option<bool>,\n}\n\npub fn anthropic_request_to_openai_request(\n    anthropic_req: AnthropicRequest,\n    options: AnthropicToOpenAiOptions,\n) -> OpenAiRequest {\n    let mut messages: Vec<OpenAiMessage> = anthropic_req\n        .messages\n        .into_iter()\n        .map(|msg| OpenAiMessage {\n            role: msg.role,\n            content: content_to_text(msg.content),\n        })\n        .collect();\n\n    if let Some(system) = &anthropic_req.system {\n        messages.insert(\n            0,\n            OpenAiMessage {\n                role: \"system\".to_string(),\n                content: system.to_text(),\n            },\n        );\n    }\n\n    OpenAiRequest {\n        model: anthropic_req.model,\n        messages,\n        max_tokens: anthropic_req.max_tokens,\n        temperature: anthropic_req.temperature,\n        stream: None,\n        enable_thinking: options.enable_thinking,\n    }\n}\n\npub fn openai_request_to_anthropic_request(openai_req: OpenAiRequest) -> AnthropicRequest {\n    let mut system: Option<SystemContent> = None;\n    let mut messages = Vec::with_capacity(openai_req.messages.len());\n\n    for message in openai_req.messages {\n        if message.role == \"system\" && system.is_none() {\n            system = Some(SystemContent::Text(message.content));\n            continue;\n        }\n\n        messages.push(Message {\n            role: message.role,\n            content: Content::Text(message.content),\n        });\n    }\n\n    AnthropicRequest {\n        model: openai_req.model,\n        messages,\n        max_tokens: openai_req.max_tokens,\n        temperature: openai_req.temperature,\n        system,\n        stream: openai_req.stream,\n        provider: None,\n    }\n}\n\npub fn openai_response_to_anthropic_response(\n    openai_resp: OpenAiResponse,\n    original_model: impl Into<String>,\n) -> AnthropicResponse {\n    let stop_reason = openai_resp\n        .choices\n        .first()\n        .and_then(|choice| choice.finish_reason.clone());\n\n    let content = openai_resp\n        .choices\n        .into_iter()\n        .filter_map(|choice| {\n            let text = choice.message.content.filter(|s| !s.is_empty());\n            if text.is_none() {\n                if choice.message.reasoning_content.is_some() {\n                    tracing::warn!(\n                        \"thinking model returned empty content (all tokens consumed by reasoning)\"\n                    );\n                }\n                return None;\n            }\n\n            Some(TextBlock {\n                block_type: \"text\".to_string(),\n                text: text.expect(\"content checked is_some\"),\n            })\n        })\n        .collect();\n\n    let usage = openai_resp\n        .usage\n        .map(|usage| Usage {\n            input_tokens: usage.prompt_tokens,\n            output_tokens: usage.completion_tokens,\n        })\n        .unwrap_or(Usage {\n            input_tokens: 0,\n            output_tokens: 0,\n        });\n\n    AnthropicResponse {\n        id: openai_resp.id,\n        response_type: \"message\".to_string(),\n        role: \"assistant\".to_string(),\n        content,\n        model: original_model.into(),\n        stop_reason: stop_reason.map(|r| map_stop_reason_openai_to_anthropic(&r)),\n        usage,\n    }\n}\n\npub fn anthropic_response_to_openai_response(\n    anthropic_resp: AnthropicResponse,\n    target_model: impl Into<String>,\n) -> OpenAiResponse {\n    let text = anthropic_resp\n        .content\n        .into_iter()\n        .filter(|block| block.block_type == \"text\")\n        .map(|block| block.text)\n        .collect::<Vec<_>>()\n        .join(\"\\n\");\n\n    OpenAiResponse {\n        id: anthropic_resp.id,\n        object: \"chat.completion\".to_string(),\n        created: 0,\n        model: target_model.into(),\n        choices: vec![OpenAiChoice {\n            index: 0,\n            message: OpenAiMessageResponse {\n                role: anthropic_resp.role,\n                content: Some(text),\n                reasoning_content: None,\n            },\n            finish_reason: anthropic_resp\n                .stop_reason\n                .map(|r| map_stop_reason_anthropic_to_openai(&r)),\n        }],\n        usage: Some(OpenAiUsage {\n            prompt_tokens: anthropic_resp.usage.input_tokens,\n            completion_tokens: anthropic_resp.usage.output_tokens,\n            total_tokens: anthropic_resp.usage.input_tokens + anthropic_resp.usage.output_tokens,\n        }),\n    }\n}\n\npub fn anthropic_tool_to_openai_function(\n    anthropic_tool: serde_json::Value,\n) -> Result<serde_json::Value, String> {\n    let name = anthropic_tool\n        .get(\"name\")\n        .and_then(serde_json::Value::as_str)\n        .ok_or(\"anthropic tool missing string field: name\")?;\n    let description = anthropic_tool\n        .get(\"description\")\n        .and_then(serde_json::Value::as_str)\n        .ok_or(\"anthropic tool missing string field: description\")?;\n    let parameters = anthropic_tool\n        .get(\"input_schema\")\n        .cloned()\n        .ok_or(\"anthropic tool missing field: input_schema\")?;\n\n    Ok(serde_json::json!({\n        \"name\": name,\n        \"description\": description,\n        \"parameters\": parameters\n    }))\n}\n\npub fn openai_function_to_anthropic_tool(\n    openai_function: serde_json::Value,\n) -> Result<serde_json::Value, String> {\n    let name = openai_function\n        .get(\"name\")\n        .and_then(serde_json::Value::as_str)\n        .ok_or(\"openai function missing string field: name\")?;\n    let description = openai_function\n        .get(\"description\")\n        .and_then(serde_json::Value::as_str)\n        .ok_or(\"openai function missing string field: description\")?;\n    let input_schema = openai_function\n        .get(\"parameters\")\n        .cloned()\n        .ok_or(\"openai function missing field: parameters\")?;\n\n    Ok(serde_json::json!({\n        \"name\": name,\n        \"description\": description,\n        \"input_schema\": input_schema\n    }))\n}\n\nfn map_stop_reason_openai_to_anthropic(reason: &str) -> String {\n    match reason {\n        \"tool_calls\" => \"tool_use\".to_string(),\n        other => other.to_string(),\n    }\n}\n\nfn map_stop_reason_anthropic_to_openai(reason: &str) -> String {\n    match reason {\n        \"tool_use\" => \"tool_calls\".to_string(),\n        other => other.to_string(),\n    }\n}\n\nfn content_to_text(content: Content) -> String {\n    match content {\n        Content::Text(text) => text,\n        Content::Blocks(blocks) => blocks\n            .into_iter()\n            .filter_map(|block| block.text)\n            .collect::<Vec<_>>()\n            .join(\"\\n\"),\n    }\n}\n","numLines":232,"startLine":1,"totalLines":232}}}
