l Anthropic SSE event payloads.\n56\t/// Unknown fields are ignored — only the relevant variants populate their fields.\n57\t#[derive(Deserialize)]\n58\tpub(super) struct AnthropicEvent {\n59\t    #[serde(rename = \"type\")]\n60\t    pub event_type: String,\n61\t    /// Present on `content_block_delta`.\n62\t    pub delta: Option<AnthropicEventDelta>,\n63\t    /// Present on `message_start`.\n64\t    pub message: Option<AnthropicEventMessage>,\n65\t    /// Present on `message_delta` (contains output token count).\n66\t    pub usage: Option<AnthropicDeltaUsage>,\n67\t    /// Present on `content_block_start`.\n68\t    pub content_block: Option<AnthropicContentBlock>,\n69\t    /// Present on `content_block_start` / `content_block_stop` / `content_block_delta`.\n70\t    pub index: Option<usize>,\n71\t}\n72\t\n73\t#[derive(Deserialize)]\n74\tpub(super) struct AnthropicContentBlock {\n75\t    #[serde(rename = \"type\")]\n76\t    pub block_type: String,\n77\t    /// Present when block_type == \"tool_use\"\n78\t    pub id: Option<String>,\n79\t    pub name: Option<String>,\n80\t}\n81\t\n82\t#[derive(Deserialize)]\n83\tpub(super) struct AnthropicEventDelta {\n84\t    #[serde(rename = \"type\")]\n85\t    pub delta_type: String,\n86\t    /// Populated when `delta_type == \"text_delta\"`.\n87\t    pub text: Option<String>,\n88\t    /// Populated when `delta_type == \"input_json_delta\"`.\n89\t    pub partial_json: Option<String>,\n90\t}\n91\t\n92\t#[derive(Deserialize)]\n93\tpub(super) struct AnthropicEventMessage {\n94\t    pub usage: Option<AnthropicUsage>,\n95\t}\n96\t\n97\t// ── Shared ─────────────────────────────────────────────────────────────────────\n98\t\n99\t#[derive(Deserialize, Clone)]\n100\tpub(super) struct AnthropicUsage {\n101\t    pub input_tokens: u32,\n102\t    pub output_tokens: u32,\n103\t}\n104\t\n105\t#[derive(Deserialize)]\n106\tpub(super) struct AnthropicDeltaUsage {\n107\t    pub output_tokens: u32,\n108\t}\n109\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"33623158-75cc-4f67-b2ef-8a696211d978","uuid":"cba50e6f-2e58-4a06-9f3a-8934e6959f23","timestamp":"2026-04-02T06:39:28.999Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/provider/src/anthropic_compat/types.rs","content":"use serde::{Deserialize, Serialize};\n\n// ── Tool types ─────────────────────────────────────────────────────────────────\n\n#[derive(Serialize, Deserialize, Debug, Clone)]\npub(super) struct AnthropicTool {\n    pub name: String,\n    pub description: String,\n    pub input_schema: serde_json::Value,\n}\n\n// ── Outgoing request ───────────────────────────────────────────────────────────\n\n#[derive(Serialize)]\npub(super) struct AnthropicRequest {\n    pub model: String,\n    /// Required by Anthropic API.\n    pub max_tokens: u32,\n    #[serde(skip_serializing_if = \"Option::is_none\")]\n    pub system: Option<String>,\n    pub messages: Vec<AnthropicMessage>,\n    pub stream: bool,\n    #[serde(skip_serializing_if = \"Option::is_none\")]\n    pub temperature: Option<f32>,\n    #[serde(skip_serializing_if = \"Vec::is_empty\")]\n    pub tools: Vec<AnthropicTool>,\n}\n\n/// Anthropic message — content 可為純字串或 content block 陣列。\n/// 純文字訊息用字串（較簡潔），含 tool_use / tool_result 的訊息用陣列。\n#[derive(Serialize, Deserialize)]\npub(super) struct AnthropicMessage {\n    pub role: String,\n    pub content: serde_json::Value,\n}\n\n// ── Non-streaming response ─────────────────────────────────────────────────────\n\n#[derive(Deserialize)]\npub(super) struct AnthropicResponse {\n    pub model: String,\n    pub content: Vec<AnthropicContent>,\n    pub usage: AnthropicUsage,\n}\n\n#[derive(Deserialize)]\npub(super) struct AnthropicContent {\n    #[serde(rename = \"type\")]\n    pub content_type: String,\n    pub text: Option<String>,\n}\n\n// ── Streaming events ───────────────────────────────────────────────────────────\n\n/// Single envelope for all Anthropic SSE event payloads.\n/// Unknown fields are ignored — only the relevant variants populate their fields.\n#[derive(Deserialize)]\npub(super) struct AnthropicEvent {\n    #[serde(rename = \"type\")]\n    pub event_type: String,\n    /// Present on `content_block_delta`.\n    pub delta: Option<AnthropicEventDelta>,\n    /// Present on `message_start`.\n    pub message: Option<AnthropicEventMessage>,\n    /// Present on `message_delta` (contains output token count).\n    pub usage: Option<AnthropicDeltaUsage>,\n    /// Present on `content_block_start`.\n    pub content_block: Option<AnthropicContentBlock>,\n    /// Present on `content_block_start` / `content_block_stop` / `content_block_delta`.\n    pub index: Option<usize>,\n}\n\n#[derive(Deserialize)]\npub(super) struct AnthropicContentBlock {\n    #[serde(rename = \"type\")]\n    pub block_type: String,\n    /// Present when block_type == \"tool_use\"\n    pub id: Option<String>,\n    pub name: Option<String>,\n}\n\n#[derive(Deserialize)]\npub(super) struct AnthropicEventDelta {\n    #[serde(rename = \"type\")]\n    pub delta_type: String,\n    /// Populated when `delta_type == \"text_delta\"`.\n    pub text: Option<String>,\n    /// Populated when `delta_type == \"input_json_delta\"`.\n    pub partial_json: Option<String>,\n}\n\n#[derive(Deserialize)]\npub(super) struct AnthropicEventMessage {\n    pub usage: Option<AnthropicUsage>,\n}\n\n// ── Shared ─────────────────────────────────────────────────────────────────────\n\n#[derive(Deserialize, Clone)]\npub(super) struct AnthropicUsage {\n    pub input_tokens: u32,\n    pub output_tokens: u32,\n}\n\n#[derive(Deserialize)]\npub(super) struct AnthropicDeltaUsage {\n    pub output_tokens: u32,\n}\n","numLines":109,"startLine":1,"totalLines":109}}}
