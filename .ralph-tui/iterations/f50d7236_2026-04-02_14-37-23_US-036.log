{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CtBrYUPYZaEHdEFuvLHsiy","type":"tool_result","content":"1\tuse async_trait::async_trait;\n2\tuse ccode_ports::provider::{LlmClient, LlmError, LlmRequest, LlmResponse, LlmStream};\n3\tuse std::sync::{\n4\t    Arc,\n5\t    atomic::{AtomicUsize, Ordering},\n6\t};\n7\t\n8\t#[derive(Debug, Clone, PartialEq)]\n9\tpub enum RoutingStrategy {\n10\t    /// Always use the first (default) provider.\n11\t    Manual,\n12\t    /// Try providers in order; advance to the next on error.\n13\t    Failover,\n14\t    /// Distribute requests round-robin across all providers.\n15\t    RoundRobin,\n16\t}\n17\t\n18\timpl RoutingStrategy {\n19\t    pub fn from_config_value(s: &str) -> Self {\n20\t        match s {\n21\t            \"failover\" => Self::Failover,\n22\t            \"round_robin\" => Self::RoundRobin,\n23\t            _ => Self::Manual,\n24\t        }\n25\t    }\n26\t}\n27\t\n28\tpub struct ProviderRouter {\n29\t    providers: Vec<Arc<dyn LlmClient>>,\n30\t    strategy: RoutingStrategy,\n31\t    rr_cursor: AtomicUsize,\n32\t}\n33\t\n34\timpl ProviderRouter {\n35\t    pub fn new(providers: Vec<Arc<dyn LlmClient>>, strategy: RoutingStrategy) -> Self {\n36\t        Self {\n37\t            providers,\n38\t            strategy,\n39\t            rr_cursor: AtomicUsize::new(0),\n40\t        }\n41\t    }\n42\t\n43\t    fn pick_primary(&self) -> Option<&Arc<dyn LlmClient>> {\n44\t        match self.strategy {\n45\t            RoutingStrategy::RoundRobin => {\n46\t                if self.providers.is_empty() {\n47\t                    return None;\n48\t                }\n49\t                let idx = self.rr_cursor.fetch_add(1, Ordering::Relaxed) % self.providers.len();\n50\t                self.providers.get(idx)\n51\t            }\n52\t            _ => self.providers.first(),\n53\t        }\n54\t    }\n55\t}\n56\t\n57\t#[async_trait]\n58\timpl LlmClient for ProviderRouter {\n59\t    fn name(&self) -> &str {\n60\t        \"router\"\n61\t    }\n62\t\n63\t    fn default_model(&self) -> &str {\n64\t        self.providers\n65\t            .first()\n66\t            .map(|p| p.default_model())\n67\t            .unwrap_or(\"\")\n68\t    }\n69\t\n70\t    async fn health_check(&self) -> Result<(), LlmError> {\n71\t        self.pick_primary()\n72\t            .ok_or_else(|| LlmError::Network(\"no providers configured\".into()))?\n73\t            .health_check()\n74\t            .await\n75\t    }\n76\t\n77\t    async fn complete(&self, req: LlmRequest) -> Result<LlmResponse, LlmError> {\n78\t        match self.strategy {\n79\t            RoutingStrategy::Failover => {\n80\t                let mut last_err = LlmError::Network(\"no providers\".into());\n81\t                for p in &self.providers {\n82\t                    match p.complete(req.clone()).await {\n83\t                        Ok(r) => return Ok(r),\n84\t                        Err(e) => {\n85\t                            tracing::warn!(\"[router] provider {} failed: {e}\", p.name());\n86\t                            last_err = e;\n87\t                        }\n88\t                    }\n89\t                }\n90\t                Err(last_err)\n91\t            }\n92\t            _ => {\n93\t                self.pick_primary()\n94\t                    .ok_or_else(|| LlmError::Network(\"no providers configured\".into()))?\n95\t                    .complete(req)\n96\t                    .await\n97\t            }\n98\t        }\n99\t    }\n100\t\n101\t    async fn stream(&self, req: LlmRequest) -> Result<LlmStream, LlmError> {\n102\t        match self.strategy {\n103\t            RoutingStrategy::Failover => {\n104\t                let mut last_err = LlmError::Network(\"no providers\".into());\n105\t                for p in &self.providers {\n106\t                    match p.stream(req.clone()).await {\n107\t                        Ok(s) => return Ok(s),\n108\t                        Err(e) => {\n109\t                            tracing::warn!(\"[router] provider {} failed: {e}\", p.name());\n110\t                            last_err = e;\n111\t                        }\n112\t                    }\n113\t                }\n114\t                Err(last_err)\n115\t            }\n116\t            _ => {\n117\t                self.pick_primary()\n118\t                    .ok_or_else(|| LlmError::Network(\"no providers configured\".into()))?\n119\t                    .stream(req)\n120\t                    .await\n121\t            }\n122\t        }\n123\t    }\n124\t}\n125\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_015ehycsq2bes8m9vz6JSD8h","session_id":"33623158-75cc-4f67-b2ef-8a696211d978","uuid":"07e2378c-59da-4c20-a822-c7961a05a0db","timestamp":"2026-04-02T06:38:17.309Z"}
