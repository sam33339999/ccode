act.md\",\n195\t        \"ultraplan-contract.md\",\n196\t        \"multi-agent-orchestration-contract.md\",\n197\t    ] {\n198\t        let text = read_text(&workspace_root.join(\"docs\").join(doc));\n199\t        assert!(\n200\t            text.to_lowercase().contains(\"terminal\"),\n201\t            \"{doc} must define terminal state semantics\"\n202\t        );\n203\t    }\n204\t\n205\t    // remote side-effects must include recoverable/idempotent semantics\n206\t    for text in [\n207\t        &read_text(&workspace_root.join(\"docs/bridge-mode-contract.md\")),\n208\t        &read_text(&workspace_root.join(\"docs/ultraplan-contract.md\")),\n209\t        &integration_contracts,\n210\t    ] {\n211\t        let lower = text.to_lowercase();\n212\t        assert!(\n213\t            lower.contains(\"idempotent\") || lower.contains(\"cleanup\") || lower.contains(\"orphan\"),\n214\t            \"remote side-effect contracts must encode idempotent/cleanup/orphan behavior\"\n215\t        );\n216\t    }\n217\t\n218\t    // spec-lock-v1 release gate checks\n219\t    assert!(\n220\t        spec_lock.contains(\"acceptance-spec.md\"),\n221\t        \"spec-lock-v1 must lock acceptance-spec.md\"\n222\t    );\n223\t    for contract in LOCKED_CORE_CONTRACTS {\n224\t        assert!(\n225\t            spec_lock.contains(contract),\n226\t            \"spec-lock-v1 missing locked contract: {contract}\"\n227\t        );\n228\t    }\n229\t    assert!(\n230\t        spec_lock.contains(\"No waiver without expiry is allowed.\"),\n231\t        \"spec-lock-v1 must fail-closed on waiver expiry\"\n232\t    );\n233\t    for waiver_field in [\"Scope\", \"Owner\", \"Risk\", \"Expiry\"] {\n234\t        assert!(\n235\t            spec_lock.contains(waiver_field),\n236\t            \"spec-lock-v1 waiver policy missing required field: {waiver_field}\"\n237\t        );\n238\t    }\n239\t    assert!(\n240\t        spec_lock.contains(\"Breaking spec changes require `spec-lock-v2.md`\"),\n241\t        \"b