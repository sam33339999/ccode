{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PHkjjFWr9rmkwTvfXR6hBE","type":"tool_result","content":"1\tuse std::fs;\n2\tuse std::path::{Path, PathBuf};\n3\t\n4\t#[derive(Clone, Copy)]\n5\tstruct ContractRule {\n6\t    codename: &'static str,\n7\t    doc: &'static str,\n8\t    required_traits: &'static [&'static str],\n9\t    required_errors: &'static [&'static str],\n10\t    allowed_trait_crates: &'static [&'static str],\n11\t    requires_cli_or_security_matrix: bool,\n12\t}\n13\t\n14\tconst LOCKED_CORE_CONTRACTS: &[&str] = &[\n15\t    \"bridge-mode-contract.md\",\n16\t    \"agent-triggers-contract.md\",\n17\t    \"chicago-mcp-contract.md\",\n18\t    \"teammem-contract.md\",\n19\t    \"ultraplan-contract.md\",\n20\t    \"kairos-contract.md\",\n21\t    \"coordinator-mode-contract.md\",\n22\t    \"llm-compat-contract.md\",\n23\t];\n24\t\n25\tconst CONTRACT_RULES: &[ContractRule] = &[\n26\t    ContractRule {\n27\t        codename: \"BRIDGE_MODE\",\n28\t        doc: \"bridge-mode-contract.md\",\n29\t        required_traits: &[\"RemoteSessionService\", \"CcrClient\"],\n30\t        required_errors: &[\"RemoteSessionError\", \"CcrClientError\"],\n31\t        allowed_trait_crates: &[\"crates/application/\", \"crates/remote-runtime/\"],\n32\t        requires_cli_or_security_matrix: true,\n33\t    },\n34\t    ContractRule {\n35\t        codename: \"AGENT_TRIGGERS\",\n36\t        doc: \"agent-triggers-contract.md\",\n37\t        required_traits: &[\"TriggerSchedulerService\", \"RemoteTriggerDispatchService\"],\n38\t        required_errors: &[\"TriggerError\"],\n39\t        allowed_trait_crates: &[\"crates/application/\"],\n40\t        requires_cli_or_security_matrix: true,\n41\t    },\n42\t    ContractRule {\n43\t        codename: \"CHICAGO_MCP\",\n44\t        doc: \"chicago-mcp-contract.md\",\n45\t        required_traits: &[\"McpCapabilityPolicy\", \"ComputerUseLifecycle\"],\n46\t        required_errors: &[\"McpPolicyError\", \"McpRuntimeError\"],\n47\t        allowed_trait_crates: &[\"crates/mcp-runtime/\"],\n48\t        requires_cli_or_security_matrix: true,\n49\t    },\n50\t    ContractRule {\n51\t        codename: \"TEAMMEM\",\n52\t        doc: \"teammem-contract.md\",\n53\t        required_traits: &[\"TeamMemorySyncService\"],\n54\t        required_errors: &[\"TeamMemError\"],\n55\t        allowed_trait_crates: &[\"crates/application/\"],\n56\t        requires_cli_or_security_matrix: true,\n57\t    },\n58\t    ContractRule {\n59\t        codename: \"ULTRAPLAN\",\n60\t        doc: \"ultraplan-contract.md\",\n61\t        required_traits: &[\"UltraplanService\"],\n62\t        required_errors: &[\"UltraplanError\"],\n63\t        allowed_trait_crates: &[\"crates/application/\"],\n64\t        requires_cli_or_security_matrix: true,\n65\t    },\n66\t    ContractRule {\n67\t        codename: \"KAIROS\",\n68\t        doc: \"kairos-contract.md\",\n69\t        required_traits: &[\"AssistantModeService\"],\n70\t        required_errors: &[\"KairosError\"],\n71\t        allowed_trait_crates: &[\"crates/application/\"],\n72\t        requires_cli_or_security_matrix: false,\n73\t    },\n74\t    ContractRule {\n75\t        codename: \"COORDINATOR_MODE\",\n76\t        doc: \"coordinator-mode-contract.md\",\n77\t        required_traits: &[\"ModeCoordinatorService\"],\n78\t        required_errors: &[\"CoordinatorModeError\"],\n79\t        allowed_trait_crates: &[\"crates/application/\"],\n80\t        requires_cli_or_security_matrix: false,\n81\t    },\n82\t    ContractRule {\n83\t        codename: \"LLM_COMPAT\",\n84\t        doc: \"llm-compat-contract.md\",\n85\t        required_traits: &[\"LlmClient\"],\n86\t        required_errors: &[\"LlmError\"],\n87\t        allowed_trait_crates: &[\"crates/ports/\"],\n88\t        requires_cli_or_security_matrix: false,\n89\t    },\n90\t    // Cross-spec orchestration contract is also enforced for consistency checks.\n91\t    ContractRule {\n92\t        codename: \"MULTI_AGENT_ORCHESTRATION\",\n93\t        doc: \"multi-agent-orchestration-contract.md\",\n94\t        required_traits: &[\"MultiAgentOrchestrator\"],\n95\t        required_errors: &[\"OrchestrationError\"],\n96\t        allowed_trait_crates: &[\"crates/application/\"],\n97\t        requires_cli_or_security_matrix: false,\n98\t    },\n99\t];\n100\t\n101\t#[test]\n102\tfn spec_governance_gate_validation_passes() {\n103\t    let workspace_root = workspace_root();\n104\t    let readme = read_text(&workspace_root.join(\"docs/README.md\"));\n105\t    let acceptance_playbook = read_text(&workspace_root.join(\"docs/acceptance-playbook.md\"));\n106\t    let acceptance_spec = read_text(&workspace_root.join(\"docs/acceptance-spec.md\"));\n107\t    let spec_lock = read_text(&workspace_root.join(\"docs/spec-lock-v1.md\"));\n108\t    let codename_mapping = read_text(&workspace_root.join(\"docs/codename-mapping.md\"));\n109\t    let integration_contracts = read_text(&workspace_root.join(\"docs/integration-contracts.md\"));\n110\t\n111\t    assert!(\n112\t        acceptance_playbook.contains(\"## 1. Spec QA Checklist\"),\n113\t        \"acceptance-playbook must define the spec QA checklist\"\n114\t    );\n115\t\n116\t    for rule in CONTRACT_RULES {\n117\t        let doc_path = workspace_root.join(\"docs\").join(rule.doc);\n118\t        let doc = read_text(&doc_path);\n119\t\n120\t        // Spec QA checklist from acceptance-playbook.md\n121\t        assert!(\n122\t            count_evidence_anchors(&doc) >= 6,\n123\t            \"{} must contain at least 6 code evidence anchors\",\n124\t            rule.doc\n125\t        );\n126\t        assert!(\n127\t            has_crate_boundary_section(&doc),\n128\t            \"{} must contain a crate boundary/ownership section\",\n129\t            rule.doc\n130\t        );\n131\t        assert!(\n132\t            has_constants_classification(&doc),\n133\t            \"{} must contain constants classification\",\n134\t            rule.doc\n135\t        );\n136\t        assert!(\n137\t            has_error_taxonomy_section(&doc),\n138\t            \"{} must contain an error taxonomy section\",\n139\t            rule.doc\n140\t        );\n141\t        assert!(\n142\t            has_contract_and_integration_matrix(&doc),\n143\t            \"{} must include contract + integration tests in acceptance matrix\",\n144\t            rule.doc\n145\t        );\n146\t        if rule.requires_cli_or_security_matrix {\n147\t            assert!(\n148\t                doc.contains(\"CLI behavior tests\") || doc.contains(\"Security tests\"),\n149\t                \"{} must include CLI behavior tests or security tests\",\n150\t                rule.doc\n151\t            );\n152\t        }\n153\t\n154\t        for trait_name in rule.required_traits {\n155\t            assert!(\n156\t                has_trait_with_methods(&doc, trait_name),\n157\t                \"{} must include explicit method signatures for trait {}\",\n158\t                rule.doc,\n159\t                trait_name\n160\t            );\n161\t        }\n162\t\n163\t        for err in rule.required_errors {\n164\t            assert!(\n165\t                err.ends_with(\"Error\"),\n166\t                \"error type naming must be *Error: {err}\"\n167\t            );\n168\t        }\n169\t\n170\t        // Cross-spec consistency checks\n171\t        assert!(\n172\t            has_fail_closed_policy_text(&doc),\n173\t            \"{} must encode fail-closed policy wording\",\n174\t            rule.doc\n175\t        );\n176\t    }\n177\t\n178\t    // acceptance-playbook IME requirement encoded in acceptance-spec\n179\t    let ime_required_terms = [\n180\t        \"Composition text (preedit)\",\n181\t        \"committed text\",\n182\t        \"delete\",\n183\t        \"display width\",\n184\t    ];\n185\t    for term in ime_required_terms {\n186\t        assert!(\n187\t            acceptance_spec.contains(term),\n188\t            \"acceptance-spec.md IME section missing term: {term}\"\n189\t        );\n190\t    }\n191\t\n192\t    // state-machine terminal state policy is explicit where state machines are defined\n193\t    for doc in [\n194\t        \"bridge-mode-contract.md\",\n195\t        \"ultraplan-contract.md\",\n196\t        \"multi-agent-orchestration-contract.md\",\n197\t    ] {\n198\t        let text = read_text(&workspace_root.join(\"docs\").join(doc));\n199\t        assert!(\n200\t            text.to_lowercase().contains(\"terminal\"),\n201\t            \"{doc} must define terminal state semantics\"\n202\t        );\n203\t    }\n204\t\n205\t    // remote side-effects must include recoverable/idempotent semantics\n206\t    for text in [\n207\t        &read_text(&workspace_root.join(\"docs/bridge-mode-contract.md\")),\n208\t        &read_text(&workspace_root.join(\"docs/ultraplan-contract.md\")),\n209\t        &integration_contracts,\n210\t    ] {\n211\t        let lower = text.to_lowercase();\n212\t        assert!(\n213\t            lower.contains(\"idempotent\") || lower.contains(\"cleanup\") || lower.contains(\"orphan\"),\n214\t            \"remote side-effect contracts must encode idempotent/cleanup/orphan behavior\"\n215\t        );\n216\t    }\n217\t\n218\t    // spec-lock-v1 release gate checks\n219\t    assert!(\n220\t        spec_lock.contains(\"acceptance-spec.md\"),\n221\t        \"spec-lock-v1 must lock acceptance-spec.md\"\n222\t    );\n223\t    for contract in LOCKED_CORE_CONTRACTS {\n224\t        assert!(\n225\t            spec_lock.contains(contract),\n226\t            \"spec-lock-v1 missing locked contract: {contract}\"\n227\t        );\n228\t    }\n229\t    assert!(\n230\t        spec_lock.contains(\"No waiver without expiry is allowed.\"),\n231\t        \"spec-lock-v1 must fail-closed on waiver expiry\"\n232\t    );\n233\t    for waiver_field in [\"Scope\", \"Owner\", \"Risk\", \"Expiry\"] {\n234\t        assert!(\n235\t            spec_lock.contains(waiver_field),\n236\t            \"spec-lock-v1 waiver policy missing required field: {waiver_field}\"\n237\t        );\n238\t    }\n239\t    assert!(\n240\t        spec_lock.contains(\"Breaking spec changes require `spec-lock-v2.md`\"),\n241\t        \"breaking locked-spec changes must require explicit next lock version\"\n242\t    );\n243\t\n244\t    // crate-boundary and code-anchor checks: service traits and error taxonomies must exist in code.\n245\t    let rust_sources = collect_rust_sources(&workspace_root.join(\"crates\"));\n246\t\n247\t    for rule in CONTRACT_RULES {\n248\t        for trait_name in rule.required_traits {\n249\t            let hits = find_token_hits(&rust_sources, &format!(\"trait {trait_name}\"));\n250\t            assert!(\n251\t                !hits.is_empty(),\n252\t                \"missing code trait anchor for {} ({})\",\n253\t                trait_name,\n254\t                rule.codename\n255\t            );\n256\t            assert!(\n257\t                hits.iter().any(|p| {\n258\t                    rule.allowed_trait_crates\n259\t                        .iter()\n260\t                        .any(|allowed| p.contains(allowed))\n261\t                }),\n262\t                \"trait {} for {} must be declared in one of {:?}, found in {:?}\",\n263\t                trait_name,\n264\t                rule.codename,\n265\t                rule.allowed_trait_crates,\n266\t                hits\n267\t            );\n268\t        }\n269\t\n270\t        for err_name in rule.required_errors {\n271\t            let hits = find_token_hits(&rust_sources, &format!(\"enum {err_name}\"));\n272\t            assert!(\n273\t                !hits.is_empty(),\n274\t                \"missing code error taxonomy anchor for {} ({})\",\n275\t                err_name,\n276\t                rule.codename\n277\t            );\n278\t        }\n279\t    }\n280\t\n281\t    // codename-mapping and README consistency at crate-name vocabulary level.\n282\t    for crate_name in [\n283\t        \"app-services\",\n284\t     