uest,\n50\t    ) -> Result<RemoteSessionSummary, CcrClientError> {\n51\t        self.create_results\n52\t            .lock()\n53\t            .await\n54\t            .pop_front()\n55\t            .expect(\"missing create result\")\n56\t    }\n57\t\n58\t    async fn get(&self, _session_id: &str) -> Result<RemoteSessionSummary, CcrClientError> {\n59\t        self.get_results\n60\t            .lock()\n61\t            .await\n62\t            .pop_front()\n63\t            .expect(\"missing get result\")\n64\t    }\n65\t\n66\t    async fn archive(&self, _session_id: &str) -> Result<ArchiveResult, CcrClientError> {\n67\t        if let Some(delay) = self.archive_delay {\n68\t            tokio::time::sleep(delay).await;\n69\t        }\n70\t\n71\t        self.archive_results\n72\t            .lock()\n73\t            .await\n74\t            .pop_front()\n75\t            .expect(\"missing archive result\")\n76\t    }\n77\t\n78\t    async fn patch_title(&self, _session_id: &str, _title: &str) -> Result<(), CcrClientError> {\n79\t        self.patch_results\n80\t            .lock()\n81\t            .await\n82\t            .pop_front()\n83\t            .expect(\"missing patch result\")\n84\t    }\n85\t}\n86\t\n87\tfn sample_summary(state: RemoteSessionState) -> RemoteSessionSummary {\n88\t    RemoteSessionSummary {\n89\t        session_id: \"session_123\".to_string(),\n90\t        title: Some(\"t\".to_string()),\n91\t        environment_id: Some(\"env_123\".to_string()),\n92\t        state,\n93\t    }\n94\t}\n95\t\n96\tfn sample_request() -> CreateRemoteSessionRequest {\n97\t    CreateRemoteSessionRequest {\n98\t        environment_id: \"env_123\".to_string(),\n99\t        title: Some(\"title\".to_string()),\n100\t        permission_mode: Some(\"default\".to_string()),\n101\t        events: vec![SessionEvent {\n102\t            event_type: \"started\".to_string(),\n103\t            payload_json: serde_json::json!({\"ok\": true}),\n104\t        }],\n105\t    }\n106\t}\n107\t\n108\t#[tokio::test]\n109\tasync fn archive_treats_conflict_as_success_equivalent() {\n110\t    let client = MockCcrClient::with_archive(vec![Ok(ArchiveResult::AlreadyArchived)]);\n111\t    let svc = ApplicationRemoteSessionService::new(client, true);\n112\t\n113\t    let result = svc\n114\t        .archive_session(\n115\t            \"session_123\",\n116\t            ArchivePolicy {\n117\t                timeout: Duration::from_millis(10),\n118\t                idempotent: true,\n119\t            },\n120\t        )\n121\t        .await;\n122\t\n123\t    assert!(result.is_ok());\n124\t}\n125\t\n126\t#[tokio::test]\n127\tasync fn reconcile_resume_returns_expired_for_expired_session() {\n128\t    let client = MockCcrClient::with_get(vec![Ok(sample_summary(RemoteSessionState::Expired))]);\n129\t    let svc = ApplicationRemoteSessionService::new(client, true);\n130\t\n131\t    let result = svc.reconcile_resume(\"session_123\").await;\n132\t\n133\t    assert!(matches!(result, Err(RemoteSessionError::Expired)));\n134\t}\n135\t\n136\t#[tokio::test]\n137\tasync fn reconcile_resume_returns_invalid_transition_for_archived() {\n138\t    let client = MockCcrClient::with_get(vec![Ok(sample_summary(RemoteSessionState::Archived))]);\n139\t    let svc = ApplicationRemoteSessionService::new(client, true);\n140\t\n141\t    let result = svc.reconcile_resume(\"session_123\").await;\n142\t\n143\t    assert!(matches!(\n144\t        result,\n145\t        Err(RemoteSessionError::InvalidStateTransition)\n146\t    ));\n147\t}\n148\t\n149\t#[tokio::test]\n150\tasync fn create_session_maps_not_found_error() {\n151\t    let client = MockCcrClient {\n152\t        create_results: Arc::new(Mutex::new(\n153\t            vec![Err(CcrClientError::Http(\"status 404: missing\".to_string()))].into(),\n154\t        )),\n155\t        ..MockCcrClient::default()\n156\t    };\n157\t    let svc = ApplicationRemoteSessionService::new(client, true);\n158\t\n159\t    let result = svc.create_session(sample_request()).await;\n160\t\n161\t    assert!(matches!(result, Err(RemoteSessionError::NotFound)));\n162\t}\n163\t\n164\t#[tokio::test]\n165\tasync fn fetch_maps_auth_unavailable_error() {\n166\t    let client = MockCcrClient::with_get(vec![Err(CcrClientError::Unauthorized)]);\n167\t    let svc = ApplicationRemoteSessionService::new(client, true);\n168\t\n169\t    let result = svc.fetch_session(\"session_123\").await;\n170\t\n171\t    assert!(matches!(result, Err(RemoteSessionError::AuthUnavailable)));\n172\t}\n173\t\n174\t#[tokio::test]\n175\tasync fn update_title_maps_entitlement_denied_error() {\n176\t    let client = MockCcrClient {\n177\t        patch_results: Arc::new(Mutex::new(vec![Err(CcrClientError::Forbidden)].into())),\n178\t        ..MockCcrClient::default()\n179\t    };\n180\t    let svc = ApplicationRemoteSessionService::new(client, true);\n181\t\n182\t    let result = svc.update_title(\"session_123\", \"new title\").await;\n183\t\n184\t    assert!(matches!(result, Err(RemoteSessionError::EntitlementDenied)));\n185\t}\n186\t\n187\t#[tokio::test]\n188\tasync fn archive_maps_upstream_error() {\n189\t    let client = MockCcrClient::with_archive(vec![Err(CcrClientError::Http(\"boom\".to_string()))]);\n190\t    let svc = ApplicationRemoteSessionService::new(client, true);\n191\t\n192\t    let result = svc\n193\t        .archive_session(\n194\t            \"session_123\",\n195\t            ArchivePolicy {\n196\t                timeout: Duration::from_millis(10),\n197\t                idempotent: true,\n198\t            },\n199\t        )\n200\t        .await;\n201\t\n202\t    assert!(matches!(result, Err(RemoteSessionError::Upstream(_))));\n203\t}\n204\t\n205\t#[tokio::test]\n206\tasync fn policy_disabled_short_circuits_as_disabled_by_policy() {\n207\t    let client = MockCcrClient::with_get(vec![Ok(sample_summary(RemoteSessionState::Running))]);\n208\t    let svc = ApplicationRemoteSessionService::new(client, false);\n209\t\n210\t    let result = svc.fetch_session(\"session_123\").await;\n211\t\n212\t    assert!(matches!(result, Err(RemoteSessionError::DisabledByPolicy)));\n213\t}\n214\t\n215\t#[tokio::test]\n216\tasync fn shutdown_archive_can_degrade_to_best_effort_on_timeout() {\n217\t    let client = MockCcrClient::with_archive_delay(Duration::from_millis(50));\n218\t    let svc = ApplicationRemoteSessionService::new(client, true);\n219\t\n220\t    let archived = svc\n221\t        .archive_on_shutdown_best_effort(\n222\t            \"session_123\",\n223\t            ArchivePolicy {\n224\t                timeout: Duration::from_millis(1),\n225\t                idempotent: true,\n226\t            },\n227\t        )\n228\t        .await;\n229\t\n230\t    assert!(!archived);\n231\t}\n232\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"aadda8d2-45d5-4dd3-ab70-25e42d8ce2e4","uuid":"49403440-1ae3-4c36-a4b9-3a6e6c7643c4","timestamp":"2026-04-02T07:07:54.842Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/application/src/remote_session_service_tests.rs","content":"use crate::{\n    remote_session_service::ApplicationRemoteSessionService,\n    spec_contracts::{\n        ArchivePolicy, ArchiveResult, CcrClient, CcrClientError, CreateRemoteSessionRequest,\n        RemoteSessionError, RemoteSessionService, RemoteSessionState, RemoteSessionSummary,\n        SessionEvent,\n    },\n};\nuse std::{collections::VecDeque, sync::Arc, time::Duration};\nuse tokio::sync::Mutex;\n\n#[derive(Default)]\nstruct MockCcrClient {\n    get_results: Arc<Mutex<VecDeque<Result<RemoteSessionSummary, CcrClientError>>>>,\n    archive_results: Arc<Mutex<VecDeque<Result<ArchiveResult, CcrClientError>>>>,\n    create_results: Arc<Mutex<VecDeque<Result<RemoteSessionSummary, CcrClientError>>>>,\n    patch_results: Arc<Mutex<VecDeque<Result<(), CcrClientError>>>>,\n    archive_delay: Option<Duration>,\n}\n\nimpl MockCcrClient {\n    fn with_get(results: Vec<Result<RemoteSessionSummary, CcrClientError>>) -> Self {\n        Self {\n            get_results: Arc::new(Mutex::new(results.into())),\n            ..Self::default()\n        }\n    }\n\n    fn with_archive(results: Vec<Result<ArchiveResult, CcrClientError>>) -> Self {\n        Self {\n            archive_results: Arc::new(Mutex::new(results.into())),\n            ..Self::default()\n        }\n    }\n\n    fn with_archive_delay(delay: Duration) -> Self {\n        Self {\n            archive_delay: Some(delay),\n            archive_results: Arc::new(Mutex::new(vec![Ok(ArchiveResult::Archived)].into())),\n            ..Self::default()\n        }\n    }\n}\n\n#[async_trait::async_trait]\nimpl CcrClient for MockCcrClient {\n    async fn create(\n        &self,\n        _req: CreateRemoteSessionRequest,\n    ) -> Result<RemoteSessionSummary, CcrClientError> {\n        self.create_results\n            .lock()\n            .await\n            .pop_front()\n            .expect(\"missing create result\")\n    }\n\n    async fn get(&self, _session_id: &str) -> Result<RemoteSessionSummary, CcrClientError> {\n        self.get_results\n            .lock()\n            .await\n            .pop_front()\n            .expect(\"missing get result\")\n    }\n\n    async fn archive(&self, _session_id: &str) -> Result<ArchiveResult, CcrClientError> {\n        if let Some(delay) = self.archive_delay {\n            tokio::time::sleep(delay).await;\n        }\n\n        self.archive_results\n            .lock()\n            .await\n            .pop_front()\n            .expect(\"missing archive result\")\n    }\n\n    async fn patch_title(&self, _session_id: &str, _title: &str) -> Result<(), CcrClientError> {\n        self.patch_results\n            .lock()\n            .await\n            .pop_front()\n            .expect(\"missing patch result\")\n    }\n}\n\nfn sample_summary(state: RemoteSessionState) -> RemoteSessionSummary {\n    RemoteSessionSummary {\n        session_id: \"session_123\".to_string(),\n        title: Some(\"t\".to_string()),\n        environment_id: Some(\"env_123\".to_string()),\n        state,\n    }\n}\n\nfn sample_request() -> CreateRemoteSessionRequest {\n    CreateRemoteSessionRequest {\n        environment_id: \"env_123\".to_string(),\n        title: Some(\"title\".to_string()),\n        permission_mode: Some(\"default\".to_string()),\n        events: vec![SessionEvent {\n            event_type: \"started\".to_string(),\n            payload_json: serde_json::json!({\"ok\": true}),\n        }],\n    }\n}\n\n#[tokio::test]\nasync fn archive_treats_conflict_as_success_equivalent() {\n    let client = MockCcrClient::with_archive(vec![Ok(ArchiveResult::AlreadyArchived)]);\n    let svc = ApplicationRemoteSessionService::new(client, true);\n\n    let result = svc\n        .archive_session(\n            \"session_123\",\n            ArchivePolicy {\n                timeout: Duration::from_millis(10),\n                idempotent: true,\n            },\n        )\n        .await;\n\n    assert!(result.is_ok());\n}\n\n#[tokio::test]\nasync fn reconcile_resume_returns_expired_for_expired_session() {\n    let client = MockCcrClient::with_get(vec![Ok(sample_summary(RemoteSessionState::Expired))]);\n    let svc = ApplicationRemoteSessionService::new(client, true);\n\n    let result = svc.reconcile_resume(\"session_123\").await;\n\n    assert!(matches!(result, Err(RemoteSessionError::Expired)));\n}\n\n#[tokio::test]\nasync fn reconcile_resume_returns_invalid_transition_for_archived() {\n    let client = MockCcrClient::with_get(vec![Ok(sample_summary(RemoteSessionState::Archived))]);\n    let svc = ApplicationRemoteSessionService::new(client, true);\n\n    let result = svc.reconcile_resume(\"session_123\").await;\n\n    assert!(matches!(\n        result,\n        Err(RemoteSessionError::InvalidStateTransition)\n    ));\n}\n\n#[tokio::test]\nasync fn create_session_maps_not_found_error() {\n    let client = MockCcrClient {\n        create_results: Arc::new(Mutex::new(\n            vec![Err(CcrClientError::Http(\"status 404: missing\".to_string()))].into(),\n        )),\n        ..MockCcrClient::default()\n    };\n    let svc = ApplicationRemoteSessionService::new(client, true);\n\n    let result = svc.create_session(sample_request()).await;\n\n    assert!(matches!(result, Err(RemoteSessionError::NotFound)));\n}\n\n#[tokio::test]\nasync fn fetch_maps_auth_unavailable_error() {\n    let client = MockCcrClient::with_get(vec![Err(CcrClientError::Unauthorized)]);\n    let svc = ApplicationRemoteSessionService::new(client, true);\n\n    let result = svc.fetch_session(\"session_123\").await;\n\n    assert!(matches!(result, Err(RemoteSessionError::AuthUnavailable)));\n}\n\n#[tokio::test]\nasync fn update_title_maps_entitlement_denied_error() {\n    let client = MockCcrClient {\n        patch_results: Arc::new(Mutex::new(vec![Err(CcrClientError::Forbidden)].into())),\n        ..MockCcrClient::default()\n    };\n    let svc = ApplicationRemoteSessionService::new(client, true);\n\n    let result = svc.update_title(\"session_123\", \"new title\").await;\n\n    assert!(matches!(result, Err(RemoteSessionError::EntitlementDenied)));\n}\n\n#[tokio::test]\nasync fn archive_maps_upstream_error() {\n    let client = MockCcrClient::with_archive(vec![Err(CcrClientError::Http(\"boom\".to_string()))]);\n    let svc = ApplicationRemoteSessionService::new(client, true);\n\n    let result = svc\n        .archive_session(\n            \"session_123\",\n            ArchivePolicy {\n                timeout: Duration::from_millis(10),\n                idempotent: true,\n            },\n        )\n        .await;\n\n    assert!(matches!(result, Err(RemoteSessionError::Upstream(_))));\n}\n\n#[tokio::test]\nasync fn policy_disabled_short_circuits_as_disabled_by_policy() {\n    let client = MockCcrClient::with_get(vec![Ok(sample_summary(RemoteSessionState::Running))]);\n    let svc = ApplicationRemoteSessionService::new(client, false);\n\n    let result = svc.fetch_session(\"session_123\").await;\n\n    assert!(matches!(result, Err(RemoteSessionError::DisabledByPolicy)));\n}\n\n#[tokio::test]\nasync fn shutdown_archive_can_degrade_to_best_effort_on_timeout() {\n    let client = MockCcrClient::with_archive_delay(Duration::from_millis(50));\n    let svc = ApplicationRemoteSessionService::new(client, true);\n\n    let archived = svc\n        .archive_on_shutdown_best_effort(\n            \"session_123\",\n            ArchivePolicy {\n                timeout: Duration::from_millis(1),\n                idempotent: true,\n            },\n        )\n        .await;\n\n    assert!(!archived);\n}\n","numLines":232,"startLine":1,"totalLines":232}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ERx1NTXt1Ee34a942Zxs17","type":"tool_result","content":"1\t# BRIDGE_MODE / CCR Contract Spec (Rust)\n2\t\n3\t## 1. Objective\n4\t\n5\tDefine a production-grade Rust contract for Remote Control (BRIDGE_MODE / CCR) that preserves current behavior while enforcing clearer boundaries.\n6\t\n7\tPrimary evidence in current code:\n8\t\n9\t1. Entitlement/gate logic: `bridge/bridgeEnabled.ts`\n10\t2. Session lifecycle API: `bridge/createSession.ts`\n11\t3. Session ID compatibility shim: `bridge/sessionIdCompat.ts`\n12\t4. Runtime protocol types and dependencies: `bridge/types.ts`\n13\t5. Command entry path and bridge wiring: `entrypoints/cli.tsx:112`\n14\t6. Session archive and shutdown behavior: `bridge/createSession.ts:263`\n15\t\n16\t## 2. Rust Ownership Boundaries\n17\t\n18\t### Crate mapping\n19\t\n20\t1. `crates/api-types`\n21\tPurpose: shared wire/domain contracts for remote sessions.\n22\t\n23\t2. `crates/app-services`\n24\tPurpose: policy and orchestration (gate behavior, retry policy, archive guarantees, resume semantics).\n25\t\n26\t3. `crates/remote-runtime`\n27\tPurpose: concrete CCR client implementation (HTTP transport, auth headers, compat session ID translation).\n28\t\n29\t4. `crates/config`\n30\tPurpose: feature gate keys, default timeouts, environment variable names.\n31\t\n32\t5. `bins/app-cli`\n33\tPurpose: user-facing command entry and message rendering only.\n34\t\n35\t### Architectural rule\n36\t\n37\t`app-cli -> app-services -> remote-runtime -> platform`\n38\t\n39\t`app-services` owns policy decisions. `remote-runtime` must not decide fail-open/fail-close behavior.\n40\t\n41\t## 3. Proposed Contracts (Rust)\n42\t\n43\t### 3.1 API types (`crates/api-types/src/remote_session.rs`)\n44\t\n45\t```rust\n46\tuse serde::{Deserialize, Serialize};\n47\tuse std::time::Duration;\n48\t\n49\t#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]\n50\tpub struct RemoteSessionId(pub String);\n51\t\n52\t#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]\n53\tpub struct EnvironmentId(pub String);\n54\t\n55\t#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]\n56\tpub enum RemoteSessionState {\n57\t    Pending,\n58\t    Running,\n59\t    Idle,\n60\t    RequiresAction,\n61\t    Archived,\n62\t    Expired,\n63\t    Failed,\n64\t}\n65\t\n66\t#[derive(Debug, Clone, Serialize, Deserialize)]\n67\tpub struct CreateRemoteSessionRequest {\n68\t    pub environment_id: EnvironmentId,\n69\t    pub title: Option<String>,\n70\t    pub permission_mode: Option<String>,\n71\t    pub events: Vec<SessionEvent>,\n72\t}\n73\t\n74\t#[derive(Debug, Clone, Serialize, Deserialize)]\n75\tpub struct SessionEvent {\n76\t    pub event_type: String,\n77\t    pub payload_json: serde_json::Value,\n78\t}\n79\t\n80\t#[derive(Debug, Clone, Serialize, Deserialize)]\n81\tpub struct RemoteSessionSummary {\n82\t    pub session_id: RemoteSessionId,\n83\t    pub title: Option<String>,\n84\t    pub environment_id: Option<EnvironmentId>,\n85\t    pub state: RemoteSessionState,\n86\t}\n87\t\n88\t#[derive(Debug, Clone, Copy)]\n89\tpub struct ArchivePolicy {\n90\t    pub timeout: Duration,\n91\t    pub idempotent: bool,\n92\t}\n93\t```\n94\t\n95\t### 3.2 Service trait (`crates/app-services/src/remote_session_service.rs`)\n96\t\n97\t```rust\n98\tuse crate::errors::RemoteSessionError;\n99\tuse api_types::remote_session::*;\n100\t\n101\t#[async_trait::async_trait]\n102\tpub trait RemoteSessionService: Send + Sync {\n103\t    async fn create_session(\n104\t        &self,\n105\t        req: CreateRemoteSessionRequest,\n106\t    ) -> Result<RemoteSessionSummary, RemoteSessionError>;\n107\t\n108\t    async fn fetch_session(\n109\t        &self,\n110\t        session_id: &RemoteSessionId,\n111\t    ) -> Result<RemoteSessionSummary, RemoteSessionError>;\n112\t\n113\t    async fn archive_session(\n114\t        &self,\n115\t        session_id: &RemoteSessionId,\n116\t        policy: ArchivePolicy,\n117\t    ) -> Result<(), RemoteSessionError>;\n118\t\n119\t    async fn update_title(\n120\t        &self,\n121\t        session_id: &RemoteSessionId,\n122\t        title: &str,\n123\t    ) -> Result<(), RemoteSessionError>;\n124\t\n125\t    async fn reconcile_resume(\n126\t        &self,\n127\t        session_id: &RemoteSessionId,\n128\t    ) -> Result<RemoteSessionSummary, RemoteSessionError>;\n129\t}\n130\t```\n131\t\n132\t### 3.3 Runtime client trait (`crates/remote-runtime/src/ccr_client.rs`)\n133\t\n134\t```rust\n135\tuse api_types::remote_session::*;\n136\tuse crate::error::CcrClientError;\n137\t\n138\t#[async_trait::async_trait]\n139\tpub trait CcrClient: Send + Sync {\n140\t    async fn create(&self, req: CreateRemoteSessionRequest)\n141\t        -> Result<RemoteSessionSummary, CcrClientError>;\n142\t    async fn get(&self, session_id: &RemoteSessionId)\n143\t        -> Result<RemoteSessionSummary, CcrClientError>;\n144\t    async fn archive(&self, session_id: &RemoteSessionId)\n145\t        -> Result<ArchiveResult, CcrClientError>;\n146\t    async fn patch_title(&self, session_id: &RemoteSessionId, title: &str)\n147\t        -> Result<(), CcrClientError>;\n148\t}\n149\t\n150\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n151\tpub enum ArchiveResult {\n152\t    Archived,\n153\t    AlreadyArchived, // maps HTTP 409 as success-equivalent\n154\t}\n155\t```\n156\t\n157\t## 4. State Machine and Invariants\n158\t\n159\t## 4.1 Session state transitions\n160\t\n161\tAllowed:\n162\t\n163\t1. `Pending -> Running | Idle | RequiresAction | Failed`\n164\t2. `Running -> Idle | RequiresAction | Archived | Failed | Expired`\n165\t3. `Idle -> Running | Archived | Expired`\n166\t4. `RequiresAction -> Running | Archived | Expired`\n167\t5. `Archived` and `Expired` are terminal.\n168\t\n169\tForbidden:\n170\t\n171\t1. `Archived -> Running` (must create/resume a new effective session context).\n172\t2. `Expired -> Running` (requires explicit recreate/reconnect flow).\n173\t\n174\t## 4.2 Archive semantics\n175\t\n176\t1. Archive is idempotent (`409` is success-equivalent).\n177\t2. Missing token/org context is a policy error in `app-services`; runtime should return typed transport/auth errors only.\n178\t3. Shutdown path can degrade to best-effort archive, but command path must report deterministic result.\n179\t\n180\t## 5. Error Taxonomy\n181\t\n182\t## 5.1 Service-level errors (`app-services`)\n183\t\n184\t```rust\n185\t#[derive(thiserror::Error, Debug)]\n186\tpub enum RemoteSessionError {\n187\t    #[error(\"remote control is disabled by build or gate\")]\n188\t    DisabledByPolicy,\n189\t    #[error(\"missing entitlement or unsupported login profile\")]\n190\t    EntitlementDenied,\n191\t    #[error(\"invalid session state transition\")]\n192\t    InvalidStateTransition,\n193\t    #[error(\"session not found\")]\n194\t    NotFound,\n195\t    #[error(\"session expired\")]\n196\t    Expired,\n197\t    #[error(\"auth unavailable\")]\n198\t    AuthUnavailable,\n199\t    #[error(\"upstream transport error: {0}\")]\n200\t    Upstream(String),\n201\t}\n202\t```\n203\t\n204\t## 5.2 Runtime-level errors (`remote-runtime`)\n205\t\n206\t```rust\n207\t#[derive(thiserror::Error, Debug)]\n208\tpub enum CcrClientError {\n209\t    #[error(\"http error: {0}\")]\n210\t    Http(String),\n211\t    #[error(\"timeout\")]\n212\t    Timeout,\n213\t    #[error(\"unauthorized\")]\n214\t    Unauthorized,\n215\t    #[error(\"forbidden\")]\n216\t    Forbidden,\n217\t    #[error(\"not found\")]\n218\t    NotFound,\n219\t    #[error(\"invalid response payload\")]\n220\t    InvalidPayload,\n221\t}\n222\t```\n223\t\n224\tPolicy: runtime errors are translated in `app-services` into stable `RemoteSessionError`.\n225\t\n226\t## 6. Compatibility Rules (session_ vs cse_)\n227\t\n228\tBased on `bridge/sessionIdCompat.ts` behavior:\n229\t\n230\t1. Keep ID compatibility translation in `remote-runtime` only.\n231\t2. `api-types` stores canonical `RemoteSessionId` as opaque string.\n232\t3. `app-services` never manipulates tag prefixes directly.\n233\t\n234\tRationale:\n235\t\n236\t1. Prefix translation is transport compatibility logic, not domain logic.\n237\t2. Prevents spread of wire-format assumptions across crates.\n238\t\n239\t## 7. Constants Classification (BRIDGE_MODE)\n240\t\n241\tPlace constants by semantics:\n242\t\n243\t1. `api-types`: state labels and event names (`RemoteSessionState`, archive result categories).\n244\t2. `config`: gate keys (`tengu_ccr_bridge`), timeout defaults, env var names.\n245\t3. `core-domain`: state transition invariants (allowed transitions).\n246\t4. `remote-runtime`: endpoint path fragments and header wiring details.\n247\t5. `ui-tui`: user-facing copy (login guidance, disconnected messages).\n248\t\n249\t## 8. Acceptance Criteria for BRIDGE_MODE\n250\t\n251\t## 8.1 Contract tests\n252\t\n253\t1. `archive(409)` maps to success-equivalent result.\n254\t2. `session_*` and `cse_*` IDs round-trip through compatibility adapter correctly.\n255\t3. Missing token/org produces `AuthUnavailable` or `EntitlementDenied` (never panic).\n256\t\n257\t## 8.2 Integration tests\n258\t\n259\t1. Create -> fetch -> archive happy path passes.\n260\t2. Resume with stale/expired session returns deterministic error classification.\n261\t3. Shutdown path performs best-effort archive under timeout budget.\n262\t\n263\t## 8.3 CLI behavior tests\n264\t\n265\t1. Disabled gate path prints actionable message.\n266\t2. Successful remote-control path yields session URL and lifecycle updates.\n267\t3. Archive failure surfaces non-fatal warning and exit remains graceful.\n268\t\n269\t## 9. Migration Sequence (Bridge Slice)\n270\t\n271\t1. Create `api-types::remote_session` models and serde contracts.\n272\t2. Define `RemoteSessionService` trait in `app-services`.\n273\t3. Implement `CcrClient` + HTTP adapter in `remote-runtime`.\n274\t4. Add compatibility adapter for session ID tags in `remote-runtime`.\n275\t5. Wire `bins/app-cli` command flow to `RemoteSessionService`.\n276\t6. Add contract/integration tests and enforce in CI.\n277\t\n278\tExit condition:\n279\t\n280\t1. Bridge vertical slice works end-to-end in Rust with test-backed parity for create/fetch/archive/resume behaviors.\n281\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"aadda8d2-45d5-4dd3-ab70-25e42d8ce2e4","uuid":"41ee47c6-be50-4e47-8e30-4491801013fd","timestamp":"2026-04-02T07:07:54.844Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/docs/bridge-mode-contract.md","content":"# BRIDGE_MODE / CCR Contract Spec (Rust)\n\n## 1. Objective\n\nDefine a production-grade Rust contract for Remote Control (BRIDGE_MODE / CCR) that preserves current behavior while enforcing clearer boundaries.\n\nPrimary evidence in current code:\n\n1. Entitlement/gate logic: `bridge/bridgeEnabled.ts`\n2. Session lifecycle API: `bridge/createSession.ts`\n3. Session ID compatibility shim: `bridge/sessionIdCompat.ts`\n4. Runtime protocol types and dependencies: `bridge/types.ts`\n5. Command entry path and bridge wiring: `entrypoints/cli.tsx:112`\n6. Session archive and shutdown behavior: `bridge/createSession.ts:263`\n\n## 2. Rust Ownership Boundaries\n\n### Crate mapping\n\n1. `crates/api-types`\nPurpose: shared wire/domain contracts for remote sessions.\n\n2. `crates/app-services`\nPurpose: policy and orchestration (gate behavior, retry policy, archive guarantees, resume semantics).\n\n3. `crates/remote-runtime`\nPurpose: concrete CCR client implementation (HTTP transport, auth headers, compat session ID translation).\n\n4. `crates/config`\nPurpose: feature gate keys, default timeouts, environment variable names.\n\n5. `bins/app-cli`\nPurpose: user-facing command entry and message rendering only.\n\n### Architectural rule\n\n`app-cli -> app-services -> remote-runtime -> platform`\n\n`app-services` owns policy decisions. `remote-runtime` must not decide fail-open/fail-close behavior.\n\n## 3. Proposed Contracts (Rust)\n\n### 3.1 API types (`crates/api-types/src/remote_session.rs`)\n\n```rust\nuse serde::{Deserialize, Serialize};\nuse std::time::Duration;\n\n#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]\npub struct RemoteSessionId(pub String);\n\n#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]\npub struct EnvironmentId(pub String);\n\n#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]\npub enum RemoteSessionState {\n    Pending,\n    Running,\n    Idle,\n    RequiresAction,\n    Archived,\n    Expired,\n    Failed,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct CreateRemoteSessionRequest {\n    pub environment_id: EnvironmentId,\n    pub title: Option<String>,\n    pub permission_mode: Option<String>,\n    pub events: Vec<SessionEvent>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct SessionEvent {\n    pub event_type: String,\n    pub payload_json: serde_json::Value,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct RemoteSessionSummary {\n    pub session_id: RemoteSessionId,\n    pub title: Option<String>,\n    pub environment_id: Option<EnvironmentId>,\n    pub state: RemoteSessionState,\n}\n\n#[derive(Debug, Clone, Copy)]\npub struct ArchivePolicy {\n    pub timeout: Duration,\n    pub idempotent: bool,\n}\n```\n\n### 3.2 Service trait (`crates/app-services/src/remote_session_service.rs`)\n\n```rust\nuse crate::errors::RemoteSessionError;\nuse api_types::remote_session::*;\n\n#[async_trait::async_trait]\npub trait RemoteSessionService: Send + Sync {\n    async fn create_session(\n        &self,\n        req: CreateRemoteSessionRequest,\n    ) -> Result<RemoteSessionSummary, RemoteSessionError>;\n\n    async fn fetch_session(\n        &self,\n        session_id: &RemoteSessionId,\n    ) -> Result<RemoteSessionSummary, RemoteSessionError>;\n\n    async fn archive_session(\n        &self,\n        session_id: &RemoteSessionId,\n        policy: ArchivePolicy,\n    ) -> Result<(), RemoteSessionError>;\n\n    async fn update_title(\n        &self,\n        session_id: &RemoteSessionId,\n        title: &str,\n    ) -> Result<(), RemoteSessionError>;\n\n    async fn reconcile_resume(\n        &self,\n        session_id: &RemoteSessionId,\n    ) -> Result<RemoteSessionSummary, RemoteSessionError>;\n}\n```\n\n### 3.3 Runtime client trait (`crates/remote-runtime/src/ccr_client.rs`)\n\n```rust\nuse api_types::remote_session::*;\nuse crate::error::CcrClientError;\n\n#[async_trait::async_trait]\npub trait CcrClient: Send + Sync {\n    async fn create(&self, req: CreateRemoteSessionRequest)\n        -> Result<RemoteSessionSummary, CcrClientError>;\n    async fn get(&self, session_id: &RemoteSessionId)\n        -> Result<RemoteSessionSummary, CcrClientError>;\n    async fn archive(&self, session_id: &RemoteSessionId)\n        -> Result<ArchiveResult, CcrClientError>;\n    async fn patch_title(&self, session_id: &RemoteSessionId, title: &str)\n        -> Result<(), CcrClientError>;\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub enum ArchiveResult {\n    Archived,\n    AlreadyArchived, // maps HTTP 409 as success-equivalent\n}\n```\n\n## 4. State Machine and Invariants\n\n## 4.1 Session state transitions\n\nAllowed:\n\n1. `Pending -> Running | Idle | RequiresAction | Failed`\n2. `Running -> Idle | RequiresAction | Archived | Failed | Expired`\n3. `Idle -> Running | Archived | Expired`\n4. `RequiresAction -> Running | Archived | Expired`\n5. `Archived` and `Expired` are terminal.\n\nForbidden:\n\n1. `Archived -> Running` (must create/resume a new effective session context).\n2. `Expired -> Running` (requires explicit recreate/reconnect flow).\n\n## 4.2 Archive semantics\n\n1. Archive is idempotent (`409` is success-equivalent).\n2. Missing token/org context is a policy error in `app-services`; runtime should return typed transport/auth errors only.\n3. Shutdown path can degrade to best-effort archive, but command path must report deterministic result.\n\n## 5. Error Taxonomy\n\n## 5.1 Service-level errors (`app-services`)\n\n```rust\n#[derive(thiserror::Error, Debug)]\npub enum RemoteSessionError {\n    #[error(\"remote control is disabled by build or gate\")]\n    DisabledByPolicy,\n    #[error(\"missing entitlement or unsupported login profile\")]\n    EntitlementDenied,\n    #[error(\"invalid session state transition\")]\n    InvalidStateTransition,\n    #[error(\"session not found\")]\n    NotFound,\n    #[error(\"session expired\")]\n    Expired,\n    #[error(\"auth unavailable\")]\n    AuthUnavailable,\n    #[error(\"upstream transport error: {0}\")]\n    Upstream(String),\n}\n```\n\n## 5.2 Runtime-level errors (`remote-runtime`)\n\n```rust\n#[derive(thiserror::Error, Debug)]\npub enum CcrClientError {\n    #[error(\"http error: {0}\")]\n    Http(String),\n    #[error(\"timeout\")]\n    Timeout,\n    #[error(\"unauthorized\")]\n    Unauthorized,\n    #[error(\"forbidden\")]\n    Forbidden,\n    #[error(\"not found\")]\n    NotFound,\n    #[error(\"invalid response payload\")]\n    InvalidPayload,\n}\n```\n\nPolicy: runtime errors are translated in `app-services` into stable `RemoteSessionError`.\n\n## 6. Compatibility Rules (session_ vs cse_)\n\nBased on `bridge/sessionIdCompat.ts` behavior:\n\n1. Keep ID compatibility translation in `remote-runtime` only.\n2. `api-types` stores canonical `RemoteSessionId` as opaque string.\n3. `app-services` never manipulates tag prefixes directly.\n\nRationale:\n\n1. Prefix translation is transport compatibility logic, not domain logic.\n2. Prevents spread of wire-format assumptions across crates.\n\n## 7. Constants Classification (BRIDGE_MODE)\n\nPlace constants by semantics:\n\n1. `api-types`: state labels and event names (`RemoteSessionState`, archive result categories).\n2. `config`: gate keys (`tengu_ccr_bridge`), timeout defaults, env var names.\n3. `core-domain`: state transition invariants (allowed transitions).\n4. `remote-runtime`: endpoint path fragments and header wiring details.\n5. `ui-tui`: user-facing copy (login guidance, disconnected messages).\n\n## 8. Acceptance Criteria for BRIDGE_MODE\n\n## 8.1 Contract tests\n\n1. `archive(409)` maps to success-equivalent result.\n2. `session_*` and `cse_*` IDs round-trip through compatibility adapter correctly.\n3. Missing token/org produces `AuthUnavailable` or `EntitlementDenied` (never panic).\n\n## 8.2 Integration tests\n\n1. Create -> fetch -> archive happy path passes.\n2. Resume with stale/expired session returns deterministic error classification.\n3. Shutdown path performs best-effort archive under timeout budget.\n\n## 8.3 CLI behavior tests\n\n1. Disabled gate path prints actionable message.\n2. Successful remote-control path yields session URL and lifecycle updates.\n3. Archive failure surfaces non-fatal warning and exit remains graceful.\n\n## 9. Migration Sequence (Bridge Slice)\n\n1. Create `api-types::remote_session` models and serde contracts.\n2. Define `RemoteSessionService` trait in `app-services`.\n3. Implement `CcrClient` + HTTP adapter in `remote-runtime`.\n4. Add compatibility adapter for session ID tags in `remote-runtime`.\n5. Wire `bins/app-cli` command flow to `RemoteSessionService`.\n6. Add contract/integration tests and enforce in CI.\n\nExit condition:\n\n1. Bridge vertical slice works end-to-end in Rust with test-backed parity for create/fetch/archive/resume behaviors.\n","numLines":281,"startLine":1,"totalLines":281}}}
