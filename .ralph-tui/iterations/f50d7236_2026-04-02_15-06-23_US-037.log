{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tc15m4PPefR5jHP8t1AbsH","type":"tool_result","content":"1\tuse anyhow::Error as AnyError;\n2\tuse ccode_application::error::AppError;\n3\tuse ccode_bootstrap::WireError;\n4\tuse serde_json::Value;\n5\tuse std::sync::atomic::{AtomicU64, Ordering};\n6\tuse std::time::{SystemTime, UNIX_EPOCH};\n7\t\n8\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n9\tpub enum ErrorCategory {\n10\t    Policy,\n11\t    Auth,\n12\t    Transport,\n13\t    State,\n14\t    Validation,\n15\t}\n16\t\n17\tpub fn error_category_label(category: ErrorCategory) -> &'static str {\n18\t    match category {\n19\t        ErrorCategory::Policy => \"policy\",\n20\t        ErrorCategory::Auth => \"auth\",\n21\t        ErrorCategory::Transport => \"transport\",\n22\t        ErrorCategory::State => \"state\",\n23\t        ErrorCategory::Validation => \"validation\",\n24\t    }\n25\t}\n26\t\n27\tpub fn worker_status_label(status: &str) -> Option<&'static str> {\n28\t    match status {\n29\t        \"Running\" => Some(\"Running\"),\n30\t        \"Completed\" => Some(\"Completed\"),\n31\t        \"Failed\" => Some(\"Failed\"),\n32\t        \"Cancelled\" => Some(\"Cancelled\"),\n33\t        _ => None,\n34\t    }\n35\t}\n36\t\n37\t#[derive(Debug, Clone)]\n38\tpub struct ErrorContext {\n39\t    pub session_id: String,\n40\t    pub provider_name: String,\n41\t}\n42\t\n43\timpl ErrorContext {\n44\t    pub fn unknown() -> Self {\n45\t        Self {\n46\t            session_id: \"unknown\".to_string(),\n47\t            provider_name: \"unknown\".to_string(),\n48\t        }\n49\t    }\n50\t}\n51\t\n52\t#[derive(Debug, Clone)]\n53\tpub struct ErrorEnvelope {\n54\t    pub category: ErrorCategory,\n55\t    pub message: String,\n56\t    pub suggestion: Option<String>,\n57\t    pub correlation_id: String,\n58\t    pub session_id: String,\n59\t    pub provider_name: String,\n60\t}\n61\t\n62\timpl ErrorEnvelope {\n63\t    fn new(\n64\t        category: ErrorCategory,\n65\t        message: impl Into<String>,\n66\t        suggestion: Option<String>,\n67\t        ctx: &ErrorContext,\n68\t    ) -> Self {\n69\t        Self {\n70\t            category,\n71\t            message: message.into(),\n72\t            suggestion,\n73\t            correlation_id: next_correlation_id(),\n74\t            session_id: ctx.session_id.clone(),\n75\t            provider_name: ctx.provider_name.clone(),\n76\t        }\n77\t    }\n78\t\n79\t    pub fn render(&self) -> String {\n80\t        let category = error_category_label(self.category);\n81\t        let mut out = format!(\"[error:{category}] {}\", self.message);\n82\t        if let Some(suggestion) = &self.suggestion {\n83\t            out.push_str(&format!(\" Hint: {suggestion}\"));\n84\t        }\n85\t        out.push_str(&format!(\n86\t            \" [correlation_id:{} session_id:{} provider:{}]\",\n87\t            self.correlation_id, self.session_id, self.provider_name\n88\t        ));\n89\t        out\n90\t    }\n91\t}\n92\t\n93\tpub fn render_error(error: &AnyError, ctx: &ErrorContext) -> String {\n94\t    let resolved_ctx = resolve_context(error, ctx);\n95\t    classify_anyhow_error(error, &resolved_ctx).render()\n96\t}\n97\t\n98\tpub fn render_error_message(message: &str, ctx: &ErrorContext) -> String {\n99\t    classify_message_into_envelope(message, ctx).render()\n100\t}\n101\t\n102\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n103\tpub enum ToolRiskLevel {\n104\t    Low,\n105\t    Medium,\n106\t    High,\n107\t}\n108\t\n109\timpl ToolRiskLevel {\n110\t    pub fn label(self) -> &'static str {\n111\t        match self {\n112\t            ToolRiskLevel::Low => \"low\",\n113\t            ToolRiskLevel::Medium => \"medium\",\n114\t            ToolRiskLevel::High => \"high\",\n115\t        }\n116\t    }\n117\t}\n118\t\n119\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n120\tpub enum ToolConfirmationDecision {\n121\t    AllowOnce,\n122\t    AllowAlways,\n123\t    Deny,\n124\t}\n125\t\n126\tpub struct StreamFormatter {\n127\t    at_line_start: bool,\n128\t}\n129\t\n130\timpl StreamFormatter {\n131\t    pub fn new() -> Self {\n132\t        Self {\n133\t            at_line_start: true,\n134\t        }\n135\t    }\n136\t\n137\t    pub fn push_delta(&mut self, content: &str) -> String {\n138\t        if !content.is_empty() {\n139\t            self.at_line_start = content.ends_with('\\n');\n140\t        }\n141\t        content.to_string()\n142\t    }\n143\t\n144\t    pub fn tool_start_line(&mut self, tool_name: &str, args: &Value) -> String {\n145\t        let mut out = String::new();\n146\t        if !self.at_line_start {\n147\t            out.push('\\n');\n148\t        }\n149\t        let risk = classify_tool_risk(tool_name).label();\n150\t        out.push_str(&format!(\n151\t            \"[tool:start] {} risk={}({})\\n\",\n152\t            tool_name,\n153\t            risk,\n154\t            summarize_tool_args(args)\n155\t        ));\n156\t        self.at_line_start = true;\n157\t        out\n158\t    }\n159\t\n160\t    pub fn tool_result_line(&mut self, tool_name: &str, result: &Result<String, String>) -> String {\n161\t        let status = if result.is_ok() { \"success\" } else { \"failure\" };\n162\t        self.at_line_start = true;\n163\t        let mut rendered = format!(\"[tool:done] {} status={}\\n\", tool_name, status);\n164\t        if let Ok(payload) = result\n165\t            && let Some(worker_line) = render_worker_status_line(payload)\n166\t        {\n167\t            rendered.push_str(worker_line.as_str());\n168\t        }\n169\t        rendered\n170\t    }\n171\t}\n172\t\n173\tpub fn summarize_tool_args(args: &Value) -> String {\n174\t    match args {\n175\t        Value::Object(map) if !map.is_empty() => {\n176\t            let mut entries = map.iter().collect::<Vec<_>>();\n177\t            entries.sort_by(|a, b| a.0.cmp(b.0));\n178\t            entries\n179\t                .into_iter()\n180\t                .map(|(k, v)| format!(\"{k}={}\", summarize_arg_value(v)))\n181\t                .collect::<Vec<_>>()\n182\t                .join(\", \")\n183\t        }\n184\t        Value::Object(_) => String::from(\"no-args\"),\n185\t        _ => summarize_arg_value(args),\n186\t    }\n187\t}\n188\t\n189\tpub fn classify_tool_risk(tool_name: &str) -> ToolRiskLevel {\n190\t    match tool_name {\n191\t        // Can execute arbitrary commands or mutate local state heavily.\n192\t        \"shell\" | \"fs_write\" | \"fs_edit\" | \"spawn_agent\" | \"agent\" | \"task_stop\"\n193\t        | \"cron_create\" => ToolRiskLevel::High,\n194\t        // External network requests with lower local impact.\n195\t        \"browser\" | \"web_fetch\" => ToolRiskLevel::Medium,\n196\t        _ => ToolRiskLevel::Low,\n197\t    }\n198\t}\n199\t\n200\tpub fn confirmation_prompt(tool_name: &str, args: &Value) -> String {\n201\t    format!(\n202\t        \"[tool:confirm] name={} params={} risk={}\\nAllow? [y/n/a]: \",\n203\t        tool_name,\n204\t        summarize_tool_args(args),\n205\t        classify_tool_risk(tool_name).label()\n206\t    )\n207\t}\n208\t\n209\tpub fn parse_confirmation_input(input: &str) -> ToolConfirmationDecision {\n210\t    match input.trim().to_ascii_lowercase().as_str() {\n211\t        \"n\" | \"no\" => ToolConfirmationDecision::Deny,\n212\t        \"a\" | \"always\" => ToolConfirmationDecision::AllowAlways,\n213\t        _ => ToolConfirmationDecision::AllowOnce,\n214\t    }\n215\t}\n216\t\n217\tpub fn classify_error(message: &str) -> ErrorCategory {\n218\t    let m = message.to_ascii_lowercase();\n219\t    if m.contains(\"timed out\")\n220\t        || m.contains(\"timeout\")\n221\t        || m.contains(\"connection\")\n222\t        || m.contains(\"dns\")\n223\t        || m.contains(\"network\")\n224\t        || m.contains(\"unreachable\")\n225\t        || m.contains(\"temporarily unavailable\")\n226\t    {\n227\t        return ErrorCategory::Transport;\n228\t    }\n229\t    if m.contains(\"401\")\n230\t        || m.contains(\"403\")\n231\t        || m.contains(\"unauthorized\")\n232\t        || m.contains(\"forbidden\")\n233\t        || m.contains(\"api key\")\n234\t        || m.contains(\"authentication\")\n235\t    {\n236\t        return ErrorCategory::Auth;\n237\t    }\n238\t    if m.contains(\"permission denied\")\n239\t        || m.contains(\"policy\")\n240\t        || m.contains(\"denied\")\n241\t        || m.contains(\"forbidden by\")\n242\t    {\n243\t        return ErrorCategory::Policy;\n244\t    }\n245\t    if m.contains(\"invalid\")\n246\t        || m.contains(\"parse error\")\n247\t        || m.contains(\"missing required\")\n248\t        || m.contains(\"bad request\")\n249\t    {\n250\t        return ErrorCategory::Validation;\n251\t    }\n252\t    if m.contains(\"not found\")\n253\t        || m.contains(\"invalid state\")\n254\t        || m.contains(\"already\")\n255\t        || m.contains(\"no llm provider configured\")\n256\t        || m.contains(\"not configured\")\n257\t    {\n258\t        return ErrorCategory::State;\n259\t    }\n260\t    ErrorCategory::State\n261\t}\n262\t\n263\tfn summarize_arg_value(v: &Value) -> String {\n264\t    const MAX_LEN: usize = 32;\n265\t    let raw = match v {\n266\t        Value::String(s) => s.clone(),\n267\t        _ => v.to_string(),\n268\t    };\n269\t    if raw.chars().count() > MAX_LEN {\n270\t        let mut shortened = raw.chars().take(MAX_LEN).collect::<String>();\n271\t        shortened.push_str(\"...\");\n272\t        shortened\n273\t    } else {\n274\t        raw\n275\t    }\n276\t}\n277\t\n278\tfn render_worker_status_line(payload: &str) -> Option<String> {\n279\t    let value: Value = serde_json::from_str(payload).ok()?;\n280\t    let task_id = value.get(\"task_id\")?.as_str()?;\n281\t    let status = value.get(\"status\")?.as_str()?;\n282\t    let status = worker_status_label(status)?;\n283\t    Some(format!(\"[worker] task_id={task_id} status={status}\\n\"))\n284\t}\n285\t\n286\tfn classify_anyhow_error(error: &AnyError, ctx: &ErrorContext) -> ErrorEnvelope {\n287\t    if let Some(wire) = find_in_chain::<WireError>(error) {\n288\t        return classify_wire_error(wire, ctx);\n289\t    }\n290\t    if let Some(app) = find_in_chain::<AppError>(error) {\n291\t        return classify_app_error(app, ctx);\n292\t    }\n293\t    classify_message_into_envelope(&error.to_string(), ctx)\n294\t}\n295\t\n296\tfn resolve_context(error: &AnyError, fallback: &ErrorContext) -> ErrorContext {\n297\t    for cause in error.chain() {\n298\t        if let Some(text) = parse_error_context(cause.to_string().as_str()) {\n299\t            return text;\n300\t        }\n301\t    }\n302\t    fallback.clone()\n303\t}\n304\t\n305\tfn parse_error_context(text: &str) -> Option<ErrorContext> {\n306\t    let prefix = \"error_context \";\n307\t    if !text.starts_with(prefix) {\n308\t        return None;\n309\t    }\n310\t    let mut session_id = None;\n311\t    let mut provider_name = None;\n312\t    for part in text[prefix.len()..].split_whitespace() {\n313\t        if let Some((k, v)) = part.split_once('=') {\n314\t            match k {\n315\t                \"session\" => session_id = Some(v.to_string()),\n316\t                \"provider\" => provider_name = Some(v.to_string()),\n317\t                _ => {}\n318\t            }\n319\t        }\n320\t    }\n321\t    Some(ErrorContext {\n322\t        session_id: session_id.unwrap_or_else(|| \"unknown\".to_string()),\n323\t        provider_name: provider_name.unwrap_or_else(|| \"unknown\".to_string()),\n324\t    })\n325\t}\n326\t\n327\tfn classify_wire_error(error: &WireError, ctx: &ErrorContext) -> ErrorEnvelope {\n328\t    match error {\n329\t        WireError::Config(config_error) => {\n330\t            classify_message_into_envelope(&config_error.to_string(), ctx)\n331\t        }\n332\t        WireError::Provider(msg) => classify_provider_error_message(msg, ctx),\n333\t        WireError::Storage(_) => ErrorEnvelope::new(\n334\t            ErrorCategory::State,\n335\t            \"Local storage is unavailable.\",\n336\t            Some(\"Check filesystem permissions and local disk state.\".to_string()),\n337\t            ctx,\n338\t        ),\n339\t        WireError::McpRuntime(msg) => ErrorEnvelope::new(\n340\t            ErrorCategory::State,\n341\t            \"MCP runtime is unavailable.\",\n342\t            Some(format!(\n343\t                \"Check MCP server configuration and startup command. ({msg})\"\n344\t            )),\n345\t            ctx,\n346\t        ),\n347\t    }\n348\t}\n349\t\n350\tfn classify_app_error(error: &AppError, ctx: &ErrorContext) -> ErrorEnvelope {\n351\t    match error {\n352\t        AppError::Port(port_error) => {\n353\t            let text = port_error.to_string();\n354\t            if let Some(provider_message) = text.strip_prefix(\"provider error: \") {\n355\t                return classify_provider_error_message(provider_message, ctx);\n356\t            }\n357\t            classify_message_into_envelope(&text, ctx)\n358\t        }\n359\t        AppError::Llm(llm_error) => classify_message_into_envelope(&llm_error.to_string(), ctx),\n360\t        AppError::Domain(domain_error) => {\n361\t            classify_message_into_envelope(&domain_error.to_string(), ctx)\n362\t        }\n363\t    }\n364\t}\n365\t\n366\tfn classify_message_into_envelope(message: &str, ctx: &ErrorContext) -> ErrorEnvelope {\n367\t    let lower = message.to_ascii_lowercase();\n368\t    if lower.contains(\"no llm provider configured\")\n369\t        || lower.contains(\"not configured\")\n370\t        || lower.contains(\"missing api_key\")\n371\t        || lower.contains(\"missing required field\")\n372\t    {\n373\t        return ErrorEnvelope::new(\n374\t            ErrorCategory::State,\n375\t            \"No provider configuration was found.\",\n376\t            Some(\n377\t                \"Copy settings from ./config.example.toml and set your API key (for example OPENROUTER_API_KEY).\".to_string(),\n378\t            ),\n379\t            ctx,\n380\t        );\n381\t    }\n382\t\n383\t    match classify_error(message) {\n384\t        ErrorCategory::Auth => ErrorEnvelope::new(\n385\t            ErrorCategory::Auth,\n386\t            \"Authentication failed.\",\n387\t            Some(\n388\t                \"Check your API key configuration and environment variables (see ./config.example.toml).\"\n389\t                    .to_string(),\n390\t            ),\n391\t            ctx,\n392\t        ),\n393\t        ErrorCategory::Transport => ErrorEnvelope::new(\n394\t            ErrorCategory::Transport,\n395\t            \"Network request failed.\",\n396\t            Some(\"Check your internet connectivity and retry.\".to_string()),\n397\t            ctx,\n398\t        ),\n399\t        ErrorCategory::Policy => ErrorEnvelope::new(\n400\t            ErrorCategory::Policy,\n401\t            \"Operation blocked by policy.\",\n402\t            None,\n403\t            ctx,\n404\t        ),\n405\t        ErrorCategory::Validation => ErrorEnvelope::new(\n406\t            ErrorCategory::Validation,\n407\t            \"Input or configuration is invalid.\",\n408\t            Some(\"Review command arguments and configuration values.\".to_string()),\n409\t            ctx,\n410\t        ),\n411\t        ErrorCategory::State => {\n412\t            if lower.contains(\"not found\") {\n413\t                ErrorEnvelope::new(\n414\t                    ErrorCategory::State,\n415\t                    \"Requested resource was not found.\",\n416\t                    None,\n417\t                    ctx,\n418\t                )\n419\t            } else if lower.contains(\"invalid state\") {\n420\t                ErrorEnvelope::new(\n421\t                    ErrorCategory::State,\n422\t                    \"Operation is not allowed in the current state.\",\n423\t                    None,\n424\t                    ctx,\n425\t                )\n426\t            } else {\n427\t                ErrorEnvelope::new(\n428\t                    ErrorCategory::State,\n429\t                    \"Unexpected internal error occurred.\",\n430\t                    Some(\"Retry the command. If it persists, report the correlation ID.\".to_string()),\n431\t                    ctx,\n432\t                )\n433\t            }\n434\t        }\n435\t    }\n436\t}\n437\t\n438\tfn classify_provider_error_message(message: &str, ctx: &ErrorContext) -> ErrorEnvelope {\n439\t    // Never surface raw remote endpoint details in user-facing output.\n440\t    match classify_error(message) {\n441\t        ErrorCategory::Auth => ErrorEnvelope::new(\n442\t            ErrorCategory::Auth,\n443\t            \"Provider authentication failed.\",\n444\t            Some(\n445\t                \"Check your API key configuration and provider credentials (see ./config.example.toml).\"\n446\t                    .to_string(),\n447\t            ),\n448\t            ctx,\n449\t        ),\n450\t        ErrorCategory::Transport => ErrorEnvelope::new(\n451\t            ErrorCategory::Transport,\n452\t            \"Provider request failed due to network transport.\",\n453\t            Some(\"Check connectivity and retry.\".to_string()),\n454\t            ctx,\n455\t        ),\n456\t        ErrorCategory::Validation => ErrorEnvelope::new(\n457\t            ErrorCategory::Validation,\n458\t            \"Provider rejected the request payload.\",\n459\t            Some(\"Review request inputs and model settings.\".to_string()),\n460\t            ctx,\n461\t        ),\n462\t        _ => ErrorEnvelope::new(\n463\t            ErrorCategory::State,\n464\t            \"Provider request failed.\",\n465\t            Some(\"Retry later or switch provider configuration.\".to_string()),\n466\t            ctx,\n467\t        ),\n468\t    }\n469\t}\n470\t\n471\tfn find_in_chain<T>(error: &AnyError) -> Option<&T>\n472\twhere\n473\t    T: std::error::Error + 'static,\n474\t{\n475\t    error.chain().find_map(|cause| cause.downcast_ref::<T>())\n476\t}\n477\t\n478\tfn next_correlation_id() -> String {\n479\t    static COUNTER: AtomicU64 = AtomicU64::new(0);\n480\t    let ts_ms = SystemTime::now()\n481\t        .duration_since(UNIX_EPOCH)\n482\t        .map(|d| d.as_millis() as u64)\n483\t        .unwrap_or_default();\n484\t    let seq = COUNTER.fetch_add(1, Ordering::Relaxed);\n485\t    format!(\"cid-{ts_ms:016x}-{seq:08x}\")\n486\t}\n487\t\n488\t#[cfg(test)]\n489\tmod tests {\n490\t    use super::*;\n491\t    use serde_json::json;\n492\t\n493\t    #[test]\n494\t    fn delta_passthrough_has_no_extra_newlines() {\n495\t        let mut formatter = StreamFormatter::new();\n496\t\n497\t        let a = formatter.push_delta(\"Hello\");\n498\t        let b = formatter.push_delta(\", world\");\n499\t        let c = formatter.push_delta(\"!\\n\");\n500\t\n501\t        assert_eq!(format!(\"{a}{b}{c}\"), \"Hello, world!\\n\");\n502\t    }\n503\t\n504\t    #[test]\n505\t    fn tool_start_shows_name_and_parameter_summary() {\n506\t        let mut formatter = StreamFormatter::new();\n507\t        let line =\n508\t            formatter.tool_start_line(\"fs_read\", &json!({\"path\": \"/tmp/a.txt\", \"offset\": 12}));\n509\t\n510\t        assert_eq!(\n511\t            line,\n512\t            \"[tool:start] fs_read risk=low(offset=12, path=/tmp/a.txt)\\n\"\n513\t        );\n514\t    }\n515\t\n516\t    #[test]\n517\t    fn tool_result_shows_success_and_failure() {\n518\t        let mut formatter = StreamFormatter::new();\n519\t\n520\t        let ok_line = formatter.tool_result_line(\"fs_read\", &Ok(\"done\".to_string()));\n521\t        let err_line = formatter.tool_result_line(\"fs_read\", &Err(\"boom\".to_string()));\n522\t\n523\t        assert_eq!(ok_line, \"[tool:done] fs_read status=success\\n\");\n524\t        assert_eq!(err_line, \"[tool:done] fs_read status=failure\\n\");\n525\t    }\n526\t\n527\t    #[test]\n528\t    fn tool_result_includes_worker_status_when_present() {\n529\t        let mut formatter = StreamFormatter::new();\n530\t        let line = formatter.tool_result_line(\n531\t            \"agent\",\n532\t            &Ok(json!({\"task_id\":\"w-1\",\"status\":\"Running\"}).to_string()),\n533\t        );\n534\t\n535\t        assert_eq!(\n536\t            line,\n537\t            \"[tool:done] agent status=success\\n[worker] task_id=w-1 status=Running\\n\"\n538\t        );\n539\t    }\n540\t\n541\t    #[test]\n542\t    fn worker_status_labels_are_stable() {\n543\t        assert_eq!(worker_status_label(\"Running\"), Some(\"Running\"));\n544\t        assert_eq!(worker_status_label(\"Completed\"), Some(\"Completed\"));\n545\t        assert_eq!(worker_status_label(\"Failed\"), Some(\"Failed\"));\n546\t        assert_eq!(worker_status_label(\"Cancelled\"), Some(\"Cancelled\"));\n547\t        assert_eq!(worker_status_label(\"unknown\"), None);\n548\t    }\n549\t\n550\t    #[test]\n551\t    fn tool_events_start_on_clean_line_mid_stream() {\n552\t        let mut formatter = StreamFormatter::new();\n553\t        let mut rendered = String::new();\n554\t\n555\t        rendered.push_str(&formatter.push_delta(\"Partial text\"));\n556\t        rendered.push_str(&formatter.tool_start_line(\"shell\", &json!({\"cmd\": \"echo hi\"})));\n557\t        rendered.push_str(&formatter.tool_result_line(\"shell\", &Ok(\"hi\".to_string())));\n558\t        rendered.push_str(&formatter.push_delta(\"resumed\"));\n559\t\n560\t        assert_eq!(\n561\t            rendered,\n562\t            \"Partial text\\n[tool:start] shell risk=high(cmd=echo hi)\\n[tool:done] shell status=success\\nresumed\"\n563\t        );\n564\t    }\n565\t\n566\t    #[test]\n567\t    fn markdown_code_fence_content_is_preserved() {\n568\t        let mut formatter = StreamFormatter::new();\n569\t        let mut rendered = String::new();\n570\t\n571\t        rendered.push_str(&formatter.push_delta(\"```rust\\n\"));\n572\t        rendered.push_str(&formatter.push_delta(\"fn main() {\\n\"));\n573\t        rendered.push_str(&formatter.push_delta(\"    println!(\\\"hi\\\");\\n\"));\n574\t        rendered.push_str(&formatter.push_delta(\"}\\n\"));\n575\t        rendered.push_str(&formatter.push_delta(\"```\\n\"));\n576\t\n577\t        assert_eq!(\n578\t            rendered,\n579\t            \"```rust\\nfn main() {\\n    println!(\\\"hi\\\");\\n}\\n```\\n\"\n580\t        );\n581\t    }\n582\t\n583\t    #[test]\n584\t    fn tool_arg_summary_truncates_long_values() {\n585\t        let long = \"x\".repeat(80);\n586\t        let summary = summarize_tool_args(&json!({\"path\": long, \"lines\": 20}));\n587\t\n588\t        assert_eq!(\n589\t            summary,\n590\t            \"lines=20, path=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx...\"\n591\t        );\n592\t    }\n593\t\n594\t    #[test]\n595\t    fn classify_error_supports_required_categories() {\n596\t        assert_eq!(classify_error(\"HTTP 401 unauthorized\"), ErrorCategory::Auth);\n597\t        assert_eq!(\n598\t            classify_error(\"connection timed out while sending request\"),\n599\t            ErrorCategory::Transport\n600\t        );\n601\t        assert_eq!(\n602\t            classify_error(\"permission denied by policy\"),\n603\t            ErrorCategory::Policy\n604\t        );\n605\t        assert_eq!(\n606\t            classify_error(\"parse error: invalid config\"),\n607\t            ErrorCategory::Validation\n608\t        );\n609\t        assert_eq!(classify_error(\"session not found\"), ErrorCategory::State);\n610\t    }\n611\t\n612\t    #[test]\n613\t    fn error_category_labels_are_stable() {\n614\t        assert_eq!(error_category_label(ErrorCategory::Policy), \"policy\");\n615\t        assert_eq!(error_category_label(ErrorCategory::Auth), \"auth\");\n616\t        assert_eq!(error_category_label(ErrorCategory::Transport), \"transport\");\n617\t        assert_eq!(error_category_label(ErrorCategory::State), \"state\");\n618\t        assert_eq!(\n619\t            error_category_label(ErrorCategory::Validation),\n620\t            \"validation\"\n621\t        );\n622\t    }\n623\t\n624\t    #[test]\n625\t    fn risk_classification_is_stable() {\n626\t        assert_eq!(classify_tool_risk(\"fs_read\"), ToolRiskLevel::Low);\n627\t        assert_eq!(classify_tool_risk(\"web_fetch\"), ToolRiskLevel::Medium);\n628\t        assert_eq!(classify_tool_risk(\"shell\"), ToolRiskLevel::High);\n629\t    }\n630\t\n631\t    #[test]\n632\t    fn confirmation_prompt_contains_required_fields_and_shortcuts() {\n633\t        let prompt = confirmation_prompt(\"fs_edit\", &json!({\"path\": \"src/main.rs\"}));\n634\t        assert_eq!(\n635\t            prompt,\n636\t            \"[tool:confirm] name=fs_edit params=path=src/main.rs risk=high\\nAllow? [y/n/a]: \"\n637\t        );\n638\t    }\n639\t\n640\t    #[test]\n641\t    fn parse_confirmation_input_supports_y_n_a() {\n642\t        assert_eq!(\n643\t            parse_confirmation_input(\"y\"),\n644\t            ToolConfirmationDecision::AllowOnce\n645\t        );\n646\t        assert_eq!(\n647\t            parse_confirmation_input(\"n\"),\n648\t            ToolConfirmationDecision::Deny\n649\t        );\n650\t        assert_eq!(\n651\t            parse_confirmation_input(\"a\"),\n652\t            ToolConfirmationDecision::AllowAlways\n653\t        );\n654\t    }\n655\t\n656\t    #[test]\n657\t    fn rendered_envelope_contains_correlation_and_context() {\n658\t        let rendered = render_error_message(\n659\t            \"connection timeout\",\n660\t            &ErrorContext {\n661\t                session_id: \"s-123\".to_string(),\n662\t                provider_name: \"openrouter\".to_string(),\n663\t            },\n664\t        );\n665\t        assert!(rendered.contains(\"[error:transport]\"));\n666\t        assert!(rendered.contains(\"correlation_id:\"));\n667\t        assert!(rendered.contains(\"session_id:s-123\"));\n668\t        assert!(rendered.contains(\"provider:openrouter\"));\n669\t    }\n670\t\n671\t    #[test]\n672\t    fn provider_error_is_sanitized_and_no_remote_details_are_leaked() {\n673\t        let rendered = render_error_message(\n674\t            \"provider error: HTTP 500: backend trace=abc123, db password=secret\",\n675\t            &ErrorContext {\n676\t                session_id: \"unknown\".to_string(),\n677\t                provider_name: \"router\".to_string(),\n678\t            },\n679\t        );\n680\t\n681\t        assert!(rendered.contains(\"[error:state]\"));\n682\t        assert!(!rendered.contains(\"trace=abc123\"));\n683\t        assert!(!rendered.contains(\"password=secret\"));\n684\t    }\n685\t\n686\t    #[test]\n687\t    fn missing_config_points_to_example_file() {\n688\t        let rendered = render_error_message(\"no LLM provider configured\", &ErrorContext::unknown());\n689\t        assert!(rendered.contains(\"[error:state]\"));\n690\t        assert!(rendered.contains(\"config.example.toml\"));\n691\t    }\n692\t\n693\t    #[test]\n694\t    fn render_error_reads_context_from_error_chain() {\n695\t        let err = anyhow::anyhow!(\"root failure\")\n696\t            .context(\"error_context provider=openrouter session=s-77\");\n697\t        let rendered = render_error(&err, &ErrorContext::unknown());\n698\t        assert!(rendered.contains(\"provider:openrouter\"));\n699\t        assert!(rendered.contains(\"session_id:s-77\"));\n700\t    }\n701\t}\n702\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"aadda8d2-45d5-4dd3-ab70-25e42d8ce2e4","uuid":"772669ff-e64b-4d1a-bc84-8740deeb8e96","timestamp":"2026-04-02T07:08:56.083Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/cli/src/cmd/output.rs","content":"use anyhow::Error as AnyError;\nuse ccode_application::error::AppError;\nuse ccode_bootstrap::WireError;\nuse serde_json::Value;\nuse std::sync::atomic::{AtomicU64, Ordering};\nuse std::time::{SystemTime, UNIX_EPOCH};\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub enum ErrorCategory {\n    Policy,\n    Auth,\n    Transport,\n    State,\n    Validation,\n}\n\npub fn error_category_label(category: ErrorCategory) -> &'static str {\n    match category {\n        ErrorCategory::Policy => \"policy\",\n        ErrorCategory::Auth => \"auth\",\n        ErrorCategory::Transport => \"transport\",\n        ErrorCategory::State => \"state\",\n        ErrorCategory::Validation => \"validation\",\n    }\n}\n\npub fn worker_status_label(status: &str) -> Option<&'static str> {\n    match status {\n        \"Running\" => Some(\"Running\"),\n        \"Completed\" => Some(\"Completed\"),\n        \"Failed\" => Some(\"Failed\"),\n        \"Cancelled\" => Some(\"Cancelled\"),\n        _ => None,\n    }\n}\n\n#[derive(Debug, Clone)]\npub struct ErrorContext {\n    pub session_id: String,\n    pub provider_name: String,\n}\n\nimpl ErrorContext {\n    pub fn unknown() -> Self {\n        Self {\n            session_id: \"unknown\".to_string(),\n            provider_name: \"unknown\".to_string(),\n        }\n    }\n}\n\n#[derive(Debug, Clone)]\npub struct ErrorEnvelope {\n    pub category: ErrorCategory,\n    pub message: String,\n    pub suggestion: Option<String>,\n    pub correlation_id: String,\n    pub session_id: String,\n    pub provider_name: String,\n}\n\nimpl ErrorEnvelope {\n    fn new(\n        category: ErrorCategory,\n        message: impl Into<String>,\n        suggestion: Option<String>,\n        ctx: &ErrorContext,\n    ) -> Self {\n        Self {\n            category,\n            message: message.into(),\n            suggestion,\n            correlation_id: next_correlation_id(),\n            session_id: ctx.session_id.clone(),\n            provider_name: ctx.provider_name.clone(),\n        }\n    }\n\n    pub fn render(&self) -> String {\n        let category = error_category_label(self.category);\n        let mut out = format!(\"[error:{category}] {}\", self.message);\n        if let Some(suggestion) = &self.suggestion {\n            out.push_str(&format!(\" Hint: {suggestion}\"));\n        }\n        out.push_str(&format!(\n            \" [correlation_id:{} session_id:{} provider:{}]\",\n            self.correlation_id, self.session_id, self.provider_name\n        ));\n        out\n    }\n}\n\npub fn render_error(error: &AnyError, ctx: &ErrorContext) -> String {\n    let resolved_ctx = resolve_context(error, ctx);\n    classify_anyhow_error(error, &resolved_ctx).render()\n}\n\npub fn render_error_message(message: &str, ctx: &ErrorContext) -> String {\n    classify_message_into_envelope(message, ctx).render()\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub enum ToolRiskLevel {\n    Low,\n    Medium,\n    High,\n}\n\nimpl ToolRiskLevel {\n    pub fn label(self) -> &'static str {\n        match self {\n            ToolRiskLevel::Low => \"low\",\n            ToolRiskLevel::Medium => \"medium\",\n            ToolRiskLevel::High => \"high\",\n        }\n    }\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub enum ToolConfirmationDecision {\n    AllowOnce,\n    AllowAlways,\n    Deny,\n}\n\npub struct StreamFormatter {\n    at_line_start: bool,\n}\n\nimpl StreamFormatter {\n    pub fn new() -> Self {\n        Self {\n            at_line_start: true,\n        }\n    }\n\n    pub fn push_delta(&mut self, content: &str) -> String {\n        if !content.is_empty() {\n            self.at_line_start = content.ends_with('\\n');\n        }\n        content.to_string()\n    }\n\n    pub fn tool_start_line(&mut self, tool_name: &str, args: &Value) -> String {\n        let mut out = String::new();\n        if !self.at_line_start {\n            out.push('\\n');\n        }\n        let risk = classify_tool_risk(tool_name).label();\n        out.push_str(&format!(\n            \"[tool:start] {} risk={}({})\\n\",\n            tool_name,\n            risk,\n            summarize_tool_args(args)\n        ));\n        self.at_line_start = true;\n        out\n    }\n\n    pub fn tool_result_line(&mut self, tool_name: &str, result: &Result<String, String>) -> String {\n        let status = if result.is_ok() { \"success\" } else { \"failure\" };\n        self.at_line_start = true;\n        let mut rendered = format!(\"[tool:done] {} status={}\\n\", tool_name, status);\n        if let Ok(payload) = result\n            && let Some(worker_line) = render_worker_status_line(payload)\n        {\n            rendered.push_str(worker_line.as_str());\n        }\n        rendered\n    }\n}\n\npub fn summarize_tool_args(args: &Value) -> String {\n    match args {\n        Value::Object(map) if !map.is_empty() => {\n            let mut entries = map.iter().collect::<Vec<_>>();\n            entries.sort_by(|a, b| a.0.cmp(b.0));\n            entries\n                .into_iter()\n                .map(|(k, v)| format!(\"{k}={}\", summarize_arg_value(v)))\n                .collect::<Vec<_>>()\n                .join(\", \")\n        }\n        Value::Object(_) => String::from(\"no-args\"),\n        _ => summarize_arg_value(args),\n    }\n}\n\npub fn classify_tool_risk(tool_name: &str) -> ToolRiskLevel {\n    match tool_name {\n        // Can execute arbitrary commands or mutate local state heavily.\n        \"shell\" | \"fs_write\" | \"fs_edit\" | \"spawn_agent\" | \"agent\" | \"task_stop\"\n        | \"cron_create\" => ToolRiskLevel::High,\n        // External network requests with lower local impact.\n        \"browser\" | \"web_fetch\" => ToolRiskLevel::Medium,\n        _ => ToolRiskLevel::Low,\n    }\n}\n\npub fn confirmation_prompt(tool_name: &str, args: &Value) -> String {\n    format!(\n        \"[tool:confirm] name={} params={} risk={}\\nAllow? [y/n/a]: \",\n        tool_name,\n        summarize_tool_args(args),\n        classify_tool_risk(tool_name).label()\n    )\n}\n\npub fn parse_confirmation_input(input: &str) -> ToolConfirmationDecision {\n    match input.trim().to_ascii_lowercase().as_str() {\n        \"n\" | \"no\" => ToolConfirmationDecision::Deny,\n        \"a\" | \"always\" => ToolConfirmationDecision::AllowAlways,\n        _ => ToolConfirmationDecision::AllowOnce,\n    }\n}\n\npub fn classify_error(message: &str) -> ErrorCategory {\n    let m = message.to_ascii_lowercase();\n    if m.contains(\"timed out\")\n        || m.contains(\"timeout\")\n        || m.contains(\"connection\")\n        || m.contains(\"dns\")\n        || m.contains(\"network\")\n        || m.contains(\"unreachable\")\n        || m.contains(\"temporarily unavailable\")\n    {\n        return ErrorCategory::Transport;\n    }\n    if m.contains(\"401\")\n        || m.contains(\"403\")\n        || m.contains(\"unauthorized\")\n        || m.contains(\"forbidden\")\n        || m.contains(\"api key\")\n        || m.contains(\"authentication\")\n    {\n        return ErrorCategory::Auth;\n    }\n    if m.contains(\"permission denied\")\n        || m.contains(\"policy\")\n        || m.contains(\"denied\")\n        || m.contains(\"forbidden by\")\n    {\n        return ErrorCategory::Policy;\n    }\n    if m.contains(\"invalid\")\n        || m.contains(\"parse error\")\n        || m.contains(\"missing required\")\n        || m.contains(\"bad request\")\n    {\n        return ErrorCategory::Validation;\n    }\n    if m.contains(\"not found\")\n        || m.contains(\"invalid state\")\n        || m.contains(\"already\")\n        || m.contains(\"no llm provider configured\")\n        || m.contains(\"not configured\")\n    {\n        return ErrorCategory::State;\n    }\n    ErrorCategory::State\n}\n\nfn summarize_arg_value(v: &Value) -> String {\n    const MAX_LEN: usize = 32;\n    let raw = match v {\n        Value::String(s) => s.clone(),\n        _ => v.to_string(),\n    };\n    if raw.chars().count() > MAX_LEN {\n        let mut shortened = raw.chars().take(MAX_LEN).collect::<String>();\n        shortened.push_str(\"...\");\n        shortened\n    } else {\n        raw\n    }\n}\n\nfn render_worker_status_line(payload: &str) -> Option<String> {\n    let value: Value = serde_json::from_str(payload).ok()?;\n    let task_id = value.get(\"task_id\")?.as_str()?;\n    let status = value.get(\"status\")?.as_str()?;\n    let status = worker_status_label(status)?;\n    Some(format!(\"[worker] task_id={task_id} status={status}\\n\"))\n}\n\nfn classify_anyhow_error(error: &AnyError, ctx: &ErrorContext) -> ErrorEnvelope {\n    if let Some(wire) = find_in_chain::<WireError>(error) {\n        return classify_wire_error(wire, ctx);\n    }\n    if let Some(app) = find_in_chain::<AppError>(error) {\n        return classify_app_error(app, ctx);\n    }\n    classify_message_into_envelope(&error.to_string(), ctx)\n}\n\nfn resolve_context(error: &AnyError, fallback: &ErrorContext) -> ErrorContext {\n    for cause in error.chain() {\n        if let Some(text) = parse_error_context(cause.to_string().as_str()) {\n            return text;\n        }\n    }\n    fallback.clone()\n}\n\nfn parse_error_context(text: &str) -> Option<ErrorContext> {\n    let prefix = \"error_context \";\n    if !text.starts_with(prefix) {\n        return None;\n    }\n    let mut session_id = None;\n    let mut provider_name = None;\n    for part in text[prefix.len()..].split_whitespace() {\n        if let Some((k, v)) = part.split_once('=') {\n            match k {\n                \"session\" => session_id = Some(v.to_string()),\n                \"provider\" => provider_name = Some(v.to_string()),\n                _ => {}\n            }\n        }\n    }\n    Some(ErrorContext {\n        session_id: session_id.unwrap_or_else(|| \"unknown\".to_string()),\n        provider_name: provider_name.unwrap_or_else(|| \"unknown\".to_string()),\n    })\n}\n\nfn classify_wire_error(error: &WireError, ctx: &ErrorContext) -> ErrorEnvelope {\n    match error {\n        WireError::Config(config_error) => {\n            classify_message_into_envelope(&config_error.to_string(), ctx)\n        }\n        WireError::Provider(msg) => classify_provider_error_message(msg, ctx),\n        WireError::Storage(_) => ErrorEnvelope::new(\n            ErrorCategory::State,\n            \"Local storage is unavailable.\",\n            Some(\"Check filesystem permissions and local disk state.\".to_string()),\n            ctx,\n        ),\n        WireError::McpRuntime(msg) => ErrorEnvelope::new(\n            ErrorCategory::State,\n            \"MCP runtime is unavailable.\",\n            Some(format!(\n                \"Check MCP server configuration and startup command. ({msg})\"\n            )),\n            ctx,\n        ),\n    }\n}\n\nfn classify_app_error(error: &AppError, ctx: &ErrorContext) -> ErrorEnvelope {\n    match error {\n        AppError::Port(port_error) => {\n            let text = port_error.to_string();\n            if let Some(provider_message) = text.strip_prefix(\"provider error: \") {\n                return classify_provider_error_message(provider_message, ctx);\n            }\n            classify_message_into_envelope(&text, ctx)\n        }\n        AppError::Llm(llm_error) => classify_message_into_envelope(&llm_error.to_string(), ctx),\n        AppError::Domain(domain_error) => {\n            classify_message_into_envelope(&domain_error.to_string(), ctx)\n        }\n    }\n}\n\nfn classify_message_into_envelope(message: &str, ctx: &ErrorContext) -> ErrorEnvelope {\n    let lower = message.to_ascii_lowercase();\n    if lower.contains(\"no llm provider configured\")\n        || lower.contains(\"not configured\")\n        || lower.contains(\"missing api_key\")\n        || lower.contains(\"missing required field\")\n    {\n        return ErrorEnvelope::new(\n            ErrorCategory::State,\n            \"No provider configuration was found.\",\n            Some(\n                \"Copy settings from ./config.example.toml and set your API key (for example OPENROUTER_API_KEY).\".to_string(),\n            ),\n            ctx,\n        );\n    }\n\n    match classify_error(message) {\n        ErrorCategory::Auth => ErrorEnvelope::new(\n            ErrorCategory::Auth,\n            \"Authentication failed.\",\n            Some(\n                \"Check your API key configuration and environment variables (see ./config.example.toml).\"\n                    .to_string(),\n            ),\n            ctx,\n        ),\n        ErrorCategory::Transport => ErrorEnvelope::new(\n            ErrorCategory::Transport,\n            \"Network request failed.\",\n            Some(\"Check your internet connectivity and retry.\".to_string()),\n            ctx,\n        ),\n        ErrorCategory::Policy => ErrorEnvelope::new(\n            ErrorCategory::Policy,\n            \"Operation blocked by policy.\",\n            None,\n            ctx,\n        ),\n        ErrorCategory::Validation => ErrorEnvelope::new(\n            ErrorCategory::Validation,\n            \"Input or configuration is invalid.\",\n            Some(\"Review command arguments and configuration values.\".to_string()),\n            ctx,\n        ),\n        ErrorCategory::State => {\n            if lower.contains(\"not found\") {\n                ErrorEnvelope::new(\n                    ErrorCategory::State,\n                    \"Requested resource was not found.\",\n                    None,\n                    ctx,\n                )\n            } else if lower.contains(\"invalid state\") {\n                ErrorEnvelope::new(\n                    ErrorCategory::State,\n                    \"Operation is not allowed in the current state.\",\n                    None,\n                    ctx,\n                )\n            } else {\n                ErrorEnvelope::new(\n                    ErrorCategory::State,\n                    \"Unexpected internal error occurred.\",\n                    Some(\"Retry the command. If it persists, report the correlation ID.\".to_string()),\n                    ctx,\n                )\n            }\n        }\n    }\n}\n\nfn classify_provider_error_message(message: &str, ctx: &ErrorContext) -> ErrorEnvelope {\n    // Never surface raw remote endpoint details in user-facing output.\n    match classify_error(message) {\n        ErrorCategory::Auth => ErrorEnvelope::new(\n            ErrorCategory::Auth,\n            \"Provider authentication failed.\",\n            Some(\n                \"Check your API key configuration and provider credentials (see ./config.example.toml).\"\n                    .to_string(),\n            ),\n            ctx,\n        ),\n        ErrorCategory::Transport => ErrorEnvelope::new(\n            ErrorCategory::Transport,\n            \"Provider request failed due to network transport.\",\n            Some(\"Check connectivity and retry.\".to_string()),\n            ctx,\n        ),\n        ErrorCategory::Validation => ErrorEnvelope::new(\n            ErrorCategory::Validation,\n            \"Provider rejected the request payload.\",\n            Some(\"Review request inputs and model settings.\".to_string()),\n            ctx,\n        ),\n        _ => ErrorEnvelope::new(\n            ErrorCategory::State,\n            \"Provider request failed.\",\n            Some(\"Retry later or switch provider configuration.\".to_string()),\n            ctx,\n        ),\n    }\n}\n\nfn find_in_chain<T>(error: &AnyError) -> Option<&T>\nwhere\n    T: std::error::Error + 'static,\n{\n    error.chain().find_map(|cause| cause.downcast_ref::<T>())\n}\n\nfn next_correlation_id() -> String {\n    static COUNTER: AtomicU64 = AtomicU64::new(0);\n    let ts_ms = SystemTime::now()\n        .duration_since(UNIX_EPOCH)\n        .map(|d| d.as_millis() as u64)\n        .unwrap_or_default();\n    let seq = COUNTER.fetch_add(1, Ordering::Relaxed);\n    format!(\"cid-{ts_ms:016x}-{seq:08x}\")\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n    use serde_json::json;\n\n    #[test]\n    fn delta_passthrough_has_no_extra_newlines() {\n        let mut formatter = StreamFormatter::new();\n\n        let a = formatter.push_delta(\"Hello\");\n        let b = formatter.push_delta(\", world\");\n        let c = formatter.push_delta(\"!\\n\");\n\n        assert_eq!(format!(\"{a}{b}{c}\"), \"Hello, world!\\n\");\n    }\n\n    #[test]\n    fn tool_start_shows_name_and_parameter_summary() {\n        let mut formatter = StreamFormatter::new();\n        let line =\n            formatter.tool_start_line(\"fs_read\", &json!({\"path\": \"/tmp/a.txt\", \"offset\": 12}));\n\n        assert_eq!(\n            line,\n            \"[tool:start] fs_read risk=low(offset=12, path=/tmp/a.txt)\\n\"\n        );\n    }\n\n    #[test]\n    fn tool_result_shows_success_and_failure() {\n        let mut formatter = StreamFormatter::new();\n\n        let ok_line = formatter.tool_result_line(\"fs_read\", &Ok(\"done\".to_string()));\n        let err_line = formatter.tool_result_line(\"fs_read\", &Err(\"boom\".to_string()));\n\n        assert_eq!(ok_line, \"[tool:done] fs_read status=success\\n\");\n        assert_eq!(err_line, \"[tool:done] fs_read status=failure\\n\");\n    }\n\n    #[test]\n    fn tool_result_includes_worker_status_when_present() {\n        let mut formatter = StreamFormatter::new();\n        let line = formatter.tool_result_line(\n            \"agent\",\n            &Ok(json!({\"task_id\":\"w-1\",\"status\":\"Running\"}).to_string()),\n        );\n\n        assert_eq!(\n            line,\n            \"[tool:done] agent status=success\\n[worker] task_id=w-1 status=Running\\n\"\n        );\n    }\n\n    #[test]\n    fn worker_status_labels_are_stable() {\n        assert_eq!(worker_status_label(\"Running\"), Some(\"Running\"));\n        assert_eq!(worker_status_label(\"Completed\"), Some(\"Completed\"));\n        assert_eq!(worker_status_label(\"Failed\"), Some(\"Failed\"));\n        assert_eq!(worker_status_label(\"Cancelled\"), Some(\"Cancelled\"));\n        assert_eq!(worker_status_label(\"unknown\"), None);\n    }\n\n    #[test]\n    fn tool_events_start_on_clean_line_mid_stream() {\n        let mut formatter = StreamFormatter::new();\n        let mut rendered = String::new();\n\n        rendered.push_str(&formatter.push_delta(\"Partial text\"));\n        rendered.push_str(&formatter.tool_start_line(\"shell\", &json!({\"cmd\": \"echo hi\"})));\n        rendered.push_str(&formatter.tool_result_line(\"shell\", &Ok(\"hi\".to_string())));\n        rendered.push_str(&formatter.push_delta(\"resumed\"));\n\n        assert_eq!(\n            rendered,\n            \"Partial text\\n[tool:start] shell risk=high(cmd=echo hi)\\n[tool:done] shell status=success\\nresumed\"\n        );\n    }\n\n    #[test]\n    fn markdown_code_fence_content_is_preserved() {\n        let mut formatter = StreamFormatter::new();\n        let mut rendered = String::new();\n\n        rendered.push_str(&formatter.push_delta(\"```rust\\n\"));\n        rendered.push_str(&formatter.push_delta(\"fn main() {\\n\"));\n        rendered.push_str(&formatter.push_delta(\"    println!(\\\"hi\\\");\\n\"));\n        rendered.push_str(&formatter.push_delta(\"}\\n\"));\n        rendered.push_str(&formatter.push_delta(\"```\\n\"));\n\n        assert_eq!(\n            rendered,\n            \"```rust\\nfn main() {\\n    println!(\\\"hi\\\");\\n}\\n```\\n\"\n        );\n    }\n\n    #[test]\n    fn tool_arg_summary_truncates_long_values() {\n        let long = \"x\".repeat(80);\n        let summary = summarize_tool_args(&json!({\"path\": long, \"lines\": 20}));\n\n        assert_eq!(\n            summary,\n            \"lines=20, path=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx...\"\n        );\n    }\n\n    #[test]\n    fn classify_error_supports_required_categories() {\n        assert_eq!(classify_error(\"HTTP 401 unauthorized\"), ErrorCategory::Auth);\n        assert_eq!(\n            classify_error(\"connection timed out while sending request\"),\n            ErrorCategory::Transport\n        );\n        assert_eq!(\n            classify_error(\"permission denied by policy\"),\n            ErrorCategory::Policy\n        );\n        assert_eq!(\n            classify_error(\"parse error: invalid config\"),\n            ErrorCategory::Validation\n        );\n        assert_eq!(classify_error(\"session not found\"), ErrorCategory::State);\n    }\n\n    #[test]\n    fn error_category_labels_are_stable() {\n        assert_eq!(error_category_label(ErrorCategory::Policy), \"policy\");\n        assert_eq!(error_category_label(ErrorCategory::Auth), \"auth\");\n        assert_eq!(error_category_label(ErrorCategory::Transport), \"transport\");\n        assert_eq!(error_category_label(ErrorCategory::State), \"state\");\n        assert_eq!(\n            error_category_label(ErrorCategory::Validation),\n            \"validation\"\n        );\n    }\n\n    #[test]\n    fn risk_classification_is_stable() {\n        assert_eq!(classify_tool_risk(\"fs_read\"), ToolRiskLevel::Low);\n        assert_eq!(classify_tool_risk(\"web_fetch\"), ToolRiskLevel::Medium);\n        assert_eq!(classify_tool_risk(\"shell\"), ToolRiskLevel::High);\n    }\n\n    #[test]\n    fn confirmation_prompt_contains_required_fields_and_shortcuts() {\n        let prompt = confirmation_prompt(\"fs_edit\", &json!({\"path\": \"src/main.rs\"}));\n        assert_eq!(\n            prompt,\n            \"[tool:confirm] name=fs_edit params=path=src/main.rs risk=high\\nAllow? [y/n/a]: \"\n        );\n    }\n\n    #[test]\n    fn parse_confirmation_input_supports_y_n_a() {\n        assert_eq!(\n            parse_confirmation_input(\"y\"),\n            ToolConfirmationDecision::AllowOnce\n        );\n        assert_eq!(\n            parse_confirmation_input(\"n\"),\n            ToolConfirmationDecision::Deny\n        );\n        assert_eq!(\n            parse_confirmation_input(\"a\"),\n            ToolConfirmationDecision::AllowAlways\n        );\n    }\n\n    #[test]\n    fn rendered_envelope_contains_correlation_and_context() {\n        let rendered = render_error_message(\n            \"connection timeout\",\n            &ErrorContext {\n                session_id: \"s-123\".to_string(),\n                provider_name: \"openrouter\".to_string(),\n            },\n        );\n        assert!(rendered.contains(\"[error:transport]\"));\n        assert!(rendered.contains(\"correlation_id:\"));\n        assert!(rendered.contains(\"session_id:s-123\"));\n        assert!(rendered.contains(\"provider:openrouter\"));\n    }\n\n    #[test]\n    fn provider_error_is_sanitized_and_no_remote_details_are_leaked() {\n        let rendered = render_error_message(\n            \"provider error: HTTP 500: backend trace=abc123, db password=secret\",\n            &ErrorContext {\n                session_id: \"unknown\".to_string(),\n                provider_name: \"router\".to_string(),\n            },\n        );\n\n        assert!(rendered.contains(\"[error:state]\"));\n        assert!(!rendered.contains(\"trace=abc123\"));\n        assert!(!rendered.contains(\"password=secret\"));\n    }\n\n    #[test]\n    fn missing_config_points_to_example_file() {\n        let rendered = render_error_message(\"no LLM provider configured\", &ErrorContext::unknown());\n        assert!(rendered.contains(\"[error:state]\"));\n        assert!(rendered.contains(\"config.example.toml\"));\n    }\n\n    #[test]\n    fn render_error_reads_context_from_error_chain() {\n        let err = anyhow::anyhow!(\"root failure\")\n            .context(\"error_context provider=openrouter session=s-77\");\n        let rendered = render_error(&err, &ErrorContext::unknown());\n        assert!(rendered.contains(\"provider:openrouter\"));\n        assert!(rendered.contains(\"session_id:s-77\"));\n    }\n}\n","numLines":702,"startLine":1,"totalLines":702}}}
