{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011Q4SPYH6f3tupPakBzfNTY","type":"tool_result","content":"1\tuse crate::contracts::{\n2\t    ArchiveResult, CcrClient, CcrClientError, CreateRemoteSessionRequest, RemoteSessionState,\n3\t    RemoteSessionSummary,\n4\t};\n5\tuse reqwest::StatusCode;\n6\tuse serde::{Deserialize, Serialize};\n7\tuse std::time::Duration;\n8\t\n9\tconst SESSION_PREFIX: &str = \"session_\";\n10\tconst CSE_PREFIX: &str = \"cse_\";\n11\tconst ORG_HEADER: &str = \"x-org-id\";\n12\t\n13\t#[derive(Debug, Clone)]\n14\tpub struct HttpCcrClientConfig {\n15\t    pub base_url: String,\n16\t    pub timeout: Duration,\n17\t    pub max_retries: u32,\n18\t    pub retry_delay: Duration,\n19\t}\n20\t\n21\timpl Default for HttpCcrClientConfig {\n22\t    fn default() -> Self {\n23\t        Self {\n24\t            base_url: \"http://127.0.0.1:8080\".to_string(),\n25\t            timeout: Duration::from_secs(10),\n26\t            max_retries: 2,\n27\t            retry_delay: Duration::from_millis(200),\n28\t        }\n29\t    }\n30\t}\n31\t\n32\t#[derive(Debug, Clone, Default)]\n33\tpub struct AuthContext {\n34\t    pub token: Option<String>,\n35\t    pub org_id: Option<String>,\n36\t}\n37\t\n38\tpub trait AuthContextProvider: Send + Sync {\n39\t    fn auth_context(&self) -> AuthContext;\n40\t}\n41\t\n42\t#[derive(Debug, Clone, Default)]\n43\tpub struct StaticAuthContextProvider {\n44\t    ctx: AuthContext,\n45\t}\n46\t\n47\timpl StaticAuthContextProvider {\n48\t    pub fn new(ctx: AuthContext) -> Self {\n49\t        Self { ctx }\n50\t    }\n51\t}\n52\t\n53\timpl AuthContextProvider for StaticAuthContextProvider {\n54\t    fn auth_context(&self) -> AuthContext {\n55\t        self.ctx.clone()\n56\t    }\n57\t}\n58\t\n59\tpub struct HttpCcrClient<P> {\n60\t    client: reqwest::Client,\n61\t    config: HttpCcrClientConfig,\n62\t    auth_provider: P,\n63\t}\n64\t\n65\timpl<P> HttpCcrClient<P>\n66\twhere\n67\t    P: AuthContextProvider,\n68\t{\n69\t    pub fn new(config: HttpCcrClientConfig, auth_provider: P) -> Self {\n70\t        Self {\n71\t            client: reqwest::Client::new(),\n72\t            config,\n73\t            auth_provider,\n74\t        }\n75\t    }\n76\t\n77\t    fn sessions_endpoint(&self) -> String {\n78\t        format!(\"{}/sessions\", self.config.base_url.trim_end_matches('/'))\n79\t    }\n80\t\n81\t    fn session_endpoint(&self, session_id: &str) -> String {\n82\t        format!(\n83\t            \"{}/{}\",\n84\t            self.sessions_endpoint(),\n85\t            normalize_session_id_for_transport(session_id)\n86\t        )\n87\t    }\n88\t\n89\t    fn add_auth_headers(&self, builder: reqwest::RequestBuilder) -> reqwest::RequestBuilder {\n90\t        let ctx = self.auth_provider.auth_context();\n91\t        let mut with_headers = builder;\n92\t        if let Some(token) = ctx.token {\n93\t            with_headers = with_headers.bearer_auth(token);\n94\t        }\n95\t        if let Some(org_id) = ctx.org_id {\n96\t            with_headers = with_headers.header(ORG_HEADER, org_id);\n97\t        }\n98\t        with_headers\n99\t    }\n100\t\n101\t    async fn send_with_retry<F>(\n102\t        &self,\n103\t        mut make_request: F,\n104\t    ) -> Result<reqwest::Response, CcrClientError>\n105\t    where\n106\t        F: FnMut() -> reqwest::RequestBuilder,\n107\t    {\n108\t        let mut attempt = 0;\n109\t        loop {\n110\t            let send_result =\n111\t                tokio::time::timeout(self.config.timeout, make_request().send()).await;\n112\t            match send_result {\n113\t                Err(_) => {\n114\t                    if attempt < self.config.max_retries {\n115\t                        attempt += 1;\n116\t                        tokio::time::sleep(self.config.retry_delay).await;\n117\t                        continue;\n118\t                    }\n119\t                    return Err(CcrClientError::Timeout);\n120\t                }\n121\t                Ok(Err(err)) => {\n122\t                    let mapped = map_transport_error(\n123\t                        if err.is_timeout() {\n124\t                            TransportErrorKind::Timeout\n125\t                        } else {\n126\t                            TransportErrorKind::Http\n127\t                        },\n128\t                        err.to_string(),\n129\t                    );\n130\t                    if matches!(mapped, CcrClientError::Timeout)\n131\t                        && attempt < self.config.max_retries\n132\t                    {\n133\t                        attempt += 1;\n134\t                        tokio::time::sleep(self.config.retry_delay).await;\n135\t                        continue;\n136\t                    }\n137\t                    return Err(mapped);\n138\t                }\n139\t                Ok(Ok(resp)) => {\n140\t                    if should_retry_status(resp.status()) && attempt < self.config.max_retries {\n141\t                        attempt += 1;\n142\t                        tokio::time::sleep(self.config.retry_delay).await;\n143\t                        continue;\n144\t                    }\n145\t                    return Ok(resp);\n146\t                }\n147\t            }\n148\t        }\n149\t    }\n150\t\n151\t    async fn decode_summary(\n152\t        resp: reqwest::Response,\n153\t    ) -> Result<RemoteSessionSummary, CcrClientError> {\n154\t        let payload: RemoteSessionSummaryWire = resp\n155\t            .json()\n156\t            .await\n157\t            .map_err(|e| map_transport_error(TransportErrorKind::InvalidPayload, e.to_string()))?;\n158\t\n159\t        let state = parse_remote_state(&payload.state).ok_or(CcrClientError::InvalidPayload)?;\n160\t        Ok(RemoteSessionSummary {\n161\t            session_id: normalize_session_id_for_response(&payload.session_id),\n162\t            title: payload.title,\n163\t            environment_id: payload.environment_id,\n164\t            state,\n165\t        })\n166\t    }\n167\t}\n168\t\n169\t#[async_trait::async_trait]\n170\timpl<P> CcrClient for HttpCcrClient<P>\n171\twhere\n172\t    P: AuthContextProvider,\n173\t{\n174\t    async fn create(\n175\t        &self,\n176\t        req: CreateRemoteSessionRequest,\n177\t    ) -> Result<RemoteSessionSummary, CcrClientError> {\n178\t        let body = CreateRemoteSessionRequestWire::from(req);\n179\t        let endpoint = self.sessions_endpoint();\n180\t        let response = self\n181\t            .send_with_retry(|| self.add_auth_headers(self.client.post(&endpoint).json(&body)))\n182\t            .await?;\n183\t\n184\t        if !response.status().is_success() {\n185\t            let status = response.status().as_u16();\n186\t            let body = response.text().await.unwrap_or_default();\n187\t            return Err(classify_status_error(status, body));\n188\t        }\n189\t\n190\t        Self::decode_summary(response).await\n191\t    }\n192\t\n193\t    async fn get(&self, session_id: &str) -> Result<RemoteSessionSummary, CcrClientError> {\n194\t        let endpoint = self.session_endpoint(session_id);\n195\t        let response = self\n196\t            .send_with_retry(|| self.add_auth_headers(self.client.get(&endpoint)))\n197\t            .await?;\n198\t\n199\t        if !response.status().is_success() {\n200\t            let status = response.status().as_u16();\n201\t            let body = response.text().await.unwrap_or_default();\n202\t            return Err(classify_status_error(status, body));\n203\t        }\n204\t\n205\t        Self::decode_summary(response).await\n206\t    }\n207\t\n208\t    async fn archive(&self, session_id: &str) -> Result<ArchiveResult, CcrClientError> {\n209\t        let endpoint = format!(\"{}/archive\", self.session_endpoint(session_id));\n210\t        let response = self\n211\t            .send_with_retry(|| self.add_auth_headers(self.client.post(&endpoint)))\n212\t            .await?;\n213\t\n214\t        if response.status() == StatusCode::CONFLICT {\n215\t            return Ok(ArchiveResult::AlreadyArchived);\n216\t        }\n217\t        if response.status().is_success() {\n218\t            return Ok(ArchiveResult::Archived);\n219\t        }\n220\t\n221\t        let status = response.status().as_u16();\n222\t        let body = response.text().await.unwrap_or_default();\n223\t        Err(classify_status_error(status, body))\n224\t    }\n225\t\n226\t    async fn patch_title(&self, session_id: &str, title: &str) -> Result<(), CcrClientError> {\n227\t        let endpoint = self.session_endpoint(session_id);\n228\t        let body = PatchTitleWire {\n229\t            title: title.to_string(),\n230\t        };\n231\t        let response = self\n232\t            .send_with_retry(|| self.add_auth_headers(self.client.patch(&endpoint).json(&body)))\n233\t            .await?;\n234\t\n235\t        if response.status().is_success() {\n236\t            Ok(())\n237\t        } else {\n238\t            let status = response.status().as_u16();\n239\t            let body = response.text().await.unwrap_or_default();\n240\t            Err(classify_status_error(status, body))\n241\t        }\n242\t    }\n243\t}\n244\t\n245\tpub fn normalize_session_id_for_transport(session_id: &str) -> String {\n246\t    if let Some(stripped) = session_id.strip_prefix(SESSION_PREFIX) {\n247\t        format!(\"{CSE_PREFIX}{stripped}\")\n248\t    } else {\n249\t        session_id.to_string()\n250\t    }\n251\t}\n252\t\n253\tpub fn normalize_session_id_for_response(session_id: &str) -> String {\n254\t    if let Some(stripped) = session_id.strip_prefix(CSE_PREFIX) {\n255\t        format!(\"{SESSION_PREFIX}{stripped}\")\n256\t    } else {\n257\t        session_id.to_string()\n258\t    }\n259\t}\n260\t\n261\tfn should_retry_status(status: StatusCode) -> bool {\n262\t    status.is_server_error() || status == StatusCode::TOO_MANY_REQUESTS\n263\t}\n264\t\n265\tpub fn classify_status_error(status: u16, _body: String) -> CcrClientError {\n266\t    match status {\n267\t        401 => CcrClientError::Unauthorized,\n268\t        403 => CcrClientError::Forbidden,\n269\t        _ => CcrClientError::Http(format!(\"status {status}\")),\n270\t    }\n271\t}\n272\t\n273\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n274\tpub enum TransportErrorKind {\n275\t    Timeout,\n276\t    InvalidPayload,\n277\t    Http,\n278\t}\n279\t\n280\tpub fn map_transport_error(kind: TransportErrorKind, message: String) -> CcrClientError {\n281\t    match kind {\n282\t        TransportErrorKind::Timeout => CcrClientError::Timeout,\n283\t        TransportErrorKind::InvalidPayload => CcrClientError::InvalidPayload,\n284\t        TransportErrorKind::Http => CcrClientError::Http(message),\n285\t    }\n286\t}\n287\t\n288\tfn parse_remote_state(state: &str) -> Option<RemoteSessionState> {\n289\t    match state {\n290\t        \"pending\" | \"Pending\" => Some(RemoteSessionState::Pending),\n291\t        \"running\" | \"Running\" => Some(RemoteSessionState::Running),\n292\t        \"idle\" | \"Idle\" => Some(RemoteSessionState::Idle),\n293\t        \"requires_action\" | \"RequiresAction\" => Some(RemoteSessionState::RequiresAction),\n294\t        \"archived\" | \"Archived\" => Some(RemoteSessionState::Archived),\n295\t        \"expired\" | \"Expired\" => Some(RemoteSessionState::Expired),\n296\t        \"failed\" | \"Failed\" => Some(RemoteSessionState::Failed),\n297\t        _ => None,\n298\t    }\n299\t}\n300\t\n301\t#[derive(Debug, Serialize)]\n302\tstruct CreateRemoteSessionRequestWire {\n303\t    environment_id: String,\n304\t    title: Option<String>,\n305\t    permission_mode: Option<String>,\n306\t    events: Vec<SessionEventWire>,\n307\t}\n308\t\n309\timpl From<CreateRemoteSessionRequest> for CreateRemoteSessionRequestWire {\n310\t    fn from(value: CreateRemoteSessionRequest) -> Self {\n311\t        Self {\n312\t            environment_id: value.environment_id,\n313\t            title: value.title,\n314\t            permission_mode: value.permission_mode,\n315\t            events: value\n316\t                .events\n317\t                .into_iter()\n318\t                .map(|event| SessionEventWire {\n319\t                    event_type: event.event_type,\n320\t                    payload_json: event.payload_json,\n321\t                })\n322\t                .collect(),\n323\t        }\n324\t    }\n325\t}\n326\t\n327\t#[derive(Debug, Serialize)]\n328\tstruct SessionEventWire {\n329\t    #[serde(rename = \"type\")]\n330\t    event_type: String,\n331\t    #[serde(rename = \"payload\")]\n332\t    payload_json: serde_json::Value,\n333\t}\n334\t\n335\t#[derive(Debug, Deserialize)]\n336\tstruct RemoteSessionSummaryWire {\n337\t    session_id: String,\n338\t    title: Option<String>,\n339\t    environment_id: Option<String>,\n340\t    state: String,\n341\t}\n342\t\n343\t#[derive(Debug, Serialize)]\n344\tstruct PatchTitleWire {\n345\t    title: String,\n346\t}\n347\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"aadda8d2-45d5-4dd3-ab70-25e42d8ce2e4","uuid":"dfbe1e9c-cf25-486e-b356-551e0434b1dd","timestamp":"2026-04-02T07:08:32.769Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yaxin/Projects/rust_projects/ccode/crates/remote-runtime/src/ccr_client.rs","content":"use crate::contracts::{\n    ArchiveResult, CcrClient, CcrClientError, CreateRemoteSessionRequest, RemoteSessionState,\n    RemoteSessionSummary,\n};\nuse reqwest::StatusCode;\nuse serde::{Deserialize, Serialize};\nuse std::time::Duration;\n\nconst SESSION_PREFIX: &str = \"session_\";\nconst CSE_PREFIX: &str = \"cse_\";\nconst ORG_HEADER: &str = \"x-org-id\";\n\n#[derive(Debug, Clone)]\npub struct HttpCcrClientConfig {\n    pub base_url: String,\n    pub timeout: Duration,\n    pub max_retries: u32,\n    pub retry_delay: Duration,\n}\n\nimpl Default for HttpCcrClientConfig {\n    fn default() -> Self {\n        Self {\n            base_url: \"http://127.0.0.1:8080\".to_string(),\n            timeout: Duration::from_secs(10),\n            max_retries: 2,\n            retry_delay: Duration::from_millis(200),\n        }\n    }\n}\n\n#[derive(Debug, Clone, Default)]\npub struct AuthContext {\n    pub token: Option<String>,\n    pub org_id: Option<String>,\n}\n\npub trait AuthContextProvider: Send + Sync {\n    fn auth_context(&self) -> AuthContext;\n}\n\n#[derive(Debug, Clone, Default)]\npub struct StaticAuthContextProvider {\n    ctx: AuthContext,\n}\n\nimpl StaticAuthContextProvider {\n    pub fn new(ctx: AuthContext) -> Self {\n        Self { ctx }\n    }\n}\n\nimpl AuthContextProvider for StaticAuthContextProvider {\n    fn auth_context(&self) -> AuthContext {\n        self.ctx.clone()\n    }\n}\n\npub struct HttpCcrClient<P> {\n    client: reqwest::Client,\n    config: HttpCcrClientConfig,\n    auth_provider: P,\n}\n\nimpl<P> HttpCcrClient<P>\nwhere\n    P: AuthContextProvider,\n{\n    pub fn new(config: HttpCcrClientConfig, auth_provider: P) -> Self {\n        Self {\n            client: reqwest::Client::new(),\n            config,\n            auth_provider,\n        }\n    }\n\n    fn sessions_endpoint(&self) -> String {\n        format!(\"{}/sessions\", self.config.base_url.trim_end_matches('/'))\n    }\n\n    fn session_endpoint(&self, session_id: &str) -> String {\n        format!(\n            \"{}/{}\",\n            self.sessions_endpoint(),\n            normalize_session_id_for_transport(session_id)\n        )\n    }\n\n    fn add_auth_headers(&self, builder: reqwest::RequestBuilder) -> reqwest::RequestBuilder {\n        let ctx = self.auth_provider.auth_context();\n        let mut with_headers = builder;\n        if let Some(token) = ctx.token {\n            with_headers = with_headers.bearer_auth(token);\n        }\n        if let Some(org_id) = ctx.org_id {\n            with_headers = with_headers.header(ORG_HEADER, org_id);\n        }\n        with_headers\n    }\n\n    async fn send_with_retry<F>(\n        &self,\n        mut make_request: F,\n    ) -> Result<reqwest::Response, CcrClientError>\n    where\n        F: FnMut() -> reqwest::RequestBuilder,\n    {\n        let mut attempt = 0;\n        loop {\n            let send_result =\n                tokio::time::timeout(self.config.timeout, make_request().send()).await;\n            match send_result {\n                Err(_) => {\n                    if attempt < self.config.max_retries {\n                        attempt += 1;\n                        tokio::time::sleep(self.config.retry_delay).await;\n                        continue;\n                    }\n                    return Err(CcrClientError::Timeout);\n                }\n                Ok(Err(err)) => {\n                    let mapped = map_transport_error(\n                        if err.is_timeout() {\n                            TransportErrorKind::Timeout\n                        } else {\n                            TransportErrorKind::Http\n                        },\n                        err.to_string(),\n                    );\n                    if matches!(mapped, CcrClientError::Timeout)\n                        && attempt < self.config.max_retries\n                    {\n                        attempt += 1;\n                        tokio::time::sleep(self.config.retry_delay).await;\n                        continue;\n                    }\n                    return Err(mapped);\n                }\n                Ok(Ok(resp)) => {\n                    if should_retry_status(resp.status()) && attempt < self.config.max_retries {\n                        attempt += 1;\n                        tokio::time::sleep(self.config.retry_delay).await;\n                        continue;\n                    }\n                    return Ok(resp);\n                }\n            }\n        }\n    }\n\n    async fn decode_summary(\n        resp: reqwest::Response,\n    ) -> Result<RemoteSessionSummary, CcrClientError> {\n        let payload: RemoteSessionSummaryWire = resp\n            .json()\n            .await\n            .map_err(|e| map_transport_error(TransportErrorKind::InvalidPayload, e.to_string()))?;\n\n        let state = parse_remote_state(&payload.state).ok_or(CcrClientError::InvalidPayload)?;\n        Ok(RemoteSessionSummary {\n            session_id: normalize_session_id_for_response(&payload.session_id),\n            title: payload.title,\n            environment_id: payload.environment_id,\n            state,\n        })\n    }\n}\n\n#[async_trait::async_trait]\nimpl<P> CcrClient for HttpCcrClient<P>\nwhere\n    P: AuthContextProvider,\n{\n    async fn create(\n        &self,\n        req: CreateRemoteSessionRequest,\n    ) -> Result<RemoteSessionSummary, CcrClientError> {\n        let body = CreateRemoteSessionRequestWire::from(req);\n        let endpoint = self.sessions_endpoint();\n        let response = self\n            .send_with_retry(|| self.add_auth_headers(self.client.post(&endpoint).json(&body)))\n            .await?;\n\n        if !response.status().is_success() {\n            let status = response.status().as_u16();\n            let body = response.text().await.unwrap_or_default();\n            return Err(classify_status_error(status, body));\n        }\n\n        Self::decode_summary(response).await\n    }\n\n    async fn get(&self, session_id: &str) -> Result<RemoteSessionSummary, CcrClientError> {\n        let endpoint = self.session_endpoint(session_id);\n        let response = self\n            .send_with_retry(|| self.add_auth_headers(self.client.get(&endpoint)))\n            .await?;\n\n        if !response.status().is_success() {\n            let status = response.status().as_u16();\n            let body = response.text().await.unwrap_or_default();\n            return Err(classify_status_error(status, body));\n        }\n\n        Self::decode_summary(response).await\n    }\n\n    async fn archive(&self, session_id: &str) -> Result<ArchiveResult, CcrClientError> {\n        let endpoint = format!(\"{}/archive\", self.session_endpoint(session_id));\n        let response = self\n            .send_with_retry(|| self.add_auth_headers(self.client.post(&endpoint)))\n            .await?;\n\n        if response.status() == StatusCode::CONFLICT {\n            return Ok(ArchiveResult::AlreadyArchived);\n        }\n        if response.status().is_success() {\n            return Ok(ArchiveResult::Archived);\n        }\n\n        let status = response.status().as_u16();\n        let body = response.text().await.unwrap_or_default();\n        Err(classify_status_error(status, body))\n    }\n\n    async fn patch_title(&self, session_id: &str, title: &str) -> Result<(), CcrClientError> {\n        let endpoint = self.session_endpoint(session_id);\n        let body = PatchTitleWire {\n            title: title.to_string(),\n        };\n        let response = self\n            .send_with_retry(|| self.add_auth_headers(self.client.patch(&endpoint).json(&body)))\n            .await?;\n\n        if response.status().is_success() {\n            Ok(())\n        } else {\n            let status = response.status().as_u16();\n            let body = response.text().await.unwrap_or_default();\n            Err(classify_status_error(status, body))\n        }\n    }\n}\n\npub fn normalize_session_id_for_transport(session_id: &str) -> String {\n    if let Some(stripped) = session_id.strip_prefix(SESSION_PREFIX) {\n        format!(\"{CSE_PREFIX}{stripped}\")\n    } else {\n        session_id.to_string()\n    }\n}\n\npub fn normalize_session_id_for_response(session_id: &str) -> String {\n    if let Some(stripped) = session_id.strip_prefix(CSE_PREFIX) {\n        format!(\"{SESSION_PREFIX}{stripped}\")\n    } else {\n        session_id.to_string()\n    }\n}\n\nfn should_retry_status(status: StatusCode) -> bool {\n    status.is_server_error() || status == StatusCode::TOO_MANY_REQUESTS\n}\n\npub fn classify_status_error(status: u16, _body: String) -> CcrClientError {\n    match status {\n        401 => CcrClientError::Unauthorized,\n        403 => CcrClientError::Forbidden,\n        _ => CcrClientError::Http(format!(\"status {status}\")),\n    }\n}\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub enum TransportErrorKind {\n    Timeout,\n    InvalidPayload,\n    Http,\n}\n\npub fn map_transport_error(kind: TransportErrorKind, message: String) -> CcrClientError {\n    match kind {\n        TransportErrorKind::Timeout => CcrClientError::Timeout,\n        TransportErrorKind::InvalidPayload => CcrClientError::InvalidPayload,\n        TransportErrorKind::Http => CcrClientError::Http(message),\n    }\n}\n\nfn parse_remote_state(state: &str) -> Option<RemoteSessionState> {\n    match state {\n        \"pending\" | \"Pending\" => Some(RemoteSessionState::Pending),\n        \"running\" | \"Running\" => Some(RemoteSessionState::Running),\n        \"idle\" | \"Idle\" => Some(RemoteSessionState::Idle),\n        \"requires_action\" | \"RequiresAction\" => Some(RemoteSessionState::RequiresAction),\n        \"archived\" | \"Archived\" => Some(RemoteSessionState::Archived),\n        \"expired\" | \"Expired\" => Some(RemoteSessionState::Expired),\n        \"failed\" | \"Failed\" => Some(RemoteSessionState::Failed),\n        _ => None,\n    }\n}\n\n#[derive(Debug, Serialize)]\nstruct CreateRemoteSessionRequestWire {\n    environment_id: String,\n    title: Option<String>,\n    permission_mode: Option<String>,\n    events: Vec<SessionEventWire>,\n}\n\nimpl From<CreateRemoteSessionRequest> for CreateRemoteSessionRequestWire {\n    fn from(value: CreateRemoteSessionRequest) -> Self {\n        Self {\n            environment_id: value.environment_id,\n            title: value.title,\n            permission_mode: value.permission_mode,\n            events: value\n                .events\n                .into_iter()\n                .map(|event| SessionEventWire {\n                    event_type: event.event_type,\n                    payload_json: event.payload_json,\n                })\n                .collect(),\n        }\n    }\n}\n\n#[derive(Debug, Serialize)]\nstruct SessionEventWire {\n    #[serde(rename = \"type\")]\n    event_type: String,\n    #[serde(rename = \"payload\")]\n    payload_json: serde_json::Value,\n}\n\n#[derive(Debug, Deserialize)]\nstruct RemoteSessionSummaryWire {\n    session_id: String,\n    title: Option<String>,\n    environment_id: Option<String>,\n    state: String,\n}\n\n#[derive(Debug, Serialize)]\nstruct PatchTitleWire {\n    title: String,\n}\n","numLines":347,"startLine":1,"totalLines":347}}}
